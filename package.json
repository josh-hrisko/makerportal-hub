{
  "name": "makerportal-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node --experimental-strip-types scripts/generate-llms.ts && astro check && astro build && npx pagefind --site dist/client && node scripts/sync-pagefind.mjs && node scripts/strip-dev-pages.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --experimental-strip-types --test src/lib/*.test.ts",
    "brand:assets": "node scripts/brand-assets/generate.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/vercel": "^11.0.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "@vercel/analytics": "^2.0.1",
    "astro": "^7.0.7",
    "d3-geo": "^3.1.1",
    "katex": "^0.16.11",
    "resend": "^6.17.2",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@resvg/resvg-js": "^2.6.2",
    "@types/d3-geo": "^3.1.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "pagefind": "^1.1.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
