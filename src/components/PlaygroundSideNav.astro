---
<nav
  id="playground-side-nav"
  class="fixed right-4 top-1/2 z-40 hidden w-[46px] -translate-y-1/2 flex-col items-end gap-3 overflow-hidden rounded-[20px] border border-border bg-card-bg/60 p-3.5 shadow-[0_12px_32px_-12px_rgba(0,0,0,0.12)] backdrop-blur-[14px] transition-all duration-300 ease-out hover:w-56 hover:bg-card-bg/90 focus-within:w-56 focus-within:bg-card-bg/90 group/sidenav 2xl:flex"
  aria-label="Table of contents"
>
  <div class="flex w-full items-center justify-end border-b border-border/40 pb-2 text-[0.62rem] font-bold uppercase tracking-[0.14em] text-muted-text/80 whitespace-nowrap min-h-6">
    <span class="opacity-0 group-hover/sidenav:opacity-100 group-focus-within/sidenav:opacity-100 transition-opacity duration-200 mr-auto">On this page</span>
    <svg class="size-4 text-muted-text/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </div>

  <div id="side-nav-track" class="flex max-h-[70vh] w-[calc(100%+1rem)] -mx-2 flex-col gap-1 items-end overflow-y-auto px-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
    <!-- Dynamically populated -->
  </div>
</nav>

<style is:global>
  /* Extra styling for active states of side navigation elements */
  .side-nav-link {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
    padding: 0.35rem 0;
    cursor: pointer;
    text-decoration: none;
    outline: none;
    transition: all 0.25s ease;
  }
  .side-nav-label {
    opacity: 0;
    transform: translateX(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--mp-muted, #6b7280);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-right: 0.75rem;
    pointer-events: none;
  }
  #playground-side-nav:hover .side-nav-label,
  #playground-side-nav:focus-within .side-nav-label {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .side-nav-dot {
    width: 0.5rem;
    height: 0.5rem;
    /* Center the dot column in the collapsed 46px rail: content box is 16px,
       dot is 8px -> 4px offset from the right edge. Also buys clearance so
       the active glow is never clipped by the track's overflow. */
    margin-right: 0.25rem;
    border-radius: 9999px;
    border: 1px solid var(--mp-border-strong, #9ca3af);
    background-color: var(--mp-elevated, #f3f4f6);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  /* Hover effects */
  .side-nav-link:hover .side-nav-label {
    color: var(--mp-text, #111827);
  }
  .side-nav-link:hover .side-nav-dot {
    border-color: var(--mp-text, #111827);
    transform: scale(1.15);
  }
  /* Keyboard focus parity with hover */
  .side-nav-link:focus-visible .side-nav-label {
    color: var(--mp-text, #111827);
  }
  .side-nav-link:focus-visible .side-nav-dot {
    border-color: var(--mp-text, #111827);
    transform: scale(1.15);
  }

  /* Active states */
  .side-nav-link.is-active .side-nav-label {
    color: var(--mp-text, #111827);
    font-weight: 650;
  }
  .side-nav-link.is-active .side-nav-dot {
    border-color: var(--mp-cta, #3b82f6);
    background-color: var(--mp-cta, #3b82f6);
    box-shadow: 0 0 6px color-mix(in srgb, var(--mp-cta) 60%, transparent);
    transform: scale(1.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .side-nav-link,
    .side-nav-label,
    .side-nav-dot {
      transition: none;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (() => {
    // ClientRouter swaps DOM but keeps the same `window`/`document`, so hooks
    // registered by a previous page's execution must be torn down first —
    // otherwise scroll listeners and observers accumulate across navigations.
    const REGISTRY_KEY = '__mpPlaygroundSideNavTeardown__';
    if (window[REGISTRY_KEY]) {
      try { window[REGISTRY_KEY](); } catch (_) {}
      window[REGISTRY_KEY] = null;
    }

    let teardownInstance = null;

    // Build a clean plain-text label from a heading: strips duplicated KaTeX
    // MathML (which would double the visible glyphs in textContent), TeX
    // delimiters/tokens, and decorative arrows that degrade in small labels.
    const cleanLabel = (heading) => {
      const explicit = heading.getAttribute('data-nav-label');
      if (explicit && explicit.trim()) return explicit.trim();

      const clone = heading.cloneNode(true);
      clone.querySelectorAll('.katex-mathml, annotation, .sr-only').forEach((n) => n.remove());

      return (clone.textContent || '')
        .replace(/\$\$?|\\\(|\\\)|\\\[|\\\]/g, '')   // TeX inline/display delimiters
        .replace(/[\^_]\{([^}]*)\}/g, '$1')           // ^{2} / _{0} tokens -> 2 / 0
        .replace(/[←-⇿➔➘-➾⬅-⬍]/g, '')  // arrows: U+2190–21FF, U+2794, U+2798–27BE, U+2B05–2B0D
        .replace(/~/g, ' ')                           // TeX non-breaking space
        .replace(/\s+/g, ' ')
        .trim();
    };

    const init = () => {
      // Idempotent: re-init always starts from a clean slate.
      if (teardownInstance) {
        teardownInstance();
        teardownInstance = null;
      }

      const navContainer = document.getElementById('playground-side-nav');
      const track = document.getElementById('side-nav-track');
      if (!navContainer || !track) return;

      // Scope to main content so site chrome can never leak into the TOC.
      const scope = document.getElementById('main-content') || document;
      const headings = Array.from(scope.querySelectorAll('h2[id]')).filter((h) => {
        if (h.classList.contains('sr-only')) return false;
        if (h.closest('header') || h.closest('footer')) return false;
        return true;
      });

      // Hide side nav if page has fewer than 2 relevant sections
      if (headings.length < 2) {
        navContainer.style.display = 'none';
        return;
      }

      track.innerHTML = '';
      navContainer.style.display = '';

      const removers = [];
      const on = (target, type, fn, opts) => {
        target.addEventListener(type, fn, opts);
        removers.push(() => target.removeEventListener(type, fn, opts));
      };

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const HEADER_OFFSET = 80;

      let activeLink = null;
      const setActive = (link) => {
        if (link === activeLink) return;
        if (activeLink) {
          activeLink.classList.remove('is-active');
          activeLink.removeAttribute('aria-current');
        }
        if (link) {
          link.classList.add('is-active');
          link.setAttribute('aria-current', 'location');
        }
        activeLink = link;
      };

      // Generate side nav links
      const items = headings.map((heading) => {
        const link = document.createElement('a');
        link.className = 'side-nav-link';
        link.setAttribute('href', `#${heading.id}`);

        const labelText = cleanLabel(heading) || heading.id;

        const label = document.createElement('span');
        label.className = 'side-nav-label';
        label.textContent = labelText;

        const dot = document.createElement('span');
        dot.className = 'side-nav-dot';

        link.appendChild(label);
        link.appendChild(dot);
        link.title = labelText; // full text tooltip when ellipsized
        track.appendChild(link);

        on(link, 'click', (e) => {
          e.preventDefault();
          setActive(link);
          const top = heading.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
          window.scrollTo({ top: Math.max(0, top), behavior: reduceMotion ? 'instant' : 'smooth' });
          history.pushState(null, '', `#${heading.id}`);
        });

        return { heading, link };
      });

      // Deterministic scroll spy (rAF-throttled): the active section is the
      // last heading above the scanline — exactly one active item by
      // construction, no stuck states on band boundaries, and fast sweeps
      // always settle on the correct section. Bottom clamp guarantees the
      // final section activates even when the page can't scroll it to the
      // scanline.
      let ticking = false;
      const computeActive = () => {
        ticking = false;
        if (!navContainer.getClientRects().length) return; // hidden (breakpoint / few headings)
        const scanline = Math.max(96, window.innerHeight * 0.3);
        let current = items[0];
        for (const item of items) {
          if (item.heading.getBoundingClientRect().top <= scanline) current = item;
          else break;
        }
        if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 8) {
          current = items[items.length - 1];
        }
        setActive(current.link);
      };
      const requestCompute = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(computeActive);
      };

      on(window, 'scroll', requestCompute, { passive: true });
      on(window, 'resize', requestCompute, { passive: true });
      computeActive();

      teardownInstance = () => {
        removers.forEach((off) => off());
        removers.length = 0;
        setActive(null);
      };
    };

    const onPageLoad = () => init();
    const onBeforeSwap = () => {
      if (teardownInstance) {
        teardownInstance();
        teardownInstance = null;
      }
    };

    // Persistent hooks live on the shared document; they are removed by the
    // registry teardown when the next page's script re-executes.
    document.addEventListener('astro:page-load', onPageLoad);
    document.addEventListener('astro:before-swap', onBeforeSwap);

    window[REGISTRY_KEY] = () => {
      document.removeEventListener('astro:page-load', onPageLoad);
      document.removeEventListener('astro:before-swap', onBeforeSwap);
      onBeforeSwap();
    };

    init();
  })();
</script>
