---
// Backward compat wrapper – new code should use SideNav directly.
// Keeps old import path alive while sharing the generic implementation.
import SideNav from './SideNav.astro';
interface Props {
  minHeadings?: number;
  selector?: string;
  rootId?: string;
  title?: string;
}
const { minHeadings = 2, selector = 'h2[id]', rootId = 'main-content', title = 'On this page' } = Astro.props;
---
<SideNav navId="playground-side-nav" trackId="side-nav-track" minHeadings={minHeadings} selector={selector} rootId={rootId} title={title} />
