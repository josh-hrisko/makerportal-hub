---
<nav 
  id="playground-side-nav" 
  class="fixed right-5 top-1/2 z-40 hidden -translate-y-1/2 flex-col items-end gap-3 rounded-[20px] border border-border bg-card-bg/40 p-3.5 backdrop-blur-[10px] shadow-[0_12px_32px_-12px_rgba(0,0,0,0.12)] transition-all duration-300 ease-out hover:w-56 w-[46px] overflow-hidden group/sidenav hover:bg-card-bg/85 hover:border-border-strong lg:flex" 
  aria-label="Table of contents"
>
  <div class="flex w-full items-center justify-end border-b border-border/40 pb-2 text-[0.62rem] font-bold uppercase tracking-[0.14em] text-muted-text/80 whitespace-nowrap min-h-6">
    <span class="opacity-0 group-hover/sidenav:opacity-100 transition-opacity duration-200 mr-auto">On this page</span>
    <svg class="size-4 text-muted-text/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </div>
  
  <div id="side-nav-track" class="flex flex-col gap-1 w-full items-end" role="list">
    <!-- Dynamically populated -->
  </div>
</nav>

<style is:global>
  /* Extra styling for active states of side navigation elements */
  .side-nav-link {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
    padding: 0.35rem 0;
    cursor: pointer;
    text-decoration: none;
    outline: none;
    transition: all 0.25s ease;
  }
  .side-nav-label {
    opacity: 0;
    transform: translateX(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--mp-muted-text, #6b7280);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-right: 0.75rem;
    pointer-events: none;
  }
  #playground-side-nav:hover .side-nav-label {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .side-nav-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    border: 1px solid var(--mp-border, #e5e7eb);
    background-color: var(--mp-elevated, #f3f4f6);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }
  
  /* Hover effects */
  .side-nav-link:hover .side-nav-label {
    color: var(--mp-text, #111827);
  }
  .side-nav-link:hover .side-nav-dot {
    border-color: var(--mp-border-strong, #9ca3af);
    transform: scale(1.15);
  }
  
  /* Active states */
  .side-nav-link.is-active .side-nav-label {
    color: var(--mp-text, #111827);
    font-weight: 650;
  }
  .side-nav-link.is-active .side-nav-dot {
    border-color: var(--mp-cta, #3b82f6);
    background-color: var(--mp-cta, #3b82f6);
    box-shadow: 0 0 8px color-mix(in srgb, var(--mp-cta) 60%, transparent);
    transform: scale(1.2);
  }
</style>

<script is:inline data-astro-rerun>
  (() => {
    const initSideNav = () => {
      const navContainer = document.getElementById('playground-side-nav');
      const track = document.getElementById('side-nav-track');
      if (!navContainer || !track) return;

      // 1. Query candidate headings on page
      const headings = Array.from(document.querySelectorAll('h2[id]')).filter(h => {
        if (h.classList.contains('sr-only')) return false;
        if (h.closest('header') || h.closest('footer')) return false;
        return true;
      });

      // Hide side nav if page has fewer than 2 relevant sections
      if (headings.length < 2) {
        navContainer.style.display = 'none';
        return;
      }

      // Ensure clean state
      track.innerHTML = '';
      navContainer.style.display = '';

      // 2. Generate side nav links
      const links = headings.map(heading => {
        const link = document.createElement('a');
        link.className = 'side-nav-link';
        link.setAttribute('role', 'listitem');
        link.setAttribute('href', `#${heading.id}`);
        
        const label = document.createElement('span');
        label.className = 'side-nav-label';
        label.textContent = heading.textContent.replace(/[\u2192\u2190]/g, '').trim(); // Remove arrow symbols if present

        const dot = document.createElement('span');
        dot.className = 'side-nav-dot';

        link.appendChild(label);
        link.appendChild(dot);
        track.appendChild(link);

        // Click interaction with offset scroll
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const headerOffset = 80;
          const elementPosition = heading.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
          
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
          
          // Fallback hash update
          if (history.pushState) {
            history.pushState(null, null, `#${heading.id}`);
          } else {
            location.hash = `#${heading.id}`;
          }
        });

        return { heading, link };
      });

      // 3. Track scrolling with IntersectionObserver
      let activeItem = null;
      const observerOptions = {
        root: null,
        rootMargin: '-10% 0px -75% 0px', // Matches upper mid-viewport scanline
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const matched = links.find(item => item.heading === entry.target);
            if (matched) {
              if (activeItem) activeItem.link.classList.remove('is-active');
              matched.link.classList.add('is-active');
              activeItem = matched;
            }
          }
        });
      }, observerOptions);

      headings.forEach(h => observer.observe(h));

      // Handle edge case where scroll is at very top
      const handleScrollTop = () => {
        if (window.scrollY < 120 && links.length > 0) {
          if (activeItem) activeItem.link.classList.remove('is-active');
          links[0].link.classList.add('is-active');
          activeItem = links[0];
        }
      };
      window.addEventListener('scroll', handleScrollTop, { passive: true });
      handleScrollTop();
    };

    initSideNav();
  })();
</script>
