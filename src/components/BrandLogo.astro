---
import BrandIconConcepts from './BrandIconConcepts.astro';
// App Grid identity. Resting lockup shows TWO crimson spots: the grid's
// bottom-right tile AND the wordmark period-dot between makerportal and ai.
// On hover: dot travels wordmark → grid, BR shrinks to its center then expands,
// then the dot fades back in at home (no reverse travel).
// Standalone icon: BR center shrink → restore pulse on hover (desktop), or
// once when scrolled into view if pulseOnView (used by the hero orbit mark).
interface Props {
  variant?: 'full' | 'icon' | 'lockup' | 'lowercase' | 'wordmark' | 'mp';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  mono?: boolean;
  animated?: boolean;
  concept?: string;
  /** Play the BR pulse once when this icon enters the viewport (not on hover). */
  pulseOnView?: boolean;
}
const { variant = 'full', size = 'md', mono = false, animated = true, class: className = '', concept = 'agm', pulseOnView = false } = Astro.props as Props;

