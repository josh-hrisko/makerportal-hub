<style is:global>
  @keyframes portal-glow-pulse {
    0%, 100% { opacity: 0.4; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.72; transform: translate(-50%, -50%) scale(1.1); }
  }
  @keyframes sparkle-idle {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.04) rotate(2deg); }
  }
  @keyframes neural-orbit {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes app-orbit-expand-settle {
    0% { transform: rotate(0deg) scale(1); }
    52% { transform: rotate(210deg) scale(1.16); }
    80% { transform: rotate(350deg) scale(0.96); }
    100% { transform: rotate(360deg) scale(1); }
  }
  @keyframes lockup-dot-mobile-settle {
    0% { cx: 184.2px; cy: 19.1px; r: 2.4px; }
    100% { cx: 16px; cy: 16px; r: 3.2px; }
  }
  @keyframes lockup-dot-toggle-settle {
    0% { cx: 184.2px; cy: 19.1px; r: 2.4px; }
    100% { cx: 17px; cy: 21px; r: 2.35px; }
  }
  @keyframes toggle-lever-mobile-on {
    0% { transform: rotate(-50deg); }
    100% { transform: rotate(0deg); }
  }
  @keyframes bus-route { 0%,100% { transform: translate(0); } 45% { transform: translate(1.5px,1.5px); } 70% { transform: translate(-.5px,-.5px); } }
  @keyframes patch-cable-live { 0%,100% { transform: scaleY(1); } 50% { transform: scaleY(.78); } }
  @keyframes chassis-lock { 0%,100% { transform: scale(1); } 35% { transform: scale(.86) rotate(-4deg); } 65% { transform: scale(1.08) rotate(2deg); } }
  @keyframes engine-cycle { 0%,100% { stroke-dashoffset: 0; } 50% { stroke-dashoffset: -18; } }
  @keyframes kernel-pulse { 0%,100% { transform: scale(1); } 45% { transform: scale(.9); } 70% { transform: scale(1.08); } }
  @keyframes foundry-dock { 0%,100% { transform: translateX(0); } 45% { transform: translateX(var(--dock)); } 72% { transform: translateX(0); } }
  @keyframes switchboard-signal { 0%,100% { stroke-dashoffset: 0; } 55% { stroke-dashoffset: -32; } }

