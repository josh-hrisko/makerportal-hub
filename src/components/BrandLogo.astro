interface Props {
  variant?: 'full' | 'icon' | 'lockup' | 'lowercase' | 'wordmark' | 'mp';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  mono?: boolean;
  animated?: boolean;
  concept?: string;
}
const { variant = 'full', size = 'md', mono = false, animated = true, class: className = '', concept } = Astro.props as Props;

