  md: { iconHeight: 'h-8 w-8', wordmarkHeight: 'h-5 w-[105px]', lockupGap: 'gap-3', lockupWidth: 'w-[140px]', textLower: 'text-xl', badgeText: 'text-[0.65rem]', mpSize: 'h-8 w-8 rounded-lg' },
  lg: { iconHeight: 'h-12 w-12', wordmarkHeight: 'h-8 w-[168px]', lockupGap: 'gap-4', lockupWidth: 'w-[218px]', textLower: 'text-3xl', badgeText: 'text-[0.8rem]', mpSize: 'h-12 w-12 rounded-xl' },
}[size];

