const dotX = 146.2;
const dotY = 19.1;
const dotRadius = 2.4;
---

<style is:global>
  /* App Grid tiles scale around their own centers (fill-box). Hover motion is
     gated to fine pointers — touch simulates :hover on tap and can stick. */
  .grid-cell {
    transform-box: fill-box;
    transform-origin: center;
  }
  @media (hover: hover) and (pointer: fine) {
    .grid-cell:not(.grid-cell-br) {
      transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1);
      will-change: transform;
    }
    .group\/icon:hover .grid-cell:not(.grid-cell-br),
    .group\/logo:hover .grid-cell:not(.grid-cell-br) {
      transform: scale(1.06);
    }
    .grid-cell:nth-of-type(1) { transition-delay: 0s; }
    .grid-cell:nth-of-type(2) { transition-delay: 0.04s; }
    .grid-cell:nth-of-type(3) { transition-delay: 0.08s; }

    /* Standalone hover pulse — skipped when pulseOnView (scroll-once instead). */
    .group\/icon:not([data-pulse-on-view]):hover .grid-cell-br {
      animation: grid-br-pulse 0.65s cubic-bezier(0.25, 1, 0.4, 1) 1 forwards;
    }

    /* Lockup, once per hover-enter:
       0–34%  dot travels wordmark → grid (behind letters)
       34–42% dot fades out at the grid
       34–55% BR shrinks to center (small remnant)
       55–72% BR expands back out
       72–100% dot fades in at home (no reverse travel) */
    .group\/logo:hover .lockup-dot {
      animation: lockup-dot-trip 1.85s cubic-bezier(0.25, 1, 0.4, 1) forwards;
    }
    .group\/logo:hover .grid-cell-br {
      animation: lockup-br-pulse 1.85s cubic-bezier(0.25, 1, 0.4, 1) forwards;
    }
  }

  /* Standalone BR: single shrink→expand, no plateau/repeat. */
  @keyframes grid-br-pulse {
    0% { transform: scale(1); }
    45% { transform: scale(0.28); }
    100% { transform: scale(1); }
  }
  /* Scroll-into-view trigger (class added once by IntersectionObserver). */
  .group\/icon[data-pulse-on-view].is-pulsing .grid-cell-br {
    animation: grid-br-pulse 0.7s cubic-bezier(0.25, 1, 0.4, 1) 1 forwards;
  }
  .group\/icon[data-pulse-on-view].is-pulsing .grid-cell:not(.grid-cell-br) {
    animation: grid-cell-nudge 0.7s cubic-bezier(0.25, 1, 0.4, 1) 1 forwards;
  }
  .group\/icon[data-pulse-on-view].is-pulsing .grid-cell-tl { animation-delay: 0s; }
  .group\/icon[data-pulse-on-view].is-pulsing .grid-cell-tr { animation-delay: 0.04s; }
  .group\/icon[data-pulse-on-view].is-pulsing .grid-cell-bl { animation-delay: 0.08s; }
  @keyframes grid-cell-nudge {
    0%, 100% { transform: scale(1); }
    45% { transform: scale(1.06); }
  }

  /* Lockup dot: rest BETWEEN makerportal and ai (181.8 abs after translate 38).
     Travels to BR tile center (20.6 = 23−2.4), fades out, snaps home invisible,
     then fades in. */
  .lockup-dot {
    x: 181.8px;
    y: 16.7px;
    width: 4.8px;
    height: 4.8px;
    rx: 2.4px;
    opacity: 1;
  }
  @keyframes lockup-dot-trip {
    0% { x: 181.8px; y: 16.7px; width: 4.8px; height: 4.8px; rx: 2.4px; opacity: 1; }
    34% { x: 20.6px; y: 20.6px; width: 4.8px; height: 4.8px; rx: 2.4px; opacity: 1; }
    42% { x: 20.6px; y: 20.6px; width: 4.8px; height: 4.8px; rx: 2.4px; opacity: 0; }
    72% { x: 181.8px; y: 16.7px; width: 4.8px; height: 4.8px; rx: 2.4px; opacity: 0; }
    100% { x: 181.8px; y: 16.7px; width: 4.8px; height: 4.8px; rx: 2.4px; opacity: 1; }
  }
  @keyframes lockup-br-pulse {
    0%, 34% { transform: scale(1); }
    55% { transform: scale(0.28); }
    72%, 100% { transform: scale(1); }
  }

  /* Touch: no autoplay — header lockup animation on load was competing with
     first paint / LCP on iOS Safari. Hover story remains desktop-only. */
  @media (prefers-reduced-motion: reduce) {
    .grid-cell, .lockup-dot { transition: none !important; animation: none !important; opacity: 1 !important; }
  }
</style>

{/* ICON - standalone */}
{
  variant === 'icon' && (
    <span
      data-brand-logo
      data-concept={concept}
      data-pulse-on-view={pulseOnView ? '' : undefined}
      class:list={['group/icon relative inline-flex items-center justify-center overflow-visible', sizes.iconHeight, className]}
      aria-hidden="true"
    >
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-full w-full overflow-visible">
        <BrandIconConcepts mono={mono} activeConcept={concept} />
      </svg>
    </span>
  )
}

{pulseOnView && (
  <script is:inline>
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const nodes = Array.from(document.querySelectorAll('[data-pulse-on-view]:not([data-pulse-wired])'));
      if (!nodes.length) return;

      // Fire once when the mark's center crosses the middle band of the viewport.
      // ±12% of viewport height around the centerline so it feels intentional on
      // both short mobile and tall desktop scrolls, without needing a min scrollY
      // (on mobile the orbit often starts below the fold and only hits mid later).
      const tryPulse = (el) => {
        if (el.classList.contains('is-pulsing')) return true;
        const rect = el.getBoundingClientRect();
        const vh = window.innerHeight || 1;
        const mid = rect.top + rect.height / 2;
        const band = vh * 0.12;
        const center = vh * 0.5;
        if (mid < center - band || mid > center + band) return false;
        el.classList.add('is-pulsing');
        return true;
      };

      const pending = new Set(nodes);
      nodes.forEach((el) => el.setAttribute('data-pulse-wired', ''));

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          for (const el of [...pending]) {
            if (tryPulse(el)) pending.delete(el);
          }
          if (!pending.size) {
            window.removeEventListener('scroll', onScroll);
            window.removeEventListener('resize', onScroll);
          }
          ticking = false;
        });
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      onScroll();
    })();
  </script>
)}

{/* WORDMARK - dot static between makerportal and ai */}
{
  variant === 'wordmark' && (
    <span class:list={['inline-flex items-center overflow-visible', sizes.wordmarkHeight, className]} aria-hidden="true">
      <svg viewBox="0 0 210 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-full w-full overflow-visible">
        <path d={makerPath} class="brand-wordmark-ink" fill="currentColor" />
        <circle cx={dotX} cy={dotY} r={dotRadius} fill={mono ? 'currentColor' : '#CE445D'} />
        <g transform="translate(-8, 0)">
          <path d={aiPath} class="brand-wordmark-ink" fill="currentColor" />
        </g>
      </svg>
    </span>
  )
}

{/* MP badge */}
{
  variant === 'mp' && (
    <span data-brand-logo data-concept={concept} class:list={['group/icon relative inline-flex items-center justify-center bg-card-bg border border-border overflow-visible', sizes.mpSize, className]}>
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-3/5 w-3/5 overflow-visible">
        <BrandIconConcepts mono={mono} activeConcept={concept} />
      </svg>
    </span>
  )
}

{/* LOCKUP - SINGLE SVG: icon at 0, wordmark translated 38, two crimson spots at rest.
      Lens flare removed 2026-07-13: the soft crimson glow circle (r12 @14%) and
      portal-glow-el span were adding visual noise against new light card shadows
      and competing with App Grid. Grid + dot travel is the identity now. */}
{
  (variant === 'lockup' || variant === 'full') && (
    <span data-brand-logo data-concept={concept} class:list={['group/logo relative inline-flex items-center overflow-visible', sizes.lockupWidth, className]}>
      <svg viewBox="0 0 210 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-full w-full overflow-visible" aria-hidden="true">
        {/* App Grid — BR always crimson at rest (second crimson spot with the wordmark dot) */}
        <BrandIconConcepts mono={mono} activeConcept={concept} />

        {/* Rendered after the icon, before the wordmark so travel passes BEHIND the letters */}
        <rect class="lockup-dot" fill={mono ? 'currentColor' : '#CE445D'} stroke="none" />

        {/* Wordmark shifted 38px right, ai shifted left 8px for perfect kerning */}
        <g transform="translate(38, 0)">
          <g class="brand-wordmark-ink" fill="currentColor" fill-rule="evenodd">
            <path d={makerPath} />
            <g transform="translate(-8, 0)">
              <path d={aiPath} />
            </g>
          </g>
        </g>
      </svg>
    </span>
  )
}
