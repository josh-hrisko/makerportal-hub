<script>
  const toggleStateKey = 'makerportal-toggle-on';

  const isToggleLogo = (logo: HTMLElement) => {
    const concept = logo.dataset.concept;
    return concept === 'cq';
  };

  const setToggleState = (logos: NodeListOf<HTMLElement>, on: boolean, persist = true) => {
    logos.forEach((logo) => {
      if (!isToggleLogo(logo)) return;
      logo.toggleAttribute('data-toggle-on', on);
    });
    if (persist) sessionStorage.setItem(toggleStateKey, on ? '1' : '0');
  };

  const initializeToggleLogos = () => {
    const logos = document.querySelectorAll<HTMLElement>('[data-brand-logo]');
    const alreadyOn = sessionStorage.getItem(toggleStateKey) === '1';
    const touchFirst = matchMedia('(hover: none), (pointer: coarse)').matches;
    let isOn = alreadyOn;

    setToggleState(logos, isOn, false);

    const toggleAll = () => {
      isOn = !isOn;
      setToggleState(logos, isOn);
    };

    logos.forEach((logo) => {
      if (!isToggleLogo(logo)) return;
      if (touchFirst) {
        logo.addEventListener('click', toggleAll);
      } else {
        logo.addEventListener('pointerenter', toggleAll);
        logo.addEventListener('focusin', toggleAll);
      }
    });
  };

  initializeToggleLogos();
</script>

