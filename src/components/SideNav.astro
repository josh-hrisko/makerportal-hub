---
interface Props {
  /** Minimum headings required to show nav (default 2) */
  minHeadings?: number;
  /** Maximum headings before hiding to avoid giant bar (default 8) */
  maxHeadings?: number;
  /** CSS selector for headings to include (default "h2") – ids auto-generated if missing */
  selector?: string;
  /** Root element id to scope query (default "main-content") */
  rootId?: string;
  /** Title shown when expanded */
  title?: string;
  /** Optional custom nav id (default "site-side-nav") – use "playground-side-nav" for legacy */
  navId?: string;
  /** Optional custom track id */
  trackId?: string;
}
const {
  minHeadings = 2,
  maxHeadings = 8,
  selector = 'h2',
  rootId = 'main-content',
  title = 'On this page',
  navId = 'site-side-nav',
  trackId = 'site-nav-track',
} = Astro.props;
---
<nav
  id={navId}
  data-min-headings={String(minHeadings)}
  data-max-headings={String(maxHeadings)}
  data-selector={selector}
  data-root={rootId}
  data-track-id={trackId}
  data-pagefind-ignore
  class="fixed right-4 top-1/2 z-40 hidden w-[46px] -translate-y-1/2 flex-col items-end gap-3 overflow-hidden rounded-[20px] border border-border bg-card-bg/60 p-3.5 shadow-[0_12px_32px_-12px_rgba(0,0,0,0.12)] backdrop-blur-[14px] transition-all duration-300 ease-out hover:w-56 hover:bg-card-bg/90 focus-within:w-56 focus-within:bg-card-bg/90 group/sidenav 2xl:flex"
  aria-label="Table of contents"
>
  <div class="flex w-full items-center justify-end border-b border-border/40 pb-2 text-[0.62rem] font-bold uppercase tracking-[0.14em] text-muted-text/80 whitespace-nowrap min-h-6">
    <span class="opacity-0 group-hover/sidenav:opacity-100 group-focus-within/sidenav:opacity-100 transition-opacity duration-200 mr-auto">{title}</span>
    <svg class="size-4 text-muted-text/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </div>

  <div id={trackId} class="flex max-h-[70vh] w-[calc(100%+1rem)] -mx-2 flex-col gap-1 items-end overflow-y-auto px-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
    <!-- Dynamically populated -->
  </div>
</nav>

<style is:global>
  /* Shared side-nav styling – supports both generic #site-side-nav and legacy #playground-side-nav */
  .side-nav-link {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
    padding: 0.35rem 0;
    cursor: pointer;
    text-decoration: none;
    outline: none;
    transition: all 0.25s ease;
  }
  .side-nav-label {
    opacity: 0;
    transform: translateX(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--mp-muted, #6b7280);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-right: 0.75rem;
    pointer-events: none;
  }
  #site-side-nav:hover .side-nav-label,
  #site-side-nav:focus-within .side-nav-label,
  #playground-side-nav:hover .side-nav-label,
  #playground-side-nav:focus-within .side-nav-label {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .side-nav-dot {
    width: 0.5rem;
    height: 0.5rem;
    margin-right: 0.25rem;
    border-radius: 9999px;
    border: 1px solid var(--mp-border-strong, #9ca3af);
    background-color: var(--mp-elevated, #f3f4f6);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }
  .side-nav-link:hover .side-nav-label {
    color: var(--mp-text, #111827);
  }
  .side-nav-link:hover .side-nav-dot {
    border-color: var(--mp-text, #111827);
    transform: scale(1.15);
  }
  .side-nav-link:focus-visible .side-nav-label {
    color: var(--mp-text, #111827);
  }
  .side-nav-link:focus-visible .side-nav-dot {
    border-color: var(--mp-text, #111827);
    transform: scale(1.15);
  }
  .side-nav-link.is-active .side-nav-label {
    color: var(--mp-text, #111827);
    font-weight: 650;
  }
  .side-nav-link.is-active .side-nav-dot {
    border-color: var(--mp-cta, #3b82f6);
    background-color: var(--mp-cta, #3b82f6);
    box-shadow: 0 0 6px color-mix(in srgb, var(--mp-cta) 60%, transparent);
    transform: scale(1.2);
  }
  @media (prefers-reduced-motion: reduce) {
    .side-nav-link,
    .side-nav-label,
    .side-nav-dot {
      transition: none;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (() => {
    // Unified teardown registry – covers both legacy and generic ids.
    // Previous playground key is still cleared to avoid duplicate listeners after migration.
    const REGISTRY_KEYS = ['__mpSideNavTeardown__', '__mpPlaygroundSideNavTeardown__'];
    for (const k of REGISTRY_KEYS) {
      if (window[k]) {
        try { window[k](); } catch (_) {}
        window[k] = null;
      }
    }

    let teardownInstance = null;

    const cleanLabel = (heading) => {
      const explicit = heading.getAttribute('data-nav-label');
      if (explicit && explicit.trim()) return explicit.trim();
      const clone = heading.cloneNode(true);
      clone.querySelectorAll('.katex-mathml, annotation, .sr-only').forEach((n) => n.remove());
      return (clone.textContent || '')
        .replace(/\$\$?|\\\(|\\\)|\\\[|\\\]/g, '')
        .replace(/[\^_]\{([^}]*)\}/g, '$1')
        .replace(/[←-⇿➔➘-➾⬅-⬍]/g, '')
        .replace(/~/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    };

    const slugify = (text) => {
      return text
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .slice(0, 64) || 'section';
    };

    const init = () => {
      if (teardownInstance) {
        teardownInstance();
        teardownInstance = null;
      }

      // Support both generic and legacy ids for smooth migration
      const navContainer =
        document.getElementById('site-side-nav') ||
        document.getElementById('playground-side-nav');
      if (!navContainer) return;

      const trackId = navContainer.getAttribute('data-track-id') || 'site-nav-track';
      const legacyTrackIds = ['site-nav-track', 'side-nav-track'];
      let track = document.getElementById(trackId);
      if (!track) {
        for (const lid of legacyTrackIds) {
          const t = document.getElementById(lid);
          if (t) { track = t; break; }
        }
      }
      if (!track) return;

      const minHeadings = parseInt(navContainer.getAttribute('data-min-headings') || '2', 10);
      const maxHeadings = parseInt(navContainer.getAttribute('data-max-headings') || '8', 10);
      const selector = navContainer.getAttribute('data-selector') || 'h2';
      const rootId = navContainer.getAttribute('data-root') || 'main-content';

      const scope = document.getElementById(rootId) || document;
      const rawHeadings = Array.from(scope.querySelectorAll(selector));
      const usedIds = new Set();
      // Pre-collect existing ids to avoid collisions
      rawHeadings.forEach((h) => { if (h.id) usedIds.add(h.id); });

      const headings = [];
      for (const h of rawHeadings) {
        if (h.classList.contains('sr-only')) continue;
        if (h.closest('header') || h.closest('footer')) continue;
        // Auto-generate id if missing (supports blog markdown without rehype-slug)
        if (!h.id) {
          const base = slugify(cleanLabel(h) || h.textContent || 'section');
          let candidate = base;
          let i = 2;
          while (usedIds.has(candidate) || document.getElementById(candidate)) {
            candidate = `${base}-${i++}`;
          }
          h.id = candidate;
          usedIds.add(candidate);
        }
        headings.push(h);
      }

      if (headings.length < minHeadings || headings.length > maxHeadings) {
        navContainer.style.display = 'none';
        return;
      }

      track.innerHTML = '';
      navContainer.style.display = '';

      const removers = [];
      const on = (target, type, fn, opts) => {
        target.addEventListener(type, fn, opts);
        removers.push(() => target.removeEventListener(type, fn, opts));
      };

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const HEADER_OFFSET = 80;
      const focusManagedHeadings = [];

      let activeLink = null;
      const setActive = (link) => {
        if (link === activeLink) return;
        if (activeLink) {
          activeLink.classList.remove('is-active');
          activeLink.removeAttribute('aria-current');
        }
        if (link) {
          link.classList.add('is-active');
          link.setAttribute('aria-current', 'location');
        }
        activeLink = link;
      };

      const items = headings.map((heading) => {
        const link = document.createElement('a');
        link.className = 'side-nav-link';
        link.setAttribute('href', `#${heading.id}`);

        const labelText = cleanLabel(heading) || heading.id;

        const label = document.createElement('span');
        label.className = 'side-nav-label';
        label.textContent = labelText;

        const dot = document.createElement('span');
        dot.className = 'side-nav-dot';

        link.appendChild(label);
        link.appendChild(dot);
        link.title = labelText;
        track.appendChild(link);

        on(link, 'click', (e) => {
          e.preventDefault();
          setActive(link);
          const top = heading.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
          window.scrollTo({ top: Math.max(0, top), behavior: reduceMotion ? 'instant' : 'smooth' });
          history.pushState(null, '', `#${heading.id}`);
          try {
            if (!heading.hasAttribute('tabindex')) {
              heading.setAttribute('tabindex', '-1');
              focusManagedHeadings.push(heading);
            }
            heading.focus({ preventScroll: true });
          } catch (_) {
            try { heading.focus(); } catch (_) {}
          }
        });

        return { heading, link };
      });

      let ticking = false;
      const computeActive = () => {
        ticking = false;
        if (!navContainer.getClientRects().length) return;
        const scanline = Math.max(96, window.innerHeight * 0.3);
        let current = items[0];
        for (const item of items) {
          if (item.heading.getBoundingClientRect().top <= scanline) current = item;
          else break;
        }
        if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 8) {
          current = items[items.length - 1];
        }
        setActive(current.link);
      };
      const requestCompute = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(computeActive);
      };

      on(window, 'scroll', requestCompute, { passive: true });
      on(window, 'resize', requestCompute, { passive: true });
      on(document, 'keydown', (e) => {
        if (e.key !== 'Escape') return;
        const ae = document.activeElement;
        if (ae && navContainer.contains(ae)) {
          ae.blur();
        }
      });
      computeActive();

      teardownInstance = () => {
        removers.forEach((off) => off());
        removers.length = 0;
        setActive(null);
        for (const h of focusManagedHeadings) {
          try {
            if (h.getAttribute('tabindex') === '-1') h.removeAttribute('tabindex');
          } catch (_) {}
        }
        focusManagedHeadings.length = 0;
      };
    };

    const onPageLoad = () => init();
    const onBeforeSwap = () => {
      if (teardownInstance) {
        teardownInstance();
        teardownInstance = null;
      }
    };

    document.addEventListener('astro:page-load', onPageLoad);
    document.addEventListener('astro:before-swap', onBeforeSwap);

    window['__mpSideNavTeardown__'] = () => {
      document.removeEventListener('astro:page-load', onPageLoad);
      document.removeEventListener('astro:before-swap', onBeforeSwap);
      onBeforeSwap();
    };
    // Also clear legacy key for backward compat
    window['__mpPlaygroundSideNavTeardown__'] = window['__mpSideNavTeardown__'];

    init();
  })();
</script>
