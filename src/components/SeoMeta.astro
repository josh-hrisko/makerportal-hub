---
interface Props {
  title?: string;
  description?: string;
  canonical?: URL | string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  image?: string;
}

const {
  title = 'MakerPortal — iOS Studio: On-Device AI & Agentic DSP',
  description = 'San Francisco studio engineering iOS & iPadOS apps with on-device ML where possible and transparent cloud for agentic DSP. CoreML, Metal, ANE, LangGraph, hybrid architecture.',
  canonical = new URL(Astro.url.pathname, Astro.site),
  noindex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  image,
} = Astro.props;

const canonicalUrl = canonical.toString();
const socialImage = image ? new URL(image, Astro.site).toString() : new URL('/social-card.png', Astro.site).toString();
const siteName = 'MakerPortal';
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="MakerPortal" />
<meta name="creator" content="MakerPortal" />
<meta name="publisher" content="MakerPortal" />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
<meta name="bingbot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

<!-- Agentic-optimized -->
<meta name="keywords" content="on-device AI, CoreML, Apple Neural Engine, iOS indie studio, SwiftUI, Metal, local neural networks, agentic DSP, LangGraph, hybrid cloud, San Francisco iOS studio, Indie iOS apps, privacy-conscious, privacy architecture" />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content="en_US" />
<meta property="og:locale:alternate" content="en_GB" />
{type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
<meta property="og:image" content={socialImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="MakerPortal — Software with a point of view. On-device first, transparent hybrid where needed." />
<meta property="og:image:type" content="image/png" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@MakerPortal" />
<meta name="twitter:creator" content="@MakerPortal" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />
<meta name="twitter:image:alt" content="MakerPortal — iOS studio: on-device AI & agentic DSP, transparent cloud" />

<!-- Preconnect for perf if needed, but self-hosted fonts now – no external font CDN -->
<meta name="format-detection" content="telephone=no" />
<meta name="theme-color" content="#0F141C" />
