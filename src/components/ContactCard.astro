---
---
<div class="relative isolate overflow-hidden rounded-3xl border border-muted-text/20 bg-card-bg shadow-2xl p-8 sm:p-12" id="contact">
  <div aria-hidden="true" class="absolute -right-20 -top-20 -z-10 size-64 rounded-full opacity-20 blur-[90px] bg-primary-cta"></div>
  
  <div class="max-w-xl">
    <p class="font-mono text-xs text-primary-cta uppercase tracking-widest">Connect</p>
    <h3 class="mt-4 text-3xl font-semibold leading-tight tracking-[-0.04em] text-white sm:text-4xl">Let's build something.</h3>
    <p class="mt-4 text-base leading-7 text-muted-text">Have a project in mind, a bug to report, or just want to say hi? Solve the verification slider to unlock the form.</p>
  </div>

  <form id="contact-form" class="mt-10 grid gap-6 sm:grid-cols-2 relative z-20">
    <div class="hidden" aria-hidden="true">
      <label for="botfield">Don't fill this out if you're human:</label>
      <input type="text" id="botfield" name="botfield" tabindex="-1" autocomplete="off" />
    </div>

    <div class="space-y-2">
      <label for="name" class="block text-sm font-medium text-white">Name</label>
      <input type="text" id="name" name="name" required class="block w-full rounded-xl border border-muted-text/20 bg-canvas/50 px-4 py-3 text-white placeholder-muted-text/50 focus:border-primary-cta focus:outline-none focus:ring-1 focus:ring-primary-cta sm:text-sm" placeholder="Tim Cook">
    </div>

    <div class="space-y-2">
      <label for="email" class="block text-sm font-medium text-white">Email</label>
      <input type="email" id="email" name="email" required class="block w-full rounded-xl border border-muted-text/20 bg-canvas/50 px-4 py-3 text-white placeholder-muted-text/50 focus:border-primary-cta focus:outline-none focus:ring-1 focus:ring-primary-cta sm:text-sm" placeholder="tim@apple.com">
    </div>

    <div class="space-y-2 sm:col-span-2">
      <label for="message" class="block text-sm font-medium text-white">Message</label>
      <textarea id="message" name="message" rows="4" required class="block w-full rounded-xl border border-muted-text/20 bg-canvas/50 px-4 py-3 text-white placeholder-muted-text/50 focus:border-primary-cta focus:outline-none focus:ring-1 focus:ring-primary-cta sm:text-sm" placeholder="How can we help?"></textarea>
    </div>

    <div class="sm:col-span-2">
      <!-- Sliding Unlock Bot Protection -->
      <div class="unlock-container relative flex h-16 items-center justify-center overflow-hidden rounded-full border border-muted-text/20 bg-canvas/50 my-6" id="unlock-container">
        <div class="unlock-bg absolute left-0 top-0 h-full rounded-l-full bg-primary-cta/10 pointer-events-none w-0" id="unlock-bg"></div>
        <div class="unlock-handle absolute left-1 top-1 flex size-14 items-center justify-center rounded-full bg-gradient-to-br from-primary-cta to-primary-cta/80 shadow-lg shadow-primary-cta/25 pointer-events-none transition-colors" id="unlock-handle">
          <svg viewBox="0 0 24 24" class="size-5 fill-none stroke-white stroke-2 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <span class="unlock-label pointer-events-none z-10 text-[0.95rem] font-medium text-muted-text select-none transition-opacity" id="unlock-label">Slide to Unlock Verification</span>
        <input type="range" min="0" max="100" value="0" class="unlock-slider absolute left-0 top-0 m-0 h-full w-full cursor-pointer appearance-none outline-none z-20 opacity-0" id="unlock-slider" style="touch-action: none;">
      </div>

      <button type="submit" id="submit-btn" class="inline-flex min-h-12 w-full sm:w-auto items-center justify-center gap-3 rounded-full bg-primary-cta px-8 text-sm font-bold text-white transition duration-300 hover:scale-[1.02] hover:bg-primary-cta/90 shadow-md shadow-primary-cta/20 hover:shadow-primary-cta/35 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none" disabled>
        <span id="submit-text">Send message</span>
        <svg id="submit-spinner" class="hidden size-4 animate-spin text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </button>
      <p id="form-status" class="mt-4 text-sm font-medium hidden"></p>
    </div>
  </form>
</div>

<style>
  .unlock-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
  }
  .unlock-slider::-moz-range-thumb {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
    border: none;
  }
</style>

<script>
  let isUnlocked = false;
  const slider = document.getElementById('unlock-slider') as HTMLInputElement;
  const handle = document.getElementById('unlock-handle') as HTMLDivElement;
  const bg = document.getElementById('unlock-bg') as HTMLDivElement;
  const label = document.getElementById('unlock-label') as HTMLSpanElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const container = document.getElementById('unlock-container') as HTMLDivElement;
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitText = document.getElementById('submit-text') as HTMLSpanElement;
  const submitSpinner = document.getElementById('submit-spinner') as HTMLElement;
  const formStatus = document.getElementById('form-status') as HTMLParagraphElement;

  if (slider && handle && bg && label && submitBtn && container) {
    slider.addEventListener('input', (e) => {
      const value = parseInt((e.target as HTMLInputElement).value, 10);
      
      handle.style.left = `calc(${value}% - ${(value / 100) * 56}px + 4px)`;
      bg.style.width = `${value}%`;
      label.style.opacity = (1 - (value / 80)).toString();

      if (value >= 98) {
        unlockForm();
      }
    });

    slider.addEventListener('change', (e) => {
      if (parseInt((e.target as HTMLInputElement).value, 10) < 98) {
        resetSlider();
      }
    });

    function resetSlider() {
      slider.value = '0';
      handle.style.left = '4px';
      bg.style.width = '0%';
      label.style.opacity = '1';
    }

    function unlockForm() {
      isUnlocked = true;
      slider.value = '100';
      handle.style.left = 'calc(100% - 60px)';
      bg.style.width = '100%';
      label.textContent = "Verification Unlocked";
      label.style.opacity = '0.8';
      label.classList.add('text-primary-cta');
      slider.disabled = true;
      slider.style.pointerEvents = 'none';

      container.classList.add('border-primary-cta');
      
      // Change icon to unlocked
      handle.innerHTML = `
        <svg viewBox="0 0 24 24" class="size-5 fill-none stroke-white stroke-2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
        </svg>
      `;

      submitBtn.disabled = false;
    }
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!isUnlocked) {
        return false;
      }
      
      submitBtn.disabled = true;
      submitText.textContent = 'Sending...';
      submitSpinner.classList.remove('hidden');
      formStatus.classList.add('hidden');
      
      const botfield = (document.getElementById('botfield') as HTMLInputElement).value;
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const message = (document.getElementById('message') as HTMLTextAreaElement).value;
      
      if (botfield !== "") {
        formStatus.textContent = 'Verification failed. Please try again.';
        formStatus.className = 'mt-4 text-sm font-medium text-red-400';
        formStatus.classList.remove('hidden');
        submitSpinner.classList.add('hidden');
        submitText.textContent = 'Send message';
        return false;
      }
      
      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, email, message, botfield })
        });
        
        const data = await response.json();
        
        if (response.ok) {
          form.style.display = 'none';
          formStatus.innerHTML = '<strong>Success!</strong><br>Your message has been sent. We will get back to you shortly.';
          formStatus.className = 'mt-4 text-sm font-medium text-emerald-400';
        } else {
          throw new Error(data.error || 'Failed to send');
        }
      } catch (error: any) {
        console.error(error);
        formStatus.textContent = error.message || 'Something went wrong. Please try again later.';
        formStatus.className = 'mt-4 text-sm font-medium text-red-400';
        submitBtn.disabled = false;
        submitText.textContent = 'Send message';
      } finally {
        submitSpinner.classList.add('hidden');
        formStatus.classList.remove('hidden');
      }
    });
  }
</script>
