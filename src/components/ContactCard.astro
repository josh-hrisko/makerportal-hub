---
---
<div class="surface-card relative isolate scroll-mt-28 overflow-hidden rounded-[28px] border bg-card-bg p-7 sm:p-10" id="contact">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(20rem_20rem_at_100%_0%,color-mix(in_srgb,var(--mp-cta)_10%,transparent),transparent_60%),radial-gradient(18rem_18rem_at_0%_100%,color-mix(in_srgb,var(--mp-anchor)_8%,transparent),transparent_55%)]"></div>
  
  <div class="max-w-xl">
    <p class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-primary-cta">Connect • Zero spam • SF → Worldwide</p>
    <h2 class="mt-3 text-[2rem] font-bold leading-[0.95] tracking-[-0.03em] text-primary-text sm:text-[2.4rem]">Let's build something fast & useful.</h2>
    <p class="mt-3 text-[0.95rem] leading-[1.6] text-muted-text">Project idea, bug report, or just saying hi? Solve the slider to unlock — we keep it human. On-device where possible, transparent where cloud is needed.</p>
  </div>

  <form id="contact-form" class="relative z-20 mt-8 grid gap-5 sm:grid-cols-2">
    <div class="hidden" aria-hidden="true">
      <label for="botfield">Don't fill this out if you're human:</label>
      <input type="text" id="botfield" name="botfield" tabindex="-1" autocomplete="off" />
    </div>

    <div class="sm:col-span-2 space-y-2.5">
      <p class="text-[0.85rem] font-medium tracking-[-0.01em] text-primary-text">What's on your mind?</p>
      <div class="flex flex-wrap gap-2">
        {[
          ['General Inquiry', 'General'],
          ['Project Proposal', 'Proposal'],
          ['Bug Report', 'Bug'],
          ['Partnership', 'Collab'],
        ].map(([value, label]) => (
          <label class="cursor-pointer">
            <input type="radio" name="topic" value={value} class="peer sr-only" checked={value==='General Inquiry'} />
            <span class="inline-flex rounded-full border border-border bg-elevated/60 px-3.5 py-2 text-[0.82rem] font-medium text-muted-text ring-1 ring-transparent transition-all peer-checked:border-brand-anchor/30 peer-checked:bg-brand-anchor/10 peer-checked:text-brand-anchor peer-checked:ring-brand-anchor/20 hover:border-[var(--mp-border-strong)] hover:text-primary-text">{label}</span>
          </label>
        ))}
      </div>
    </div>

    <div class="relative">
      <input type="text" id="name" name="name" required autocomplete="name" class="peer block w-full rounded-[14px] border border-border bg-canvas px-4 pb-2.5 pt-6 text-[0.95rem] text-primary-text placeholder-transparent transition-colors focus:border-brand-anchor focus:outline-none focus:ring-2 focus:ring-brand-anchor/20" placeholder="Name" />
      <label for="name" class="absolute left-4 top-2 text-[0.7rem] font-medium text-muted-text transition-all peer-placeholder-shown:top-[1.05rem] peer-placeholder-shown:text-[0.9rem] peer-focus:top-2 peer-focus:text-[0.7rem] peer-focus:text-brand-anchor">Name</label>
    </div>

    <div class="relative">
      <input type="email" id="email" name="email" required autocomplete="email" class="peer block w-full rounded-[14px] border border-border bg-canvas px-4 pb-2.5 pt-6 text-[0.95rem] text-primary-text placeholder-transparent transition-colors focus:border-brand-anchor focus:outline-none focus:ring-2 focus:ring-brand-anchor/20" placeholder="Email" />
      <label for="email" class="absolute left-4 top-2 text-[0.7rem] font-medium text-muted-text transition-all peer-placeholder-shown:top-[1.05rem] peer-placeholder-shown:text-[0.9rem] peer-focus:top-2 peer-focus:text-[0.7rem] peer-focus:text-brand-anchor">Email Address</label>
    </div>

    <div class="relative sm:col-span-2">
      <textarea id="message" name="message" rows="4" required placeholder="Message" class="peer block w-full resize-none rounded-[14px] border border-border bg-canvas px-4 pb-3 pt-6 text-[0.95rem] leading-[1.5] text-primary-text placeholder-transparent transition-colors focus:border-brand-anchor focus:outline-none focus:ring-2 focus:ring-brand-anchor/20"></textarea>
      <label for="message" class="absolute left-4 top-2 text-[0.7rem] font-medium text-muted-text transition-all peer-placeholder-shown:top-[1.05rem] peer-placeholder-shown:text-[0.9rem] peer-focus:top-2 peer-focus:text-[0.7rem] peer-focus:text-brand-anchor">How can we help? Keep it brief.</label>
    </div>

    <div class="sm:col-span-2 space-y-4">
      <div class="unlock-container relative flex h-[3.75rem] items-center justify-center overflow-hidden rounded-full border border-border bg-canvas" id="unlock-container">
        <div class="unlock-bg absolute left-0 top-0 h-full rounded-full bg-brand-anchor/10 pointer-events-none w-0 transition-[width] duration-100" id="unlock-bg"></div>
        <div class="unlock-handle absolute left-1 top-1/2 flex size-[2.75rem] -translate-y-1/2 items-center justify-center rounded-full bg-primary-text text-canvas shadow-[0_4px_16px_rgba(0,0,0,0.12)] pointer-events-none transition-[left]" id="unlock-handle" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="size-4 fill-none stroke-current stroke-[2.2]"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
        </div>
        <span class="unlock-label pointer-events-none z-10 select-none text-[0.88rem] font-medium text-muted-text transition-opacity" id="unlock-label">Slide to verify • Human check</span>
        <input type="range" min="0" max="100" value="0" aria-label="Slide to unlock contact form" class="unlock-slider absolute inset-0 m-0 h-full w-full cursor-pointer appearance-none opacity-0" id="unlock-slider" style="touch-action: none;" />
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button type="submit" id="submit-btn" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-primary-text px-6 text-[0.9rem] font-bold tracking-[-0.01em] text-canvas shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all hover:scale-[1.02] hover:opacity-90 disabled:opacity-40 disabled:pointer-events-none" disabled>
          <span id="submit-text">Send message</span>
          <svg id="submit-spinner" class="hidden size-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
        </button>
        <span class="font-mono text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">Avg reply • 4h • No newsletter, ever</span>
      </div>
      <p id="form-status" class="hidden rounded-xl border border-border bg-elevated/60 px-4 py-3 text-[0.875rem] font-medium"></p>
    </div>
  </form>
</div>

<style>
  .unlock-slider::-webkit-slider-thumb { -webkit-appearance:none; width:60px; height:60px; border-radius:9999px; background:transparent; cursor:pointer; }
  .unlock-slider::-moz-range-thumb { width:60px; height:60px; border-radius:9999px; background:transparent; cursor:pointer; border:none; }
</style>

<script>
  let isUnlocked = false;
  const slider = document.getElementById('unlock-slider') as HTMLInputElement;
  const handle = document.getElementById('unlock-handle') as HTMLDivElement;
  const bg = document.getElementById('unlock-bg') as HTMLDivElement;
  const label = document.getElementById('unlock-label') as HTMLSpanElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const container = document.getElementById('unlock-container') as HTMLDivElement;
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitText = document.getElementById('submit-text') as HTMLSpanElement;
  const submitSpinner = document.getElementById('submit-spinner') as HTMLElement;
  const formStatus = document.getElementById('form-status') as HTMLParagraphElement;

  if (slider && handle && bg && label && submitBtn && container) {
    let raf = 0;
    slider.addEventListener('input', (e) => {
      const value = parseInt((e.target as HTMLInputElement).value, 10);
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        // Fix: handle is 2.75rem = 44px, container has 4px inset each side.
        // Travel = W - 44px - 8px = W - 52px for symmetric, but to reach flush right
        // we use 48px travel (W - 48px) so handle snaps to edge: left = 4px + v*(W-48px)
        // = calc(v% - v*48px + 4px) → at 100% = calc(100% - 44px) flush.
        handle.style.left = `calc(${value}% - ${(value / 100) * 48}px + 4px)`;
        bg.style.width = `${value}%`;
        label.style.opacity = (1 - (value / 80)).toString();
      });
      if (value >= 96) unlockForm();
    });
    slider.addEventListener('change', (e) => {
      if (parseInt((e.target as HTMLInputElement).value, 10) < 96) resetSlider();
    });
    function resetSlider() {
      slider.value = '0';
      handle.style.left = '4px';
      bg.style.width = '0%';
      label.style.opacity = '1';
    }
    function unlockForm() {
      isUnlocked = true;
      slider.value = '100';
      handle.style.left = 'calc(100% - 44px)';
      bg.style.width = '100%';
      label.textContent = "Verified ✓";
      label.style.opacity = '1';
      // Use primary-text not hardcoded white — works in both themes
      label.classList.add('text-primary-text');
      slider.disabled = true;
      container.classList.add('border-brand-anchor/30', 'shadow-[0_0_24px_rgba(37,105,151,0.18)]');
      // Handle was bg-primary-text text-canvas; strip both possible variants
      handle.classList.remove('bg-white','bg-primary-text','text-canvas');
      handle.classList.add('bg-brand-anchor','text-white');
      handle.innerHTML = `<svg viewBox="0 0 24 24" class="size-4 stroke-[2.5]" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
      submitBtn.disabled = false;
    }
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!isUnlocked) return;
      submitBtn.disabled = true;
      submitText.textContent = 'Sending…';
      submitSpinner.classList.remove('hidden');
      formStatus.classList.add('hidden');

      const botfield = (document.getElementById('botfield') as HTMLInputElement).value;
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const message = (document.getElementById('message') as HTMLTextAreaElement).value;
      const topicNode = document.querySelector('input[name="topic"]:checked') as HTMLInputElement;
      const topic = topicNode ? topicNode.value : 'General Inquiry';

      if (botfield !== "") {
        formStatus.textContent = 'Verification failed.';
        formStatus.className = 'mt-2 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-[0.875rem] font-medium text-red-300';
        formStatus.classList.remove('hidden');
        submitSpinner.classList.add('hidden');
        submitText.textContent = 'Send message';
        return;
      }

      let timezone = 'Unknown';
      try { timezone = Intl.DateTimeFormat().resolvedOptions().timeZone; } catch {}

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message, botfield, topic, timezone, userAgent: navigator.userAgent, screenSize: `${screen.width}x${screen.height}`, url: location.href })
        });
        const data = await response.json();
        if (response.ok) {
          form.style.display = 'none';
          formStatus.innerHTML = '<strong class="text-brand-anchor">Sent ✓</strong><br>Thanks — we reply within a few hours, SF time. No spam, just build notes.';
          formStatus.className = 'mt-2 rounded-xl border border-brand-anchor/20 bg-brand-anchor/10 px-4 py-3 text-[0.875rem] font-medium text-primary-text';
        } else throw new Error(data.error || 'Failed');
      } catch (err: any) {
        formStatus.textContent = err.message || 'Something went wrong.';
        formStatus.className = 'mt-2 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-[0.875rem] font-medium text-red-300';
        submitBtn.disabled = false;
        submitText.textContent = 'Send message';
      } finally {
        submitSpinner.classList.add('hidden');
        formStatus.classList.remove('hidden');
      }
    });
  }
</script>
