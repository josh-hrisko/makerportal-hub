---
import { pillarMeta, fallbackPillar } from '../data/trends';
import { playground, relatedPlayground } from '../data/playground';


interface Props {
  title: string;
  lead: string;
  pillarHint?: string;
  isGrounded?: boolean;
  relatedApp?: string;
  relatedAppUrl?: string;
  relatedFieldNote?: string;
}

const {
  title,
  lead,
  pillarHint,
  isGrounded: groundedProp,
  relatedApp: relatedAppProp,
  relatedAppUrl: relatedAppUrlProp,
  relatedFieldNote: relatedFieldNoteProp,
} = Astro.props;
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).at(-1) ?? '';
const currentEntry = playground.find((entry) => entry.slug === currentSlug);
const isGrounded = groundedProp ?? currentEntry?.isGrounded ?? false;
const relatedApp = relatedAppProp ?? currentEntry?.relatedApp;
const relatedAppUrl = relatedAppUrlProp ?? currentEntry?.relatedAppUrl;
const relatedFieldNote = relatedFieldNoteProp ?? currentEntry?.relatedFieldNote;
const pillarInfo = (pillarHint ?? currentEntry?.pillarHint) ? (pillarMeta[pillarHint ?? currentEntry?.pillarHint ?? ''] ?? fallbackPillar) : null;
const related = relatedPlayground(currentSlug);
---

<section class="hero-grid border-b border-border">
  <div class="mx-auto max-w-[88rem] px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
    <div class="flex flex-wrap items-center gap-2">
      <p class="section-kicker">Playground · {isGrounded ? 'app-grounded instrument' : 'research instrument'}</p>
      {pillarInfo && (
        <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.64rem] font-medium uppercase tracking-[0.12em] text-muted-text">
          <span class="h-1.5 w-1.5 rounded-full" style={`background: ${pillarInfo.color};`} aria-hidden="true"></span>
          {pillarInfo.label}
        </span>
      )}
    </div>
    <h1 class="mt-6 max-w-4xl text-balance text-[clamp(2.4rem,5vw,4rem)] font-[700] leading-[0.95] tracking-[-0.055em] text-primary-text">{title}</h1>
    <p class="mt-6 max-w-2xl text-[1.05rem] leading-[1.75] text-muted-text sm:text-lg">{lead}</p>
    
    {isGrounded ? (
      <div class="mt-8 flex flex-wrap items-center gap-3">
        {relatedAppUrl && relatedApp && (
          <a href={relatedAppUrl} class="inline-flex min-h-11 items-center gap-1.5 rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">
            Grounded in {relatedApp} ↗
          </a>
        )}
        {relatedFieldNote && (
          <a href={`/blog/${relatedFieldNote}`} class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor">
            Read the field note
          </a>
        )}
      </div>
    ) : (
      <>
        <p class="mt-5 max-w-2xl text-[0.85rem] leading-[1.6] text-muted-text/80">
          Independent research instrument — not claimed as MakerPortal shipped product code. Methods, equations, assumptions, and limitations are disclosed so you can inspect what the page does and does not establish.
        </p>
        {relatedFieldNote && (
          <a href={`/blog/${relatedFieldNote}`} class="mt-6 inline-flex min-h-11 items-center rounded-full border border-border bg-card-bg px-5 text-[0.9rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor">
            Read the field note →
          </a>
        )}
      </>
    )}
  </div>
</section>

<slot />

{related.length > 0 && (
  <section class="border-t border-border bg-elevated/20" aria-labelledby="related-instruments-title">
    <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="section-kicker">Continue the experiment</p>
          <h2 id="related-instruments-title" class="mt-2 text-[clamp(1.35rem,3vw,1.8rem)] font-[650] tracking-[-0.035em] text-primary-text">Related instruments</h2>
        </div>
        <a href="/playground" class="inline-flex min-h-10 items-center text-[0.8rem] font-semibold text-brand-anchor underline-offset-4 hover:underline">All playground labs →</a>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-3">
        {related.map((entry) => {
          const meta = entry.pillarHint ? (pillarMeta[entry.pillarHint] ?? fallbackPillar) : null;
          return (
            <a href={`/playground/${entry.slug}`} class="group rounded-[16px] border border-border bg-card-bg p-4 transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated">
              <div class="flex items-center justify-between gap-2">
                <span class="font-mono text-[0.58rem] uppercase tracking-[0.12em] text-muted-text">{meta?.label ?? 'Research'}</span>
                {entry.relatedFieldNote && <span class="rounded-full border border-border px-2 py-0.5 font-mono text-[0.54rem] uppercase tracking-[0.08em] text-muted-text">Field note</span>}
              </div>
              <h3 class="mt-3 text-[1rem] font-semibold leading-tight text-primary-text transition-colors group-hover:text-primary-cta">{entry.title}</h3>
              <p class="mt-1.5 text-[0.78rem] leading-[1.5] text-muted-text">{entry.tagline}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}

<section class="border-t border-border">
  <div class="mx-auto max-w-[88rem] px-5 py-10 sm:px-8 lg:px-10">
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 font-mono text-[0.7rem] uppercase tracking-[0.14em] text-muted-text">
      <a href="/playground" class="hover:text-primary-text">← All Playground</a>
      {isGrounded && relatedAppUrl && relatedApp && <a href={relatedAppUrl} class="hover:text-primary-text">{relatedApp} ↗</a>}
      {isGrounded && relatedFieldNote && <a href={`/blog/${relatedFieldNote}`} class="hover:text-primary-text">Field note</a>}
      <a href="/blog" class="hover:text-primary-text">Field notes</a>
    </div>
  </div>
</section>
