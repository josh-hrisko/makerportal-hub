---
/**
 * FabOrderPanel — export-adjacent CTA for PCBWay / JLCPCB.
 * Only renders when a real referral / shared-project URL exists.
 * If both merchants are missing, renders nothing (G2 stub compliance).
 *
 * Stack: per handoff Priority 2 — export CSV/gerber/stackup → order on PCBWay/JLCPCB.
 * Yield: Shared Projects pay 10% PCB + 10% SMT; referral ~5%. Higher than Amazon electronics.
 *
 * Usage:
 *   <FabOrderPanel simulator="signal-integrity-lab" exportLabel="Export stackup CSV" />
 *   JS must dispatch event `fab-export-ready` with detail {filename, blobUrl}
 *   or set data-export-ready="true" on panel via external script.
 *
 * Owner ask: When PCBWay/JLCPCB IDs land, fill constants in src/data/affiliate-links.ts
 * (PCBWAY_REFERRAL_CODE, PCBWAY_SHARED_PROJECTS, JLCPCB_REFERRAL_CODE).
 */
import {
  PCBWAY_REFERRAL_CODE,
  PCBWAY_SHARED_PROJECTS,
  JLCPCB_REFERRAL_CODE,
  JLCPCB_SPONSORSHIP_URL,
  buildPcbWayUrl,
  buildJlcUrl,
  isFabLive,
} from '../data/affiliate-links';

interface Props {
  simulator: string;
  exportLabel?: string;
  description?: string;
  compact?: boolean;
}

const {
  simulator,
  exportLabel = 'Export for fab',
  description = 'Export your tuned stackup / Gerbers and order boards — supports shared-project revenue (10% PCB + 10% SMT) when you use our project link.',
  compact = false,
} = Astro.props;

const live = isFabLive();
const pcbwayProject = PCBWAY_SHARED_PROJECTS[simulator];
const hasPcbway = Boolean(pcbwayProject || PCBWAY_REFERRAL_CODE);
const hasJlc = Boolean(JLCPCB_SPONSORSHIP_URL || JLCPCB_REFERRAL_CODE);

const pcbwayUrl = hasPcbway
  ? pcbwayProject
    ? buildPcbWayUrl(pcbwayProject)
    : buildPcbWayUrl('')
  : null;

const jlcUrl = hasJlc
  ? JLCPCB_SPONSORSHIP_URL
    ? buildJlcUrl(JLCPCB_SPONSORSHIP_URL)
    : buildJlcUrl()
  : null;

const show = hasPcbway || hasJlc;
---

{show && (
  <section class="fab-order-panel border-b border-border" aria-labelledby="fab-title" data-sim={simulator} data-export-label={exportLabel}>
    <div class:list={["mx-auto max-w-[88rem] px-5 sm:px-8 lg:px-10", compact ? "py-8 sm:py-10" : "py-12 sm:py-16"]}>
      <div class="rounded-[20px] border border-border bg-card-bg overflow-hidden">
        <div class="flex flex-wrap items-start justify-between gap-4 border-b border-border bg-elevated/40 px-5 py-4 sm:px-6">
          <div>
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Fabricate this design</p>
            <h3 id="fab-title" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.015em] text-primary-text">From sim → PCB</h3>
            <p class="mt-1 max-w-2xl text-[0.84rem] leading-[1.5] text-muted-text">{description}</p>
          </div>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-canvas px-3 py-1 font-mono text-[0.62rem] uppercase tracking-[0.08em] text-muted-text">
            <span class="h-2 w-2 rounded-full bg-emerald-400"></span> Export-ready CTA
          </span>
        </div>

        <div class="grid grid-cols-1 gap-4 p-5 sm:p-6 lg:grid-cols-[1fr_320px]">
          <div class="space-y-3">
            <div class="rounded-[12px] border border-dashed border-border bg-canvas p-4">
              <p class="font-mono text-[0.65rem] uppercase tracking-[0.08em] text-muted-text">What you get</p>
              <ul class="mt-2 list-disc space-y-1 pl-4 text-[0.84rem] leading-[1.5] text-muted-text">
                <li><strong class="text-primary-text">Stackup CSV / Gerbers</strong> tuned in sim (W/H/εr, microstrip Z₀, array spacing → fab notes)</li>
                <li><strong class="text-primary-text">PCBWay Shared Project</strong> if available — 10% PCB + 10% SMT revenue when others order same design</li>
                <li><strong class="text-primary-text">Privacy-safe</strong> — no extra tracking beyond merchant checkout; disclosure in <a href="/privacy#affiliates" class="underline">/privacy#affiliates</a></li>
              </ul>
            </div>

            <div class="flex flex-wrap items-center gap-2 text-[0.72rem] text-muted-text">
              <span class="font-mono text-[0.6rem] uppercase tracking-[0.1em]">Sim</span>
              <code class="rounded-md border border-border bg-elevated px-1.5 py-0.5 font-mono text-[0.7rem]">{simulator}</code>
              <span class="h-px w-6 bg-border"></span>
              <span id="fab-export-status" class="font-mono text-[0.68rem]">No export yet — tune then export</span>
            </div>
          </div>

          <div class="rounded-[14px] border border-border bg-elevated/30 p-4 space-y-3">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.1em] text-muted-text">Order boards</p>

            {pcbwayUrl && (
              <a
                href={pcbwayUrl}
                target="_blank"
                rel="sponsored noopener noreferrer"
                data-fab="pcbway"
                data-sim={simulator}
                class="group flex w-full items-center justify-between gap-3 rounded-[12px] bg-primary-text px-4 py-3.5 text-canvas transition-opacity hover:opacity-90"
              >
                <span class="flex flex-col text-left">
                  <span class="text-[0.9rem] font-semibold leading-[1.2]">Order on PCBWay</span>
                  <span class="mt-0.5 font-mono text-[0.62rem] opacity-80">{pcbwayProject ? 'Shared Project · 10% PCB+SMT' : 'Referral · 5%+'}</span>
                </span>
                <span class="text-[0.8rem] opacity-80 group-hover:translate-x-[2px] transition-transform">↗</span>
              </a>
            )}

            {jlcUrl && (
              <a
                href={jlcUrl}
                target="_blank"
                rel="sponsored noopener noreferrer"
                data-fab="jlcpcb"
                data-sim={simulator}
                class="flex w-full items-center justify-between gap-3 rounded-[12px] border border-border bg-card-bg px-4 py-3.5 text-primary-text transition-all hover:border-[var(--mp-border-strong)]"
              >
                <span class="flex flex-col text-left">
                  <span class="text-[0.9rem] font-semibold leading-[1.2]">Order on JLCPCB</span>
                  <span class="mt-0.5 font-mono text-[0.62rem] text-muted-text">Brand Advocate / Free PCB sponsor path</span>
                </span>
                <span class="text-[0.8rem] opacity-70">↗</span>
              </a>
            )}

            <p class="text-[0.68rem] leading-[1.5] text-muted-text">
              {hasPcbway && hasJlc
                ? 'Choose one fab — both links are tracked. Shared Projects pay 10% PCB + 10% SMT for PCBWay (higher yield than Amazon electronics ~1–2.5%).'
                : hasPcbway
                  ? 'PCBWay Shared Projects pay 10% PCB + 10% SMT — one fab conversion beats many Amazon electronics clicks.'
                  : 'JLCPCB path is sponsorship + coupon heavy — best as co-brand once approved.'}
            </p>

            <div class="rounded-[10px] border border-border bg-canvas px-3 py-2 font-mono text-[0.6rem] leading-[1.4] text-muted-text">
              <span class="uppercase tracking-[0.08em]">Status</span>
              <span class="ml-2 text-primary-text">{live.pcbway ? 'PCBWay live' : 'PCBWay pending owner ID'} · {live.jlcpcb ? 'JLCPCB live' : 'JLCPCB pending'}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .fab-order-panel :global(a[data-fab]) {
    --mp-fab-ring: transparent;
  }
</style>

<script>
  // @ts-nocheck
  // Lightweight analytics & export-ready hint (privacy-safe, no pixels)
  function bindFab() {
    document.querySelectorAll<HTMLElement>('.fab-order-panel').forEach((panel) => {
      if (panel.dataset.bound === '1') return;
      panel.dataset.bound = '1';
      const statusEl = panel.querySelector<HTMLElement>('#fab-export-status');
      const sim = panel.dataset.sim || 'unknown';

      // Listen for export-ready event from sim JS: window.dispatchEvent(new CustomEvent('fab-export-ready', {detail:{sim, filename}}))
      const onExportReady = (e: Event) => {
        const ce = e as CustomEvent;
        if (ce.detail?.sim && ce.detail.sim !== sim) return;
        if (statusEl) {
          statusEl.textContent = `Export ready: ${ce.detail?.filename || 'file'} — order now`;
          statusEl.classList.add('text-emerald-500');
        }
      };
      window.addEventListener('fab-export-ready' as any, onExportReady);

      // Track clicks with privacy-safe postMessage/event (no third-party)
      panel.querySelectorAll<HTMLAnchorElement>('a[data-fab]').forEach((a) => {
        a.addEventListener('click', () => {
          const merchant = a.dataset.fab;
          // First-party analytics event name per handoff: kit_cta_click / gear_click / export_gate_unlock + fab_click
          try {
            // @ts-ignore — plausible analytics hook if present, otherwise no-op
            window.dispatchEvent(new CustomEvent('mp:analytics', { detail: { event: `fab_${merchant}_click`, sim } }));
            console.debug(`[analytics] fab_${merchant}_click`, { sim });
          } catch {}
        });
      });
    });
  }

  bindFab();
  document.addEventListener('astro:page-load', bindFab);
</script>
