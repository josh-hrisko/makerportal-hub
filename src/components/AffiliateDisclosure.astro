---
import { AMAZON_ASSOCIATE_TAG, SPARKFUN_AFFILIATE_CODE, isFabLive } from '../data/affiliate-links';

export interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
const fab = isFabLive();
const fabParts: string[] = [];
if (fab.pcbway) fabParts.push('PCBWay');
if (fab.jlcpcb) fabParts.push('JLCPCB');
const fabText = fabParts.length ? ` + ${fabParts.join(' + ')} fab referral` : '';
---

<p class={`text-[0.8rem] leading-[1.6] text-muted-text ${className}`}>
  <strong class="font-semibold text-primary-text">Affiliate disclosure:</strong>
  Some links below are affiliate links — Amazon Associates (tag <code>{AMAZON_ASSOCIATE_TAG}</code>) and/or SparkFun Affiliate (<code>ref={SPARKFUN_AFFILIATE_CODE}</code>, 10% on SparkFun Originals{fabText}).
  SparkFun third-party (Pi, Jetson, Teensy) is tracked referral but may pay $0 under their program — we label Originals.
  {fab.pcbway && 'PCBWay Shared Projects pay 10% PCB + 10% SMT. '}
  {fab.jlcpcb && 'JLCPCB via Brand Advocate / referral. '}
  If you buy through them we may earn a commission at no extra cost to you — we only recommend gear we actually use.
  Full policy in our <a href="/privacy#affiliates" class="text-brand-anchor underline underline-offset-2 hover:text-primary-text">disclosure</a>.
</p>
