---
---

<div id="search-modal" class="fixed inset-0 z-[100] hidden items-start justify-center pt-[10vh] pb-[10vh] px-4 opacity-0 transition-opacity duration-200" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search">
  <div id="search-backdrop" class="fixed inset-0 bg-canvas/80 backdrop-blur-sm"></div>
  <div class="relative flex w-full max-w-2xl max-h-full transform flex-col overflow-hidden rounded-2xl border border-border bg-card-bg shadow-2xl transition-all scale-95 opacity-0" id="search-container">
    <div id="search-ui" class="text-primary-text min-h-[300px] overflow-y-auto overscroll-contain p-6"></div>
  </div>
</div>

<style is:global>
  /* Pagefind UI overrides for our theme */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--mp-anchor);
    --pagefind-ui-text: var(--mp-text);
    --pagefind-ui-background: var(--mp-card);
    --pagefind-ui-border: var(--mp-border);
    --pagefind-ui-tag: var(--mp-elevated);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-font: inherit;
  }
  .pagefind-ui__search-input {
    background-color: var(--mp-canvas) !important;
    border: 1px solid var(--mp-border) !important;
    color: var(--mp-text) !important;
  }
  .pagefind-ui__search-clear {
    background-color: transparent !important;
  }
  .pagefind-ui__result {
    border-bottom-color: var(--mp-border) !important;
  }
  .pagefind-ui__result-title {
    color: var(--mp-text) !important;
    font-weight: 600 !important;
  }
  .pagefind-ui__result-excerpt {
    color: var(--mp-muted) !important;
  }
</style>

<script is:inline>
  (() => {
    let initialized = false;
    let isOpen = false;
    let lastFocused = null;
    const modal = document.getElementById('search-modal');
    const backdrop = document.getElementById('search-backdrop');
    const container = document.getElementById('search-container');
    const searchBtns = document.querySelectorAll('#site-search-btn');

    const trapTab = (e) => {
      if (e.key !== 'Tab' || !isOpen) return;
      const focusable = container.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    };

    const enhanceAndFocusInput = () => {
      const input = document.querySelector('.pagefind-ui__search-input');
      if (!input) return null;
      // Mobile keyboard hints – helps iOS/Android summon keyboard on focus
      try {
        input.setAttribute('inputmode', 'search');
        input.setAttribute('enterkeyhint', 'search');
        input.setAttribute('autocomplete', 'off');
        input.setAttribute('autocorrect', 'off');
        input.setAttribute('spellcheck', 'false');
        // Ensure type is search if Pagefind didn't set it
        if (input.getAttribute('type') !== 'search') {
          // keep as search for better UX, but don't break if Pagefind expects text
          input.setAttribute('type', 'search');
        }
      } catch (_) {}
      // One-time Enter -> blur to dismiss keyboard
      if (!input.dataset.mpEnhanced) {
        input.dataset.mpEnhanced = 'true';
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            // Small delay so Pagefind processes the query before blur
            setTimeout(() => {
              try { input.blur(); } catch (_) {}
            }, 50);
          }
        });
      }
      return input;
    };

    const focusInput = (attemptSync) => {
      const input = enhanceAndFocusInput();
      if (!input) return;
      if (attemptSync) {
        try { input.focus({ preventScroll: true }); } catch (_) { try { input.focus(); } catch {} }
      }
      // rAF + micro-delay for render race, still close to gesture
      requestAnimationFrame(() => {
        try { input.focus({ preventScroll: true }); } catch (_) { try { input.focus(); } catch {} }
        // iOS sometimes needs second tick after keyboard anim
        setTimeout(() => {
          const active = document.activeElement;
          if (active !== input) {
            try { input.focus({ preventScroll: true }); } catch (_) { try { input.focus(); } catch {} }
          }
        }, 120);
      });
    };

    const openSearch = () => {
      if (isOpen) return;
      isOpen = true;
      lastFocused = document.activeElement;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      
      // Initialize Pagefind on first open
      if (!initialized) {
        initialized = true;
        
        const loadPagefind = async () => {
          // Add CSS
          const link = document.createElement('link');
          link.href = '/pagefind/pagefind-ui.css';
          link.rel = 'stylesheet';
          document.head.appendChild(link);

          // Add JS
          const script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          script.onload = () => {
            new window.PagefindUI({
              element: "#search-ui",
              showSubResults: true,
              showImages: false,
              resetStyles: false
            });
            // After injection, enhance + focus. For first load this is async (lose gesture),
            // but inputmode=search + second-tick focus improves iOS.
            // We keep a zero-delay sync attempt + rAF as best we can.
            enhanceAndFocusInput();
            focusInput(false);
          };
          document.head.appendChild(script);
        };
        loadPagefind();
      } else {
        // Second+ opens: focus synchronously to preserve user gesture chain for iOS keyboard
        focusInput(true);
      }

      // Animate in
      requestAnimationFrame(() => {
        modal.classList.remove('opacity-0');
        modal.classList.add('opacity-100');
        container.classList.remove('scale-95', 'opacity-0');
        container.classList.add('scale-100', 'opacity-100');
        modal.setAttribute('aria-hidden', 'false');
        // If already initialized, re-focus after animation frame (in case first sync missed)
        if (initialized) {
          // Only for first paint – already attempted sync focus above
          requestAnimationFrame(() => focusInput(false));
        }
      });
    };

    const closeSearch = () => {
      if (!isOpen) return;
      isOpen = false;
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      container.classList.remove('scale-100', 'opacity-100');
      container.classList.add('scale-95', 'opacity-0');
      modal.setAttribute('aria-hidden', 'true');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
        if (lastFocused) lastFocused.focus();
      }, 200);
    };

    searchBtns.forEach(btn => btn.addEventListener('click', openSearch));
    backdrop.addEventListener('click', closeSearch);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeSearch();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        isOpen ? closeSearch() : openSearch();
      }
      trapTab(e);
    });
  })();
</script>
