---
interface Props {
  kicker: string;
  title: string;
  lead: string;
  status?: string;
}

const { kicker, title, lead, status = 'Hub scaffold · Expanding' } = Astro.props;
---

<section class="hero-grid border-b border-border">
  <div class="mx-auto max-w-[88rem] px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
    <div class="flex flex-wrap items-center gap-2">
      <p class="section-kicker">{kicker}</p>
      <span class="rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.64rem] font-medium uppercase tracking-[0.12em] text-muted-text">{status}</span>
    </div>
    <h1 class="mt-6 max-w-4xl text-balance text-[clamp(2.6rem,5.5vw,4.5rem)] font-[700] leading-[0.92] tracking-[-0.06em] text-primary-text">{title}</h1>
    <p class="mt-6 max-w-2xl text-[1.05rem] leading-[1.75] text-muted-text sm:text-lg">{lead}</p>
    <slot name="hero-actions" />
  </div>
</section>

<slot />
