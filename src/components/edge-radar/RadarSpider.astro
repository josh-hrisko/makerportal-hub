---
/**
 * Interactive Hero "Radar" (Polar/Spider Plot) & Board Fit Inspector.
 * Seeded entirely from snapshot fit matrix — zero random, zero 3rd-party JS.
 * Progressive enhancement: vanilla JS inline script enables instant vertex/board
 * switching to inspect model fit lists, RAM ceilings, and headroom.
 */
interface BoardLite {
  id: string;
  name: string;
  class: string;
  ramLabel?: string;
  modelCeilingBytes: number;
}
interface ModelLite {
  id: string;
  runtimeBytes: number;
  fileBytes: number;
  quant?: string | null;
  format: string;
}
interface FitLite {
  modelId: string;
  boardId: string;
  verdict: 'fits' | 'tight' | 'no';
}

interface Props {
  boards: BoardLite[];
  models: ModelLite[];
  fits: FitLite[];
}

import { shortBoardLabel } from '../../lib/edge-radar-labels';

const { boards, models, fits } = Astro.props;

const totalModels = models.length || 1;

const GIB = 1024 * 1024 * 1024;
const MIB = 1024 * 1024;
const fmtBytes = (n: number) => (n >= GIB ? `${(n / GIB).toFixed(1)} GiB` : `${(n / MIB).toFixed(0)} MiB`);

// Compact label with RAM SKU — never strip parentheses alone (Pi 5 8GB vs 16GB)
function getFullShortName(name: string): string {
  return shortBoardLabel(name);
}

// Calculate board stats for radar axes
const boardStats = boards.map((b) => {
  const bFits = fits.filter((f) => f.boardId === b.id);
  const fitsList = bFits.filter((f) => f.verdict === 'fits').map((f) => models.find((m) => m.id === f.modelId)).filter(Boolean) as ModelLite[];
  const tightList = bFits.filter((f) => f.verdict === 'tight').map((f) => models.find((m) => m.id === f.modelId)).filter(Boolean) as ModelLite[];
  const noList = bFits.filter((f) => f.verdict === 'no').map((f) => models.find((m) => m.id === f.modelId)).filter(Boolean) as ModelLite[];

  const fitsCount = fitsList.length;
  const tightCount = tightList.length;
  const noCount = noList.length;

  const fitsScore = fitsCount / totalModels;
  const tightScore = (fitsCount + tightCount) / totalModels;
  const fitPct = Math.round((fitsCount / totalModels) * 100);
  const fullShortName = getFullShortName(b.name);

  return {
    board: b,
    fullShortName,
    fitsCount,
    tightCount,
    noCount,
    fitsScore,
    tightScore,
    fitPct,
    fitsList,
    tightList,
    noList,
  };
});

// Canvas dimensions & ViewBox coordinate system with negative origin (-80, -20)
// to guarantee long labels like "Jetson Orin Nano" are NEVER clipped on the left edge.
const VB_X = -80;
const VB_Y = -20;
const VB_W = 600;
const VB_H = 320;

const CX = 220; // radar center X
const CY = 140; // radar center Y
const R = 90;  // radar polygon radius

const N = boardStats.length;
// Angles for axes starting top (-PI/2)
const axes = boardStats.map((st, i) => {
  const angle = -Math.PI / 2 + (i * 2 * Math.PI) / N;
  return {
    ...st,
    index: i,
    angle,
    cos: Math.cos(angle),
    sin: Math.sin(angle),
  };
});

// Points for Clean Fits Polygon (Emerald)
const fitsPolyPoints = axes.map((ax) => {
  const rEff = Math.max(ax.fitsScore, 0.05) * R;
  return { x: CX + rEff * ax.cos, y: CY + rEff * ax.sin };
});
const fitsPolyStr = fitsPolyPoints.map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');

// Points for Tight Fits Polygon (Amber)
const tightPolyPoints = axes.map((ax) => {
  const rEff = Math.max(ax.tightScore, 0.05) * R;
  return { x: CX + rEff * ax.cos, y: CY + rEff * ax.sin };
});
const tightPolyStr = tightPolyPoints.map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');

// Concentric grid rings (25%, 50%, 75%, 100%)
const rings = [0.25, 0.5, 0.75, 1.0];

// Default selected board (Pi 5 or first with fits)
const defaultBoardIdx = axes.findIndex((a) => a.fitsCount > 0) >= 0 ? axes.findIndex((a) => a.fitsCount > 0) : 0;
const componentId = `radar-${Math.random().toString(36).substring(2, 7)}`;
---

<div class="relative w-full rounded-[20px] border border-border bg-card-bg p-5 shadow-sm" id={componentId}>
  {/* Component Header */}
  <div class="flex flex-wrap items-center justify-between gap-2 border-b border-border pb-3">
    <div>
      <div class="flex items-center gap-1.5 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-primary-text">
        <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
        Interactive Board Coverage Radar
      </div>
      <p class="mt-0.5 font-mono text-[0.6rem] text-muted-text">
        Click any board vertex or pill below to inspect model headroom & RAM limits.
      </p>
    </div>
    <div class="flex items-center gap-2 font-mono text-[0.58rem] text-muted-text">
      <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-emerald-500"></span> Fits (≤80%)</span>
      <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-amber-500"></span> Tight (&le;100%)</span>
    </div>
  </div>

  {/* Radar Board Chip Selector Bar */}
  <div class="mt-3 flex flex-wrap gap-1.5" id={`${componentId}-chips`} role="tablist" aria-label="Select hardware board to inspect">
    {axes.map((ax, idx) => (
      <button
        type="button"
        role="tab"
        aria-selected={idx === defaultBoardIdx ? 'true' : 'false'}
        data-board-idx={idx}
        class={`radar-chip-btn rounded-full border px-2.5 py-1 font-mono text-[0.6rem] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor ${
          idx === defaultBoardIdx
            ? 'active border-primary-text bg-primary-text font-bold text-canvas'
            : 'border-border bg-elevated text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text'
        }`}
      >
        {ax.fullShortName} ({ax.fitsCount})
      </button>
    ))}
  </div>

  {/* SVG Radar Chart Canvas — ViewBox starting at -80 to ensure zero text clipping */}
  <div class="relative mt-2 w-full" style={`aspect-ratio: ${VB_W}/${VB_H};`}>
    <svg
      viewBox={`${VB_X} ${VB_Y} ${VB_W} ${VB_H}`}
      width="100%"
      height="100%"
      role="img"
      aria-label={`Interactive radar chart showing fit capacity across ${N} hardware boards`}
      class="absolute inset-0 h-full w-full overflow-visible text-primary-text"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <radialGradient id={`${componentId}-glow`} cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="var(--mp-cta)" stop-opacity="0.25"></stop>
          <stop offset="100%" stop-color="var(--mp-cta)" stop-opacity="0.02"></stop>
        </radialGradient>
      </defs>

      {/* Grid rings */}
      <g aria-hidden="true">
        {rings.map((rFrac) => {
          const rVal = rFrac * R;
          const ringPoints = axes
            .map((ax) => `${(CX + rVal * ax.cos).toFixed(1)},${(CY + rVal * ax.sin).toFixed(1)}`)
            .join(' ');
          return (
            <polygon
              points={ringPoints}
              fill="none"
              stroke="var(--mp-border)"
              stroke-width={rFrac === 1.0 ? '1.2' : '0.8'}
              stroke-dasharray={rFrac === 1.0 ? '0' : '3 3'}
              opacity={rFrac === 1.0 ? '0.9' : '0.5'}
            />
          );
        })}

        {/* Axis radial spokes */}
        {axes.map((ax) => (
          <line
            x1={CX}
            y1={CY}
            x2={CX + R * ax.cos}
            y2={CY + R * ax.sin}
            stroke="var(--mp-border)"
            stroke-width="1"
            opacity="0.7"
          />
        ))}
      </g>

      {/* Radial background glow */}
      <circle cx={CX} cy={CY} r={R} fill={`url(#${componentId}-glow)`} aria-hidden="true" />

      {/* Tight Fits Polygon (Amber outline/fill) */}
      <polygon
        points={tightPolyStr}
        fill="#f59e0b"
        fill-opacity="0.15"
        stroke="#f59e0b"
        stroke-width="1.5"
        stroke-dasharray="3 3"
        stroke-linejoin="round"
      />

      {/* Clean Fits Polygon (Emerald fill) */}
      <polygon
        points={fitsPolyStr}
        fill="#10b981"
        fill-opacity="0.28"
        stroke="#10b981"
        stroke-width="2.2"
        stroke-linejoin="round"
      />

      {/* Vertices & Axis Labels */}
      {axes.map((ax, i) => {
        const fp = fitsPolyPoints[i];
        const labelDist = R + 24;
        const lx = CX + labelDist * ax.cos;
        const ly = CY + labelDist * ax.sin;

        // Text anchor alignment:
        // Top (i=0): middle anchor
        // Right side (cos > 0.15): start anchor
        // Left side (cos < -0.15): end anchor
        const textAnchor = Math.abs(ax.cos) < 0.15 ? 'middle' : ax.cos > 0 ? 'start' : 'end';
        const isSelected = i === defaultBoardIdx;

        return (
          <g
            class="radar-vertex-group cursor-pointer"
            data-board-idx={i}
            tabindex="0"
            role="button"
            aria-label={`Inspect ${ax.fullShortName} board — ${ax.fitsCount} fits`}
          >
            {/* Outer halo highlight when selected */}
            <circle
              cx={CX + R * ax.cos}
              cy={CY + R * ax.sin}
              r={isSelected ? 10 : 0}
              fill="none"
              stroke="var(--mp-cta)"
              stroke-width="1.8"
              class="vertex-highlight transition-all"
            />

            {/* Axis boundary dot */}
            <circle
              cx={CX + R * ax.cos}
              cy={CY + R * ax.sin}
              r="3.5"
              fill="var(--mp-border-strong)"
            />

            {/* Fits vertex dot */}
            {ax.fitsCount > 0 && (
              <circle
                cx={fp.x}
                cy={fp.y}
                r="4.5"
                fill="var(--mp-card)"
                stroke="#10b981"
                stroke-width="2"
              />
            )}

            {/* Label — full short name with zero clipping thanks to -80 viewBox origin */}
            <text
              x={lx}
              y={ly - 4}
              text-anchor={textAnchor}
              font-family="var(--font-sans)"
              font-size="10"
              font-weight="700"
              fill="currentColor"
              class="text-primary-text"
            >
              {ax.fullShortName}
            </text>
            <text
              x={lx}
              y={ly + 8}
              text-anchor={textAnchor}
              font-family="var(--font-mono)"
              font-size="8.5"
              fill="currentColor"
              class={ax.fitsCount > 0 ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'text-muted-text'}
            >
              {ax.fitsCount}/{totalModels} fit ({ax.fitPct}%)
            </text>
          </g>
        );
      })}

      {/* Center origin */}
      <circle cx={CX} cy={CY} r="2.5" fill="var(--mp-border-strong)" />
    </svg>
  </div>

  {/* Interactive Board Detail Inspector Panel */}
  <div class="mt-2 border-t border-border pt-3" id={`${componentId}-inspector`}>
    {axes.map((ax, idx) => (
      <div
        data-inspector-idx={idx}
        class={`inspector-panel ${idx === defaultBoardIdx ? 'block' : 'hidden'}`}
      >
        <div class="flex items-center justify-between gap-2">
          <div>
            <span class="rounded-full bg-elevated border border-border px-2 py-0.5 font-mono text-[0.55rem] uppercase tracking-[0.1em] text-muted-text">
              {ax.board.class}
            </span>
            <h4 class="mt-1 font-mono text-[0.88rem] font-bold text-primary-text">
              {ax.board.name}
            </h4>
          </div>
          <div class="text-right font-mono text-[0.62rem]">
            <span class="block text-primary-text font-bold">Ceiling: {fmtBytes(ax.board.modelCeilingBytes)}</span>
            <span class="text-muted-text">{ax.board.ramLabel}</span>
          </div>
        </div>

        {/* Model Breakdown for Selected Board */}
        <div class="mt-2.5 flex items-center gap-3 font-mono text-[0.65rem]">
          <span class="inline-flex items-center gap-1 text-emerald-600 dark:text-emerald-400 font-semibold">
            ✔ {ax.fitsCount} Fits
          </span>
          {ax.tightCount > 0 && (
            <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400 font-semibold">
              ⚠ {ax.tightCount} Tight
            </span>
          )}
          <span class="inline-flex items-center gap-1 text-muted-text">
            ✖ {ax.noCount} Exceed Ceiling
          </span>
        </div>

        {/* Fits Model List Pills */}
        <div class="mt-2 flex flex-wrap gap-1.5">
          {ax.fitsList.length > 0 ? (
            ax.fitsList.slice(0, 4).map((m) => (
              <a
                href={`#radar`}
                class="inline-flex items-center gap-1 rounded-md border border-border bg-canvas px-2 py-0.5 font-mono text-[0.6rem] text-primary-text hover:border-[var(--mp-border-strong)]"
              >
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                <span class="truncate max-w-[120px]">{m.id.split('/')[1] || m.id}</span>
                <span class="text-muted-text">({fmtBytes(m.runtimeBytes)})</span>
              </a>
            ))
          ) : (
            <span class="font-mono text-[0.6rem] text-muted-text italic">
              No scanned models fit within this board's {fmtBytes(ax.board.modelCeilingBytes)} ceiling.
            </span>
          )}
        </div>
      </div>
    ))}
  </div>
</div>

{/* Inline Vanilla Script — Event Delegation + Idempotent Binding (View-Transition safe) */}
<script is:inline define:vars={{ componentId }}>
  function setupRadarInspector() {
    const root = document.getElementById(componentId);
    if (!root) return;
    // Avoid rebinding duplicate listeners on Astro view transitions
    if (root.dataset.radarBound === 'true') {
      // Re-query live nodes for state sync after DOM swap, then exit early; delegated listeners survive
      return;
    }
    root.dataset.radarBound = 'true';

    function setActiveBoard(idx) {
      const chips = root.querySelectorAll('.radar-chip-btn');
      const vertices = root.querySelectorAll('.radar-vertex-group');
      const panels = root.querySelectorAll('.inspector-panel');

      chips.forEach((c) => {
        const cIdx = parseInt(c.getAttribute('data-board-idx') || '0', 10);
        const isActive = cIdx === idx;
        if (isActive) {
          c.classList.add('active', 'border-primary-text', 'bg-primary-text', 'font-bold', 'text-canvas');
          c.classList.remove('border-border', 'bg-elevated', 'text-muted-text');
          c.setAttribute('aria-selected', 'true');
        } else {
          c.classList.remove('active', 'border-primary-text', 'bg-primary-text', 'font-bold', 'text-canvas');
          c.classList.add('border-border', 'bg-elevated', 'text-muted-text');
          c.setAttribute('aria-selected', 'false');
        }
      });

      vertices.forEach((v) => {
        const vIdx = parseInt(v.getAttribute('data-board-idx') || '0', 10);
        const hl = v.querySelector('.vertex-highlight');
        if (hl) hl.setAttribute('r', vIdx === idx ? '10' : '0');
      });

      panels.forEach((p) => {
        const pIdx = parseInt(p.getAttribute('data-inspector-idx') || '0', 10);
        if (pIdx === idx) {
          p.classList.remove('hidden');
          p.classList.add('block');
        } else {
          p.classList.remove('block');
          p.classList.add('hidden');
        }
      });
    }

    // Single delegated click handler for chips + SVG vertices
    root.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('.radar-chip-btn, .radar-vertex-group');
      if (!btn) return;
      // Ensure clicked element belongs to this root instance
      if (!root.contains(btn)) return;
      const raw = btn.getAttribute('data-board-idx');
      if (raw === null) return;
      const idx = parseInt(raw, 10);
      if (Number.isNaN(idx)) return;
      setActiveBoard(idx);
    });

    // Keyboard activation for SVG vertices (Enter/Space)
    root.addEventListener('keydown', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const vertex = target.closest('.radar-vertex-group');
      if (!vertex || !root.contains(vertex)) return;
      e.preventDefault();
      const idx = parseInt(vertex.getAttribute('data-board-idx') || '0', 10);
      setActiveBoard(idx);
    });
  }

  function initRadarAll() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupRadarInspector, { once: true });
    } else {
      setupRadarInspector();
    }
  }

  initRadarAll();
  document.addEventListener('astro:page-load', () => {
    const root = document.getElementById(componentId);
    if (root) {
      // Clear bound flag so fresh DOM can rebind after full page swap, but delegated pattern stays idempotent
      if (!root.dataset.radarBound) {
        setupRadarInspector();
      } else {
        // Edge case: same id persisted but new children: ensure listeners still exist; if not, reset flag and re-init
        // We keep flag true to avoid double binding; setActive still callable via new click events.
      }
    } else {
      setupRadarInspector();
    }
  });
  document.addEventListener('astro:after-swap', setupRadarInspector);
</script>
