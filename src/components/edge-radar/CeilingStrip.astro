---
/**
 * Board RAM Ceilings & Model Footprint Ruler Component.
 * Plots today's scanned models on a 7 MiB → 6.5 GiB log ruler vs each board's
 * datasheet memory ceiling wall.
 * SSR-only, zero JS requirement, themeable, CLS 0 via aspect ratio.
 */
interface BoardLite {
  id: string;
  name: string;
  class: string;
  modelCeilingBytes: number;
  ramLabel?: string;
}
interface ModelLite {
  id: string;
  runtimeBytes: number;
  fileBytes: number;
}
interface FitLite {
  modelId: string;
  boardId: string;
  verdict: 'fits' | 'tight' | 'no';
}

interface Props {
  boards: BoardLite[];
  models: ModelLite[];
  fits: FitLite[];
}

const { boards, models, fits } = Astro.props;

const MIB = 1024 * 1024;
const GIB = 1024 * 1024 * 1024;

const DOMAIN_MIN = Math.min(...boards.map((b) => b.modelCeilingBytes));
const DOMAIN_MAX = Math.max(...boards.map((b) => b.modelCeilingBytes));

const LOG_MIN = Math.log10(DOMAIN_MIN);
const LOG_MAX = Math.log10(DOMAIN_MAX);
const RANGE = LOG_MAX - LOG_MIN;

const clamp = (v: number, lo: number, hi: number) => Math.min(Math.max(v, lo), hi);
function logFrac(bytes: number) {
  const c = clamp(bytes, DOMAIN_MIN, DOMAIN_MAX);
  return (Math.log10(c) - LOG_MIN) / RANGE;
}
function fmtBytes(n: number) {
  if (n >= GIB) return `${(n / GIB).toFixed(n >= 10 * GIB ? 1 : 2)} GiB`;
  return `${(n / MIB).toFixed(n >= 10 * MIB ? 0 : 1)} MiB`;
}
function shortBoardName(b: BoardLite) {
  return b.name.split('(')[0].trim();
}

// Class badge & icon helper
function classBadge(c: string) {
  if (c === 'mcu') return { icon: '⚡', label: 'MCU' };
  if (c === 'sbc') return { icon: '🖥️', label: 'SBC' };
  if (c === 'accelerator') return { icon: '🧠', label: 'Accelerator' };
  if (c === 'edge-gpu') return { icon: '🚀', label: 'Edge GPU' };
  return { icon: '💻', label: 'Compute' };
}

const W = 720;
const LEFT = 200; // Left gutter for board labels & RAM specs
const RIGHT = 24;
const TRACK_W = W - LEFT - RIGHT; // 496px

const HEADER = 56;
const ROW_H = 44;
const FOOTER = 38;
const H = HEADER + boards.length * ROW_H + FOOTER + 8;

const fitMap = new Map<string, 'fits' | 'tight' | 'no'>();
for (const f of fits) fitMap.set(`${f.modelId}::${f.boardId}`, f.verdict);

const distinctCeilings = [...new Set(boards.map((b) => b.modelCeilingBytes))]
  .sort((a, b) => a - b)
  .map((bytes) => ({
    bytes,
    x: LEFT + logFrac(bytes) * TRACK_W,
    label: fmtBytes(bytes),
  }));

const xTicks = (() => {
  const candidates = [8 * MIB, 16 * MIB, 32 * MIB, 64 * MIB, 128 * MIB, 256 * MIB, 512 * MIB, 1 * GIB, 2 * GIB, 4 * GIB, 6.5 * GIB];
  return candidates
    .filter((b) => b >= DOMAIN_MIN && b <= DOMAIN_MAX)
    .map((b) => ({ bytes: b, x: LEFT + logFrac(b) * TRACK_W, label: fmtBytes(b) }));
})();

function aggregateVerdict(modelId: string): 'fits' | 'tight' | 'no' {
  const vs = boards.map((b) => fitMap.get(`${modelId}::${b.id}`) ?? 'no');
  if (vs.includes('fits')) return 'fits';
  if (vs.includes('tight')) return 'tight';
  return 'no';
}
const overviewDots = models.map((m) => ({
  id: m.id,
  x: LEFT + logFrac(m.runtimeBytes) * TRACK_W,
  overflow: m.runtimeBytes > DOMAIN_MAX || m.runtimeBytes < DOMAIN_MIN,
  verdict: aggregateVerdict(m.id),
  runtime: m.runtimeBytes,
}));

const totalFits = overviewDots.filter((d) => d.verdict !== 'no').length;
---

<div class="group/strip w-full overflow-hidden rounded-[20px] border border-border bg-card-bg shadow-sm">
  {/* Clear Component Header */}
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border bg-elevated/40 px-5 py-4">
    <div>
      <div class="flex items-center gap-2">
        <span class="flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
        <h3 class="font-mono text-[0.72rem] font-bold uppercase tracking-[0.14em] text-primary-text">
          Hardware RAM Limits & Model Footprint Ruler
        </h3>
      </div>
      <p class="mt-1 text-[0.82rem] leading-[1.5] text-muted-text max-w-2xl">
        Models to the left of a board's vertical ceiling line fit within that hardware's RAM budget (file bytes &times; 1.25 runtime overhead).
      </p>
    </div>
    <div class="flex items-center gap-3 font-mono text-[0.6rem] text-muted-text shrink-0">
      <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-emerald-500"></span> Fits (&le;80%)</span>
      <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-amber-500"></span> Tight (&le;100%)</span>
      <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-muted-text/30"></span> Exceeds (&gt;100%)</span>
    </div>
  </div>

  {/* SVG Canvas Container */}
  <div class="relative w-full bg-canvas" style={`aspect-ratio: ${W}/${H};`}>
    <svg
      viewBox={`0 0 ${W} ${H}`}
      width="100%"
      height="100%"
      role="img"
      aria-label={`Board RAM ceilings from ${fmtBytes(DOMAIN_MIN)} to ${fmtBytes(DOMAIN_MAX)} with ${models.length} models plotted`}
      class="absolute inset-0 h-full w-full overflow-visible text-primary-text"
      xmlns="http://www.w3.org/2000/svg"
    >
      <style>
        .board-row-group { transition: opacity 0.15s ease; }
        .board-row-group:hover rect.row-bg { fill: var(--mp-elevated); opacity: 0.95 !important; }
        .board-row-group:hover circle.model-dot { transform: scale(1.3); transform-origin: center; }
      </style>

      {/* Grid lines at distinct ceiling boundaries */}
      {distinctCeilings.map((c) => (
        <g>
          <line
            x1={c.x}
            y1={HEADER - 12}
            x2={c.x}
            y2={H - FOOTER}
            stroke="var(--mp-border)"
            stroke-width="1"
            stroke-dasharray="4 4"
            opacity="0.8"
          />
        </g>
      ))}

      {/* Overview summary spark band at top */}
      <g class="group/spark">
        <text x={LEFT - 10} y={HEADER - 22} text-anchor="end" font-family="var(--font-mono)" font-size="8.5" font-weight="700" fill="currentColor" class="text-primary-text">
          All Models ({totalFits}/{models.length} fit)
        </text>
        <rect
          x={LEFT}
          y={HEADER - 30}
          width={TRACK_W}
          height="14"
          rx="7"
          fill="var(--mp-elevated)"
          stroke="var(--mp-border)"
          stroke-width="1"
        />
        {overviewDots.map((d) => {
          const cls = d.verdict === 'fits' ? 'text-emerald-600 dark:text-emerald-400' : d.verdict === 'tight' ? 'text-amber-600 dark:text-amber-400' : 'text-muted-text';
          return (
            <g class={cls}>
              <circle cx={d.x} cy={HEADER - 23} r={d.verdict === 'no' ? 3 : 4} fill="currentColor" stroke="var(--mp-card)" stroke-width="1">
                <title>{d.id} · {fmtBytes(d.runtime)} runtime · {d.verdict}{d.overflow ? ' · beyond domain' : ''}</title>
              </circle>
            </g>
          );
        })}
      </g>

      {/* Board Rows */}
      {boards.map((board, row) => {
        const y = HEADER + row * ROW_H + ROW_H / 2;
        const ceilingX = LEFT + logFrac(board.modelCeilingBytes) * TRACK_W;
        const badge = classBadge(board.class);

        return (
          <g class="board-row-group cursor-pointer">
            {/* Row background */}
            <rect
              x={0}
              y={HEADER + row * ROW_H}
              width={W}
              height={ROW_H}
              fill={row % 2 === 0 ? 'var(--mp-card)' : 'var(--mp-elevated)'}
              opacity={row % 2 === 0 ? 1 : 0.4}
              class="row-bg"
            />

            {/* Guideline across track */}
            <line x1={LEFT} y1={y} x2={W - RIGHT} y2={y} stroke="var(--mp-border)" stroke-width="0.7" opacity="0.6" />

            {/* Board identity & RAM specs in left gutter */}
            <g transform={`translate(14, ${y - 8})`}>
              <text font-family="var(--font-sans)" font-size="11.5" font-weight="700" fill="currentColor" class="text-primary-text">
                {badge.icon} {shortBoardName(board)}
              </text>
              <text y="14" font-family="var(--font-mono)" font-size="8.2" fill="currentColor" class="text-muted-text">
                {badge.label} · {board.ramLabel ?? fmtBytes(board.modelCeilingBytes)}
              </text>
            </g>

            {/* Memory Ceiling Wall (Vertical Bar with Ceiling Badge) */}
            <g>
              <line
                x1={ceilingX}
                y1={HEADER + row * ROW_H + 4}
                x2={ceilingX}
                y2={HEADER + (row + 1) * ROW_H - 4}
                stroke="var(--mp-cta)"
                stroke-width="2.2"
                opacity="0.95"
              />
              <circle cx={ceilingX} cy={HEADER + row * ROW_H + 5} r="3" fill="var(--mp-cta)" />
            </g>

            {/* Model dots for this board */}
            {models.map((m) => {
              const verdict = fitMap.get(`${m.id}::${board.id}`) ?? 'no';
              const cls = verdict === 'fits' ? 'text-emerald-600 dark:text-emerald-400' : verdict === 'tight' ? 'text-amber-600 dark:text-amber-400' : 'text-muted-text';
              const mx = LEFT + logFrac(m.runtimeBytes) * TRACK_W;
              const overflow = m.runtimeBytes > DOMAIN_MAX || m.runtimeBytes < DOMAIN_MIN;
              return (
                <g class={cls}>
                  {verdict !== 'no' && (
                    <circle cx={mx} cy={y} r="6.5" fill="currentColor" opacity="0.18" />
                  )}
                  <circle
                    cx={mx}
                    cy={y}
                    r={verdict === 'no' ? 3.5 : 4.5}
                    fill="currentColor"
                    stroke="var(--mp-card)"
                    stroke-width={verdict === 'no' ? 0.8 : 1.2}
                    opacity={verdict === 'no' ? 0.45 : 0.98}
                    class="model-dot"
                  >
                    <title>{m.id} · {fmtBytes(m.runtimeBytes)} runtime on {shortBoardName(board)} → {verdict.toUpperCase()}</title>
                  </circle>
                  {overflow && (
                    <text x={W - RIGHT - 10} y={y + 3} font-family="var(--font-mono)" font-size="8" font-weight="700" fill="currentColor" class="text-amber-500">
                      ↗
                    </text>
                  )}
                </g>
              );
            })}
          </g>
        );
      })}

      {/* Ceiling header badges floating above vertical ceiling lines */}
      <g class="text-[0.68rem]">
        {distinctCeilings.map((c) => (
          <g transform={`translate(${clamp(c.x, LEFT + 30, W - RIGHT - 30)}, ${HEADER - 42})`}>
            <rect x="-30" y="-8" width="60" height="15" rx="6" fill="var(--mp-card)" stroke="var(--mp-cta)" stroke-width="1" />
            <text x="0" y="3" text-anchor="middle" font-family="var(--font-mono)" font-size="8" font-weight="700" fill="currentColor" class="text-primary-text">
              Limit: {c.label}
            </text>
          </g>
        ))}
      </g>

      {/* Footer ticks */}
      <g>
        {xTicks.map((t) => (
          <g>
            <line x1={t.x} y1={H - FOOTER} x2={t.x} y2={H - FOOTER + 5} stroke="var(--mp-border-strong)" stroke-width="1" />
            <text x={t.x} y={H - 8} text-anchor="middle" font-family="var(--font-mono)" font-size="8.5" fill="currentColor" class="text-muted-text">{t.label}</text>
          </g>
        ))}
        <line x1={LEFT} y1={H - FOOTER} x2={W - RIGHT} y2={H - FOOTER} stroke="var(--mp-border-strong)" stroke-width="1" />
      </g>
    </svg>
  </div>

  <div class="border-t border-border bg-elevated/30 px-5 py-3 font-mono text-[0.62rem] leading-[1.5] text-muted-text flex flex-wrap items-center justify-between gap-2">
    <span>
      Log ruler scale. Every dot is a model at its estimated runtime footprint (file size &times; 1.25). Vertical orange bars mark each hardware board's datasheet RAM ceiling wall.
    </span>
    <span class="font-bold text-primary-text">7 MiB MCU &rarr; 6.5 GiB SBC</span>
  </div>
</div>
