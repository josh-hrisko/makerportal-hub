---
/**
 * Interactive Hardware RAM Containment & Model Headroom Inspector.
 * Replaces flat static log plots with dynamic memory containment gauges
 * showing exact RAM occupation, 80% safety thresholds, and headroom across 5 board classes.
 */
interface BoardLite {
  id: string;
  name: string;
  class: string;
  modelCeilingBytes: number;
  ramLabel?: string;
}
interface ModelLite {
  id: string;
  runtimeBytes: number;
  fileBytes: number;
  quant?: string | null;
  format: string;
}
interface FitLite {
  modelId: string;
  boardId: string;
  verdict: 'fits' | 'tight' | 'no';
}

interface Props {
  boards: BoardLite[];
  models: ModelLite[];
  fits?: FitLite[];
}

const { boards, models } = Astro.props;

const MIB = 1024 * 1024;
const GIB = 1024 * 1024 * 1024;

const fmtBytes = (n: number) => {
  if (n >= GIB) return `${(n / GIB).toFixed(n >= 10 * GIB ? 1 : 2)} GiB`;
  return `${(n / MIB).toFixed(n >= 10 * MIB ? 0 : 1)} MiB`;
};

const shortBoardName = (b: BoardLite) => b.name.split('(')[0].trim();

function classBadge(c: string) {
  if (c === 'mcu') return { icon: '⚡', label: 'Microcontroller' };
  if (c === 'sbc') return { icon: '🖥️', label: 'Single Board Computer' };
  if (c === 'accelerator') return { icon: '🧠', label: 'AI Accelerator' };
  if (c === 'edge-gpu') return { icon: '🚀', label: 'Edge GPU' };
  return { icon: '💻', label: 'Embedded System' };
}

// Calculate default selected model stats
const defaultModel = models[0] || { id: 'default', runtimeBytes: 100 * MIB, fileBytes: 80 * MIB, format: 'GGUF' };
const componentId = `headroom-${Math.random().toString(36).substring(2, 7)}`;

// Build initial fit payload for SSR
const boardPayload = boards.map((b) => {
  const ceiling = b.modelCeilingBytes;
  const initialRuntime = defaultModel.runtimeBytes;
  const pct = Math.min(Math.round((initialRuntime / ceiling) * 100), 999);

  let status: 'fits' | 'tight' | 'exceeds' = 'fits';
  if (pct > 100) status = 'exceeds';
  else if (pct > 80) status = 'tight';

  const diff = Math.abs(ceiling - initialRuntime);
  let statusText = '';
  if (status === 'fits') statusText = `❇️ ${fmtBytes(diff)} Free Headroom`;
  else if (status === 'tight') statusText = `⚠️ ${fmtBytes(diff)} Tight Margin`;
  else statusText = `🛑 Exceeds Ceiling by ${fmtBytes(diff)}`;

  return {
    board: b,
    badge: classBadge(b.class),
    shortName: shortBoardName(b),
    pct,
    status,
    statusText,
  };
});

// Clean payload for script
const modelsData = models.map((m) => ({ id: m.id, runtimeBytes: m.runtimeBytes }));
---

<div class="w-full overflow-hidden rounded-[20px] border border-border bg-card-bg shadow-sm" id={componentId}>
  {/* Component Header */}
  <div class="border-b border-border bg-elevated/40 px-5 py-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <div class="flex items-center gap-2 font-mono text-[0.68rem] font-bold uppercase tracking-[0.14em] text-primary-text">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Hardware RAM Containment & Headroom Inspector
        </div>
        <p class="mt-1 text-[0.82rem] leading-[1.5] text-muted-text max-w-2xl">
          Click any scanned model below to inspect how its runtime footprint occupies memory across targets — from 7 MiB microcontrollers to 6.5 GiB single-board computers.
        </p>
      </div>
      <div class="flex items-center gap-3 font-mono text-[0.6rem] text-muted-text shrink-0">
        <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-emerald-500"></span> Fits (&le;80%)</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-amber-500"></span> Tight (&le;100%)</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-red-500"></span> Exceeds (&gt;100%)</span>
      </div>
    </div>

    {/* Interactive Model Selector Pills */}
    <div class="mt-3.5 flex flex-wrap items-center gap-1.5">
      <span class="font-mono text-[0.6rem] font-semibold text-primary-text uppercase tracking-wider mr-1">
        Select Model:
      </span>
      {models.map((m, idx) => {
        const nameLabel = m.id.split('/')[1] || m.id;
        const isSelected = idx === 0;
        return (
          <button
            type="button"
            data-model-idx={idx}
            class={`model-select-btn rounded-full border px-2.5 py-1 font-mono text-[0.6rem] transition-all ${
              isSelected
                ? 'active border-primary-text bg-primary-text font-bold text-canvas shadow-xs'
                : 'border-border bg-canvas text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text'
            }`}
          >
            <span class="font-medium">{nameLabel}</span>
            <span class="ml-1 opacity-75">({fmtBytes(m.runtimeBytes)})</span>
          </button>
        );
      })}
    </div>
  </div>

  {/* Live Active Model Banner */}
  <div class="border-b border-border bg-canvas px-5 py-2.5 flex items-center justify-between font-mono text-[0.65rem]">
    <div class="flex items-center gap-2">
      <span class="text-muted-text">Active Model:</span>
      <span class="font-bold text-primary-text" id={`${componentId}-active-name`}>
        {defaultModel.id}
      </span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-muted-text">Estimated Runtime Footprint:</span>
      <span class="font-bold text-emerald-600 dark:text-emerald-400" id={`${componentId}-active-bytes`}>
        {fmtBytes(defaultModel.runtimeBytes)}
      </span>
    </div>
  </div>

  {/* Board Memory Containment Vessels (5 Rows) */}
  <div class="p-5 space-y-4">
    {boardPayload.map((item) => (
      <div
        class="board-vessel-card rounded-[14px] border border-border bg-elevated/30 p-3.5 transition-colors hover:border-[var(--mp-border-strong)]"
        data-board-id={item.board.id}
        data-ceiling-bytes={item.board.modelCeilingBytes}
      >
        {/* Vessel Header */}
        <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
          <div class="flex items-center gap-2">
            <span class="text-sm">{item.badge.icon}</span>
            <div>
              <span class="font-mono text-[0.82rem] font-bold text-primary-text">
                {item.shortName}
              </span>
              <span class="ml-2 font-mono text-[0.58rem] uppercase tracking-wider text-muted-text rounded-md bg-canvas border border-border px-1.5 py-0.5">
                {item.badge.label}
              </span>
            </div>
          </div>
          <div class="font-mono text-[0.62rem] text-right">
            <span class="text-muted-text">RAM Budget Ceiling: </span>
            <span class="font-bold text-primary-text">{fmtBytes(item.board.modelCeilingBytes)}</span>
            {item.board.ramLabel && <span class="text-muted-text ml-1">({item.board.ramLabel})</span>}
          </div>
        </div>

        {/* Progress Vessel Bar with 80% Safety Line */}
        <div class="relative h-6 w-full rounded-full bg-canvas border border-border overflow-hidden">
          {/* 80% Safety Line Marker */}
          <div
            class="absolute top-0 bottom-0 w-[2px] bg-amber-500/70 z-10"
            style="left: 80%;"
            title="80% Recommended Safety Threshold"
          ></div>

          {/* Filled Memory Progress Gauge */}
          <div
            class={`vessel-bar h-full transition-all duration-300 rounded-full ${
              item.status === 'fits'
                ? 'bg-emerald-500'
                : item.status === 'tight'
                ? 'bg-amber-500'
                : 'bg-red-500'
            }`}
            style={`width: ${Math.min(item.pct, 100)}%;`}
          ></div>
        </div>

        {/* Vessel Footer Metrics */}
        <div class="mt-2 flex items-center justify-between font-mono text-[0.64rem]">
          <div class="flex items-center gap-2">
            <span class="text-muted-text">Occupied:</span>
            <span class="font-bold text-primary-text vessel-occupied-text">
              {fmtBytes(defaultModel.runtimeBytes)} ({item.pct}%)
            </span>
          </div>
          <div class="font-bold vessel-headroom-badge">
            <span class={item.status === 'fits' ? 'text-emerald-600 dark:text-emerald-400' : item.status === 'tight' ? 'text-amber-600 dark:text-amber-400' : 'text-red-600 dark:text-red-400'}>
              {item.statusText}
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* Footer Log Ruler Macro Summary */}
  <div class="border-t border-border bg-elevated/20 px-5 py-3 font-mono text-[0.62rem] text-muted-text flex flex-wrap items-center justify-between gap-2">
    <span>
      Memory containment evaluates required runtime bytes (file &times; 1.25 for KV cache & tensors) against hardware ceiling limits.
    </span>
    <span class="font-bold text-primary-text">7 MiB MCU &rarr; 6.5 GiB SBC</span>
  </div>
</div>

{/* Inline Vanilla Script for Interactive Model Switching */}
<script is:inline define:vars={{ componentId, modelsData }}>
  function setupHeadroomInspector() {
    const root = document.getElementById(componentId);
    if (!root) return;

    const selectBtns = root.querySelectorAll('.model-select-btn');
    const activeNameEl = root.getElementById(`${componentId}-active-name`);
    const activeBytesEl = root.getElementById(`${componentId}-active-bytes`);
    const vesselCards = root.querySelectorAll('.board-vessel-card');

    const GIB = 1024 * 1024 * 1024;
    const MIB = 1024 * 1024;
    function formatBytes(n) {
      if (n >= GIB) return (n / GIB).toFixed(n >= 10 * GIB ? 1 : 2) + ' GiB';
      return (n / MIB).toFixed(n >= 10 * MIB ? 0 : 1) + ' MiB';
    }

    function selectModel(mIdx) {
      const model = modelsData[mIdx];
      if (!model) return;

      // Update button active styling
      selectBtns.forEach((btn) => {
        const idx = parseInt(btn.getAttribute('data-model-idx') || '0', 10);
        if (idx === mIdx) {
          btn.classList.add('active', 'border-primary-text', 'bg-primary-text', 'font-bold', 'text-canvas', 'shadow-xs');
          btn.classList.remove('border-border', 'bg-canvas', 'text-muted-text');
        } else {
          btn.classList.remove('active', 'border-primary-text', 'bg-primary-text', 'font-bold', 'text-canvas', 'shadow-xs');
          btn.classList.add('border-border', 'bg-canvas', 'text-muted-text');
        }
      });

      // Update Header active banner
      if (activeNameEl) activeNameEl.textContent = model.id;
      if (activeBytesEl) activeBytesEl.textContent = formatBytes(model.runtimeBytes);

      // Update each board vessel gauge
      vesselCards.forEach((card) => {
        const ceiling = parseFloat(card.getAttribute('data-ceiling-bytes') || '1');
        const runtime = model.runtimeBytes;
        const pct = Math.round((runtime / ceiling) * 100);

        let status = 'fits';
        if (pct > 100) status = 'exceeds';
        else if (pct > 80) status = 'tight';

        const diff = Math.abs(ceiling - runtime);
        let statusText = '';
        let statusClass = 'text-emerald-600 dark:text-emerald-400';
        let barBgClass = 'bg-emerald-500';

        if (status === 'fits') {
          statusText = `❇️ ${formatBytes(diff)} Free Headroom`;
          statusClass = 'text-emerald-600 dark:text-emerald-400';
          barBgClass = 'bg-emerald-500';
        } else if (status === 'tight') {
          statusText = `⚠️ ${formatBytes(diff)} Tight Margin`;
          statusClass = 'text-amber-600 dark:text-amber-400';
          barBgClass = 'bg-amber-500';
        } else {
          statusText = `🛑 Exceeds Ceiling by ${formatBytes(diff)}`;
          statusClass = 'text-red-600 dark:text-red-400';
          barBgClass = 'bg-red-500';
        }

        // Update progress bar
        const bar = card.querySelector('.vessel-bar');
        if (bar) {
          bar.style.width = Math.min(pct, 100) + '%';
          bar.className = `vessel-bar h-full transition-all duration-300 rounded-full ${barBgClass}`;
        }

        // Update occupied text
        const occ = card.querySelector('.vessel-occupied-text');
        if (occ) {
          occ.textContent = `${formatBytes(runtime)} (${pct}%)`;
        }

        // Update headroom badge text
        const hBadge = card.querySelector('.vessel-headroom-badge');
        if (hBadge) {
          hBadge.innerHTML = `<span class="${statusClass}">${statusText}</span>`;
        }
      });
    }

    selectBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-model-idx') || '0', 10);
        selectModel(idx);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupHeadroomInspector);
  } else {
    setupHeadroomInspector();
  }
  document.addEventListener('astro:page-load', setupHeadroomInspector);
</script>
