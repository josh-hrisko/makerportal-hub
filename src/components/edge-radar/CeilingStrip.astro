---
/**
 * Edge AI Hardware Memory Containment & Context Pressure Inspector.
 * Uses Event Delegation for bulletproof client-side reactivity and domain-grounded
 * architectural class filtering (so 7B models report clean class boundaries on MCUs
 * rather than nonsensical 98,000% overflow numbers).
 */
interface BoardLite {
  id: string;
  name: string;
  class: string;
  modelCeilingBytes: number;
  ramLabel?: string;
}
interface ModelLite {
  id: string;
  runtimeBytes: number;
  fileBytes: number;
  quant?: string | null;
  format: string;
}
interface FitLite {
  modelId: string;
  boardId: string;
  verdict: 'fits' | 'tight' | 'no';
}

interface Props {
  boards: BoardLite[];
  models: ModelLite[];
  fits?: FitLite[];
}

const { boards, models } = Astro.props;

const MIB = 1024 * 1024;
const GIB = 1024 * 1024 * 1024;

const fmtBytes = (n: number) => {
  if (n >= GIB) return `${(n / GIB).toFixed(n >= 10 * GIB ? 1 : 2)} GiB`;
  return `${(n / MIB).toFixed(n >= 10 * MIB ? 0 : 1)} MiB`;
};

const shortBoardName = (b: BoardLite) => b.name.split('(')[0].trim();

function classBadge(c: string) {
  if (c === 'mcu') return { icon: '⚡', label: 'Microcontroller' };
  if (c === 'sbc') return { icon: '🖥️', label: 'Single-Board Computer' };
  if (c === 'accelerator') return { icon: '🧠', label: 'AI Accelerator' };
  if (c === 'edge-gpu') return { icon: '🚀', label: 'Edge GPU' };
  return { icon: '💻', label: 'Embedded System' };
}

const defaultModel = models[0] || { id: 'default', runtimeBytes: 100 * MIB, fileBytes: 80 * MIB, format: 'GGUF' };
const componentId = `simulator-${Math.random().toString(36).substring(2, 7)}`;

const defaultSeqLen = 2048;

// Domain-grounded fit evaluator: handles class mismatch gracefully
function evaluateBoardFit(mBytes: number, fBytes: number, board: BoardLite, seqLen: number) {
  const ceiling = board.modelCeilingBytes;
  
  // MCU & Accelerator Class Boundary Check:
  // If model is > 32 MB and board ceiling is <= 16 MB, flag as Class Mismatch rather than 90,000% overflow
  if (fBytes > 32 * MIB && ceiling <= 16 * MIB) {
    return {
      status: 'incompatible' as const,
      isCompatible: false,
      reason: board.class === 'accelerator' 
        ? 'Edge TPU model cache ceiling (8 MB TFLite graph limit)' 
        : 'Microcontroller RAM ceiling (Requires sub-16 MiB TinyML model)',
      weightsPct: 100,
      kvPct: 0,
      overheadPct: 0,
      totalPct: 0,
      total: fBytes,
      diff: fBytes - ceiling,
    };
  }

  const weights = fBytes;
  const overhead = Math.max(fBytes * 0.12, 512 * 1024);
  const baseKvRatio = ceiling < 32 * MIB ? 0.08 : 0.04;
  const kvCache = Math.max(mBytes * baseKvRatio * (seqLen / 2048), 256 * 1024);
  const total = weights + overhead + kvCache;

  const totalPct = Math.round((total / ceiling) * 100);
  const normDenom = Math.max(total, ceiling);

  const weightsPct = Math.min((weights / normDenom) * 100, 100);
  const overheadPct = Math.min((overhead / normDenom) * 100, 100);
  const kvPct = Math.min((kvCache / normDenom) * 100, 100);

  let status: 'fits' | 'tight' | 'exceeds' = 'fits';
  if (totalPct > 100) status = 'exceeds';
  else if (totalPct > 80) status = 'tight';

  const diff = Math.abs(ceiling - total);

  return {
    status,
    isCompatible: true,
    reason: '',
    weights,
    overhead,
    kvCache,
    total,
    totalPct,
    weightsPct,
    overheadPct,
    kvPct,
    diff,
  };
}

const initialBoardSims = boards.map((b) => ({
  board: b,
  badge: classBadge(b.class),
  shortName: shortBoardName(b),
  sim: evaluateBoardFit(defaultModel.runtimeBytes, defaultModel.fileBytes, b, defaultSeqLen),
}));

// Clean payload for inline JS script
const modelsJson = JSON.stringify(models.map((m) => ({
  id: m.id,
  runtimeBytes: m.runtimeBytes,
  fileBytes: m.fileBytes,
  quant: m.quant ?? 'Q4_K_M',
  format: m.format,
})));

const boardsJson = JSON.stringify(boards.map((b) => ({
  id: b.id,
  name: b.name,
  class: b.class,
  modelCeilingBytes: b.modelCeilingBytes,
})));
---

<div class="w-full overflow-hidden rounded-[24px] border border-border bg-card-bg shadow-md" id={componentId}>
  {/* Header Title Banner */}
  <div class="border-b border-border bg-elevated/50 px-6 py-5">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <div class="flex items-center gap-2 font-mono text-[0.7rem] font-bold uppercase tracking-[0.14em] text-primary-text">
          <span class="h-2.5 w-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
          Hardware RAM Containment & Context Pressure Simulator
        </div>
        <p class="mt-1 text-[0.85rem] leading-[1.5] text-muted-text max-w-3xl">
          Select any scanned model and adjust the context slider to simulate tensor weights, runtime overhead, and expanding KV cache memory occupation across hardware targets.
        </p>
      </div>
      {/* Visual Legend */}
      <div class="flex flex-wrap items-center gap-3 font-mono text-[0.62rem] text-muted-text shrink-0">
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-emerald-500"></span> Tensors</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-cyan-400"></span> KV Cache</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-slate-500"></span> Overhead</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-amber-500"></span> Tight (80-100%)</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-red-500"></span> Exceeds (&gt;100%)</span>
      </div>
    </div>

    {/* Simulator Control Panel */}
    <div class="mt-5 grid gap-4 lg:grid-cols-12 lg:items-center border-t border-border/60 pt-4">
      {/* Model Selection Pills */}
      <div class="lg:col-span-7">
        <span class="block font-mono text-[0.6rem] font-bold uppercase tracking-wider text-muted-text mb-2">
          1. Select Model Weights:
        </span>
        <div class="flex flex-wrap items-center gap-1.5" id={`${componentId}-model-pills`}>
          {models.map((m, idx) => {
            const nameLabel = m.id.split('/')[1] || m.id;
            const isSelected = idx === 0;
            return (
              <button
                type="button"
                data-model-idx={idx}
                class={`sim-pill-btn rounded-full border px-3 py-1 font-mono text-[0.62rem] transition-all cursor-pointer ${
                  isSelected
                    ? 'active border-primary-text bg-primary-text font-bold text-canvas shadow-xs'
                    : 'border-border bg-canvas text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text'
                }`}
              >
                <span>{nameLabel}</span>
                <span class="ml-1 opacity-75">({fmtBytes(m.fileBytes)})</span>
              </button>
            );
          })}
        </div>
      </div>

      {/* Interactive Context Window Slider */}
      <div class="lg:col-span-5 rounded-[14px] border border-border bg-canvas p-3.5 shadow-xs">
        <div class="flex items-center justify-between font-mono text-[0.65rem]">
          <span class="font-bold text-primary-text uppercase tracking-wider">2. Context Length:</span>
          <span class="font-bold text-cyan-600 dark:text-cyan-400 text-[0.8rem]" id={`${componentId}-seq-label`}>
            2,048 tokens
          </span>
        </div>
        <input
          type="range"
          id={`${componentId}-seq-slider`}
          min="512"
          max="8192"
          step="512"
          value="2048"
          class="mt-2.5 w-full h-2 accent-cyan-500 rounded-lg cursor-pointer bg-elevated"
        />
        <div class="flex justify-between font-mono text-[0.58rem] text-muted-text mt-1.5">
          <span>512 tks</span>
          <span>2,048 tks</span>
          <span>4,096 tks</span>
          <span>8,192 tks</span>
        </div>
      </div>
    </div>
  </div>

  {/* Active Simulation Summary Banner */}
  <div class="border-b border-border bg-canvas/90 px-6 py-3 flex flex-wrap items-center justify-between gap-3 font-mono text-[0.68rem]">
    <div class="flex items-center gap-2">
      <span class="text-muted-text">Active Model:</span>
      <span class="font-bold text-primary-text" id={`${componentId}-active-name`}>
        {defaultModel.id}
      </span>
      <span class="text-muted-text">({defaultModel.format}{defaultModel.quant ? ` · ${defaultModel.quant}` : ''})</span>
    </div>
    <div class="flex flex-wrap items-center gap-4 text-muted-text">
      <span>Tensors: <strong class="text-emerald-600 dark:text-emerald-400" id={`${componentId}-active-weights`}>{fmtBytes(defaultModel.fileBytes)}</strong></span>
      <span>KV Cache: <strong class="text-cyan-600 dark:text-cyan-400" id={`${componentId}-active-kv`}>{fmtBytes(defaultModel.runtimeBytes * 0.04)}</strong></span>
      <span>Overhead: <strong class="text-primary-text" id={`${componentId}-active-overhead`}>{fmtBytes(defaultModel.fileBytes * 0.12)}</strong></span>
    </div>
  </div>

  {/* Hardware Memory Topology Vessels (5 Rows) */}
  <div class="p-6 space-y-4">
    {initialBoardSims.map((item) => (
      <div
        class="sim-card rounded-[16px] border border-border bg-elevated/40 p-4 transition-all hover:border-[var(--mp-border-strong)] shadow-xs"
        data-board-id={item.board.id}
        data-ceiling-bytes={item.board.modelCeilingBytes}
      >
        {/* Vessel Header info */}
        <div class="flex flex-wrap items-center justify-between gap-2 mb-2.5">
          <div class="flex items-center gap-2.5">
            <span class="text-lg">{item.badge.icon}</span>
            <div>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[0.9rem] font-bold text-primary-text">
                  {item.shortName}
                </span>
                <span class="font-mono text-[0.58rem] uppercase tracking-wider text-muted-text rounded-md bg-canvas border border-border px-2 py-0.5 font-semibold">
                  {item.badge.label}
                </span>
              </div>
              <p class="text-[0.72rem] text-muted-text mt-0.5">
                {item.board.ramLabel || `${fmtBytes(item.board.modelCeilingBytes)} RAM Budget`}
              </p>
            </div>
          </div>
          <div class="font-mono text-[0.68rem] text-right">
            <span class="text-muted-text">Datasheet Ceiling: </span>
            <span class="font-bold text-primary-text">{fmtBytes(item.board.modelCeilingBytes)}</span>
          </div>
        </div>

        {/* Multi-Segmented Memory Track */}
        <div class="relative h-7 w-full rounded-xl bg-canvas border border-border overflow-hidden flex">
          <div class="absolute top-0 bottom-0 w-[2px] bg-amber-500/80 z-20" style="left: 80%;" title="80% Safety Threshold"></div>

          {item.sim.isCompatible ? (
            <>
              <div class="sim-seg-weights h-full bg-emerald-500 transition-all duration-200" style={`width: ${item.sim.weightsPct}%;`}></div>
              <div class="sim-seg-kv h-full bg-cyan-400 transition-all duration-200" style={`width: ${item.sim.kvPct}%;`}></div>
              <div class="sim-seg-overhead h-full bg-slate-500/70 transition-all duration-200" style={`width: ${item.sim.overheadPct}%;`}></div>
            </>
          ) : (
            <div class="h-full w-full bg-elevated/80 flex items-center justify-center font-mono text-[0.62rem] text-muted-text italic px-3">
              Architectural Class Limit Exceeded
            </div>
          )}
        </div>

        {/* Vessel Footprint & Headroom Verdict Footer */}
        <div class="mt-2.5 flex flex-wrap items-center justify-between gap-2 font-mono text-[0.66rem]">
          <div>
            {item.sim.isCompatible ? (
              <span>Total Load: <strong class="text-primary-text sim-occupied-label">{fmtBytes(item.sim.total!)} ({item.sim.totalPct}%)</strong></span>
            ) : (
              <span class="text-muted-text font-medium">Class: <strong class="text-amber-600 dark:text-amber-400">Not Fittable (Size &gt; MCU / TPU Ceiling)</strong></span>
            )}
          </div>

          <div class="sim-verdict-badge font-bold">
            {!item.sim.isCompatible ? (
              <span class="text-muted-text font-normal">{item.sim.reason}</span>
            ) : item.sim.status === 'fits' ? (
              <span class="text-emerald-600 dark:text-emerald-400">❇️ Fits · {fmtBytes(item.sim.diff)} Free Headroom</span>
            ) : item.sim.status === 'tight' ? (
              <span class="text-amber-600 dark:text-amber-400">⚠️ Tight · {fmtBytes(item.sim.diff)} Margin</span>
            ) : (
              <span class="text-red-600 dark:text-red-400">🛑 Exceeds Ceiling by +{fmtBytes(item.sim.diff)}</span>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* Simulator Footer Notes */}
  <div class="border-t border-border bg-elevated/30 px-6 py-3 font-mono text-[0.62rem] text-muted-text flex flex-wrap items-center justify-between gap-2">
    <span>
      Domain evaluation: Models exceeding micro-architecture ceilings (7-16 MiB) display clean class boundaries rather than fabricated overflow metrics.
    </span>
    <span class="font-bold text-primary-text">7 MiB MCU &rarr; 6.5 GiB SBC</span>
  </div>
</div>

{/* Bulletproof Event-Delegated Script */}
<script is:inline define:vars={{ componentId, modelsJson, boardsJson }}>
  (function initSim() {
    const rawModels = JSON.parse(modelsJson);
    const rawBoards = JSON.parse(boardsJson);

    let activeModelIdx = 0;
    let activeSeqLen = 2048;

    const GIB = 1024 * 1024 * 1024;
    const MIB = 1024 * 1024;
    function formatBytes(n) {
      if (n >= GIB) return (n / GIB).toFixed(n >= 10 * GIB ? 1 : 2) + ' GiB';
      return (n / MIB).toFixed(n >= 10 * MIB ? 0 : 1) + ' MiB';
    }

    function render() {
      const root = document.getElementById(componentId);
      if (!root) return;

      const model = rawModels[activeModelIdx];
      if (!model) return;

      // Update Slider Label
      const seqLabel = root.getElementById(`${componentId}-seq-label`);
      if (seqLabel) seqLabel.textContent = activeSeqLen.toLocaleString() + ' tokens';

      // Update Header Text
      const nameEl = root.getElementById(`${componentId}-active-name`);
      const weightsEl = root.getElementById(`${componentId}-active-weights`);
      const overheadEl = root.getElementById(`${componentId}-active-overhead`);
      const kvEl = root.getElementById(`${componentId}-active-kv`);

      const weights = model.fileBytes;
      const overhead = Math.max(model.fileBytes * 0.12, 512 * 1024);

      if (nameEl) nameEl.textContent = model.id;
      if (weightsEl) weightsEl.textContent = formatBytes(weights);
      if (overheadEl) overheadEl.textContent = formatBytes(overhead);

      // Update Pill Button active classes
      const buttons = root.querySelectorAll('.sim-pill-btn');
      buttons.forEach((btn) => {
        const idx = parseInt(btn.getAttribute('data-model-idx') || '0', 10);
        if (idx === activeModelIdx) {
          btn.classList.add('active', 'border-primary-text', 'bg-primary-text', 'font-bold', 'text-canvas', 'shadow-xs');
          btn.classList.remove('border-border', 'bg-canvas', 'text-muted-text');
        } else {
          btn.classList.remove('active', 'border-primary-text', 'bg-primary-text', 'font-bold', 'text-canvas', 'shadow-xs');
          btn.classList.add('border-border', 'bg-canvas', 'text-muted-text');
        }
      });

      // Update Board Cards
      const cards = root.querySelectorAll('.sim-card');
      cards.forEach((card, boardIdx) => {
        const b = rawBoards[boardIdx];
        if (!b) return;

        const ceiling = b.modelCeilingBytes;
        const baseKvRatio = ceiling < 32 * MIB ? 0.08 : 0.04;
        const kvCache = Math.max(model.runtimeBytes * baseKvRatio * (activeSeqLen / 2048), 256 * 1024);
        const total = weights + overhead + kvCache;

        if (boardIdx === 0 && kvEl) kvEl.textContent = formatBytes(kvCache);

        const isMCU = ceiling <= 16 * MIB;
        const isClassExceeded = weights > 32 * MIB && isMCU;

        const occLabel = card.querySelector('.sim-occupied-label');
        const badge = card.querySelector('.sim-verdict-badge');
        const segW = card.querySelector('.sim-seg-weights');
        const segKv = card.querySelector('.sim-seg-kv');
        const segOv = card.querySelector('.sim-seg-overhead');

        if (isClassExceeded) {
          if (segW) segW.style.width = '0%';
          if (segKv) segKv.style.width = '0%';
          if (segOv) segOv.style.width = '0%';

          if (badge) {
            badge.innerHTML = `<span class="text-muted-text font-normal">Exceeds ${b.class === 'accelerator' ? 'Edge TPU 8 MB cache' : 'MCU 16 MiB class ceiling'}</span>`;
          }
        } else {
          const totalPct = Math.round((total / ceiling) * 100);
          const normDenom = Math.max(total, ceiling);

          const wPct = Math.min((weights / normDenom) * 100, 100);
          const oPct = Math.min((overhead / normDenom) * 100, 100);
          const kPct = Math.min((kvCache / normDenom) * 100, 100);

          if (segW) segW.style.width = wPct.toFixed(1) + '%';
          if (segKv) segKv.style.width = kPct.toFixed(1) + '%';
          if (segOv) segOv.style.width = oPct.toFixed(1) + '%';

          if (occLabel) occLabel.textContent = `${formatBytes(total)} (${totalPct}%)`;

          if (badge) {
            const diff = Math.abs(ceiling - total);
            if (totalPct <= 80) {
              badge.innerHTML = `<span class="text-emerald-600 dark:text-emerald-400">❇️ Fits · ${formatBytes(diff)} Free Headroom</span>`;
            } else if (totalPct <= 100) {
              badge.innerHTML = `<span class="text-amber-600 dark:text-amber-400">⚠️ Tight · ${formatBytes(diff)} Margin</span>`;
            } else {
              badge.innerHTML = `<span class="text-red-600 dark:text-red-400">🛑 Exceeds Ceiling by +${formatBytes(diff)} (${totalPct}%)</span>`;
            }
          }
        }
      });
    }

    // Bulletproof Event Delegation on Root Container
    function attachListeners() {
      const root = document.getElementById(componentId);
      if (!root) return;

      root.addEventListener('click', (e) => {
        const btn = e.target.closest('.sim-pill-btn');
        if (btn) {
          const idx = parseInt(btn.getAttribute('data-model-idx') || '0', 10);
          activeModelIdx = idx;
          render();
        }
      });

      const slider = root.querySelector(`#${componentId}-seq-slider`);
      if (slider) {
        slider.addEventListener('input', (e) => {
          activeSeqLen = parseInt(e.target.value, 10);
          render();
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => { attachListeners(); render(); });
    } else {
      attachListeners();
      render();
    }
    document.addEventListener('astro:page-load', () => { attachListeners(); render(); });
  })();
</script>
