---
/**
 * Board Fit Distribution Component (Item 4 in visual-first queue).
 * Displays stacked distribution bars per board (Fits / Tight / No) with exact counts.
 * SSR-only, zero JS, CLS 0 via aspect ratio, themeable via --mp-* tokens.
 */
interface BoardLite {
  id: string;
  name: string;
  class: string;
  modelCeilingBytes: number;
  ramBytes?: number;
}
interface ModelLite {
  id: string;
}
interface FitLite {
  modelId: string;
  boardId: string;
  verdict: 'fits' | 'tight' | 'no';
}

interface Props {
  boards: BoardLite[];
  models: ModelLite[];
  fits: FitLite[];
}

const { boards, models, fits } = Astro.props;

const totalModels = models.length || 1;

const GIB = 1024 * 1024 * 1024;
const MIB = 1024 * 1024;
const fmtBytes = (n: number) => (n >= GIB ? `${(n / GIB).toFixed(1)} GiB` : `${(n / MIB).toFixed(0)} MiB`);

const boardDist = [...boards]
  .sort((a, b) => b.modelCeilingBytes - a.modelCeilingBytes || (b.ramBytes ?? 0) - (a.ramBytes ?? 0) || a.name.localeCompare(b.name))
  .map((b) => {
    const bFits = fits.filter((f) => f.boardId === b.id);
    const fitsCount = bFits.filter((f) => f.verdict === 'fits').length;
    const tightCount = bFits.filter((f) => f.verdict === 'tight').length;
    const noCount = bFits.filter((f) => f.verdict === 'no').length;

    const fitsPct = (fitsCount / totalModels) * 100;
    const tightPct = (tightCount / totalModels) * 100;
    const noPct = (noCount / totalModels) * 100;

    return {
      board: b,
      shortName: b.name.split('(')[0].trim(),
      fitsCount,
      tightCount,
      noCount,
      fitsPct,
      tightPct,
      noPct,
    };
  });
---

<div class="w-full overflow-hidden rounded-[16px] border border-border bg-card-bg p-5">
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border pb-3">
    <div>
      <h3 class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">
        Board Fit Breakdown · {totalModels} Scanned Models
      </h3>
      <p class="mt-0.5 text-[0.78rem] text-muted-text">
        Percentage of today's models fitting within each board's datasheet memory limit.
      </p>
    </div>
    <div class="flex items-center gap-3 font-mono text-[0.6rem] text-muted-text">
      <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-emerald-500"></span> Fits (≤80%)</span>
      <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-amber-500"></span> Tight (80-100%)</span>
      <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-muted-text/40"></span> No (&gt;100%)</span>
    </div>
  </div>

  <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
    {boardDist.map((item) => (
      <div class="flex flex-col justify-between rounded-[12px] border border-border bg-canvas p-3.5 hover:border-[var(--mp-border-strong)]">
        <div>
          <div class="flex items-center justify-between gap-1">
            <span class="rounded-full bg-elevated border border-border px-2 py-0.5 font-mono text-[0.55rem] uppercase tracking-[0.08em] text-muted-text">
              {item.board.class}
            </span>
            <span class="font-mono text-[0.6rem] text-muted-text">
              {fmtBytes(item.board.modelCeilingBytes)}
            </span>
          </div>
          <h4 class="mt-2 text-[0.85rem] font-bold leading-tight text-primary-text">
            {item.shortName}
          </h4>
        </div>

        <div class="mt-3">
          {/* Stacked Spark Bar */}
          <div class="relative flex h-3 w-full overflow-hidden rounded-full border border-border bg-elevated">
            {item.fitsCount > 0 && (
              <div
                style={`width: ${item.fitsPct}%;`}
                class="h-full bg-emerald-500 transition-all"
                title={`${item.fitsCount} fits (${Math.round(item.fitsPct)}%)`}
              ></div>
            )}
            {item.tightCount > 0 && (
              <div
                style={`width: ${item.tightPct}%;`}
                class="h-full bg-amber-500 transition-all"
                title={`${item.tightCount} tight (${Math.round(item.tightPct)}%)`}
              ></div>
            )}
            {item.noCount > 0 && (
              <div
                style={`width: ${item.noPct}%;`}
                class="h-full bg-muted-text/20 transition-all"
                title={`${item.noCount} no fit (${Math.round(item.noPct)}%)`}
              ></div>
            )}
          </div>

          <div class="mt-2 flex items-center justify-between font-mono text-[0.62rem]">
            <span class={item.fitsCount > 0 ? 'font-bold text-emerald-600 dark:text-emerald-400' : 'text-muted-text'}>
              {item.fitsCount} Fits
            </span>
            {item.tightCount > 0 && (
              <span class="font-medium text-amber-600 dark:text-amber-400">
                {item.tightCount} Tight
              </span>
            )}
            <span class="text-muted-text">
              {item.noCount} No
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
