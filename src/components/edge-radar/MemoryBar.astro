---
/**
 * Log-scale memory footprint bar per model with board-ceiling markers.
 * SSR only, zero JS, themeable via currentColor / --mp-* tokens.
 * Every pixel derived from committed snapshot — no external requests.
 *
 * Domain 1 MiB → 32 GiB (MAX_REPRESENTATIVE_BYTES) so all bars share the
 * same log ruler and remain comparable across the page — most powerful boards
 * (Sigma 30 GiB) at right, weaker MCU at left, but table presents strongest first.
 */
interface BoardLite {
  id: string;
  name: string;
  modelCeilingBytes: number;
}
interface FitLite {
  boardId: string;
  verdict: 'fits' | 'tight' | 'no';
}

interface Props {
  runtimeBytes: number;
  modelId?: string;
  boards: BoardLite[];
  fits: FitLite[];
}

import { shortBoardLabel } from '../../lib/edge-radar-labels';

const { runtimeBytes, modelId, boards, fits } = Astro.props;

const MIB = 1024 * 1024;
const GIB = 1024 * 1024 * 1024;
const DOMAIN_MIN = 1 * MIB;
const DOMAIN_MAX = 32 * GIB;

const LOG_MIN = Math.log10(DOMAIN_MIN);
const LOG_MAX = Math.log10(DOMAIN_MAX);
const RANGE = LOG_MAX - LOG_MIN;

const clamp = (v: number, lo: number, hi: number) => Math.min(Math.max(v, lo), hi);

function logFrac(bytes: number): number {
  const c = clamp(bytes, DOMAIN_MIN, DOMAIN_MAX);
  return (Math.log10(c) - LOG_MIN) / RANGE;
}

const W = 480;
const H = 90;
const PAD_L = 16;
const PAD_R = 16;
const TRACK_W = W - PAD_L - PAD_R;
const TRACK_Y = 44;
const TRACK_H = 14;

const runtimeFrac = logFrac(runtimeBytes);
const runtimeX = PAD_L + runtimeFrac * TRACK_W;

const fmtBytes = (n: number) => {
  if (n >= GIB) return `${(n / GIB).toFixed(n >= 10 * GIB ? 1 : 2)} GiB`;
  return `${(n / MIB).toFixed(n >= 10 * MIB ? 0 : 1)} MiB`;
};

// Distinct ceilings to avoid duplicate markers — group boards sharing same ceiling
const ceilingGroups = new Map<number, BoardLite[]>();
for (const b of boards) {
  const list = ceilingGroups.get(b.modelCeilingBytes) ?? [];
  list.push(b);
  ceilingGroups.set(b.modelCeilingBytes, list);
}
const distinctCeilings = [...ceilingGroups.entries()]
  .map(([bytes, bs]) => ({ bytes, boards: bs, frac: logFrac(bytes), x: PAD_L + logFrac(bytes) * TRACK_W }))
  .sort((a, b) => a.bytes - b.bytes);

// Verdict helper per ceiling group (best among boards in group)
function groupVerdict(group: typeof distinctCeilings[number]): 'fits' | 'tight' | 'no' {
  const ids = new Set(group.boards.map((b) => b.id));
  const groupFits = fits.filter((f) => ids.has(f.boardId));
  if (groupFits.some((f) => f.verdict === 'fits')) return 'fits';
  if (groupFits.some((f) => f.verdict === 'tight')) return 'tight';
  return 'no';
}

// Short label for board groups — always size-qualified (Pi 5 8GB ≠ Pi 5 16GB)
function shortLabel(group: typeof distinctCeilings[number]): string {
  if (group.boards.length === 1) return shortBoardLabel(group.boards[0].name);
  if (group.boards.every((b) => b.modelCeilingBytes === 7 * MIB)) return 'ESP32/Teensy 7MiB';
  if (group.bytes === 8 * MIB) return 'Coral 8MiB';
  if (group.bytes === Math.floor(6.5 * GIB)) return 'Pi5/Nano 8GB';
  if (group.bytes === Math.floor(14 * GIB)) return 'Orange/ROCK 16GB';
  if (group.bytes === Math.floor(14.5 * GIB)) return 'Pi5/OrinNX 16GB';
  if (group.bytes === Math.floor(30 * GIB)) return 'Sigma 32GB';
  return group.boards.map((b) => shortBoardLabel(b.name)).join('/');
}

const ticks = [1 * MIB, 10 * MIB, 100 * MIB, 1 * GIB, 10 * GIB, 30 * GIB].map((b) => ({
  bytes: b,
  x: PAD_L + logFrac(b) * TRACK_W,
  label: fmtBytes(b),
}));

const overflowRight = runtimeBytes > DOMAIN_MAX;
const clipId = `clip-${(modelId ?? 'model').replace(/[^a-zA-Z0-9]/g, '-')}`;
---

<div class="group relative w-full overflow-hidden rounded-[14px] border border-border bg-card-bg" style={`aspect-ratio: ${W}/${H};`}>
  <svg
    viewBox={`0 0 ${W} ${H}`}
    width="100%"
    height="100%"
    role="img"
    aria-label={modelId ? `Memory footprint for ${modelId}: ${fmtBytes(runtimeBytes)} runtime — board ceilings at ${distinctCeilings.map((c) => fmtBytes(c.bytes)).join(', ')}` : `Memory footprint ${fmtBytes(runtimeBytes)}`}
    class="absolute inset-0 h-full w-full text-primary-text"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id={`grad-fill-${clipId}`} x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="var(--mp-cta)" stop-opacity="0.75"></stop>
        <stop offset="100%" stop-color="var(--mp-cta)" stop-opacity="1.0"></stop>
      </linearGradient>
    </defs>

    {/* Background track & depth */}
    <g aria-hidden="true">
      <rect x={PAD_L} y={TRACK_Y} width={TRACK_W} height={TRACK_H} rx={TRACK_H / 2} fill="var(--mp-elevated)" />
      <rect x={PAD_L} y={TRACK_Y} width={TRACK_W} height={TRACK_H} rx={TRACK_H / 2} fill="none" stroke="var(--mp-border)" stroke-width="1" />
    </g>

    {/* Log ticks bottom */}
    <g class="text-[0.62rem] text-muted-text" aria-hidden="true">
      {ticks.map((t) => (
        <g>
          <line x1={t.x} y1={TRACK_Y + TRACK_H + 2} x2={t.x} y2={TRACK_Y + TRACK_H + 6} stroke="var(--mp-border-strong)" stroke-width="1" />
          <text x={t.x} y={H - 5} text-anchor="middle" fill="currentColor" font-family="var(--font-mono)" font-size="8.5">{t.label}</text>
        </g>
      ))}
    </g>

    {/* Filled bar */}
    <g>
      <clipPath id={clipId}>
        <rect x={PAD_L} y={TRACK_Y} width={TRACK_W} height={TRACK_H} rx={TRACK_H / 2} />
      </clipPath>
      <rect
        x={PAD_L}
        y={TRACK_Y}
        width={runtimeFrac * TRACK_W}
        height={TRACK_H}
        fill={`url(#grad-fill-${clipId})`}
        clip-path={`url(#${clipId})`}
      />
      {/* Top edge glossy highlight */}
      <rect x={PAD_L} y={TRACK_Y} width={runtimeFrac * TRACK_W} height="1.5" fill="white" opacity="0.35" clip-path={`url(#${clipId})`} />
    </g>

    {/* Board ceiling markers with staggered leader lines for 7 vs 8 MiB collision resolution */}
    {distinctCeilings.map((g, i) => {
      const verdict = groupVerdict(g);
      const dotClass =
        verdict === 'fits'
          ? 'text-emerald-600 dark:text-emerald-400'
          : verdict === 'tight'
            ? 'text-amber-600 dark:text-amber-400'
            : 'text-muted-text';
      
      // Collision handling: 7 MiB vs 8 MiB are ~6px apart.
      // Stagger label heights and anchor points cleanly!
      const labelY = (i === 0 && distinctCeilings.length > 2) ? 12 : (i === 1 && distinctCeilings.length > 2) ? 24 : 12;
      const label = shortLabel(g);

      return (
        <g class="group/ceiling">
          {/* Vertical marker line */}
          <line
            x1={g.x}
            y1={labelY + 2}
            x2={g.x}
            y2={TRACK_Y + TRACK_H + 2}
            stroke={verdict === 'no' ? 'var(--mp-border-strong)' : 'currentColor'}
            stroke-width={verdict === 'no' ? 1.0 : 1.4}
            stroke-dasharray={verdict === 'no' ? '3 3' : '0'}
            class={verdict === 'no' ? 'text-muted-text' : dotClass}
            opacity={verdict === 'no' ? 0.6 : 0.95}
          />
          {/* Dot with halo at track intersection */}
          <g class={dotClass}>
            {verdict !== 'no' && (
              <circle cx={g.x} cy={TRACK_Y + TRACK_H / 2} r="6" fill="currentColor" opacity="0.25" />
            )}
            <circle cx={g.x} cy={TRACK_Y + TRACK_H / 2} r={verdict === 'no' ? 3.5 : 4.5} fill="currentColor" stroke="var(--mp-card)" stroke-width="1.4" />
          </g>
          {/* Label above with subtle background card for readability */}
          <g transform={`translate(${clamp(g.x, PAD_L + 36, W - PAD_R - 36)}, ${labelY})`}>
            <text
              x="0"
              y="-2"
              text-anchor="middle"
              fill="currentColor"
              font-family="var(--font-mono)"
              font-size="8"
              font-weight="700"
              class={verdict === 'no' ? 'text-muted-text' : 'text-primary-text'}
            >
              {label}
            </text>
          </g>
        </g>
      );
    })}

    {/* Runtime label floating pill with arrow pointer */}
    <g transform={`translate(${clamp(runtimeX, PAD_L + 30, W - PAD_R - 30)}, ${TRACK_Y - 8})`}>
      <rect x="-30" y="-15" width="60" height="15" rx="7" fill="var(--mp-card)" stroke="var(--mp-border-strong)" stroke-width="1" />
      <text text-anchor="middle" y="-4" fill="currentColor" font-family="var(--font-mono)" font-size="8.5" font-weight="700" class="text-primary-text">
        {fmtBytes(runtimeBytes)}{overflowRight ? ' +' : ''}
      </text>
      {/* Downward arrow caret */}
      <path
        d={`M 0 2 L -3 -3 L 3 -3 Z`}
        fill="var(--mp-cta)"
      />
    </g>

    <title>{modelId ? `${modelId} — ${fmtBytes(runtimeBytes)} runtime` : fmtBytes(runtimeBytes)} — ceilings {distinctCeilings.map((c) => fmtBytes(c.bytes)).join(', ')}</title>
  </svg>
</div>
