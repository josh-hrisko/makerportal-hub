---
interface Props {
  sponsorName?: string;
  message?: string;
  linkUrl?: string;
  logoSvg?: string;
}

const { sponsorName, message, linkUrl = '/advertise', logoSvg } = Astro.props;

const isSelfAd = !sponsorName;
const displayMessage = message || (isSelfAd
  ? 'Sponsor this simulator. Reach engineering practitioners.'
  : message);
---

<div
  class="sim-sponsor-rail flex h-10 items-center justify-between rounded-[10px] border border-border/60 bg-elevated/10 px-3.5 text-[0.76rem] tracking-tight transition-colors hover:border-border"
  data-sponsor={sponsorName || 'self'}
>
  <div class="flex items-center gap-2.5 min-w-0">
    {logoSvg ? (
      <Fragment set:html={logoSvg} />
    ) : (
      <span class="rounded-[4px] border border-border/80 bg-elevated/40 px-1.5 py-0.5 font-mono text-[0.58rem] font-bold uppercase tracking-[0.08em] text-muted-text">
        {isSelfAd ? 'Sponsor' : 'Partner'}
      </span>
    )}
    <span class="truncate font-medium text-muted-text">
      {sponsorName && <strong class="text-primary-text font-semibold mr-1">{sponsorName}</strong>}
      {displayMessage}
    </span>
  </div>
  <a
    href={linkUrl}
    target={isSelfAd ? undefined : '_blank'}
    rel={isSelfAd ? undefined : 'sponsored noopener noreferrer'}
    class="flex-shrink-0 text-[0.72rem] font-semibold uppercase tracking-[0.05em] text-primary-text hover:text-brand-anchor inline-flex items-center gap-0.5"
  >
    {isSelfAd ? 'Details' : 'Explore'} ↗
  </a>
</div>
