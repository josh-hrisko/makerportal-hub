---
import { Image } from 'astro:assets';
import type { AppEntry } from '../data/apps';

type Props = AppEntry;

const { title, description, url, icon, date, category, featured = false } = Astro.props;
---

<article class:list={[
  'group relative flex h-full flex-col overflow-hidden rounded-2xl border bg-neutral-900/60 p-6 transition duration-300 hover:-translate-y-1 hover:border-emerald-400/40 hover:bg-neutral-900 motion-reduce:transform-none motion-reduce:transition-none',
  featured ? 'border-emerald-500/30 shadow-[0_20px_80px_-45px_rgba(16,185,129,0.5)]' : 'border-neutral-800',
]}>
  {featured && (
    <span class="absolute right-0 top-0 rounded-bl-xl border-b border-l border-emerald-500/20 bg-emerald-500/10 px-3 py-1.5 text-[0.625rem] font-semibold uppercase tracking-[0.16em] text-emerald-300">
      Latest release
    </span>
  )}

  <div class="mb-6 flex items-start gap-4 pr-16">
    <Image
      src={icon}
      alt=""
      width={48}
      height={48}
      loading={featured ? 'eager' : 'lazy'}
      fetchpriority={featured ? 'high' : 'auto'}
      class="size-12 shrink-0 rounded-xl border border-white/10 bg-neutral-800"
    />
    <div class="min-w-0 pt-0.5">
      <h2 class="text-lg font-semibold tracking-tight text-white transition-colors group-hover:text-emerald-300">
        {title}
      </h2>
      <p class="mt-1 font-mono text-[0.6875rem] uppercase tracking-wider text-neutral-400">{date}</p>
    </div>
  </div>

  <p class="mb-7 flex-1 text-sm leading-6 text-neutral-400">{description}</p>

  <div class="flex items-center justify-between gap-4 border-t border-neutral-800 pt-4">
    <span class="rounded-full border border-neutral-700 bg-neutral-800/80 px-2.5 py-1 text-[0.6875rem] font-medium text-neutral-400">
      {category}
    </span>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Launch app: ${title} (opens in a new tab)`}
      class="inline-flex min-h-11 items-center gap-2 rounded-lg px-3 text-sm font-semibold text-neutral-200 transition-colors hover:bg-emerald-400 hover:text-neutral-950 motion-reduce:transition-none"
    >
      Launch app
      <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="size-4 transition-transform group-hover:translate-x-0.5 motion-reduce:transform-none">
        <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</article>
