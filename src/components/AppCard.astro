---
import { Image } from 'astro:assets';
import type { AppAccent, AppEntry } from '../data/apps';

type Props = AppEntry;

const { title, tagline, description, url, icon, date, category, platform, sequence, accent, techBadges, featured = false } = Astro.props;

const accentClasses: Record<AppAccent, { border: string; glow: string; ink: string; wash: string }> = {
  signal: {
    border: 'hover:border-primary-cta/50',
    glow: 'bg-primary-cta',
    ink: 'text-primary-cta',
    wash: 'from-primary-cta/15',
  },
  violet: {
    border: 'hover:border-violet-500/50',
    glow: 'bg-violet-500',
    ink: 'text-violet-400',
    wash: 'from-violet-500/15',
  },
  rose: {
    border: 'hover:border-brand-anchor/50',
    glow: 'bg-brand-anchor',
    ink: 'text-brand-anchor',
    wash: 'from-brand-anchor/15',
  },
  amber: {
    border: 'hover:border-amber-500/50',
    glow: 'bg-amber-500',
    ink: 'text-amber-400',
    wash: 'from-amber-500/15',
  },
};

const colors = accentClasses[accent];
---

<article class:list={[
  'app-card group relative isolate flex min-h-[27rem] flex-col overflow-hidden rounded-[1.75rem] border border-muted-text/20 bg-card-bg p-6 transition duration-500 hover:-translate-y-1 motion-reduce:transform-none motion-reduce:transition-none sm:p-7',
  colors.border,
  featured && 'md:col-span-2 lg:col-span-3 lg:min-h-[34rem] lg:p-9',
]}>
  <div aria-hidden="true" class:list={['absolute inset-0 -z-10 bg-gradient-to-br to-transparent via-transparent opacity-70 transition-opacity duration-500 group-hover:opacity-100', colors.wash]}></div>
  <div aria-hidden="true" class:list={['absolute -right-20 -top-20 -z-10 size-64 rounded-full opacity-0 blur-[90px] transition-opacity duration-500 group-hover:opacity-20', colors.glow]}></div>

  <div class="flex items-center justify-between gap-4 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text">
    <span>Release / {sequence}</span>
    <span class="inline-flex items-center gap-2">
      <span class:list={['size-1.5 rounded-full', colors.glow]}></span>
      {featured ? 'Now shipping' : date}
    </span>
  </div>

  <div class:list={['mt-12 flex flex-1 flex-col', featured && 'lg:mt-16 lg:grid lg:grid-cols-[1.2fr_0.8fr] lg:items-end lg:gap-12']}>
    <div>
      <Image
        src={icon}
        alt={`${title} application icon`}
        width={featured ? 80 : 64}
        height={featured ? 80 : 64}
        loading={featured ? 'eager' : 'lazy'}
        fetchpriority={featured ? 'high' : 'auto'}
        class:list={['rounded-[1.3rem] border border-muted-text/30 shadow-2xl transition duration-500 group-hover:scale-105', featured ? 'size-20' : 'size-16']}
      />
      <p class:list={['mt-8 font-mono text-[0.68rem] uppercase tracking-[0.2em]', colors.ink]}>{category} · {platform}</p>
      <h3 class:list={['mt-3 font-semibold leading-none tracking-[-0.045em] text-white', featured ? 'text-5xl sm:text-6xl' : 'text-4xl']}>{title}</h3>
      <p class:list={['mt-4 font-medium leading-snug text-primary-text', featured ? 'max-w-xl text-xl sm:text-2xl' : 'text-lg']}>{tagline}</p>
    </div>

    <div class:list={['mt-8 flex flex-col justify-end', featured && 'lg:mt-0']}>
      <p class="text-sm leading-6 text-muted-text sm:text-base sm:leading-7">{description}</p>
      
      {techBadges && techBadges.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {techBadges.map((badge) => (
            <span class="rounded-full border border-muted-text/20 bg-canvas/40 px-2.5 py-0.5 font-mono text-[0.62rem] uppercase tracking-wider text-muted-text">
              {badge}
            </span>
          ))}
        </div>
      )}

      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Explore ${title} (opens in a new tab)`}
        class:list={[
          'mt-7 inline-flex min-h-12 w-fit items-center gap-3 rounded-full px-5 text-sm font-semibold transition duration-300 hover:scale-[1.02] motion-reduce:transition-none',
          featured 
            ? 'bg-primary-cta text-white hover:bg-primary-cta/90 shadow-md shadow-primary-cta/20 hover:shadow-primary-cta/35 border border-primary-cta/20' 
            : 'bg-[#1D2B3A] text-primary-text border border-muted-text/30 hover:border-brand-anchor hover:text-brand-anchor hover:bg-[#233547]'
        ]}
      >
        Explore {title}
        <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="size-4 transition-transform group-hover:translate-x-1 motion-reduce:transform-none">
          <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</article>
