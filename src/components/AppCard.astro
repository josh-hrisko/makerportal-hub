---
import { Image } from 'astro:assets';
import type { AppAccent, AppEntry } from '../data/apps';
import { apps as allApps } from '../data/apps';

type Props = AppEntry & { class?: string; showRelated?: boolean };

const {
  title,
  tagline,
  description,
  url,
  icon,
  date,
  category,
  platform,
  sequence,
  accent,
  techBadges,
  class: className,
  iconDot,
  external,
  showRelated = true,
} = Astro.props as Props;

/* Accent map: glow / category text still uses brand tokens.
    Tech badges now use icon-derived colors (sampled from actual app icons via
    ImageMagick histogram) for the dot, with high-contrast primary-text for the label.
    This fixes "yellow over light brown" – previously bg-amber-500/10 (10% wash) + text-amber-300
    light yellow was ~1.5:1 on white, now primary-text 16:1 on elevated pill + dot shows icon hue.

    Icon histogram (dark / light accessible pair) — updated 2026-07-13 expansion:
    - Biquadia: #D98065 / #8C4A3A
    - Notiary: #779589 / #385348
    - Thumb-Dash: #D49371 / #5E3A2F (new icon #363130/#D49371 histogram)
    - PopCloset: #B3AEB1 / #424240
    - AuraLinter: #8AA0C6 / #2B3C5E — #070B28/#4C6492 dark navy
    - nymic: #E69433 / #7A3410 — #C16223 burnt orange
    - akous: #E7A6A2 / #7A4744 — dusty rose
    - itria: #E6524A / #8C2F2C — coral red
    - GridVerse: #B59CDC / #4E1A9E — #631FCB purple
    - MotionLink: #4FC3E8 / #0F4F6B — #09A1D2 cyan
    - BLExAR: #7FB8BE / #1F4E54 — #3C888F teal
*/
const accentMap: Record<AppAccent, { glow: string; text: string; bg: string; border: string; dot: string }> = {
  signal: { glow: 'bg-primary-cta', text: 'text-primary-cta', bg: 'bg-primary-cta/10 border-primary-cta/20', border: 'group-hover:border-primary-cta/30', dot: 'bg-primary-cta' },
  violet: { glow: 'bg-violet-500', text: 'text-violet-300', bg: 'bg-violet-500/10 border-violet-500/15', border: 'group-hover:border-violet-400/25', dot: 'bg-violet-500' },
  rose:   { glow: 'bg-brand-anchor', text: 'text-brand-anchor', bg: 'bg-brand-anchor/10 border-brand-anchor/15', border: 'group-hover:border-brand-anchor/30', dot: 'bg-brand-anchor' },
  amber:  { glow: 'bg-amber-400', text: 'text-amber-300', bg: 'bg-amber-500/10 border-amber-500/15', border: 'group-hover:border-amber-400/25', dot: 'bg-amber-500' },
  emerald:{ glow: 'bg-emerald-500', text: 'text-emerald-300', bg: 'bg-emerald-500/10 border-emerald-500/15', border: 'group-hover:border-emerald-400/25', dot: 'bg-emerald-500' },
  cyan:   { glow: 'bg-cyan-500', text: 'text-cyan-300', bg: 'bg-cyan-500/10 border-cyan-500/15', border: 'group-hover:border-cyan-400/25', dot: 'bg-cyan-500' },
};

const iconBadgeDot: Record<AppAccent, { light: string; dark: string }> = {
  signal: { light: '#8C4A3A', dark: '#D98065' },
  violet: { light: '#385348', dark: '#779589' },
  amber:  { light: '#7A4D3F', dark: '#D19274' },
  rose:   { light: '#424240', dark: '#B3AEB1' },
  emerald:{ light: '#1F4E54', dark: '#7FB8BE' }, // BLExAR teal
  cyan:   { light: '#0F4F6B', dark: '#4FC3E8' }, // MotionLink cyan
};

const colors = accentMap[accent as AppAccent] ?? accentMap['signal'];
const dotColors = iconDot ?? iconBadgeDot[accent as AppAccent] ?? iconBadgeDot['signal'];

// Inter-app related — same category, exclude self, max 2
const relatedApps = showRelated
  ? allApps.filter((a) => a.category === category && a.title !== title).slice(0, 2)
  : [];
---

<article 
  class:list={[
    // surface-card supplies theme-aware bg / border / shadow; no hardcoded #1A232E or border-white
    'app-card surface-card group relative isolate flex flex-col overflow-hidden rounded-[28px] border bg-card-bg p-7 transition-[transform,box-shadow,border-color] duration-500 hover:-translate-y-1.5 motion-reduce:transform-none motion-reduce:transition-none',
    colors.border,
    className
  ]}
  data-app-card
>
  <!-- Spotlight: white overlay 6%→transparent works in dark; in light it's subtle but
       kept decorative. Uses color-mix for better theming than raw rgba white. -->
  <div aria-hidden="true" class="spotlight pointer-events-none absolute -inset-px opacity-0 transition-opacity duration-500 group-hover:opacity-100" style={`background: radial-gradient(600px circle at var(--mouse-x,50%) var(--mouse-y,50%), color-mix(in srgb, var(--mp-text) 6%, transparent), transparent 40%)`}></div>
  
  <!-- Accent glow — low opacity, decorative -->
  <div aria-hidden="true" class:list={['absolute -right-24 -top-24 -z-10 size-72 rounded-full blur-[80px] opacity-0 transition-all duration-700 group-hover:opacity-[0.12] group-hover:scale-110', colors.glow]}></div>

  <!-- Noise texture overlay — 2.5% opacity, blend-soft-light for tactile card -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.025] mix-blend-soft-light" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/></svg>')"></div>

  <div class="relative flex items-start justify-between gap-4">
    <div class="relative flex size-[3.75rem] items-center justify-center rounded-[16px] bg-canvas p-2 ring-1 ring-border shadow-[inset_0_1px_1px_rgba(255,255,255,0.06),0_4px_12px_rgba(0,0,0,0.08)] transition-all duration-500 group-hover:ring-border group-hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_8px_20px_rgba(0,0,0,0.14)] group-hover:scale-[1.02]">
      <!-- Icon container — bg-canvas gives contrast against bg-card-bg in both themes (dark canvas darker, light canvas darker than white card) -->
      <Image 
        src={icon} 
        alt={`${title} app icon`}
        width={48}
        height={48}
        densities={[1,2]}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-contain drop-shadow-lg transition-transform duration-500 group-hover:scale-105 group-hover:rotate-[-2deg]"
      />
      <div class="pointer-events-none absolute inset-0 rounded-[16px] bg-gradient-to-b from-[color-mix(in_srgb,var(--mp-text)_6%,transparent)] to-transparent opacity-60"></div>
    </div>

    <div class="flex items-center gap-2">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.62rem] font-medium uppercase tracking-[0.12em] text-muted-text">
        <span class:list={['size-1.5 rounded-full animate-pulse', colors.dot]}></span>
        Live
      </span>
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open ${title} – ${tagline} (external)`}
        class="group/link relative z-10 flex size-10 items-center justify-center rounded-full border border-border bg-elevated text-muted-text transition-all duration-300 hover:scale-110 hover:border-[var(--mp-border-strong)] hover:bg-elevated hover:text-primary-text before:absolute before:inset-0 before:-z-10 before:rounded-full before:bg-gradient-to-b before:from-[color-mix(in_srgb,var(--mp-text)_8%,transparent)] before:to-transparent before:opacity-0 hover:before:opacity-100"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="size-4 transition-transform duration-300 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5">
          <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="relative mt-6 flex flex-1 flex-col">
    <div class="flex items-baseline gap-3">
      <h3 class="text-[1.65rem] font-bold leading-none tracking-[-0.03em] text-primary-text">{title}</h3>
      <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">{sequence}</span>
    </div>
    <p
      class="icon-cat mt-2 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
      style={`--cat-light:${dotColors.light}; --cat-dark:${dotColors.dark}; color: var(--cat-light);`}
    >{category} • {tagline}</p>
    <style>
      html[data-theme="dark"] .icon-cat {
        color: var(--cat-dark) !important;
      }
    </style>
    
    <p class="mt-4 flex-1 text-[0.92rem] leading-[1.7] text-muted-text text-pretty">{description}</p>
    
    <div class="mt-7 flex flex-col gap-4 border-t border-border pt-5">
      <div class="flex flex-wrap items-center justify-between gap-3 text-[0.78rem] text-muted-text">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-elevated/70 px-2.5 py-1 ring-1 ring-border">
          <svg class="size-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          {platform}
        </span>
        <span class="inline-flex items-center gap-1.5 text-muted-text/80">
          <span class="size-1 rounded-full bg-border"></span>
          {date}
        </span>
      </div>
      
      {techBadges && techBadges.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {techBadges.map((badge: string) => {
            return (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.08em] text-primary-text transition-colors">
                <span
                  class="icon-dot size-1.5 shrink-0 rounded-full"
                  style={`--dot-light:${dotColors.light}; --dot-dark:${dotColors.dark}; background-color: var(--dot-light);`}
                  aria-hidden="true"
                ></span>
                {badge}
              </span>
            );
          })}
        </div>
      )}
      <style>
        html[data-theme="dark"] .icon-dot {
          background-color: var(--dot-dark) !important;
        }
      </style>

      {/* Inter-app navigation footer — theme-aware, no backdrop-filter */}
      <div class="mt-5 flex flex-wrap items-center justify-between gap-2 border-t border-border pt-4">
        <div class="flex items-center gap-2 text-[0.74rem]">
          <a href="/apps" class="font-medium text-muted-text transition-colors hover:text-primary-text">
            Explore {allApps.length} apps →
          </a>
          {external && (
            <span class="rounded-full bg-elevated px-2 py-0.5 font-mono text-[0.6rem] uppercase tracking-[0.1em] text-muted-text">Legacy • makersportal.com</span>
          )}
        </div>
        {relatedApps.length > 0 && (
          <div class="flex items-center gap-1.5 text-[0.74rem] text-muted-text">
            <span class="font-mono text-[0.62rem] uppercase tracking-[0.12em]">Related:</span>
            {relatedApps.map((r, i) => (
              <>
                {i > 0 && <span class="text-muted-text/40">·</span>}
                <a href={r.url} target="_blank" rel="noopener noreferrer" class="font-medium text-muted-text transition-colors hover:text-primary-text">
                  {r.title}
                </a>
              </>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Bottom accent line on hover -->
  <div aria-hidden="true" class:list={['pointer-events-none absolute inset-x-7 bottom-0 h-px origin-left scale-x-0 bg-gradient-to-r opacity-0 transition-all duration-700 group-hover:scale-x-100 group-hover:opacity-100', colors.glow]}></div>
</article>

<script is:inline>
  // Spotlight – fine pointers only (skip touch devices; no hover value there).
  if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    document.querySelectorAll('[data-app-card]').forEach((card) => {
      let rect = null;
      let pending = false;
      let lastX = 0;
      let lastY = 0;
      const measure = () => { rect = card.getBoundingClientRect(); };
      card.addEventListener('pointerenter', measure, { passive: true });
      window.addEventListener('resize', measure, { passive: true });
      card.addEventListener('pointermove', (e) => {
        lastX = e.clientX;
        lastY = e.clientY;
        if (!rect) measure();
        if (pending) return;
        pending = true;
        requestAnimationFrame(() => {
          const x = ((lastX - rect.left) / rect.width) * 100;
          const y = ((lastY - rect.top) / rect.height) * 100;
          card.style.setProperty('--mouse-x', x + '%');
          card.style.setProperty('--mouse-y', y + '%');
          pending = false;
        });
      }, { passive: true });
    });
  }
</script>
