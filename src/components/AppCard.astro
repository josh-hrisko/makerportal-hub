---
import { Image } from 'astro:assets';
import type { AppAccent, AppEntry } from '../data/apps';

type Props = AppEntry & { class?: string };

const { title, tagline, description, url, icon, date, category, platform, sequence, accent, techBadges, class: className } = Astro.props;

const accentClasses: Record<AppAccent, { glow: string; text: string; bg: string }> = {
  signal: { glow: 'group-hover:bg-primary-cta', text: 'text-primary-cta', bg: 'bg-primary-cta/10' },
  violet: { glow: 'group-hover:bg-violet-500', text: 'text-violet-400', bg: 'bg-violet-500/10' },
  rose: { glow: 'group-hover:bg-brand-anchor', text: 'text-brand-anchor', bg: 'bg-brand-anchor/10' },
  amber: { glow: 'group-hover:bg-amber-500', text: 'text-amber-400', bg: 'bg-amber-500/10' },
};

const colors = accentClasses[accent];
---

<article class:list={[
  'app-card animate-on-scroll group relative isolate flex flex-col overflow-hidden rounded-[28px] border border-white/5 bg-[#1A232E]/80 backdrop-blur-xl shadow-[0_10px_30px_-10px_rgba(0,0,0,0.5)] p-7 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.7)] hover:border-white/10 motion-reduce:transform-none motion-reduce:transition-none',
  className
]}>
  <div aria-hidden="true" class:list={['absolute -right-20 -top-20 -z-10 size-64 rounded-full opacity-0 blur-[90px] transition-opacity duration-500 group-hover:opacity-15', colors.glow.replace('group-hover:', '')]}></div>

  <div class="flex items-start justify-between gap-4">
    <div class="flex size-14 items-center justify-center rounded-2xl bg-canvas p-2.5 ring-1 shadow-inner shadow-white/5 ring-white/10 relative z-10 transition-colors group-hover:ring-white/20">
      <img src={icon} alt={`${title} icon`} class="h-full w-full object-contain drop-shadow-md" loading="lazy" />
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Explore ${title} (opens in a new tab)`}
      class="flex size-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-muted-text transition-all duration-300 hover:scale-110 hover:border-white/20 hover:text-white hover:bg-white/10 before:absolute before:inset-0"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="size-4">
        <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>

  <div class="mt-6 flex flex-col flex-1">
    <h3 class="text-2xl font-bold tracking-tight text-white">{title}</h3>
    <p class:list={['mt-1 font-mono text-[0.65rem] uppercase tracking-wider', colors.text]}>{category} · {sequence}</p>
    
    <p class="mt-4 text-sm leading-6 text-muted-text">{description}</p>
    
    <div class="mt-8 flex flex-col gap-4 border-t border-white/5 pt-5 flex-1 justify-end">
      <div class="flex items-center justify-between text-xs text-muted-text font-medium">
        <span class="flex items-center gap-1.5">
          <svg class="size-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          {platform}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="size-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          {date}
        </span>
      </div>
      
      {techBadges && techBadges.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-1">
          {techBadges.map((badge) => (
            <span class:list={['rounded-full px-2.5 py-1 font-mono text-[0.62rem] uppercase tracking-wider', colors.bg, colors.text]}>
              {badge}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>
