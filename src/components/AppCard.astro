---
import { Image } from 'astro:assets';
import type { AppAccent, AppEntry } from '../data/apps';

type Props = AppEntry & { class?: string };

const { title, tagline, description, url, icon, date, category, platform, sequence, accent, techBadges, class: className } = Astro.props as Props;

const accentMap: Record<AppAccent, { glow: string; text: string; bg: string; border: string; dot: string }> = {
  signal: { glow: 'bg-primary-cta', text: 'text-primary-cta', bg: 'bg-primary-cta/10 border-primary-cta/20', border: 'group-hover:border-primary-cta/30', dot: 'bg-primary-cta' },
  violet: { glow: 'bg-violet-500', text: 'text-violet-300', bg: 'bg-violet-500/10 border-violet-500/15', border: 'group-hover:border-violet-400/25', dot: 'bg-violet-400' },
  rose:   { glow: 'bg-brand-anchor', text: 'text-brand-anchor', bg: 'bg-brand-anchor/10 border-brand-anchor/15', border: 'group-hover:border-brand-anchor/30', dot: 'bg-brand-anchor' },
  amber:  { glow: 'bg-amber-400', text: 'text-amber-300', bg: 'bg-amber-500/10 border-amber-500/15', border: 'group-hover:border-amber-400/25', dot: 'bg-amber-400' },
};

const colors = accentMap[accent as AppAccent];
---

<article 
  class:list={[
    'app-card group relative isolate flex flex-col overflow-hidden rounded-[28px] border border-white/[0.06] bg-[#1A232E]/80 backdrop-blur-xl shadow-[0_10px_30px_-10px_rgba(0,0,0,0.5),inset_0_1px_1px_rgba(255,255,255,0.06)] p-7 transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_24px_48px_-12px_rgba(0,0,0,0.6),inset_0_1px_1px_rgba(255,255,255,0.08)] hover:border-white/10 will-change-transform motion-reduce:transform-none motion-reduce:transition-none',
    colors.border,
    className
  ]}
  data-app-card
>
  <!-- Spotlight gradient that follows mouse – frontier 2026 -->
  <div aria-hidden="true" class="spotlight pointer-events-none absolute -inset-px opacity-0 transition-opacity duration-500 group-hover:opacity-100" style={`background: radial-gradient(600px circle at var(--mouse-x,50%) var(--mouse-y,50%), rgba(255,255,255,0.06), transparent 40%)`}></div>
  
  <!-- Accent glow -->
  <div aria-hidden="true" class:list={['absolute -right-24 -top-24 -z-10 size-72 rounded-full blur-[80px] opacity-0 transition-all duration-700 group-hover:opacity-[0.12] group-hover:scale-110', colors.glow]}></div>

  <!-- Noise texture overlay -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.025] mix-blend-soft-light" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/></svg>')"></div>

  <div class="relative flex items-start justify-between gap-4">
    <div class="relative flex size-[3.75rem] items-center justify-center rounded-[16px] bg-[#0F141C] p-2 ring-1 ring-white/10 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_4px_12px_rgba(0,0,0,0.3)] transition-all duration-500 group-hover:ring-white/20 group-hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.12),0_8px_20px_rgba(0,0,0,0.4)] group-hover:scale-[1.02]">
      <!-- Icon container with optimized image -->
      <Image 
        src={icon} 
        alt={`${title} app icon`}
        width={48}
        height={48}
        densities={[1,2]}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-contain drop-shadow-lg transition-transform duration-500 group-hover:scale-105 group-hover:rotate-[-2deg]"
      />
      <div class="pointer-events-none absolute inset-0 rounded-[16px] bg-gradient-to-b from-white/[0.08] to-transparent"></div>
    </div>

    <div class="flex items-center gap-2">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-white/5 bg-white/[0.03] px-2.5 py-1 font-mono text-[0.58rem] uppercase tracking-[0.14em] text-primary-text/70 backdrop-blur-sm">
        <span class:list={['size-1 rounded-full animate-pulse', colors.dot]}></span>
        Live
      </span>
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open ${title} – ${tagline} (external)`}
        class="group/link relative z-10 flex size-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-muted-text backdrop-blur-md transition-all duration-300 hover:scale-110 hover:border-white/20 hover:bg-white/[0.08] hover:text-white before:absolute before:inset-0 before:-z-10 before:rounded-full before:bg-gradient-to-b before:from-white/10 before:to-transparent before:opacity-0 hover:before:opacity-100"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="size-4 transition-transform duration-300 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5">
          <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="relative mt-6 flex flex-1 flex-col">
    <div class="flex items-baseline gap-3">
      <h3 class="text-[1.65rem] font-bold leading-none tracking-[-0.03em] text-white">{title}</h3>
      <span class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-muted-text/60">{sequence}</span>
    </div>
    <p class:list={['mt-2 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em]', colors.text]}>{category} • {tagline}</p>
    
    <p class="mt-4 flex-1 text-[0.92rem] leading-[1.7] text-primary-text/75 text-pretty">{description}</p>
    
    <div class="mt-7 flex flex-col gap-4 border-t border-white/[0.06] pt-5">
      <div class="flex flex-wrap items-center justify-between gap-3 text-[0.78rem] text-muted-text">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-canvas/60 px-2.5 py-1 ring-1 ring-white/5">
          <svg class="size-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          {platform}
        </span>
        <span class="inline-flex items-center gap-1.5 text-muted-text/80">
          <span class="size-1 rounded-full bg-white/20"></span>
          {date}
        </span>
      </div>
      
      {techBadges && techBadges.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {techBadges.map((badge: string) => (
            <span class:list={['inline-flex items-center rounded-full border px-2.5 py-1 font-mono text-[0.6rem] font-medium uppercase tracking-[0.1em] backdrop-blur-sm transition-colors', colors.bg, colors.text]}>
              {badge}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Bottom accent line on hover -->
  <div aria-hidden="true" class:list={['pointer-events-none absolute inset-x-7 bottom-0 h-px origin-left scale-x-0 bg-gradient-to-r opacity-0 transition-all duration-700 group-hover:scale-x-100 group-hover:opacity-100', colors.glow]}></div>
</article>

<script is:inline>
  // Spotlight effect – frontier 2026
  document.querySelectorAll('[data-app-card]').forEach((card) => {
    card.addEventListener('pointermove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      card.style.setProperty('--mouse-x', x + '%');
      card.style.setProperty('--mouse-y', y + '%');
    });
  });
</script>
