---
import { Image } from 'astro:assets';
import type { AppAccent, AppEntry } from '../data/apps';

type Props = AppEntry;

const { title, tagline, description, url, icon, date, category, platform, sequence, accent, featured = false } = Astro.props;

const accentClasses: Record<AppAccent, { border: string; glow: string; ink: string; wash: string }> = {
  signal: {
    border: 'hover:border-lime-300/50',
    glow: 'bg-lime-300',
    ink: 'text-lime-300',
    wash: 'from-lime-300/15',
  },
  violet: {
    border: 'hover:border-violet-400/50',
    glow: 'bg-violet-400',
    ink: 'text-violet-300',
    wash: 'from-violet-400/15',
  },
  rose: {
    border: 'hover:border-rose-400/50',
    glow: 'bg-rose-400',
    ink: 'text-rose-300',
    wash: 'from-rose-400/15',
  },
  amber: {
    border: 'hover:border-orange-400/50',
    glow: 'bg-orange-400',
    ink: 'text-orange-300',
    wash: 'from-orange-400/15',
  },
};

const colors = accentClasses[accent];
---

<article class:list={[
  'app-card group relative isolate flex min-h-[27rem] flex-col overflow-hidden rounded-[1.75rem] border border-white/10 bg-[#111111] p-6 transition duration-500 hover:-translate-y-1 motion-reduce:transform-none motion-reduce:transition-none sm:p-7',
  colors.border,
  featured && 'md:col-span-2 lg:col-span-3 lg:min-h-[34rem] lg:p-9',
]}>
  <div aria-hidden="true" class:list={['absolute inset-0 -z-10 bg-gradient-to-br to-transparent via-transparent opacity-70 transition-opacity duration-500 group-hover:opacity-100', colors.wash]}></div>
  <div aria-hidden="true" class:list={['absolute -right-20 -top-20 -z-10 size-64 rounded-full opacity-0 blur-[90px] transition-opacity duration-500 group-hover:opacity-20', colors.glow]}></div>

  <div class="flex items-center justify-between gap-4 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-zinc-400">
    <span>Release / {sequence}</span>
    <span class="inline-flex items-center gap-2">
      <span class:list={['size-1.5 rounded-full', colors.glow]}></span>
      {featured ? 'Now shipping' : date}
    </span>
  </div>

  <div class:list={['mt-12 flex flex-1 flex-col', featured && 'lg:mt-16 lg:grid lg:grid-cols-[1fr_0.8fr] lg:items-end lg:gap-12']}>
    <div>
      <Image
        src={icon}
        alt=""
        width={featured ? 80 : 64}
        height={featured ? 80 : 64}
        loading={featured ? 'eager' : 'lazy'}
        fetchpriority={featured ? 'high' : 'auto'}
        class:list={['rounded-[1.3rem] border border-white/10 shadow-2xl', featured ? 'size-20' : 'size-16']}
      />
      <p class:list={['mt-8 font-mono text-[0.68rem] uppercase tracking-[0.2em]', colors.ink]}>{category} · {platform}</p>
      <h2 class:list={['mt-3 font-semibold leading-none tracking-[-0.045em] text-white', featured ? 'text-5xl sm:text-6xl' : 'text-4xl']}>{title}</h2>
      <p class:list={['mt-4 font-medium leading-snug text-zinc-200', featured ? 'max-w-xl text-xl sm:text-2xl' : 'text-lg']}>{tagline}</p>
    </div>

    <div class:list={['mt-8 flex flex-col justify-end', featured && 'lg:mt-0']}>
      <p class="text-sm leading-6 text-zinc-400 sm:text-base sm:leading-7">{description}</p>
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Explore ${title} (opens in a new tab)`}
        class="mt-7 inline-flex min-h-12 w-fit items-center gap-3 rounded-full border border-white/15 bg-white px-5 text-sm font-semibold text-black transition duration-300 hover:border-white hover:bg-lime-300 motion-reduce:transition-none"
      >
        Explore {title}
        <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="size-4 transition-transform group-hover:translate-x-1 motion-reduce:transform-none">
          <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</article>
