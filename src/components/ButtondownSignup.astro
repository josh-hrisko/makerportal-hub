---
import { BUTTONDOWN_USERNAME as globalUsername, BUTTONDOWN_ENABLED, BUTTONDOWN_EMBED_URL } from '../data/newsletter';

interface Props {
  username?: string; // e.g. "makerportal" — overrides global if provided
  tag?: string; // Buttondown tag for segmentation
  title?: string;
  blurb?: string;
  compact?: boolean;
  class?: string;
  source?: string; // analytics source: blog, shop, resources, export-gate-{sim}
}
const {
  username = globalUsername,
  tag = "makerportal-hub",
  title = "Get archive drops first.",
  blurb = "Privacy-first newsletter via Buttondown — no tracking pixels, markdown-friendly. Free snippet from BLExAR archive as lead magnet.",
  compact = false,
  class: className = "",
  source = "generic",
} = Astro.props as Props;

const effectiveUsername = (username || globalUsername || "").trim();
const hasUsername = Boolean(effectiveUsername);
const formAction = hasUsername ? `https://buttondown.com/api/emails/embed-subscribe/${effectiveUsername}` : BUTTONDOWN_ENABLED ? BUTTONDOWN_EMBED_URL : "";
---

<div class={`surface-card rounded-[20px] border bg-card-bg p-5 ${className}`} data-newsletter data-source={source} data-tag={tag} data-username={effectiveUsername}>
  {!compact && (
    <div>
      <p class="font-mono text-[0.6rem] uppercase tracking-[0.14em] text-primary-cta">Newsletter · Privacy-first</p>
      <h3 class="mt-2 text-[1.1rem] font-semibold tracking-[-0.02em] text-primary-text">{title}</h3>
      <p class="mt-2 text-[0.85rem] leading-[1.6] text-muted-text">{blurb}</p>
    </div>
  )}
  {hasUsername ? (
    <form action={formAction} method="post" target="_blank" class="newsletter-form mt-4 flex gap-2" data-source={source}>
      <input type="email" name="email" required placeholder="you@example.com" autocomplete="email" class="min-h-11 flex-1 rounded-full border border-border bg-canvas px-4 text-[0.9rem] text-primary-text placeholder:text-muted-text/60 focus:border-brand-anchor focus:outline-none focus:ring-2 focus:ring-brand-anchor/20" />
      <input type="hidden" name="tag" value={tag} />
      <button type="submit" class="min-h-11 rounded-full bg-primary-text px-5 text-[0.85rem] font-bold text-canvas hover:opacity-90 transition-opacity">Join</button>
    </form>
  ) : (
    <div class="mt-4 space-y-2">
      <div class="flex gap-2">
        <input type="email" disabled placeholder="you@lab.edu — coming soon (needs Buttondown username)" class="min-h-11 flex-1 rounded-full border border-border bg-canvas px-4 text-[0.9rem] text-primary-text placeholder:text-muted-text/60" />
        <span class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.8rem] font-medium text-muted-text">Soon</span>
      </div>
      <div class="rounded-[10px] border border-dashed border-border bg-elevated/40 px-3 py-2">
        <p class="font-mono text-[0.6rem] leading-[1.4] text-muted-text">
          Owner action: 1) create Buttondown account at buttondown.com 2) set <code class="rounded bg-canvas px-1">PUBLIC_BUTTONDOWN_USERNAME</code> env or edit <code class="rounded bg-canvas px-1">src/data/newsletter.ts</code> → <code class="rounded bg-canvas px-1">BUTTONDOWN_USERNAME</code>. No tracking pixels per D-014. ExportGate localStorage path still works.
        </p>
      </div>
    </div>
  )}
  <div class="newsletter-status mt-2 hidden rounded-[10px] border px-3 py-2 font-mono text-[0.7rem] leading-[1.4]"></div>
  <p class="mt-2 font-mono text-[0.6rem] text-muted-text">No tracking, unsubscribe anytime · RSS at <a href="/rss.xml" class="text-brand-anchor hover:text-primary-text">/rss.xml</a> · Privacy-first per D-014</p>
</div>

<script>
// @ts-nocheck
// Newsletter form — privacy-first, progressive enhancement
// If JS enabled, intercept submit, POST via fetch no-cors to Buttondown for better UX,
// then show inline success without navigation. Falls back to native form action with target=_blank.
(() => {
  function bindNewsletterForms() {
    document.querySelectorAll('.newsletter-form').forEach((form) => {
      if (form.dataset.bound === '1') return;
      form.dataset.bound = '1';
      form.addEventListener('submit', async (e) => {
        const fd = new FormData(form);
        const email = (fd.get('email') || '').toString().trim();
        if (!email || !email.includes('@')) return; // let native validation handle
        const action = form.getAttribute('action');
        if (!action) return;
        // Try JS-enhanced path — prevent navigation, POST no-cors
        try {
          e.preventDefault();
          const statusEl = form.parentElement?.querySelector('.newsletter-status');
          const btn = form.querySelector('button[type="submit"]');
          if (btn) {
            btn.disabled = true;
            btn.textContent = 'Joining…';
          }
          // Determine source tag from closest container
          const container = form.closest('[data-newsletter]');
          const source = container?.getAttribute('data-source') || form.getAttribute('data-source') || 'generic';
          // Append extra metadata as tags if supported — Buttondown embed only reads tag, but we keep generic
          // Ensure tag field exists
          fetch(action, {
            method: 'POST',
            body: fd,
            mode: 'no-cors',
          }).catch(() => {}).finally(() => {});

          // Analytics — first-party only
          try {
            window.dispatchEvent(new CustomEvent('mp:analytics', { detail: { event: 'newsletter_subscribe', source, email_domain: email.split('@')[1] } }));
          } catch {}

          // Store optionally for ExportGate cross-pollination
          try {
            localStorage.setItem('mp_newsletter_email', email);
            localStorage.setItem('mp_newsletter_source', source);
          } catch {}

          if (statusEl) {
            statusEl.classList.remove('hidden');
            statusEl.classList.remove('border-red-300', 'text-red-600');
            statusEl.classList.add('border-emerald-500/30', 'text-emerald-700', 'bg-emerald-500/5', 'border');
            statusEl.textContent = `✓ Subscribed as ${email} — check inbox for confirmation (if double opt-in enabled).`;
          }
          if (btn) {
            btn.textContent = '✓ Joined';
            btn.classList.add('bg-emerald-600');
          }
          form.reset();
          setTimeout(() => {
            if (btn) {
              btn.disabled = false;
              btn.textContent = 'Join';
              btn.classList.remove('bg-emerald-600');
            }
          }, 4000);
        } catch {
          // fallback to native submit if fetch fails
          form.submit();
        }
      });
    });

    // Expose global username for ExportGate to reuse
    try {
      const first = document.querySelector('[data-newsletter][data-username]');
      if (first) {
        const u = first.getAttribute('data-username');
        if (u) window.__MP_BUTTONDOWN_USER__ = u;
      }
    } catch {}
  }

  bindNewsletterForms();
  document.addEventListener('astro:page-load', bindNewsletterForms);
})();
</script>
