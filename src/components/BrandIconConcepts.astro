---
/**
 * BrandIconConcepts – App Grid
 * 2x2 grid of app tiles. The bottom-right tile is the accent cell: shown
 * crimson wherever the icon stands alone (showCore), or neutral in the
 * lockup so the wordmark's dot can visibly "deliver" its color there on hover
 * (see .grid-cell-br / .lockup-dot in BrandLogo.astro).
 */
interface Props { mono?: boolean; showCore?: boolean; activeConcept?: string; }
const { mono = false, showCore = false, activeConcept = 'agm' } = Astro.props as Props;
const accent = mono ? 'currentColor' : '#CE445D';
const brFill = mono ? 'currentColor' : (showCore ? accent : '#2A4A6B');

function svgFor(key: string): string {
  const agm = `<g class="grid-stack"><rect class="grid-cell" x="3" y="3" width="12" height="12" rx="3" fill="${mono ? 'currentColor' : '#2A4A6B'}" /><rect class="grid-cell" x="17" y="3" width="12" height="12" rx="3" fill="${mono ? 'currentColor' : '#345E86'}" /><rect class="grid-cell" x="3" y="17" width="12" height="12" rx="3" fill="${mono ? 'currentColor' : '#3E6C99'}" /><rect class="grid-cell grid-cell-br" x="17" y="17" width="12" height="12" rx="3" fill="${brFill}" /></g>`;
  const map: Record<string,string> = { agm };
  return map[key] || map['agm'];
}

const current = svgFor(activeConcept);
---

<g set:html={current} />
