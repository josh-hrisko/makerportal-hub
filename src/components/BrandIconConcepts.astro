---
/**
 * BrandIconConcepts – App Grid
 * 2×2 grid of app tiles. Bottom-right is always the crimson accent cell at rest
 * (both standalone icon and lockup). Lockup hover choreography lives in
 * BrandLogo.astro: wordmark dot → grid, BR center shrink/expand, dot fades
 * back in at home (no reverse travel).
 */
interface Props { mono?: boolean; showCore?: boolean; activeConcept?: string; }
const { mono = false, activeConcept = 'agm' } = Astro.props as Props;
const accent = mono ? 'currentColor' : '#CE445D';
const brFill = accent;

function svgFor(key: string): string {
  const tl = mono ? 'currentColor' : '#2A4A6B';
  const tr = mono ? 'currentColor' : '#345E86';
  const bl = mono ? 'currentColor' : '#3E6C99';
  const agm = `<g class="grid-stack"><rect class="grid-cell grid-cell-tl" x="3" y="3" width="12" height="12" rx="3" fill="${tl}" /><rect class="grid-cell grid-cell-tr" x="17" y="3" width="12" height="12" rx="3" fill="${tr}" /><rect class="grid-cell grid-cell-bl" x="3" y="17" width="12" height="12" rx="3" fill="${bl}" /><rect class="grid-cell grid-cell-br" x="17" y="17" width="12" height="12" rx="3" fill="${brFill}" /></g>`;
  const map: Record<string,string> = { agm };
  return map[key] || map['agm'];
}

const current = svgFor(activeConcept);
---

<g set:html={current} />
