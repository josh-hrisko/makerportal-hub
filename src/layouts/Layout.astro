---
import BrandLogo from '../components/BrandLogo.astro';
import SeoMeta from '../components/SeoMeta.astro';
import '../styles/global.css';
// @ts-ignore – fontsource side-effect import has no types
import '@fontsource-variable/plus-jakarta-sans';
// @ts-ignore
import '@fontsource-variable/inter';
// Resolved, hashed URLs for the primary (latin) subset woff2 files — used below to
// (a) preload the exact critical font asset (fixes chained-request / LCP path) and
// (b) re-declare the latin @font-face with font-display:optional instead of the
//     fontsource default `swap`, so a late font swap can never reflow the hero text
//     and regress CLS (root cause of the 0.667 CLS regression).
// @ts-ignore – vite `?url` suffix has no types
import plusJakartaLatinUrl from '@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url';
// @ts-ignore
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  canonical?: URL | string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, canonical, noindex, type, publishedTime, modifiedTime } = Astro.props;
const year = new Date().getFullYear();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://makersportal.com/#organization',
      name: 'MakerPortal',
      url: 'https://makersportal.com',
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.makerportal.ai/icon-512.png',
        width: 512,
        height: 512
      },
      sameAs: ['https://www.makerportal.ai', 'https://github.com/josh-hrisko', 'https://x.com/MakerPortal'],
      description: 'An independent San Francisco software studio crafting privacy-first iOS & iPadOS applications powered by on-device neural networks, Apple Silicon native intelligence.',
      foundingDate: '2023',
      founder: { '@type': 'Person', name: 'Josh Hrisco', sameAs: 'https://github.com/josh-hrisko' },
      location: { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: 'San Francisco', addressRegion: 'CA', addressCountry: 'US' } }
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.makerportal.ai/#website',
      url: 'https://www.makerportal.ai',
      name: 'MakerPortal',
      description: 'Independent AI & iOS software studio building privacy-first applications with on-device machine learning.',
      publisher: { '@id': 'https://makersportal.com/#organization' },
      inLanguage: 'en-US',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://www.makerportal.ai/blog?q={search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://www.makerportal.ai/#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' }
      ]
    }
  ],
};
---

<!doctype html>
<html lang="en" class="bg-canvas scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0F141C" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap.xml" />
    <!-- Self-hosted variable fonts via fontsource - no render-blocking CDN.
         Preload the primary (latin) subset so the browser fetches it immediately,
         shortening the critical request chain instead of discovering it only after
         CSS parses. -->
    <link rel="preload" as="font" type="font/woff2" href={plusJakartaLatinUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatinUrl} crossorigin />
    <style set:html={`
      @font-face {
        font-family: 'Plus Jakarta Sans Variable';
        font-style: normal;
        font-display: optional;
        font-weight: 200 800;
        src: url(${plusJakartaLatinUrl}) format('woff2-variations');
        unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
      }
      @font-face {
        font-family: 'Inter Variable';
        font-style: normal;
        font-display: optional;
        font-weight: 100 900;
        src: url(${interLatinUrl}) format('woff2-variations');
        unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+2122,U+2212,U+2215,U+FEFF,U+FFFD;
      }
    `} />
    <SeoMeta title={title} description={description} canonical={canonical} noindex={noindex} type={type} publishedTime={publishedTime} modifiedTime={modifiedTime} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    <slot name="head" />
    <!-- Agentic browsing meta -->
    <meta name="ai:publisher" content="MakerPortal – Josh Hrisco – San Francisco" />
    <meta name="ai:content-type" content="technology, iOS development, on-device AI, privacy-first software" />
  </head>
  <body class="flex min-h-screen flex-col overflow-x-clip font-sans text-primary-text antialiased selection:bg-primary-cta selection:text-white">
    <a href="#main-content" class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-full bg-brand-anchor px-4 py-2.5 font-semibold text-canvas shadow-lg transition-transform duration-300 focus:translate-y-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white">Skip to main content</a>

    <header class="pointer-events-none fixed inset-x-0 top-0 z-50 mx-auto w-full max-w-[88rem] px-4 pt-[max(1rem,env(safe-area-inset-top))] sm:px-6 lg:px-8">
      <!-- Opaque pill nav (no backdrop-filter) — live backdrop-blur on a fixed
           header is a known iOS Safari compositor tax during scroll. -->
      <nav aria-label="Primary" class="pointer-events-auto relative flex h-[3.875rem] items-center justify-between rounded-full border border-white/[0.08] bg-[#151D27]/95 px-4 shadow-[0_8px_32px_-8px_rgba(0,0,0,0.6),inset_0_1px_1px_rgba(255,255,255,0.08)] transition-[transform,box-shadow,border-color,background-color] duration-300 hover:border-white/[0.12] hover:bg-[#1A232E] hover:shadow-[0_12px_40px_-8px_rgba(0,0,0,0.7)] sm:px-6" data-nav>
        
        <a href="/" class="group/logo relative inline-flex items-center gap-3 rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor focus-visible:ring-offset-2 focus-visible:ring-offset-canvas" aria-label="MakerPortal — Home">
          <BrandLogo variant="lockup" size="md" />
        </a>

        <div class="hidden items-center gap-1 md:flex">
          <a href="/#apps" class="relative inline-flex min-h-9 items-center rounded-full px-3.5 text-[0.875rem] font-[500] tracking-[-0.01em] text-primary-text/80 transition-colors hover:text-white after:absolute after:bottom-0 after:left-3.5 after:right-3.5 after:h-px after:origin-center after:scale-x-0 after:bg-white after:transition-transform hover:after:scale-x-100">Apps</a>
          <a href="/blog" class="relative inline-flex min-h-9 items-center rounded-full px-3.5 text-[0.875rem] font-[500] tracking-[-0.01em] text-primary-text/80 transition-colors hover:text-white after:absolute after:bottom-0 after:left-3.5 after:right-3.5 after:h-px after:origin-center after:scale-x-0 after:bg-white after:transition-transform hover:after:scale-x-100">Field notes</a>
          <a href="/#contact" class="relative inline-flex min-h-9 items-center rounded-full px-3.5 text-[0.875rem] font-[500] tracking-[-0.01em] text-primary-text/70 transition-colors hover:text-white">Contact</a>
          <a href="https://makersportal.com" rel="me noopener" target="_blank" class="ml-2 inline-flex min-h-9 items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.06] px-3.5 text-[0.84rem] font-semibold tracking-[-0.01em] text-white transition-colors hover:border-white/15 hover:bg-white/[0.10]">
            Studio <span aria-hidden="true" class="opacity-60 transition-transform group-hover:translate-x-0.5">↗</span>
          </a>
        </div>

        <div class="flex items-center gap-2 md:hidden">
          <a href="/blog" class="inline-flex min-h-10 items-center rounded-full px-3.5 text-[0.875rem] font-medium text-primary-text/75 transition-colors hover:text-white">Notes</a>
          <button
            id="mobile-menu-toggle"
            type="button"
            class="relative z-[60] grid size-10 place-items-center rounded-full border border-white/10 bg-white/[0.08] text-white transition-colors hover:border-white/20 hover:bg-white/[0.12]"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Open navigation"
          >
            <span class="sr-only">Menu</span>
            <span aria-hidden="true" class="relative flex size-4 flex-col items-center justify-center gap-1">
              <span id="menu-line-1" class="block h-0.5 w-4 origin-center rounded-full bg-white transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]"></span>
              <span id="menu-line-2" class="block h-0.5 w-4 origin-center rounded-full bg-white transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]"></span>
            </span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Solid dimmer + solid drawer (no backdrop-filter). Stacked full-viewport
         blurs with the fixed nav was the main iOS Safari menu/open lag source. -->
    <div id="mobile-menu-backdrop" class="fixed inset-0 z-40 hidden bg-[#0A0E14]/72 opacity-0 transition-opacity duration-200 md:hidden" aria-hidden="true"></div>

    <div
      id="mobile-menu"
      class="fixed inset-y-0 right-0 z-50 flex w-[88vw] max-w-[22rem] translate-x-full flex-col border-l border-white/[0.08] bg-[#121A24] shadow-[-24px_0_64px_rgba(0,0,0,0.55)] transition-[transform,translate] duration-250 ease-[cubic-bezier(0.25,1,0.5,1)] touch-pan-y md:hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation"
      aria-hidden="true"
      inert
    >
      <div class="flex h-[4.25rem] shrink-0 items-center justify-between border-b border-white/[0.06] px-6">
        <span class="inline-flex items-center gap-2 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text"><BrandLogo variant="icon" size="sm" class="opacity-80" /> Navigation</span>
        <span class="font-mono text-[0.6rem] tracking-[0.16em] text-muted-text/70">2026 • SF</span>
      </div>

      <div class="flex flex-1 flex-col overflow-y-auto px-4 pb-8 pt-6">
        <ul class="space-y-1" role="list">
          <li><a href="/" class="mobile-link group flex items-center justify-between rounded-2xl px-4 py-3.5 text-[1.35rem] font-semibold tracking-[-0.02em] text-white transition-colors hover:bg-white/[0.04]">01 • Home <span aria-hidden="true" class="text-muted-text/70 transition-transform group-hover:translate-x-1">→</span></a></li>
          <li><a href="/#apps" class="mobile-link group flex items-center justify-between rounded-2xl px-4 py-3.5 text-[1.35rem] font-semibold tracking-[-0.02em] text-white/80 transition-colors hover:bg-white/[0.04] hover:text-white">02 • Apps <span aria-hidden="true" class="text-muted-text/70 transition-transform group-hover:translate-x-1">→</span></a></li>
          <li><a href="/blog" class="mobile-link group flex items-center justify-between rounded-2xl px-4 py-3.5 text-[1.35rem] font-semibold tracking-[-0.02em] text-white/80 transition-colors hover:bg-white/[0.04] hover:text-white">03 • Field Notes <span aria-hidden="true" class="text-muted-text/70">→</span></a></li>
          <li><a href="/#contact" class="mobile-link group flex items-center justify-between rounded-2xl px-4 py-3.5 text-[1.35rem] font-semibold tracking-[-0.02em] text-white/80 transition-colors hover:bg-white/[0.04] hover:text-white">04 • Contact <span aria-hidden="true" class="text-muted-text/70">→</span></a></li>
        </ul>

        <div class="mt-auto pt-6">
          <div class="rounded-[20px] border border-white/[0.06] bg-[#1A232E] p-5">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text/70">Studio Journal • makersportal.com</p>
            <a href="https://makersportal.com" rel="me" class="mt-3 inline-flex w-full items-center justify-between rounded-full bg-white px-4 py-3 text-[0.9rem] font-bold tracking-[-0.01em] text-canvas transition hover:bg-primary-text"><span>Open journal</span><span aria-hidden="true">↗</span></a>
            <div class="mt-4 flex items-center gap-3 font-mono text-[0.65rem] uppercase tracking-[0.14em] text-muted-text/70">
              <a href="https://github.com/josh-hrisko" rel="me" class="hover:text-white">GitHub</a><span>•</span><a href="/rss.xml" class="hover:text-white">RSS</a><span>•</span><a href="/brand" class="hover:text-white">Brand</a>
            </div>
          </div>
          <p class="mt-4 px-2 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-muted-text/70">On-device • Private • Crafted in San Francisco</p>
        </div>
      </div>
    </div>

    <button
      id="back-to-top"
      type="button"
      aria-label="Back to top"
      class="fixed bottom-[max(1.5rem,env(safe-area-inset-bottom))] right-5 z-40 grid size-11 translate-y-2 place-items-center rounded-full border border-white/10 bg-[#1A232E] text-primary-text opacity-0 shadow-[0_8px_24px_-4px_rgba(0,0,0,0.5),inset_0_1px_1px_rgba(255,255,255,0.08)] transition-[opacity,transform] duration-250 pointer-events-none hover:border-brand-anchor/40 hover:bg-[#212D3A] hover:text-white focus-visible:pointer-events-auto focus-visible:opacity-100 focus-visible:translate-y-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor sm:right-8 lg:right-10"
    >
      <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="size-4"><path d="M10 16V4M10 4L4.5 9.5M10 4l5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </button>

    <script is:inline>
      (() => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const backdrop = document.getElementById('mobile-menu-backdrop');
        const line1 = document.getElementById('menu-line-1');
        const line2 = document.getElementById('menu-line-2');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        if (!toggle || !menu || !backdrop || !line1 || !line2) return;

        let isOpen = false;
        let lastFocus = null;
        let rafId = null;

        const openMenu = () => {
          if (isOpen) return;
          isOpen = true;
          lastFocus = document.activeElement;
          toggle.setAttribute('aria-expanded', 'true');
          toggle.setAttribute('aria-label', 'Close navigation');
          menu.removeAttribute('inert');
          menu.setAttribute('aria-hidden', 'false');
          backdrop.classList.remove('hidden');
          // Single rAF so the browser paints the un-hidden backdrop before the
          // opacity/transform transition — avoids double-rAF (~32ms) open lag.
          rafId = requestAnimationFrame(() => {
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-100');
            menu.classList.remove('translate-x-full');
            menu.classList.add('translate-x-0');
          });
          document.body.style.overflow = 'hidden';
          line1.classList.add('translate-y-[3px]', 'rotate-45');
          line2.classList.add('-translate-y-[3px]', '-rotate-45');
          setTimeout(() => {
            const first = menu.querySelector('a');
            if (first) first.focus();
          }, 60);
        };

        const closeMenu = () => {
          if (!isOpen) return;
          isOpen = false;
          if (rafId) cancelAnimationFrame(rafId);
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open navigation');
          menu.setAttribute('aria-hidden', 'true');
          backdrop.classList.remove('opacity-100');
          backdrop.classList.add('opacity-0');
          menu.classList.remove('translate-x-0');
          menu.classList.add('translate-x-full');
          document.body.style.overflow = '';
          line1.classList.remove('translate-y-[3px]', 'rotate-45');
          line2.classList.remove('-translate-y-[3px]', '-rotate-45');
          setTimeout(() => {
            backdrop.classList.add('hidden');
            try { menu.setAttribute('inert', ''); } catch {}
            if (lastFocus && lastFocus.focus) lastFocus.focus();
          }, 260);
        };

        toggle.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });
        backdrop.addEventListener('click', closeMenu);
        mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) { e.preventDefault(); closeMenu(); } });

        let resizeTimer;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => { if (window.innerWidth >= 768 && isOpen) closeMenu(); }, 120);
        }, { passive: true });

        try { menu.setAttribute('inert', ''); } catch {}

        // Swipe-to-dismiss (rightward). touch-pan-y on the panel lets vertical
        // scroll keep working while horizontal stays available to JS. iOS was
        // failing the old strict axis lock + high threshold on diagonal flicks.
        let dragging = false;
        let dragDecided = false;
        let dragAxis = null;
        let dragStartX = 0;
        let dragStartY = 0;
        let dragDeltaX = 0;
        let dragLastX = 0;
        let dragLastT = 0;
        let dragVelocityX = 0;
        let menuWidthCache = 0;
        let activePointerId = null;
        let suppressClick = false;

        const clearDragStyles = () => {
          menu.style.transition = '';
          menu.style.translate = '';
          menu.style.transform = '';
          backdrop.style.transition = '';
          backdrop.style.opacity = '';
          menu.style.touchAction = '';
        };

        const endDrag = (shouldClose) => {
          if (!dragging) return;
          dragging = false;
          const axis = dragAxis;
          dragAxis = null;
          activePointerId = null;
          if (axis !== 'x') {
            clearDragStyles();
            return;
          }
          menu.style.transition = 'transform 0.22s cubic-bezier(0.25,1,0.5,1), translate 0.22s cubic-bezier(0.25,1,0.5,1)';
          backdrop.style.transition = 'opacity 0.2s ease';
          if (shouldClose) {
            suppressClick = true;
            menu.style.translate = `${menuWidthCache}px`;
            menu.style.transform = `translate3d(${menuWidthCache}px,0,0)`;
            backdrop.style.opacity = '0';
            closeMenu();
            setTimeout(clearDragStyles, 260);
          } else {
            menu.style.translate = '0px';
            menu.style.transform = 'translate3d(0,0,0)';
            backdrop.style.opacity = '1';
            setTimeout(clearDragStyles, 230);
          }
        };

        menu.addEventListener('pointerdown', (e) => {
          if (!isOpen || e.button !== 0) return;
          // Ignore multi-touch / secondary pointers mid-drag.
          if (activePointerId !== null) return;
          dragging = true;
          dragDecided = false;
          dragAxis = null;
          dragDeltaX = 0;
          dragVelocityX = 0;
          dragStartX = e.clientX;
          dragStartY = e.clientY;
          dragLastX = e.clientX;
          dragLastT = performance.now();
          menuWidthCache = menu.offsetWidth || menu.getBoundingClientRect().width;
          activePointerId = e.pointerId;
          try { menu.setPointerCapture(e.pointerId); } catch {}
        });

        menu.addEventListener('pointermove', (e) => {
          if (!dragging || e.pointerId !== activePointerId) return;
          const dx = e.clientX - dragStartX;
          const dy = e.clientY - dragStartY;
          const now = performance.now();
          const dt = Math.max(1, now - dragLastT);
          // Instantaneous velocity (px/ms) for flick-to-close.
          dragVelocityX = (e.clientX - dragLastX) / dt;
          dragLastX = e.clientX;
          dragLastT = now;

          if (!dragDecided) {
            // Slightly higher gate so taps don't steal; bias to horizontal when
            // the gesture is clearly rightward (dismiss direction).
            if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
            dragDecided = true;
            const rightward = dx > 0;
            const horizontalBias = rightward
              ? Math.abs(dx) >= Math.abs(dy) * 0.65
              : Math.abs(dx) > Math.abs(dy) * 1.15;
            dragAxis = horizontalBias ? 'x' : 'y';
            if (dragAxis === 'x') {
              menu.style.transition = 'none';
              backdrop.style.transition = 'none';
              menu.style.touchAction = 'none';
            }
          }
          if (dragAxis !== 'x') return;
          // Keep the browser from scrolling/claiming the gesture once locked.
          if (e.cancelable) e.preventDefault();
          dragDeltaX = Math.max(0, dx);
          menu.style.translate = `${dragDeltaX}px`;
          menu.style.transform = `translate3d(${dragDeltaX}px,0,0)`;
          backdrop.style.opacity = String(Math.max(0, 1 - dragDeltaX / Math.max(1, menuWidthCache)));
        }, { passive: false });

        const onPointerEnd = (e) => {
          if (!dragging || (activePointerId !== null && e.pointerId !== activePointerId)) return;
          if (dragAxis !== 'x') {
            endDrag(false);
            return;
          }
          // Distance OR flick velocity (px/ms ≈ 0.45 → ~450px/s).
          const distanceOk = dragDeltaX > Math.min(56, menuWidthCache * 0.18);
          const flickOk = dragVelocityX > 0.45 && dragDeltaX > 12;
          endDrag(distanceOk || flickOk);
        };
        menu.addEventListener('pointerup', onPointerEnd);
        menu.addEventListener('pointercancel', (e) => {
          if (activePointerId !== null && e.pointerId !== activePointerId) return;
          endDrag(false);
        });
        // After a successful swipe, swallow the synthetic click so a link under
        // the finger doesn't navigate while the drawer closes.
        menu.addEventListener('click', (e) => {
          if (!suppressClick) return;
          e.preventDefault();
          e.stopPropagation();
          suppressClick = false;
        }, true);

        // Single scroll rAF: nav shadow + back-to-top visibility (avoids two
        // competing scroll listeners thrashing style under the fixed header).
        const nav = document.querySelector('[data-nav]');
        const backToTop = document.getElementById('back-to-top');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let lastY = 0;
        let ticking = false;
        let btVisible = false;
        window.addEventListener('scroll', () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const y = window.scrollY;
            if (nav) {
              nav.classList.toggle('translate-y-[-4px]', y > 24 && y > lastY);
              nav.classList.toggle('scale-[0.99]', y > 24 && y > lastY);
              nav.classList.toggle('shadow-[0_12px_48px_-12px_rgba(0,0,0,0.8)]', y > 12);
            }
            if (backToTop) {
              const show = y > 480;
              if (show !== btVisible) {
                btVisible = show;
                backToTop.classList.toggle('opacity-0', !show);
                backToTop.classList.toggle('pointer-events-none', !show);
                backToTop.classList.toggle('translate-y-2', !show);
                backToTop.classList.toggle('opacity-100', show);
                backToTop.classList.toggle('translate-y-0', show);
              }
            }
            lastY = y;
            ticking = false;
          });
        }, { passive: true });
        if (backToTop) {
          backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
          });
        }
      })();
