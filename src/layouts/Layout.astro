---
import BrandLogo from '../components/BrandLogo.astro';
import SeoMeta from '../components/SeoMeta.astro';
import SearchModal from '../components/SearchModal.astro';
import { footerColumns, primaryNav, socials } from '../data/site-nav';
import '../styles/global.css';
// @ts-ignore – fontsource side-effect import has no types
import '@fontsource-variable/plus-jakarta-sans';
// @ts-ignore
import '@fontsource-variable/inter';
// Resolved, hashed URLs for the primary (latin) subset woff2 files — used below to
// (a) preload the exact critical font asset (fixes chained-request / LCP path) and
// (b) re-declare the latin @font-face with font-display:optional instead of the
//     fontsource default `swap`, so a late font swap can never reflow the hero text
//     and regress CLS (root cause of the 0.667 CLS regression).
// @ts-ignore – vite `?url` suffix has no types
import plusJakartaLatinUrl from '@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url';
// @ts-ignore
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  canonical?: URL | string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, canonical, noindex, type, publishedTime, modifiedTime } = Astro.props;
const year = new Date().getFullYear();
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (!href || href.startsWith('http') || href.startsWith('#')) return false;
  const clean = href.split('#')[0].replace(/\/$/, '') || '/';
  if (clean === '/') return path === '/';
  return path === clean || path.startsWith(`${clean}/`);
};
// A mega-menu can legitimately cross-link into another section's page (e.g.
// Shop's "Affiliate picks" -> /resources#tools). Without this, isActive on
// that sub-link would also light up Shop while on /resources, alongside
// Guides (whose own href IS /resources) — two nav items active at once.
// Whichever item actually owns the current path via its own href wins
// outright; sub-link matching is only a fallback for pages no item owns
// directly.
const directMatchHref = primaryNav.find((item) => isActive(item.href))?.href;
const isNavItemActive = (href: string, columns?: { links: { href: string }[] }[]) => {
  if (columns && directMatchHref) return href === directMatchHref;
  if (isActive(href)) return true;
  return columns?.some((col) => col.links.some((l) => isActive(l.href))) ?? false;
};
const footerLinkClass = (href: string) =>
  isActive(href)
    ? 'w-fit font-medium text-primary-text'
    : 'w-fit text-muted-text transition-colors hover:text-primary-text';
/**
 * Ecosystem navigation rule (D-009):
 * - *.makerportal.ai + makersportal.com = same-tab (studio cluster, back-button journey)
 * - Truly external (github.com, x.com, youtube.com) = new-tab with noopener
 * - Internal hub routes = same-tab
 * Only github/x/youtube get target=_blank.
 */
const isTrulyExternal = (href: string) =>
  href.includes('github.com') || href.includes('x.com/') || href.includes('youtube.com') || href.includes('youtu.be');

const linkAttrs = (href: string, external?: boolean) => {
  if (!external) return { href };
  // Even if marked external, ecosystem domains stay same-tab
  if (href.includes('makerportal.ai') || href.includes('makersportal.com')) {
    return { href, rel: 'noopener' };
  }
  if (isTrulyExternal(href)) {
    return { href, target: '_blank', rel: href.includes('github.com/makerportal') || href.includes('MakerPortal') || href.includes('x.com/MakerPortal') ? 'me noopener noreferrer' : 'noopener noreferrer' };
  }
  // Fallback: non-ecosystem external without explicit true-external flag? Stay same-tab safe.
  return { href, target: '_blank', rel: 'noopener noreferrer' };
};

/** Long-form routes default readers toward paper; theme toggle still works sitewide. */
const isReadingPath =
  path.startsWith('/blog') ||
  path === '/privacy' ||
  path === '/terms';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://makersportal.com/#organization',
      name: 'MakerPortal',
      url: 'https://makersportal.com',
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.makerportal.ai/icon-512.png',
        width: 512,
        height: 512
      },
      sameAs: ['https://www.makerportal.ai', 'https://github.com/makerportal', 'https://x.com/MakerPortal'],
      description: 'An independent San Francisco software studio crafting iOS & iPadOS applications — on-device ML where possible, transparent hybrid cloud for agentic DSP (AuraLinter), CoreML, Metal, ANE, LangGraph.',
      foundingDate: '2023',
      location: { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: 'San Francisco', addressRegion: 'CA', addressCountry: 'US' } }
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.makerportal.ai/#website',
      url: 'https://www.makerportal.ai',
      name: 'MakerPortal',
      description: 'Independent iOS software studio building on-device AI and agentic DSP apps with transparent architecture — CoreML, Metal, ANE, hybrid cloud where needed.',
      publisher: { '@id': 'https://makersportal.com/#organization' },
      inLanguage: 'en-US',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://www.makerportal.ai/blog?q={search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://www.makerportal.ai/#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' }
      ]
    }
  ],
};
---

<!doctype html>
<html lang="en" class="bg-canvas scroll-smooth" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#F4F1EB" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F141C" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap.xml" />
    <!-- FOUC-free theme: light default (was dark studio brand).
         Stored preference wins, otherwise ?theme= param, otherwise light.
         Toggle UI is now hidden — secret triggers: triple-click logo, Shift+T, double-click footer pill.
         See global.css .theme-toggle {display:none} + JS below for easter-egg. -->
    <script is:inline>
      (() => {
        try {
          const params = new URLSearchParams(window.location.search);
          const paramTheme = params.get('theme');
          const stored = localStorage.getItem('mp-theme');
          // Light default — was dark studio, now light for broader appeal.
          // Only switch to dark if stored=dark or ?theme=dark or paramTheme.
          let theme = 'light';
          if (paramTheme === 'dark' || paramTheme === 'light') {
            theme = paramTheme;
          } else if (stored === 'light' || stored === 'dark') {
            theme = stored;
          }
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.colorScheme = theme;
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <!-- Self-hosted variable fonts via fontsource - no render-blocking CDN.
         Preload the primary (latin) subset so the browser fetches it immediately,
         shortening the critical request chain instead of discovering it only after
         CSS parses. -->
    <link rel="preload" as="font" type="font/woff2" href={plusJakartaLatinUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatinUrl} crossorigin />
    <style set:html={`
      @font-face {
        font-family: 'Plus Jakarta Sans Variable';
        font-style: normal;
        font-display: optional;
        font-weight: 200 800;
        src: url(${plusJakartaLatinUrl}) format('woff2-variations');
        unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
      }
      @font-face {
        font-family: 'Inter Variable';
        font-style: normal;
        font-display: optional;
        font-weight: 100 900;
        src: url(${interLatinUrl}) format('woff2-variations');
        unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+2122,U+2212,U+2215,U+FEFF,U+FFFD;
      }
    `} />
    <SeoMeta title={title} description={description} canonical={canonical} noindex={noindex} type={type} publishedTime={publishedTime} modifiedTime={modifiedTime} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    <slot name="head" />
    <!-- Agentic browsing meta -->
    <meta name="ai:publisher" content="MakerPortal – San Francisco" />
    <meta name="ai:content-type" content="technology, iOS development, on-device AI, agentic DSP, transparent hybrid architecture" />
  </head>
  <body class="flex min-h-screen flex-col overflow-x-clip bg-canvas font-sans text-primary-text antialiased selection:bg-primary-cta selection:text-white" data-reading-path={isReadingPath ? 'true' : 'false'}>
    <a href="#main-content" class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-full bg-brand-anchor px-4 py-2.5 font-semibold text-canvas shadow-lg transition-transform duration-300 focus:translate-y-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white">Skip to main content</a>

    <header class="fixed inset-x-0 top-0 z-50 border-b border-border bg-canvas/95 px-4 transition-[box-shadow,background-color] duration-300 sm:px-6 lg:px-8" data-nav>
      <nav aria-label="Primary" class="mx-auto flex h-[3.875rem] max-w-[88rem] items-center justify-between">
        
        <a href="/" class="group/logo relative inline-flex shrink-0 items-center gap-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor focus-visible:ring-offset-2 focus-visible:ring-offset-canvas" aria-label="MakerPortal — Home">
          <BrandLogo variant="lockup" size="md" />
        </a>

        <!-- Desktop: Centered Links with active underlines -->
        <div class="hidden flex-1 items-center justify-center gap-1 lg:flex">
          {primaryNav.map((item) => {
            const active = isNavItemActive(item.href, item.columns);
            const hasMega = Boolean(item.columns?.length);
            if (!hasMega) {
              return (
                <a
                  href={item.href}
                  class:list={['relative inline-flex h-9 items-center px-3.5 text-[0.84rem] font-medium tracking-[-0.01em] transition-colors', active ? 'text-primary-text' : 'text-muted-text hover:text-primary-text']}
                  aria-current={active ? 'page' : undefined}
                >
                  {item.label}
                  {active && <span aria-hidden="true" class="absolute inset-x-3.5 -bottom-[0.9rem] h-[2px] bg-primary-text rounded-t-full"></span>}
                </a>
              );
            }
            return (
              <div class="relative" data-mega-root>
                <button
                  type="button"
                  class:list={['relative inline-flex h-9 items-center gap-1.5 px-3.5 text-[0.84rem] font-medium tracking-[-0.01em] transition-colors', active ? 'text-primary-text' : 'text-muted-text hover:text-primary-text']}
                  aria-expanded="false"
                  aria-haspopup="true"
                  data-mega-trigger
                  data-mega-for={item.id}
                >
                  {item.label}
                  <svg aria-hidden="true" viewBox="0 0 12 12" class="size-2.5 opacity-50"><path d="M2.5 4.5L6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  {active && <span aria-hidden="true" class="absolute inset-x-3.5 -bottom-[0.9rem] h-[2px] bg-primary-text rounded-t-full"></span>}
                </button>
                <div
                  id={`mega-${item.id}`}
                  data-mega-panel
                  class="invisible absolute left-1/2 top-[calc(100%+1.1rem)] z-[70] w-[min(92vw,42rem)] -translate-x-1/2 translate-y-1 scale-[0.98] opacity-0 transition-[opacity,transform,visibility] duration-150"
                  hidden
                >
                  <div class="surface-card overflow-hidden rounded-[22px] border p-5 shadow-xl">
                    <div class:list={['grid gap-6', item.featured ? 'sm:grid-cols-[1fr_0.85fr]' : '']}>
                      <div class:list={['grid gap-5', (item.columns?.length ?? 0) > 1 ? 'sm:grid-cols-2' : '']}>
                        {item.columns?.map((col) => (
                          <div class={col.links.length > 6 ? 'sm:col-span-2 lg:col-span-1' : ''}>
                            <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">{col.title} {col.links.length > 6 ? `· ${col.links.length}` : ''}</p>
                            <ul class:list={['mt-3 space-y-1', col.links.length > 6 ? 'grid grid-cols-1 gap-1 sm:grid-cols-2 sm:space-y-0' : '']} role="list">
                              {col.links.map((link) => (
                                <li>
                                  <a
                                    {...linkAttrs(link.href, link.external)}
                                    class="group block rounded-xl px-2.5 py-2 transition-colors hover:bg-elevated/80"
                                  >
                                    <span class="flex items-center gap-2 text-[0.9rem] font-medium text-primary-text">
                                      {link.label}
                                      {link.external && <span class="text-[0.7rem] text-muted-text">↗</span>}
                                      {link.badge && <span class="rounded-full bg-primary-cta/15 px-1.5 py-0.5 font-mono text-[0.6rem] font-medium uppercase tracking-wider text-primary-cta">{link.badge}</span>}
                                    </span>
                                    {link.description && <span class="mt-0.5 block text-[0.75rem] text-muted-text">{link.description}</span>}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ))}
                      </div>
                      {item.featured && (
                        <a href={item.featured.href} class="flex flex-col justify-between rounded-2xl border border-border bg-canvas p-4 transition-colors hover:border-brand-anchor/30">
                          <div>
                            <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-primary-cta">{item.featured.kicker}</p>
                            <p class="mt-2 text-[1.05rem] font-semibold tracking-[-0.02em] text-primary-text">{item.featured.title}</p>
                            <p class="mt-2 text-[0.8rem] leading-[1.55] text-muted-text">{item.featured.description}</p>
                          </div>
                          <span class="mt-4 text-[0.8rem] font-semibold text-brand-anchor">{item.featured.cta}</span>
                        </a>
                      )}
                    </div>
                    <div class="mt-4 flex items-center justify-between border-t border-border pt-3">
                      <a href={item.href} class="text-[0.8rem] font-medium text-muted-text hover:text-primary-text">All {item.label.toLowerCase()} →</a>
                      <a href="/contact" class="text-[0.75rem] font-medium text-muted-text hover:text-primary-text">Contact</a>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <div class="flex items-center gap-1 md:gap-2">
          <!-- Site Search Button -->
          <button
            type="button"
            id="site-search-btn"
            class="grid size-9 place-items-center rounded-full text-muted-text transition-colors hover:bg-elevated hover:text-primary-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor"
            aria-label="Search site"
          >
            <svg viewBox="0 0 24 24" fill="none" class="size-[1.1rem]"><path d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          
          <button
            type="button"
            class="theme-toggle grid size-9 place-items-center rounded-full text-muted-text transition-colors hover:bg-elevated hover:text-primary-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor"
            data-theme-toggle
            aria-label="Toggle color theme"
            title="Toggle light / dark"
          >
            <svg class="icon-moon size-[1.1rem]" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 14.5A8.5 8.5 0 019.5 3 7 7 0 1021 14.5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
            <svg class="icon-sun size-[1.1rem]" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
          
          <a href="/contact" class="hidden ml-1 min-h-9 items-center rounded-full border border-border bg-elevated/80 px-4 text-[0.82rem] font-semibold tracking-[-0.01em] text-primary-text transition-colors hover:border-brand-anchor/40 hover:bg-elevated lg:inline-flex">
            Contact
          </a>

          <button
            id="mobile-menu-toggle"
            type="button"
            class="relative z-[60] ml-1 grid size-9 place-items-center rounded-full border border-border bg-elevated/80 text-primary-text transition-colors hover:border-brand-anchor/40 hover:bg-elevated lg:hidden"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Open navigation"
          >
            <span class="sr-only">Menu</span>
            <span aria-hidden="true" class="relative flex size-4 flex-col items-center justify-center gap-1">
              <span id="menu-line-1" class="block h-0.5 w-4 origin-center rounded-full bg-current transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]"></span>
              <span id="menu-line-2" class="block h-0.5 w-4 origin-center rounded-full bg-current transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]"></span>
            </span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Solid dimmer + solid drawer (no backdrop-filter). Stacked full-viewport
         blurs with the fixed nav was the main iOS Safari menu/open lag source. -->
    <div id="mobile-menu-backdrop" class="fixed inset-0 z-40 hidden bg-canvas/70 opacity-0 transition-opacity duration-200 lg:hidden" aria-hidden="true"></div>

    <div
      id="mobile-menu"
      class="surface-drawer fixed inset-y-0 right-0 z-50 flex w-[88vw] max-w-[22rem] translate-x-full flex-col border-l transition-[transform,translate] duration-250 ease-[cubic-bezier(0.25,1,0.5,1)] touch-pan-y lg:hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation"
      aria-hidden="true"
      inert
    >
      <div class="flex h-[4.25rem] shrink-0 items-center justify-between border-b border-border px-5 pl-6">
        <span class="inline-flex items-center gap-2 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text"><BrandLogo variant="icon" size="sm" class="opacity-80" /> Navigation</span>
        <div class="flex items-center gap-2">
          <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle color theme" title="Toggle light / dark">
            <svg class="icon-moon size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 14.5A8.5 8.5 0 019.5 3 7 7 0 1021 14.5z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/></svg>
            <svg class="icon-sun size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
          </button>
          <button
            id="mobile-menu-close"
            type="button"
            aria-label="Close navigation"
            class="grid size-10 place-items-center rounded-full border border-border bg-elevated/60 text-primary-text transition-colors hover:border-brand-anchor/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor"
          >
            <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="size-4">
              <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </div>

      <div class="flex flex-1 flex-col overflow-y-auto px-4 pb-8 pt-4">
        <a href="/" class="mobile-link mb-2 rounded-2xl px-4 py-3 text-[1.15rem] font-semibold text-primary-text hover:bg-elevated">Home</a>
        <div class="space-y-1" data-mobile-nav>
          {primaryNav.map((item, index) => {
            const active = isNavItemActive(item.href, item.columns);
            return (
              <div class="rounded-2xl border border-transparent" data-mobile-section>
                {item.columns?.length ? (
                  <>
                    <button
                      type="button"
                      class:list={['flex w-full items-center justify-between rounded-2xl px-4 py-3.5 text-left text-[1.2rem] font-semibold tracking-[-0.02em] hover:bg-elevated', active ? 'text-primary-text bg-elevated/50' : 'text-primary-text']}
                      aria-expanded="false"
                      data-mobile-accordion
                    >
                      <span>{String(index + 1).padStart(2, '0')} · {item.label}</span>
                      <span aria-hidden="true" class="text-muted-text/60 transition-transform data-[open]:rotate-90" data-chevron>→</span>
                    </button>
                    <div class="hidden space-y-0.5 px-2 pb-3" data-mobile-panel>
                      <a href={item.href} class="mobile-link block rounded-xl px-3 py-2.5 text-[0.95rem] font-medium text-brand-anchor hover:bg-elevated">Overview →</a>
                      {item.columns.flatMap((col) =>
                        col.links.map((link) => {
                          const linkActive = isNavItemActive(link.href);
                          return (
                            <a
                              {...linkAttrs(link.href, link.external)}
                              class:list={['mobile-link block rounded-xl px-3 py-2.5 text-[0.95rem] hover:bg-elevated hover:text-primary-text', linkActive ? 'text-primary-text font-medium bg-elevated/30' : 'text-muted-text']}
                              aria-current={linkActive ? 'page' : undefined}
                            >
                              {link.label}{link.external ? ' ↗' : ''}
                            </a>
                          );
                        })
                      )}
                    </div>
                  </>
                ) : (
                  <a href={item.href} aria-current={active ? 'page' : undefined} class:list={['mobile-link flex items-center justify-between rounded-2xl px-4 py-3.5 text-[1.2rem] font-semibold tracking-[-0.02em] hover:bg-elevated', active ? 'text-primary-text bg-elevated/50' : 'text-primary-text']}>
                    <span>{String(index + 1).padStart(2, '0')} · {item.label}</span>
                    <span aria-hidden="true" class="text-muted-text/60">→</span>
                  </a>
                )}
              </div>
            );
          })}
        </div>
        <a href="/contact" class="mobile-link mt-2 rounded-2xl bg-primary-text px-4 py-3.5 text-center text-[1rem] font-bold text-canvas hover:opacity-90">Contact studio</a>

        <div class="mt-auto pt-6">
          <div class="surface-card rounded-[20px] border p-5">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">Social · Subscribe</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {socials.map((s) => (
                <a
                  {...linkAttrs(s.href, s.external)}
                  class="rounded-full border border-border px-3 py-1.5 font-mono text-[0.62rem] uppercase tracking-[0.12em] text-muted-text hover:text-primary-text"
                >
                  {s.label}
                </a>
              ))}
            </div>
          </div>
          <p class="mt-4 px-2 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-muted-text">On-device first · Transparent · SF</p>
        </div>
      </div>
    </div>

    <button
      id="back-to-top"
      type="button"
      aria-label="Back to top"
      class="fixed bottom-[max(1.5rem,env(safe-area-inset-bottom))] right-5 z-40 grid size-11 translate-y-2 place-items-center rounded-full border border-border bg-card-bg text-primary-text opacity-0 shadow-[0_8px_24px_-4px_rgba(0,0,0,0.25)] transition-[opacity,transform] duration-250 pointer-events-none hover:border-brand-anchor/40 hover:bg-elevated focus-visible:pointer-events-auto focus-visible:opacity-100 focus-visible:translate-y-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor sm:right-8 lg:right-10"
    >
      <svg aria-hidden="true" viewBox="0 0 20 20" fill="none" class="size-4"><path d="M10 16V4M10 4L4.5 9.5M10 4l5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </button>

    <script is:inline>
      (() => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const backdrop = document.getElementById('mobile-menu-backdrop');
        const closeBtn = document.getElementById('mobile-menu-close');
        const line1 = document.getElementById('menu-line-1');
        const line2 = document.getElementById('menu-line-2');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        if (!toggle || !menu || !backdrop || !line1 || !line2) return;

        let isOpen = false;
        let lastFocus = null;
        let rafId = null;

        const openMenu = () => {
          if (isOpen) return;
          isOpen = true;
          lastFocus = document.activeElement;
          toggle.setAttribute('aria-expanded', 'true');
          toggle.setAttribute('aria-label', 'Close navigation');
          menu.removeAttribute('inert');
          menu.setAttribute('aria-hidden', 'false');
          backdrop.classList.remove('hidden');
          // Single rAF so the browser paints the un-hidden backdrop before the
          // opacity/transform transition — avoids double-rAF (~32ms) open lag.
          rafId = requestAnimationFrame(() => {
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-100');
            menu.classList.remove('translate-x-full');
            menu.classList.add('translate-x-0');
          });
          document.body.style.overflow = 'hidden';
          line1.classList.add('translate-y-[3px]', 'rotate-45');
          line2.classList.add('-translate-y-[3px]', '-rotate-45');
          setTimeout(() => {
            const first = menu.querySelector('a');
            if (first) first.focus();
          }, 60);
        };

        const closeMenu = () => {
          if (!isOpen) return;
          isOpen = false;
          if (rafId) cancelAnimationFrame(rafId);
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open navigation');
          menu.setAttribute('aria-hidden', 'true');
          backdrop.classList.remove('opacity-100');
          backdrop.classList.add('opacity-0');
          menu.classList.remove('translate-x-0');
          menu.classList.add('translate-x-full');
          document.body.style.overflow = '';
          line1.classList.remove('translate-y-[3px]', 'rotate-45');
          line2.classList.remove('-translate-y-[3px]', '-rotate-45');
          setTimeout(() => {
            backdrop.classList.add('hidden');
            try { menu.setAttribute('inert', ''); } catch {}
            if (lastFocus && lastFocus.focus) lastFocus.focus();
          }, 260);
        };

        toggle.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);
        backdrop.addEventListener('click', closeMenu);
        mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) { e.preventDefault(); closeMenu(); } });

        let resizeTimer;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => { if (window.innerWidth >= 768 && isOpen) closeMenu(); }, 120);
        }, { passive: true });

        try { menu.setAttribute('inert', ''); } catch {}

        // Single scroll rAF: nav shadow + back-to-top visibility (avoids two
        // competing scroll listeners thrashing style under the fixed header).
        const nav = document.querySelector('[data-nav]');
        const backToTop = document.getElementById('back-to-top');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let ticking = false;
        let btVisible = false;
        window.addEventListener('scroll', () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const y = window.scrollY;
            if (nav) {
              nav.classList.toggle('shadow-sm', y > 12);
            }
            if (backToTop) {
              const show = y > 480;
              if (show !== btVisible) {
                btVisible = show;
                backToTop.classList.toggle('opacity-0', !show);
                backToTop.classList.toggle('pointer-events-none', !show);
                backToTop.classList.toggle('translate-y-2', !show);
                backToTop.classList.toggle('opacity-100', show);
                backToTop.classList.toggle('translate-y-0', show);
              }
            }
            ticking = false;
          });
        }, { passive: true });
        if (backToTop) {
          backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
          });
        }

        // Desktop mega menus — click/keyboard (more reliable than hover-only).
        const megaRoots = document.querySelectorAll('[data-mega-root]');
        const closeAllMegas = (except) => {
          megaRoots.forEach((root) => {
            if (except && root === except) return;
            const trigger = root.querySelector('[data-mega-trigger]');
            const panel = root.querySelector('[data-mega-panel]');
            if (!trigger || !panel) return;
            trigger.setAttribute('aria-expanded', 'false');
            panel.hidden = true;
            panel.classList.add('invisible', 'opacity-0', 'scale-[0.98]', 'translate-y-1');
            panel.classList.remove('visible', 'opacity-100', 'scale-100', 'translate-y-0');
          });
        };
        megaRoots.forEach((root) => {
          const trigger = root.querySelector('[data-mega-trigger]');
          const panel = root.querySelector('[data-mega-panel]');
          if (!trigger || !panel) return;
          trigger.addEventListener('click', (e) => {
            e.stopPropagation();
            const open = trigger.getAttribute('aria-expanded') === 'true';
            closeAllMegas(root);
            if (open) {
              trigger.setAttribute('aria-expanded', 'false');
              panel.hidden = true;
              panel.classList.add('invisible', 'opacity-0', 'scale-[0.98]', 'translate-y-1');
              panel.classList.remove('visible', 'opacity-100', 'scale-100', 'translate-y-0');
            } else {
              trigger.setAttribute('aria-expanded', 'true');
              panel.hidden = false;
              requestAnimationFrame(() => {
                panel.classList.remove('invisible', 'opacity-0', 'scale-[0.98]', 'translate-y-1');
                panel.classList.add('visible', 'opacity-100', 'scale-100', 'translate-y-0');
              });
            }
          });
        });
        document.addEventListener('click', () => closeAllMegas());
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeAllMegas();
        });

        // Mobile accordion sections
        document.querySelectorAll('[data-mobile-accordion]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const section = btn.closest('[data-mobile-section]');
            const panel = section && section.querySelector('[data-mobile-panel]');
            const chevron = btn.querySelector('[data-chevron]');
            if (!panel) return;
            const open = !panel.classList.contains('hidden');
            panel.classList.toggle('hidden', open);
            btn.setAttribute('aria-expanded', open ? 'false' : 'true');
            if (chevron) chevron.style.transform = open ? '' : 'rotate(90deg)';
          });
        });

        // Theme toggle — now LIGHT default, UI hidden, secret triggers.
        // Visible toggle buttons are hidden via CSS (.theme-toggle {display:none}), but logic stays.
        // Secret triggers:
        //   • Triple-click logo (data-brand-logo) within 1.2s
        //   • Shift+T keyboard shortcut
        //   • Double-click footer status pill [data-theme-easter-egg]
        //   • ?theme=dark|light URL param (handled in head script, also persisted)
        const applyTheme = (theme) => {
          const next = theme === 'light' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          document.documentElement.style.colorScheme = next;
          try { localStorage.setItem('mp-theme', next); } catch (_) {}
          document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
            btn.setAttribute('aria-label', next === 'light' ? 'Switch to dark theme' : 'Switch to light theme');
            btn.setAttribute('title', next === 'light' ? 'Dark theme (hidden: Shift+T or triple-click logo)' : 'Light theme (hidden: Shift+T or triple-click logo)');
          });
          const metas = document.querySelectorAll('meta[name="theme-color"]');
          metas.forEach((m) => {
            // Keep both media-tagged metas, but also update non-media one if present
            if (!m.getAttribute('media')) {
              m.setAttribute('content', next === 'light' ? '#F4F1EB' : '#0F141C');
            }
          });
          // Optional: dispatch event for other components
          try { window.dispatchEvent(new CustomEvent('mp:theme', { detail: { theme: next } })); } catch (_) {}
        };

        const toggleTheme = () => {
          const current = document.documentElement.getAttribute('data-theme') || 'light';
          applyTheme(current === 'dark' ? 'light' : 'dark');
        };

        // Keep existing (now hidden) toggle buttons functional
        document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleTheme();
          });
        });

        // Secret 1: Triple-click logo within 1.2s
        (() => {
          let clicks = 0;
          let last = 0;
          const logos = document.querySelectorAll('[data-brand-logo]');
          logos.forEach((logo) => {
            logo.style.cursor = 'pointer';
            logo.addEventListener('click', () => {
              const now = Date.now();
              if (now - last > 1200) clicks = 0;
              clicks++;
              last = now;
              if (clicks >= 3) {
                clicks = 0;
                toggleTheme();
                // Tiny haptic/feedback: brief scale
                logo.style.transition = 'transform 0.12s ease';
                logo.style.transform = 'scale(0.96)';
                setTimeout(() => { logo.style.transform = ''; }, 140);
              }
            });
          });
        })();

        // Secret 2: Keyboard Shift+T
        document.addEventListener('keydown', (e) => {
          if (e.shiftKey && (e.key === 'T' || e.key === 't') && !e.metaKey && !e.ctrlKey) {
            // Don't trigger when typing in input/textarea
            const tag = document.activeElement && document.activeElement.tagName;
            if (tag === 'INPUT' || tag === 'TEXTAREA' || document.activeElement?.isContentEditable) return;
            e.preventDefault();
            toggleTheme();
          }
        });

        // Secret 3: Double-click footer status pill
        (() => {
          const eggs = document.querySelectorAll('[data-theme-easter-egg]');
          eggs.forEach((el) => {
            el.title = 'Double-click to toggle dark / light (also Shift+T or triple-click logo)';
            el.style.cursor = 'pointer';
            el.addEventListener('dblclick', (e) => {
              e.preventDefault();
              toggleTheme();
            });
          });
        })();

        // Optional: respect ?theme= in URL on client nav (already handled in head, but keep sync for SPA nav)
        // No OS sync anymore — light default intentional. Only stored or param wins.
        try {
          const params = new URLSearchParams(window.location.search);
          const paramTheme = params.get('theme');
          if (paramTheme === 'dark' || paramTheme === 'light') {
            // Apply param if no stored yet, or always respect param for explicit link sharing
            const stored = localStorage.getItem('mp-theme');
            if (!stored) applyTheme(paramTheme);
          }
        } catch (_) {}
      })();
    </script>

    <main id="main-content" data-pagefind-body class="flex flex-1 flex-col pt-[max(4rem,calc(env(safe-area-inset-top)+4rem))]"><slot /></main>

    <footer class="surface-footer relative isolate mt-auto overflow-hidden border-t border-border">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_bottom,color-mix(in_srgb,var(--mp-anchor)_12%,transparent),transparent_60%),radial-gradient(ellipse_at_top_right,color-mix(in_srgb,var(--mp-cta)_10%,transparent),transparent_50%)]"></div>
      <div class="mx-auto grid max-w-[88rem] gap-12 px-5 py-16 sm:px-8 lg:grid-cols-[1fr_2.2fr] lg:px-10">
        <div>
          <a href="/" class="inline-flex items-center gap-3 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor" aria-label="MakerPortal home">
            <BrandLogo variant="lockup" size="md" />
          </a>
          <p class="mt-4 max-w-md text-[0.925rem] leading-relaxed text-muted-text">Independent software + media for on-device AI and agentic DSP. iOS apps, field notes, video, and digital archives — on-device first where possible, transparent where cloud is needed. San Francisco.</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {socials.map((s) => (
              <a
                {...linkAttrs(s.href, s.external)}
                class="rounded-full border border-border bg-card-bg/50 px-3 py-1.5 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text transition-colors hover:border-brand-anchor/30 hover:text-primary-text"
              >
                {s.label}
              </a>
            ))}
          </div>
        </div>
        <div class="grid grid-cols-2 gap-x-8 gap-y-10 text-[0.875rem] sm:grid-cols-3 lg:grid-cols-5">
          {footerColumns.map((col) => (
            <div class="flex flex-col gap-3">
              <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-primary-text/80">{col.title}</span>
              {col.links.map((link) => (
                <a
                  {...linkAttrs(link.href, link.external)}
                  class={footerLinkClass(link.href)}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>
      <div class="border-t border-border bg-canvas/80">
        <div class="mx-auto flex max-w-[88rem] flex-col gap-4 px-5 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-8 lg:px-10">
          <div class="flex flex-wrap items-center gap-3">
            <div data-theme-easter-egg class="inline-flex items-center gap-2.5 rounded-full border border-border bg-card-bg px-3.5 py-1.5 select-none">
              <span class="relative flex size-1.5">
                <span class="absolute inline-flex h-full w-full rounded-full bg-brand-anchor opacity-60 motion-safe:animate-[ping_3s_cubic-bezier(0,0,0.2,1)_infinite]"></span>
                <span class="relative inline-flex size-1.5 rounded-full bg-brand-anchor"></span>
              </span>
              <span class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-primary-text">MakerPortal © {year}</span>
            </div>
            <span data-theme-easter-egg class="font-mono text-[0.6rem] uppercase tracking-[0.14em] text-muted-text select-none">SF · Worldwide · 11 apps</span>
          </div>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-muted-text">
            <a href="/privacy" class="hover:text-primary-text">Privacy</a>
            <a href="/terms" class="hover:text-primary-text">Terms</a>
            <a href="/privacy#affiliates" class="hover:text-primary-text">Affiliates</a>
            <a href="/sitemap.xml" class="hover:text-primary-text">Sitemap</a>
          </div>
        </div>
      </div>
    </footer>
    <SearchModal />
  </body>
</html>
