---
import SeoMeta from '../components/SeoMeta.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: URL | string;
  noindex?: boolean;
  type?: 'website' | 'article';
}

const { title, description, canonical, noindex, type } = Astro.props;
const year = new Date().getFullYear();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://makersportal.com/#organization',
      name: 'MakerPortal',
      url: 'https://makersportal.com',
      sameAs: ['https://www.makerportal.ai', 'https://github.com/josh-hrisko'],
      description: 'An independent software studio creating focused utility, productivity, and lifestyle applications.',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.makerportal.ai/#website',
      url: 'https://www.makerportal.ai',
      name: 'MakerPortal',
      publisher: { '@id': 'https://makersportal.com/#organization' },
      inLanguage: 'en-US',
    },
  ],
};
---

<!doctype html>
<html lang="en" class="bg-canvas scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0F141C" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <SeoMeta title={title} description={description} canonical={canonical} noindex={noindex} type={type} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col overflow-x-clip font-sans text-primary-text antialiased">
    <a href="#main-content" class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-full bg-primary-cta px-4 py-2 font-semibold text-white transition-transform focus:translate-y-0">Skip to content</a>

    <header class="relative z-50 border-b border-muted-text/15 bg-canvas/90 backdrop-blur-md">
      <nav aria-label="Primary navigation" class="mx-auto flex h-[4.75rem] max-w-[88rem] items-center justify-between px-5 sm:px-8 lg:px-10">
        <a href="/" class="group inline-flex items-center gap-3 rounded-lg">
          <span aria-hidden="true" class="relative grid size-9 place-items-center overflow-hidden rounded-full bg-primary-cta text-xs font-black text-white">
            MP
            <span class="absolute inset-x-0 bottom-0 h-1/2 translate-y-full bg-white/20 transition-transform duration-300 group-hover:translate-y-0"></span>
          </span>
          <span class="text-sm font-bold tracking-[0.12em] text-white">MAKERPORTAL</span>
        </a>

        <div class="flex items-center gap-1 sm:gap-2">
          <a href="/#apps" class="hidden min-h-11 items-center rounded-full px-4 text-sm font-medium text-muted-text transition-colors hover:text-white sm:inline-flex">Apps</a>
          <a href="/blog" class="inline-flex min-h-11 items-center rounded-full px-3 text-sm font-medium text-primary-text/90 transition-colors hover:text-white sm:px-4"><span class="sm:hidden">Notes</span><span class="hidden sm:inline">Field notes</span></a>
          <a href="https://makersportal.com" rel="me" class="inline-flex min-h-11 items-center rounded-full border border-muted-text/30 px-3 text-sm font-semibold text-white transition-colors hover:border-brand-anchor hover:text-brand-anchor sm:px-4">
            Studio <span aria-hidden="true" class="ml-1.5">↗</span>
          </a>
        </div>
      </nav>
    </header>

    <main id="main-content" class="flex-1"><slot /></main>

    <footer class="border-t border-muted-text/15 bg-canvas">
      <div class="mx-auto grid max-w-[88rem] gap-10 px-5 py-12 sm:px-8 md:grid-cols-[1fr_auto] md:items-end lg:px-10">
        <div>
          <a href="/" class="text-xl font-semibold tracking-tight text-white">MakerPortal<span class="text-primary-cta">.</span></a>
          <p class="mt-3 max-w-md text-sm leading-6 text-muted-text">Independent software for people who care about the details.</p>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-muted-text md:justify-end">
          <a href="/#apps" class="hover:text-white">Apps</a>
          <a href="/blog" class="hover:text-white">Field notes</a>
          <a href="https://makersportal.com" rel="me" class="hover:text-white">Studio journal ↗</a>
          <a href="https://github.com/josh-hrisko" rel="me" class="hover:text-white">GitHub ↗</a>
        </div>
      </div>
      <div class="border-t border-muted-text/10">
        <div class="mx-auto flex max-w-[88rem] flex-col gap-2 px-5 py-5 font-mono text-[0.65rem] uppercase tracking-[0.16em] text-muted-text/80 sm:flex-row sm:justify-between sm:px-8 lg:px-10">
          <p>© {year} MakerPortal</p>
          <p>Built slowly enough to care · Shipped quickly enough to matter</p>
        </div>
      </div>
    </footer>
  </body>
</html>
