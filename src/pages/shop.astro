---
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';
import ButtondownSignup from '../components/ButtondownSignup.astro';
import shopData from '../data/shop.json';

const title = 'Shop — MakerPortal Digital Goods & Archives';
const description =
  'Code packs, templates, and digital archives from MakerPortal. Real code from real builds, priced $19-29, MoR tax handled via Lemon Squeezy.';

const products = shopData;
const archives = products.filter((p) => !p.pwyw);
const tipProduct = products.find((p) => p.pwyw);
const bundlePrice = 49;
const bundleSave = 39;
const liveArchiveCount = archives.filter((p) => Boolean(p.lemonUrl)).length;
const allLive = liveArchiveCount === archives.length && archives.length > 0;
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Shop · Digital goods · Archives"
    title="Own the archive."
    lead="Real code from real builds — not invented. Each archive is $19-29 (bundle $49 saves $39), MoR tax handled, secure signed downloads via Lemon Squeezy. Affiliate tools live under Learn with full disclosure."
    status="Shop"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#products" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Browse archives ↓</a>
        <a href="/resources#gear" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Affiliate gear →</a>
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Wholesale / licensing</a>
      </div>
      <p class="mt-4 max-w-xl font-mono text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">Lemon Squeezy is Merchant of Record — global VAT/GST handled, no tax forms for you. 5%+50c fee, zero monthly.</p>
    </Fragment>
  </HubShell>

  <section id="products" class="border-b border-border" aria-label="Products">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      {/* Bundle banner — shows live only when all 3 have lemonUrl, else pending with owner action */}
      <div class="mb-8 rounded-[20px] border border-primary-cta/20 bg-primary-cta/5 p-5 sm:p-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-primary-cta">Bundle · Save ${bundleSave} · {liveArchiveCount}/{archives.length} live</p>
            <h2 id="bundle-title" class="mt-2 text-[1.1rem] font-semibold tracking-[-0.02em] text-primary-text">All 3 archives — <span class="text-primary-cta">${bundlePrice}</span> <span class="text-muted-text line-through text-[0.9rem]"> $77</span></h2>
            <p class="mt-1 text-[0.85rem] text-muted-text">BLExAR Nano+OLED + CoreML Offline + Biquadia DSP. One checkout, three secure downloads via Lemon customer portal. MoR VAT handled.</p>
          </div>
          <div class="flex gap-2">
            {allLive ? (
              <a href="#newsletter" class="rounded-full bg-primary-cta px-3.5 py-1.5 font-mono text-[0.7rem] font-bold uppercase tracking-[0.1em] text-white">Bundle live — {liveArchiveCount} archives</a>
            ) : (
              <span class="rounded-full bg-primary-cta px-3.5 py-1.5 font-mono text-[0.7rem] font-bold uppercase tracking-[0.1em] text-white">{liveArchiveCount} live — {archives.length - liveArchiveCount} pending owner Buy URLs</span>
            )}
          </div>
        </div>
        <p class="mt-3 font-mono text-[0.6rem] text-muted-text">
          Owner action: create Lemon store <code class="rounded bg-card-bg px-1">makerportal</code>, 3 digital products, upload zips &lt;50MB, enable secure delivery, customer portal, discount <code class="rounded bg-card-bg px-1">LAUNCH20</code>, PWYW floor $9. Copy real Buy URLs into <code class="rounded bg-card-bg px-1">src/data/shop.json</code> <code class="rounded bg-card-bg px-1">lemonUrl</code>. Lemon.js overlay verified via <code class="rounded bg-card-bg px-1">lemonsqueezy-button</code> class. See docs/MONETIZATION.md P1 shop MVP.
          {liveArchiveCount > 0 && ` Tip jar live: ${tipProduct?.lemonUrl ? '✓ tip URL' : '—'}.`}
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {archives.map((p) => (
          <article id={p.id} class="surface-card group relative flex flex-col scroll-mt-24 rounded-[24px] border bg-card-bg p-6 transition-[transform,border-color] hover:scale-[1.01] hover:border-[var(--mp-border-strong)]">
            <div class="flex items-center justify-between">
              <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-primary-cta">{p.tag}{p.featured ? ' · Featured' : ''}</p>
              {p.pillars?.length ? (
                <span class="font-mono text-[0.55rem] uppercase tracking-[0.1em] text-muted-text">{p.pillars.join(' · ')}</span>
              ) : null}
            </div>
            <h2 id={`${p.id}-title`} class="mt-3 text-xl font-semibold tracking-[-0.03em] text-primary-text">{p.title}</h2>
            <p class="mt-3 text-[0.92rem] leading-[1.65] text-muted-text">{p.blurb}</p>
            {p.includes?.length && (
              <ul class="mt-4 space-y-1.5 border-t border-border pt-4">
                {p.includes.map((inc) => (
                  <li class="flex gap-2 text-[0.8rem] leading-[1.5] text-muted-text">
                    <span aria-hidden="true" class="mt-0.5 text-primary-cta">✓</span>{inc}
                  </li>
                ))}
              </ul>
            )}
            <div class="mt-6 flex items-baseline gap-2">
              <span class="text-[1.4rem] font-bold tracking-[-0.02em] text-primary-text">${p.price}</span>
              {p.compareAt && <span class="text-[0.85rem] text-muted-text line-through">${p.compareAt}</span>}
              <span class="ml-auto font-mono text-[0.6rem] uppercase tracking-[0.1em] text-muted-text">MoR VAT incl.</span>
            </div>
            <div class="mt-4 space-y-2">
              {p.lemonUrl ? (
                <>
                  <a href={p.lemonUrl} class="lemonsqueezy-button inline-flex min-h-11 w-full items-center justify-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90" data-product={p.id} data-analytics="shop-buy">
                    Buy for ${p.price} — secure download
                  </a>
                  <p class="font-mono text-[0.6rem] leading-[1.4] text-muted-text">Lemon overlay → secure signed link, customer portal, VAT incl. {p.lemonId ? `ID ${p.lemonId}` : ''}</p>
                </>
              ) : (
                <>
                  <span class="inline-flex min-h-11 w-full items-center justify-center rounded-full border border-border bg-elevated px-5 text-[0.85rem] font-medium text-muted-text">Coming soon — needs Lemon Buy URL</span>
                  <p class="font-mono text-[0.6rem] leading-[1.4] text-muted-text">Real code only — from {p.relatedTo?.join(', ')} builds. Join newsletter below for launch. Owner: add <code class="rounded bg-card-bg px-1">lemonUrl</code> to <code class="rounded bg-card-bg px-1">shop.json</code>.</p>
                  <a href="#newsletter" class="inline-flex text-[0.7rem] font-medium text-brand-anchor hover:text-primary-text">Notify me →</a>
                </>
              )}
            </div>
          </article>
        ))}
      </div>

      {/* Tip jar */}
      {tipProduct && (
        <div class="mt-8 grid gap-5 md:grid-cols-[1.1fr_0.9fr]">
          <article id={tipProduct.id} class="surface-card flex flex-col rounded-[24px] border border-dashed border-border bg-elevated/40 p-6">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-primary-cta">{tipProduct.tag} · PWYW floor ${tipProduct.price}</p>
            <h2 id={`${tipProduct.id}-title`} class="mt-3 text-xl font-semibold text-primary-text">{tipProduct.title}</h2>
            <p class="mt-2 text-[0.9rem] leading-[1.6] text-muted-text">{tipProduct.blurb}</p>
            <ul class="mt-4 space-y-1">
              {tipProduct.includes?.map((inc) => (
                <li class="text-[0.8rem] text-muted-text">• {inc}</li>
              ))}
            </ul>
            <div class="mt-6 space-y-2">
              {tipProduct.lemonUrl ? (
                <>
                  <a href={tipProduct.lemonUrl} class="lemonsqueezy-button inline-flex min-h-11 items-center justify-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90" data-product={tipProduct.id} data-analytics="tip">Tip ${tipProduct.price}+ — support studio</a>
                  <p class="font-mono text-[0.6rem] text-muted-text">Live via Lemon overlay — verified. PWYW floor ${tipProduct.price}. MoR handles VAT.</p>
                </>
              ) : (
                <span class="inline-flex min-h-11 items-center rounded-full border border-border bg-card-bg px-5 text-[0.85rem] font-medium text-muted-text">Tip jar — needs Lemon Buy URL</span>
              )}
            </div>
          </article>
          <div class="rounded-[24px] border border-border bg-card-bg p-6">
            <h3 class="font-mono text-[0.65rem] uppercase tracking-[0.14em] text-muted-text">How it works</h3>
            <ul class="mt-3 space-y-2 text-[0.85rem] leading-[1.6] text-muted-text">
              <li>• <strong class="text-primary-text">Merchant of Record:</strong> Lemon Squeezy handles global VAT/GST, fraud, invoices.</li>
              <li>• <strong class="text-primary-text">Secure delivery:</strong> Signed links, customer portal, re-download anytime.</li>
              <li>• <strong class="text-primary-text">Zero monthly:</strong> 5%+50¢ per sale, no subscription (D-014).</li>
              <li>• <strong class="text-primary-text">Real code:</strong> Only code actually used in shipped builds, README with provenance.</li>
            </ul>
            <p class="mt-4 text-[0.78rem] text-muted-text">Affiliate gear on <a href="/resources#gear" class="text-brand-anchor hover:text-primary-text">/resources#gear</a> is separate — disclosed, `rel="sponsored"`.</p>
          </div>
        </div>
      )}

      <p class="mt-10 max-w-2xl text-[0.85rem] leading-[1.6] text-muted-text">
        Archive packaging: README + Xcode/Arduino + LICENSE + CHANGELOG, &lt;50MB zip. Test unzip + `open Xcode` builds.
        Pricing verified via BoilerplateHub avg $166, Codester $14-95, Hacking with Swift $20-50. $5-10 underpriced for premium studio — $19-29 corrects fee drag.
        See <a href="/privacy#affiliates" class="text-brand-anchor hover:text-primary-text">privacy #affiliates</a> + docs/MONETIZATION.md.
      </p>
    </div>
  </section>

  {/* Newsletter embed — Buttondown component, needs username */}
  <section id="newsletter" class="border-b border-border bg-elevated/30">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
      <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr]">
        <div>
          <h2 id="newsletter-title" class="text-[clamp(1.4rem,3vw,1.8rem)] font-[650] tracking-[-0.03em] text-primary-text">Get archive drops first.</h2>
          <p class="mt-3 max-w-xl text-[0.95rem] leading-[1.65] text-muted-text">Privacy-first newsletter via Buttondown (no tracking pixels, markdown-friendly, per D-014). Free until 100 subs, then $9/mo. Lead magnet: free snippet from BLExAR archive.</p>
          <p class="mt-4 font-mono text-[0.62rem] text-muted-text">Buttondown free first 100, $9/mo per addon (paid subs, analytics). No tracking per D-014.</p>
        </div>
        <ButtondownSignup tag="shop-interest" source="shop-page" title="Newsletter · Privacy-first" blurb="Get archive drops, field notes, and early access. No tracking, markdown-friendly." />
      </div>
    </div>
  </section>

  <script is:inline src="https://assets.lemonsqueezy.com/lemon.js" defer></script>
  <script>
    // @ts-nocheck
    // Lemon.js overlay verification + analytics (privacy-safe, first-party)
    // Lemon.js creates window.LemonSqueezy and intercepts .lemonsqueezy-button clicks to show overlay
    (() => {
      function bindShop() {
        document.querySelectorAll('a.lemonsqueezy-button').forEach((a) => {
          if (a.dataset.bound === '1') return;
          a.dataset.bound = '1';
          a.addEventListener('click', () => {
            const product = a.getAttribute('data-product') || a.href;
            const kind = a.getAttribute('data-analytics') || 'shop';
            try {
              window.dispatchEvent(new CustomEvent('mp:analytics', { detail: { event: `${kind}_click`, product, url: a.href } }));
              console.debug(`[analytics] ${kind}_click`, { product });
            } catch {}
          });
        });

        // Verify Lemon.js loaded
        let tries = 0;
        const check = setInterval(() => {
          tries++;
          if (window.LemonSqueezy || window.createLemonSqueezyOverlay || document.querySelector('script[src*="lemon.js"]')) {
            console.debug('[shop] Lemon.js detected', { tries, overlay: !!window.LemonSqueezy });
            clearInterval(check);
          }
          if (tries > 20) clearInterval(check);
        }, 500);
      }
      bindShop();
      document.addEventListener('astro:page-load', bindShop);
    })();
  </script>
</Layout>
