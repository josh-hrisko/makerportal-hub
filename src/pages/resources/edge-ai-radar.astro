---
/**
 * Edge AI Radar — Editorial Data Story Page.
 * Renders the latest src/content/edge-radar/*.json snapshot.
 *
 * DESIGN LAW (owner directive 2026-07-22, see docs/PASSIVE-CONTENT-ENGINES-2026.md rule 5):
 *  - Editorial Data Story: large hero stats, tight mono kickers, generous whitespace,
 *    optical alignment, proper type scale, visual cadence between sections.
 *  - Rich Data Graphics:
 *    (1) Deterministic Hero "Radar" Spider Mark (RadarSpider.astro)
 *    (2) Memory Landscape Today (CeilingStrip.astro)
 *    (3) Per-Model Footprint Arithmetic (MemoryBar.astro)
 *    (4) Quantization BPW Spectrum (QuantSpectrum.astro)
 *    (5) Board Fit Breakdown (BoardFitDistribution.astro)
 *    (6) Snapshot Release Trend (TrendSparkline.astro)
 *  - Hard constraints intact:
 *    (1) Zero client JS required (all SSR SVG)
 *    (2) Zero external requests at load (kit links are text-only rows)
 *    (3) CLS 0 via fixed aspect-ratio containers
 *    (4) Fit matrix scrolls horizontally on mobile with a STICKY first column.
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { affiliateLinks, resolveAffiliateLink } from '../../data/affiliate-links';
import MemoryBar from '../../components/edge-radar/MemoryBar.astro';
import CeilingStrip from '../../components/edge-radar/CeilingStrip.astro';
import RadarSpider from '../../components/edge-radar/RadarSpider.astro';
import QuantSpectrum from '../../components/edge-radar/QuantSpectrum.astro';
import BoardFitDistribution from '../../components/edge-radar/BoardFitDistribution.astro';
import TrendSparkline from '../../components/edge-radar/TrendSparkline.astro';
import { shortBoardLabel } from '../../lib/edge-radar-labels';

const entries = await getCollection('edge-radar');
const sorted = entries.sort((a, b) => b.id.localeCompare(a.id));
const latest = sorted[0];

const dateStr = latest?.id ?? null;
const generatedAt = latest?.data.generatedAt ?? null;
const boards = latest?.data.boards ?? [];
const models = latest?.data.models ?? [];
const fits = latest?.data.fits ?? [];

// Most powerful first: 30 GiB Sigma → 14.5 GiB Orin/Pi16 → 8/6.5 GiB → 8 MiB TPU → 7 MiB MCU
const boardsDesc = [...boards].sort((a, b) =>
  b.modelCeilingBytes - a.modelCeilingBytes ||
  b.ramBytes - a.ramBytes ||
  a.name.localeCompare(b.name)
);

const fitFor = (modelId: string, boardId: string) =>
  fits.find((f) => f.modelId === modelId && f.boardId === boardId);

const GIB = 1024 * 1024 * 1024;
const MIB = 1024 * 1024;
const fmtBytes = (n: number) => (n >= GIB ? `${(n / GIB).toFixed(2)} GiB` : `${(n / MIB).toFixed(1)} MiB`);
const fmtParams = (n: number | null) => {
  if (n === null) return '—';
  if (n >= 1e9) return `${(n / 1e9).toFixed(2)}B`;
  if (n >= 1e6) return `${(n / 1e6).toFixed(0)}M`;
  return n.toLocaleString('en-US');
};
const fmtFlops = (n: number | null) => {
  if (n === null) return '—';
  if (n >= 1e12) return `${(n / 1e12).toFixed(2)} TFLOP`;
  return `${(n / 1e9).toFixed(1)} GFLOP`;
};

const verdictMeta = {
  fits: { label: 'Fits', dot: 'bg-emerald-500', text: 'text-emerald-600 dark:text-emerald-400 font-semibold' },
  tight: { label: 'Tight', dot: 'bg-amber-500', text: 'text-amber-600 dark:text-amber-400 font-semibold' },
  no: { label: 'No', dot: 'bg-muted-text/30', text: 'text-muted-text' },
} as const;

const formattedDate = dateStr
  ? new Date(dateStr + 'T12:00:00Z').toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      year: 'numeric',
      timeZone: 'UTC',
    })
  : null;

const fitsCount = (modelId: string) => fits.filter((f) => f.modelId === modelId && f.verdict !== 'no').length;

// Boards with curated buy paths — most powerful first so best performance is visible top
const boardKits = boardsDesc
  .filter((b) => b.linkIds.length > 0)
  .map((b) => ({
    board: b,
    links: b.linkIds
      .map((id) => affiliateLinks.find((l) => l.id === id))
      .filter((l) => l !== undefined)
      .map((l) => resolveAffiliateLink(l)),
  }));

// Summary Stats — dynamic across 10 boards (7 MiB → 30 GiB)
const totalModels = models.length;
const totalBoards = boards.length;

const fitsForBoard = (boardId: string) => models.filter((m) => {
  const f = fitFor(m.id, boardId);
  return f && f.verdict !== 'no';
}).length;

// 16GB+ class fits
const pi5_16Fits = fitsForBoard('raspberry-pi-5-16gb');
const orinNx16Fits = fitsForBoard('jetson-orin-nx-16gb');
const sigma32Fits = fitsForBoard('latte-panda-sigma-32gb');
// Max fits across all 6.5+ GiB boards
const highRamBoards = boards.filter((b) => b.modelCeilingBytes >= Math.floor(6.5 * 1024*1024*1024)).map((b) => b.id);
const highRamFits = models.filter((m) => highRamBoards.some((bid) => {
  const f = fitFor(m.id, bid);
  return f && f.verdict !== 'no';
})).length;

const minCeil = Math.min(...boards.map((b) => b.modelCeilingBytes));
const maxCeil = Math.max(...boards.map((b) => b.modelCeilingBytes));
const fmtCeilRange = `${(minCeil / MIB).toFixed(0)}M–${(maxCeil / GIB).toFixed(maxCeil >= 30*GIB ? 0 : 1)}G`;

const boardListDesc = boardsDesc.map((b) => shortBoardLabel(b.name)).slice(0, 6).join(', ') + (boardsDesc.length > 6 ? ` +${boardsDesc.length - 6} more` : '');

const title = 'Edge AI Radar — Daily TinyML & GGUF Hardware Fit Report | MakerPortal';
const description =
  `Daily deterministic radar: fresh GGUF/ONNX releases (Q4_K_M etc) sized against real memory ceilings of ${boardListDesc} (${fmtCeilRange}).`;
---

<Layout title={title} description={description}>
  <HubShell
    kicker={`Library · Edge AI Radar${dateStr ? ` · ${dateStr}` : ''}`}
    title="Which fresh models actually fit your board."
    lead="A daily, deterministic scan of new GGUF and ONNX releases on Hugging Face — verified file bytes in, datasheet memory ceilings out. Every fit verdict on this page is arithmetic you can check, not a benchmark we invented."
    status="Daily"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-2.5">
        <a href="#landscape" class="inline-flex min-h-11 items-center gap-1.5 rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor">
          Memory landscape ↓
        </a>
        <a href="#radar" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Fit matrix ↓</a>
        <a href="#quant-spectrum" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">BPW spectrum ↓</a>
        <a href="#methodology" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Methodology</a>
        <a href="/resources" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">← Library</a>
      </div>
      {generatedAt && (
        <p class="mt-6 font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">
          {formattedDate} · {totalModels} models × {totalBoards} boards · generated {new Date(generatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZoneName: 'short' })}
        </p>
      )}
    </Fragment>
  </HubShell>

  {latest ? (
    <>
      {/* ── Editorial Hero Overview & Radar Mark ───────────────────── */}
      <section class="border-b border-border bg-card-bg/40 py-10 sm:py-14">
        <div class="mx-auto max-w-[88rem] px-5 sm:px-8 lg:px-10">
          <div class="grid gap-8 lg:grid-cols-12 lg:items-center">
            {/* Left: Stat Kicker Cards */}
            <div class="space-y-6 lg:col-span-7">
              <div>
                <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                  Daily Snapshot · {dateStr}
                </span>
                <h2 class="mt-3 text-[clamp(1.5rem,3.2vw,2.2rem)] font-bold tracking-[-0.04em] text-primary-text leading-tight">
                  Real file sizes vs real hardware memory limits.
                </h2>
                <p class="mt-2 text-[0.95rem] leading-[1.65] text-muted-text max-w-2xl">
                  Quantized model weights vary dramatically by quantization scheme. Below is today's verified fit profile across microcontrollers, single-board computers, and edge GPU accelerators.
                </p>
              </div>

              {/* Stat Grid — now reflects 7M–30G span and high-RAM family */}
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                <div class="rounded-[14px] border border-border bg-card-bg p-4">
                  <span class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">Scanned</span>
                  <div class="mt-1 font-mono text-[1.4rem] font-bold text-primary-text">{totalModels}</div>
                  <span class="text-[0.7rem] text-muted-text">HF Releases · {totalBoards} boards</span>
                </div>
                <div class="rounded-[14px] border border-border bg-card-bg p-4">
                  <span class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">Ceilings</span>
                  <div class="mt-1 font-mono text-[1.25rem] font-bold text-primary-text">{fmtCeilRange}</div>
                  <span class="text-[0.7rem] text-muted-text">RAM Span · MCU→Sigma</span>
                </div>
                <div class="rounded-[14px] border border-border bg-card-bg p-4">
                  <span class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">SBC+GPU Fits</span>
                  <div class="mt-1 font-mono text-[1.4rem] font-bold text-emerald-600 dark:text-emerald-400">{highRamFits}/{totalModels}</div>
                  <span class="text-[0.7rem] text-muted-text">Any ≥6.5 GiB board</span>
                </div>
                <div class="rounded-[14px] border border-border bg-card-bg p-4">
                  <span class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">16 GB+ Fits</span>
                  <div class="mt-1 font-mono text-[1.4rem] font-bold text-primary-text">{Math.max(pi5_16Fits, orinNx16Fits)}/{totalModels}</div>
                  <span class="text-[0.7rem] text-muted-text">Pi5 16GB / Orin NX · Sigma {sigma32Fits}/{totalModels}</span>
                </div>
              </div>
            </div>

            {/* Right: Deterministic Hero Radar Spider Mark — strongest boards first, top-down */}
            <div class="lg:col-span-5">
              <RadarSpider boards={boardsDesc} models={models} fits={fits} />
            </div>
          </div>
        </div>
      </section>

      {/* ── Section 1: Memory Allocation & Context Simulator ──────── */}
      <section id="landscape" class="border-b border-border bg-canvas" aria-labelledby="landscape-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Interactive Simulator 01</span>
              <h2 id="landscape-title" class="mt-1 text-[clamp(1.4rem,3vw,1.9rem)] font-bold tracking-[-0.04em] text-primary-text">Memory topology & context pressure</h2>
              <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
                Simulate how model tensor weights, runtime scratchpads, and expanding KV cache context windows occupy memory across hardware targets — from 7 MiB microcontrollers to 30 GiB x86 edge servers (Pi 5 8GB/16GB, Orange Pi 5 Plus 16GB, Rock 5B 16GB, Orin Nano/NX, Sigma 32GB).
              </p>
            </div>
            <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card-bg px-3.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Live Context Simulator
            </span>
          </div>

          <div class="mt-8">
            <CeilingStrip boards={boardsDesc} models={models} fits={fits} />
          </div>

          <div class="mt-6 flex flex-wrap gap-2 font-mono text-[0.6rem] text-muted-text">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-3 py-1">
              🟢 Weights + 🟦 Overhead + 🔷 KV Cache
            </span>
            <span class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-3 py-1">{fmtCeilRange} MCU → Sigma 32GB</span>
            <span class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-3 py-1">512 to 8,192 token context scaling</span>
          </div>
        </div>
      </section>

      {/* ── Section 2: Fit Matrix ──────────────────────────────────── */}
      <section id="radar" class="border-b border-border bg-card-bg/20" aria-labelledby="radar-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Data Table 02</span>
              <h2 id="radar-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">Today's fit matrix</h2>
              <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
                Representative quant file per repo (Q4_K_M preferred), runtime estimate = verified bytes × 1.25, against each board's disclosed model-memory ceiling. <span class="text-emerald-600 dark:text-emerald-400 font-semibold">Fits</span> ≤ 80% of ceiling · <span class="text-amber-600 dark:text-amber-400 font-semibold">Tight</span> ≤ 100% · otherwise No.
              </p>
            </div>
            <span class="inline-flex items-center rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="mr-1.5 inline-block h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
              Scan {dateStr}
            </span>
          </div>

          <div class="mt-8 overflow-x-auto rounded-[20px] border border-border bg-card-bg shadow-sm">
            <table class="w-full min-w-[1080px] border-collapse text-left">
              <thead>
                <tr class="border-b border-border bg-elevated/40">
                  <th scope="col" class="sticky left-0 z-10 bg-card-bg px-4 py-3.5 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-muted-text">Model · representative file</th>
                  <th scope="col" class="px-3 py-3.5 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-muted-text">Runtime est.</th>
                  {boardsDesc.map((b) => (
                    <th scope="col" class="px-3 py-3.5 text-center font-mono text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-muted-text">
                      {shortBoardLabel(b.name)}
                      <span class="block text-[0.56rem] font-normal normal-case tracking-normal text-muted-text/70">{fmtBytes(b.modelCeilingBytes)} ceiling</span>
                    </th>
                  ))}
                  <th scope="col" class="px-3 py-3.5 text-center font-mono text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-muted-text">Score</th>
                </tr>
              </thead>
              <tbody>
                {models.map((m) => (
                  <tr class="border-b border-border/60 last:border-0 hover:bg-elevated/60 transition-colors">
                    <td class="sticky left-0 z-10 max-w-[22rem] bg-card-bg px-4 py-3.5 shadow-[8px_0_12px_-8px_var(--mp-card-shadow,rgba(0,0,0,0.08))]">
                      <a href={m.url} target="_blank" rel="noopener noreferrer" class="text-[0.88rem] font-bold leading-snug text-primary-text hover:text-primary-cta">
                        {m.id}
                      </a>
                      <span class="mt-0.5 block font-mono text-[0.62rem] text-muted-text">
                        {m.format.toUpperCase()}{m.quant ? ` · ${m.quant}` : ''} · {fmtBytes(m.fileBytes)} file{m.pipelineTag ? ` · ${m.pipelineTag}` : ''}
                      </span>
                    </td>
                    <td class="whitespace-nowrap px-3 py-3.5 font-mono text-[0.78rem] font-medium text-primary-text">{fmtBytes(m.runtimeBytes)}</td>
                    {boardsDesc.map((b) => {
                      const f = fitFor(m.id, b.id);
                      const meta = f ? verdictMeta[f.verdict] : verdictMeta.no;
                      return (
                        <td class="px-3 py-3.5 text-center">
                          <span class={`inline-flex items-center gap-1.5 rounded-full border border-border bg-canvas px-2.5 py-0.5 font-mono text-[0.62rem] ${meta.text}`}>
                            <span class={`h-1.5 w-1.5 rounded-full ${meta.dot}`} aria-hidden="true"></span>
                            {meta.label}
                          </span>
                        </td>
                      );
                    })}
                    <td class="px-3 py-3.5 text-center font-mono text-[0.78rem] font-semibold text-muted-text">{fitsCount(m.id)}/{boardsDesc.length}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {/* ── Section 3: Quant Spectrum & Board Fit Breakdown (Items 3 & 4) ──── */}
      <section id="quant-spectrum" class="border-b border-border bg-canvas" aria-labelledby="spectrum-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10 space-y-8">
          <div>
            <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Analytics 03 & 04</span>
            <h2 id="spectrum-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">Quantization & board fit analytics</h2>
            <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
              Bits-per-weight distribution across today's models and breakdown of fit capacity per hardware board class.
            </p>
          </div>

          <div class="grid gap-6 lg:grid-cols-2">
            <QuantSpectrum models={models} />
            <BoardFitDistribution boards={boardsDesc} models={models} fits={fits} />
          </div>
        </div>
      </section>

      {/* ── Section 4: Model detail cards (Item 1 MemoryBar) ───────── */}
      <section class="border-b border-border bg-card-bg/20" aria-labelledby="models-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Per-Model Cards 05</span>
          <h2 id="models-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">The arithmetic, per model</h2>
          <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
            File bytes come from the repo's verified Hugging Face file tree. Parameter count is back-derived from those bytes ÷ the quant's published bits-per-weight. FLOPs/token is the dense-transformer 2·P rule.
          </p>
          <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {models.map((m) => {
              const perModelFits = fits.filter((f) => f.modelId === m.id);
              return (
                <li class="flex flex-col rounded-[16px] border border-border bg-card-bg p-5 shadow-sm hover:border-[var(--mp-border-strong)] transition-all">
                  <div class="flex items-center justify-between gap-2">
                    <span class="rounded-full bg-elevated border border-border px-2.5 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] font-semibold text-muted-text">{m.format}{m.quant ? ` · ${m.quant}` : ''}</span>
                    <span class="font-mono text-[0.62rem] font-semibold text-muted-text">{fitsCount(m.id)}/{boardsDesc.length} boards</span>
                  </div>
                  <a href={m.url} target="_blank" rel="noopener noreferrer" class="mt-3 text-[0.95rem] font-bold leading-snug text-primary-text hover:text-primary-cta">
                    {m.id}
                  </a>
                  <span class="mt-1 truncate font-mono text-[0.62rem] text-muted-text" title={m.fileName}>{m.fileName}</span>
                  <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 border-t border-border pt-4">
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">File</dt><dd class="font-mono text-[0.78rem] font-medium text-primary-text">{fmtBytes(m.fileBytes)}</dd></div>
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">Runtime est.</dt><dd class="font-mono text-[0.78rem] font-medium text-primary-text">{fmtBytes(m.runtimeBytes)}</dd></div>
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">≈ Params</dt><dd class="font-mono text-[0.78rem] font-medium text-primary-text">{fmtParams(m.approxParams)}</dd></div>
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">FLOPs/token</dt><dd class="font-mono text-[0.78rem] font-medium text-primary-text">{fmtFlops(m.flopsPerToken)}</dd></div>
                  </dl>
                  {/* Re-crafted MemoryBar (Items 1 & 2) — strongest first, log 1 MiB→32 GiB */}
                  <div class="mt-4">
                    <div class="mb-1.5 flex items-center justify-between">
                      <span class="font-mono text-[0.56rem] uppercase tracking-[0.12em] text-muted-text">Footprint vs ceilings · log 1 MiB→32 GiB</span>
                      <span class="font-mono text-[0.56rem] font-semibold text-primary-text">{fmtBytes(m.runtimeBytes)}</span>
                    </div>
                    <MemoryBar runtimeBytes={m.runtimeBytes} modelId={m.id} boards={boardsDesc} fits={perModelFits} />
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </section>

      {/* ── Section 5: Historical Release Trend (Item 6) ───────────── */}
      <section class="border-b border-border bg-canvas" aria-labelledby="trend-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10 space-y-6">
          <div>
            <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Historical Trend 06</span>
            <h2 id="trend-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">Daily release & fit history</h2>
            <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
              Tracking total Hugging Face releases vs edge-fittable models across daily radar snapshots.
            </p>
          </div>

          <TrendSparkline entries={entries} />
        </div>
      </section>

      {/* ── Section 6: Boards + Curated Dev Kits ───────────────────── */}
      <section class="border-b border-border bg-card-bg/20" aria-labelledby="boards-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Hardware 07</span>
              <h2 id="boards-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">The boards behind the ceilings</h2>
              <AffiliateDisclosure class="mt-3 max-w-2xl" />
            </div>
          </div>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {boardKits.map(({ board, links }) => (
              <div class="flex flex-col rounded-[16px] border border-border bg-card-bg p-5 shadow-sm">
                <div class="flex items-center justify-between gap-2">
                  <span class="rounded-full bg-elevated border border-border px-2.5 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] font-semibold text-muted-text">{board.class}</span>
                  <span class="font-mono text-[0.62rem] text-muted-text">{fmtBytes(board.modelCeilingBytes)} ceiling</span>
                </div>
                <h3 class="mt-3 text-[0.95rem] font-bold text-primary-text">{shortBoardLabel(board.name)}</h3>
                <p class="mt-0.5 font-mono text-[0.62rem] text-muted-text">{board.ramLabel}</p>
                <p class="mt-2 flex-1 text-[0.82rem] leading-[1.55] text-muted-text">{board.note}</p>
                {links.length > 0 && (
                  <ul class="mt-3 space-y-1.5 border-t border-border pt-3">
                    {links.map((l) => (
                      <li>
                        <a
                          href={l.url}
                          target="_blank"
                          rel="sponsored noopener noreferrer"
                          class="group/link flex items-center justify-between gap-2 rounded-[10px] border border-border bg-canvas px-3 py-2 text-[0.78rem] font-semibold text-primary-text hover:border-[var(--mp-border-strong)] hover:text-primary-cta transition-colors"
                        >
                          <span class="truncate">{l.title}</span>
                          <span class="shrink-0 font-mono text-[0.68rem] text-muted-text">{l.price ? `${l.price} ↗` : '↗'}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── Section 7: Methodology ─────────────────────────────────── */}
      <section id="methodology" class="border-b border-border bg-canvas" aria-labelledby="method-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Verification 08</span>
          <h2 id="method-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">Methodology — deterministic, checkable</h2>
          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            <div class="rounded-[16px] border border-border bg-card-bg p-6">
              <h3 class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">Inputs (ground truth only)</h3>
              <ul class="mt-4 space-y-2.5 text-[0.85rem] leading-[1.6] text-muted-text">
                <li><strong class="text-primary-text">Verified file bytes</strong> — each repo's public Hugging Face file tree, fetched at build time. No benchmark claims, no tokens/sec, no accuracy numbers.</li>
                <li><strong class="text-primary-text">Datasheet memory constants</strong> — ESP32-S3 N8R8 (512 KB + 8 MB PSRAM), Teensy 4.1 +8MB, Pi 5 8GB/16GB, Orange Pi 5+ 16GB, ROCK 5B 16GB, Coral TPU (8 MB cache), Orin Nano 8GB / NX 16GB, Sigma 32GB. Hardcoded in <span class="font-mono text-[0.78rem]">scripts/edgespec/radar-core.mjs</span> with sources in comments.</li>
                <li><strong class="text-primary-text">Published quant formats</strong> — llama.cpp bits-per-weight values (Q4_K_M ≈ 4.85 bpw, Q8_0 ≈ 8.5, …).</li>
              </ul>
            </div>
            <div class="rounded-[16px] border border-border bg-card-bg p-6">
              <h3 class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">Formulas (nothing else)</h3>
              <ul class="mt-4 space-y-2.5 font-mono text-[0.78rem] leading-[1.7] text-muted-text">
                <li>runtime = fileBytes × 1.25 <span class="text-muted-text/70">(weights + KV/buffers)</span></li>
                <li>≈params = fileBytes × 8 ÷ bitsPerWeight <span class="text-muted-text/70">(GGUF only)</span></li>
                <li>FLOPs/token = 2 × params <span class="text-muted-text/70">(dense transformer rule)</span></li>
                <li>fits ≤ 80% ceiling · tight ≤ 100% · else no</li>
              </ul>
              <p class="mt-4 text-[0.8rem] leading-[1.6] text-muted-text">
                Gate tests (<span class="font-mono text-[0.72rem]">scripts/edgespec/pipeline.test.mjs</span>) run before every publish in CI. Days with zero grounded models publish nothing — the same anti-abuse posture as the Signals Journal.
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* ── Section 8: FAQ ─────────────────────────────────────────── */}
      <section aria-labelledby="faq-title" class="bg-card-bg/20">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted-text">Questions 09</span>
          <h2 id="faq-title" class="mt-1 text-[clamp(1.4rem,3vw,1.8rem)] font-bold tracking-[-0.04em] text-primary-text">Frequently Asked Questions</h2>
          <div class="mt-6 grid gap-3 lg:grid-cols-2">
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">Why no tokens-per-second or accuracy numbers?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">Because we'd have to invent them. Throughput depends on your exact runtime, cooling, and build flags — a number we didn't measure on the named board would be fabrication. This radar answers only the question arithmetic can answer honestly: does the model's memory footprint fit the board's ceiling?</p>
            </details>
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">Why does a “fits” verdict stop at 80% of the ceiling?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">KV cache grows with context length, runtimes allocate scratch buffers, and OS/framework overhead varies. The 20% margin is the difference between “loads once in a demo” and “runs reliably on your bench.” Tight means it fits on paper — plan your context budget carefully.</p>
            </details>
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">The repo name says 27B but your table shows fewer params — why?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">We derive ≈params from the verified file bytes ÷ the quant's bits-per-weight, not from the repo's title. Some repos ship partial, draft, or experimental files whose real size doesn't match the name. The bytes are the ground truth; the name is marketing.</p>
            </details>
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">When does this page update?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">A daily GitHub Action (<span class="font-mono text-[0.78rem]">edgespec-digest.yml</span>) rescans Hugging Face, re-runs the gate tests, and commits a new dated snapshot only when grounded models pass. This site itself makes zero runtime requests — the fetch happens at build time, per our <a href="/privacy" class="text-brand-anchor hover:text-primary-text">privacy boundary</a>.</p>
            </details>
          </div>
        </div>
      </section>
    </>
  ) : (
    <section class="border-b border-border bg-canvas py-24 text-center">
      <p class="text-muted-text">No radar snapshot has been published yet — the daily pipeline writes one after the first successful scan.</p>
      <a href="/resources" class="mt-6 inline-flex min-h-10 items-center rounded-full bg-primary-text px-5 text-[0.85rem] font-bold text-canvas">← Library</a>
    </section>
  )}
</Layout>
