---
/**
 * Edge AI Radar — renders the latest src/content/edge-radar/*.json snapshot.
 *
 * DESIGN LAW for this generated surface (owner directive 2026-07-22, see
 * docs/PASSIVE-CONTENT-ENGINES-2026.md rule 5):
 *  - Visual-first upgrade is QUEUED HERE: log-scale memory bars vs board
 *    ceilings, board-ceiling strip, quant spectrum, fit distribution. All
 *    graphics must derive from `latest.data` only — no decorative filler.
 *  - Keep the three shipped properties intact while adding graphics:
 *    (1) zero client JS required, (2) zero external requests at load
 *    (kit links are text-only rows on purpose — no merchant <img> here),
 *    (3) CLS 0 via fixed aspect-ratio containers.
 *  - The fit matrix scrolls horizontally on mobile with a STICKY first
 *    column (sticky left-0 z-10 bg-card-bg + offset shadow) — regression-
 *    tested in QA via wrapper.scrollLeft, not just document overflow.
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { affiliateLinks, resolveAffiliateLink } from '../../data/affiliate-links';
import MemoryBar from '../../components/edge-radar/MemoryBar.astro';
import CeilingStrip from '../../components/edge-radar/CeilingStrip.astro';

const entries = await getCollection('edge-radar');
const sorted = entries.sort((a, b) => b.id.localeCompare(a.id));
const latest = sorted[0];

const dateStr = latest?.id ?? null;
const generatedAt = latest?.data.generatedAt ?? null;
const boards = latest?.data.boards ?? [];
const models = latest?.data.models ?? [];
const fits = latest?.data.fits ?? [];

const fitFor = (modelId: string, boardId: string) =>
  fits.find((f) => f.modelId === modelId && f.boardId === boardId);

const GIB = 1024 * 1024 * 1024;
const MIB = 1024 * 1024;
const fmtBytes = (n: number) => (n >= GIB ? `${(n / GIB).toFixed(2)} GiB` : `${(n / MIB).toFixed(1)} MiB`);
const fmtParams = (n: number | null) => {
  if (n === null) return '—';
  if (n >= 1e9) return `${(n / 1e9).toFixed(2)}B`;
  if (n >= 1e6) return `${(n / 1e6).toFixed(0)}M`;
  return n.toLocaleString('en-US');
};
const fmtFlops = (n: number | null) => {
  if (n === null) return '—';
  if (n >= 1e12) return `${(n / 1e12).toFixed(2)} TFLOP`;
  return `${(n / 1e9).toFixed(1)} GFLOP`;
};

const verdictMeta = {
  fits: { label: 'Fits', dot: 'bg-emerald-500', text: 'text-emerald-600 dark:text-emerald-400' },
  tight: { label: 'Tight', dot: 'bg-amber-500', text: 'text-amber-600 dark:text-amber-400' },
  no: { label: 'No', dot: 'bg-muted-text/30', text: 'text-muted-text' },
} as const;

const formattedDate = dateStr
  ? new Date(dateStr + 'T12:00:00Z').toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      year: 'numeric',
      timeZone: 'UTC',
    })
  : null;

const fitsCount = (modelId: string) => fits.filter((f) => f.modelId === modelId && f.verdict !== 'no').length;

// Boards with curated buy paths, resolved through the audited affiliate registry.
const boardKits = boards
  .filter((b) => b.linkIds.length > 0)
  .map((b) => ({
    board: b,
    links: b.linkIds
      .map((id) => affiliateLinks.find((l) => l.id === id))
      .filter((l) => l !== undefined)
      .map((l) => resolveAffiliateLink(l)),
  }));

const title = 'Edge AI Radar — Daily TinyML & GGUF Hardware Fit Report | MakerPortal';
const description =
  'Daily deterministic radar: fresh GGUF/ONNX model releases from Hugging Face, sized against the real memory ceilings of ESP32-S3, Teensy 4.1, Raspberry Pi 5, Coral Edge TPU and Jetson Orin Nano. No benchmarks invented — only verified file bytes and datasheet math.';
---

<Layout title={title} description={description}>
  <HubShell
    kicker={`Learn · Resources · Edge AI Radar${dateStr ? ` · ${dateStr}` : ''}`}
    title="Which fresh models actually fit your board."
    lead="A daily, deterministic scan of new GGUF and ONNX releases on Hugging Face — verified file bytes in, datasheet memory ceilings out. Every fit verdict on this page is arithmetic you can check, not a benchmark we invented."
    status="Daily"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-2">
        <a href="#landscape" class="inline-flex min-h-11 items-center gap-1.5 rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor">
          Memory landscape ↓
        </a>
        <a href="#radar" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Matrix ↓</a>
        <a href="#methodology" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Methodology</a>
        <a href="/resources" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">← Resources</a>
      </div>
      {generatedAt && (
        <p class="mt-6 font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">
          {formattedDate} · {models.length} models × {boards.length} boards · generated {new Date(generatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZoneName: 'short' })}
        </p>
      )}
    </Fragment>
  </HubShell>

  {latest ? (
    <>
      {/* ── Visual-first: board ceiling strip (item 2) ─────────────── */}
      <section id="landscape" class="border-b border-border bg-canvas" aria-labelledby="landscape-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 id="landscape-title" class="text-[clamp(1.4rem,3vw,1.9rem)] font-[700] tracking-[-0.04em] text-primary-text">Memory landscape, today</h2>
              <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
                Log ruler from the smallest MCU ceiling (7 MiB) to the biggest SBC ceiling (6.5 GiB). Every dot is a model at its runtime estimate — left of a board's line you have headroom, right you don't. Top band shows best verdict across all boards.
              </p>
            </div>
            <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card-bg px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> log scale · {models.length} models plotted
            </span>
          </div>

          <div class="mt-8">
            <CeilingStrip boards={boards} models={models} fits={fits} />
          </div>

          <div class="mt-6 flex flex-wrap gap-2 font-mono text-[0.6rem] text-muted-text">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-2.5 py-1">
              <span class="h-1 w-16 rounded-full bg-gradient-to-r from-[var(--mp-elevated)] to-[var(--mp-cta)]" aria-hidden="true"></span>
              footprint ↑ grows → right (log)
            </span>
            <span class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-2.5 py-1">7 MiB MCU → 6.5 GiB SBC</span>
            <span class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-2.5 py-1">zero JS · SSR SVG · CLS 0</span>
          </div>
        </div>
      </section>

      {/* ── Fit matrix ─────────────────────────────────────────────── */}
      <section id="radar" class="border-b border-border" aria-labelledby="radar-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 id="radar-title" class="text-[clamp(1.3rem,2.8vw,1.7rem)] font-[650] tracking-[-0.04em] text-primary-text">Today's fit matrix</h2>
              <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
                Representative quant file per repo (Q4_K_M preferred), runtime estimate = verified bytes × 1.25, against each board's disclosed model-memory ceiling. <span class="text-emerald-600 dark:text-emerald-400 font-medium">Fits</span> ≤ 80% of ceiling · <span class="text-amber-600 dark:text-amber-400 font-medium">Tight</span> ≤ 100% · otherwise No.
              </p>
            </div>
            <span class="inline-flex items-center rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="mr-1.5 inline-block h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
              Scan {dateStr}
            </span>
          </div>

          <div class="mt-8 overflow-x-auto rounded-[20px] border border-border bg-card-bg">
            <table class="w-full min-w-[760px] border-collapse text-left">
              <thead>
                <tr class="border-b border-border">
                  <th scope="col" class="sticky left-0 z-10 bg-card-bg px-4 py-3 font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-muted-text">Model · representative file</th>
                  <th scope="col" class="px-3 py-3 font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-muted-text">Runtime est.</th>
                  {boards.map((b) => (
                    <th scope="col" class="px-3 py-3 text-center font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-muted-text">
                      {b.name.split('(')[0].trim()}
                      <span class="block text-[0.55rem] font-normal normal-case tracking-normal text-muted-text/70">{fmtBytes(b.modelCeilingBytes)} ceiling</span>
                    </th>
                  ))}
                  <th scope="col" class="px-3 py-3 text-center font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-muted-text">Score</th>
                </tr>
              </thead>
              <tbody>
                {models.map((m) => (
                  <tr class="border-b border-border/60 last:border-0 hover:bg-elevated/50">
                    <td class="sticky left-0 z-10 max-w-[22rem] bg-card-bg px-4 py-3 shadow-[8px_0_12px_-8px_var(--mp-card-shadow,rgba(0,0,0,0.08))]">
                      <a href={m.url} target="_blank" rel="noopener noreferrer" class="text-[0.85rem] font-semibold leading-snug text-primary-text hover:text-primary-cta">
                        {m.id}
                      </a>
                      <span class="mt-0.5 block font-mono text-[0.62rem] text-muted-text">
                        {m.format.toUpperCase()}{m.quant ? ` · ${m.quant}` : ''} · {fmtBytes(m.fileBytes)} file{m.pipelineTag ? ` · ${m.pipelineTag}` : ''}
                      </span>
                    </td>
                    <td class="whitespace-nowrap px-3 py-3 font-mono text-[0.75rem] text-primary-text">{fmtBytes(m.runtimeBytes)}</td>
                    {boards.map((b) => {
                      const f = fitFor(m.id, b.id);
                      const meta = f ? verdictMeta[f.verdict] : verdictMeta.no;
                      return (
                        <td class="px-3 py-3 text-center">
                          <span class={`inline-flex items-center gap-1.5 rounded-full border border-border bg-canvas px-2 py-0.5 font-mono text-[0.62rem] ${meta.text}`}>
                            <span class={`h-1.5 w-1.5 rounded-full ${meta.dot}`} aria-hidden="true"></span>
                            {meta.label}
                          </span>
                        </td>
                      );
                    })}
                    <td class="px-3 py-3 text-center font-mono text-[0.75rem] text-muted-text">{fitsCount(m.id)}/{boards.length}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {/* ── Model detail cards ─────────────────────────────────────── */}
      <section class="border-b border-border" aria-labelledby="models-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <h2 id="models-title" class="text-[clamp(1.3rem,2.8vw,1.7rem)] font-[650] tracking-[-0.04em] text-primary-text">The arithmetic, per model</h2>
          <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
            File bytes come from the repo's verified Hugging Face file tree. Parameter count is back-derived from those bytes ÷ the quant's published bits-per-weight — an approximation, labeled as one. FLOPs/token is the dense-transformer 2·P rule.
          </p>
          <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {models.map((m) => {
              const perModelFits = fits.filter((f) => f.modelId === m.id);
              return (
                <li class="flex flex-col rounded-[16px] border border-border bg-card-bg p-5">
                  <div class="flex items-center justify-between gap-2">
                    <span class="rounded-full bg-elevated border border-border px-2 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">{m.format}{m.quant ? ` · ${m.quant}` : ''}</span>
                    <span class="font-mono text-[0.6rem] text-muted-text">{fitsCount(m.id)}/{boards.length} boards</span>
                  </div>
                  <a href={m.url} target="_blank" rel="noopener noreferrer" class="mt-3 text-[0.95rem] font-semibold leading-snug text-primary-text hover:text-primary-cta">{m.id}</a>
                  <span class="mt-1 truncate font-mono text-[0.62rem] text-muted-text" title={m.fileName}>{m.fileName}</span>
                  <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 border-t border-border pt-4">
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">File</dt><dd class="font-mono text-[0.78rem] text-primary-text">{fmtBytes(m.fileBytes)}</dd></div>
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">Runtime est.</dt><dd class="font-mono text-[0.78rem] text-primary-text">{fmtBytes(m.runtimeBytes)}</dd></div>
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">≈ Params</dt><dd class="font-mono text-[0.78rem] text-primary-text">{fmtParams(m.approxParams)}</dd></div>
                    <div><dt class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">FLOPs/token</dt><dd class="font-mono text-[0.78rem] text-primary-text">{fmtFlops(m.flopsPerToken)}</dd></div>
                  </dl>
                  {/* item 1: log-scale memory bar with board ceiling markers — SSR SVG, zero JS, CLS fixed */}
                  <div class="mt-4">
                    <div class="mb-1.5 flex items-center justify-between">
                      <span class="font-mono text-[0.56rem] uppercase tracking-[0.12em] text-muted-text">Footprint vs ceilings · log 1 MiB→16 GiB</span>
                      <span class="font-mono text-[0.56rem] text-muted-text">{fmtBytes(m.runtimeBytes)}</span>
                    </div>
                    <MemoryBar runtimeBytes={m.runtimeBytes} modelId={m.id} boards={boards} fits={perModelFits} />
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </section>

      {/* ── Boards + curated kits ──────────────────────────────────── */}
      <section class="border-b border-border" aria-labelledby="boards-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 id="boards-title" class="text-[clamp(1.3rem,2.8vw,1.7rem)] font-[650] tracking-[-0.04em] text-primary-text">The boards behind the ceilings</h2>
              <AffiliateDisclosure class="mt-3 max-w-2xl" />
            </div>
          </div>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {boardKits.map(({ board, links }) => (
              <div class="flex flex-col rounded-[16px] border border-border bg-card-bg p-5">
                <div class="flex items-center justify-between gap-2">
                  <span class="rounded-full bg-elevated border border-border px-2 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">{board.class}</span>
                  <span class="font-mono text-[0.62rem] text-muted-text">{board.ramLabel}</span>
                </div>
                <h3 class="mt-3 text-[0.95rem] font-semibold text-primary-text">{board.name}</h3>
                <p class="mt-2 flex-1 text-[0.8rem] leading-[1.55] text-muted-text">{board.note}</p>
                <p class="mt-3 font-mono text-[0.68rem] text-primary-text">Model ceiling · {fmtBytes(board.modelCeilingBytes)}</p>
                {links.length > 0 && (
                  <ul class="mt-3 space-y-1.5 border-t border-border pt-3">
                    {links.map((l) => (
                      <li>
                        <a
                          href={l.url}
                          target="_blank"
                          rel="sponsored noopener noreferrer"
                          class="group/link flex items-center justify-between gap-2 rounded-[10px] border border-border bg-canvas px-3 py-2 text-[0.78rem] font-medium text-primary-text hover:border-[var(--mp-border-strong)] hover:text-primary-cta"
                        >
                          <span class="truncate">{l.title}</span>
                          <span class="shrink-0 font-mono text-[0.68rem] text-muted-text">{l.price ? `${l.price} ↗` : '↗'}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── Methodology ────────────────────────────────────────────── */}
      <section id="methodology" class="border-b border-border" aria-labelledby="method-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <h2 id="method-title" class="text-[clamp(1.3rem,2.8vw,1.7rem)] font-[650] tracking-[-0.04em] text-primary-text">Methodology — deterministic, checkable</h2>
          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            <div class="rounded-[16px] border border-border bg-card-bg p-6">
              <h3 class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">Inputs (ground truth only)</h3>
              <ul class="mt-4 space-y-2.5 text-[0.85rem] leading-[1.6] text-muted-text">
                <li><strong class="text-primary-text">Verified file bytes</strong> — each repo's public Hugging Face file tree, fetched at build time. No benchmark claims, no tokens/sec, no accuracy numbers.</li>
                <li><strong class="text-primary-text">Datasheet memory constants</strong> — ESP32-S3 (512 KB SRAM + 8 MB PSRAM), Teensy 4.1 (1 MB + 8 MB PSRAM), Pi 5 (8 GB), Coral Edge TPU (8 MB on-chip model cache), Jetson Orin Nano (8 GB unified). Hardcoded in <span class="font-mono text-[0.78rem]">scripts/edgespec/radar-core.mjs</span> with sources in comments.</li>
                <li><strong class="text-primary-text">Published quant formats</strong> — llama.cpp bits-per-weight values (Q4_K_M ≈ 4.85 bpw, Q8_0 ≈ 8.5, …).</li>
              </ul>
            </div>
            <div class="rounded-[16px] border border-border bg-card-bg p-6">
              <h3 class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">Formulas (nothing else)</h3>
              <ul class="mt-4 space-y-2.5 font-mono text-[0.78rem] leading-[1.7] text-muted-text">
                <li>runtime = fileBytes × 1.25 <span class="text-muted-text/70">(weights + KV/buffers)</span></li>
                <li>≈params = fileBytes × 8 ÷ bitsPerWeight <span class="text-muted-text/70">(GGUF only)</span></li>
                <li>FLOPs/token = 2 × params <span class="text-muted-text/70">(dense transformer rule)</span></li>
                <li>fits ≤ 80% ceiling · tight ≤ 100% · else no</li>
              </ul>
              <p class="mt-4 text-[0.8rem] leading-[1.6] text-muted-text">
                Gate tests (<span class="font-mono text-[0.72rem]">scripts/edgespec/pipeline.test.mjs</span>) run before every publish in CI. Days with zero grounded models publish nothing — the same anti-abuse posture as the Signals Journal.
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* ── FAQ ────────────────────────────────────────────────────── */}
      <section aria-labelledby="faq-title">
        <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
          <h2 id="faq-title" class="text-[clamp(1.3rem,2.8vw,1.7rem)] font-[650] tracking-[-0.04em] text-primary-text">FAQ</h2>
          <div class="mt-6 grid gap-3 lg:grid-cols-2">
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">Why no tokens-per-second or accuracy numbers?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">Because we'd have to invent them. Throughput depends on your exact runtime, cooling, and build flags — a number we didn't measure on the named board would be fabrication. This radar answers only the question arithmetic can answer honestly: does the model's memory footprint fit the board's ceiling?</p>
            </details>
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">Why does a “fits” verdict stop at 80% of the ceiling?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">KV cache grows with context length, runtimes allocate scratch buffers, and OS/framework overhead varies. The 20% margin is the difference between “loads once in a demo” and “runs reliably on your bench.” Tight means it fits on paper — plan your context budget carefully.</p>
            </details>
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">The repo name says 27B but your table shows fewer params — why?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">We derive ≈params from the verified file bytes ÷ the quant's bits-per-weight, not from the repo's title. Some repos ship partial, draft, or experimental files whose real size doesn't match the name. The bytes are the ground truth; the name is marketing.</p>
            </details>
            <details class="group rounded-[14px] border border-border bg-card-bg p-5 open:bg-elevated/50">
              <summary class="cursor-pointer list-none text-[0.9rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">When does this page update?<span class="float-right text-muted-text group-open:rotate-45">+</span></summary>
              <p class="mt-3 text-[0.85rem] leading-[1.65] text-muted-text">A daily GitHub Action (<span class="font-mono text-[0.78rem]">edgespec-digest.yml</span>) rescans Hugging Face, re-runs the gate tests, and commits a new dated snapshot only when grounded models pass. This site itself makes zero runtime requests — the fetch happens at build time, per our <a href="/privacy" class="text-brand-anchor hover:text-primary-text">privacy boundary</a>.</p>
            </details>
          </div>
        </div>
      </section>
    </>
  ) : (
    <section class="border-b border-border bg-canvas py-24 text-center">
      <p class="text-muted-text">No radar snapshot has been published yet — the daily pipeline writes one after the first successful scan.</p>
      <a href="/resources" class="mt-6 inline-flex min-h-10 items-center rounded-full bg-primary-text px-5 text-[0.85rem] font-bold text-canvas">← Resources</a>
    </section>
  )}
</Layout>
