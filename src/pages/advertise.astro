---
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';

const title = 'Advertise — Sponsor MakerPortal';
const description =
  'Sponsorships, sponsored notes, and newsletter placements on MakerPortal. Privacy-respecting audience of on-device AI and iOS builders.';
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Advertise · Sponsors · Partners"
    title="Reach builders who care."
    lead="Sponsored field notes, resource placements, and video integrations for brands that fit on-device, privacy-first, and Apple platform craft. No dark patterns. No fake engagement."
    status="Media kit scaffold"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-full bg-white px-5 text-[0.9rem] font-bold text-canvas hover:bg-primary-text">Talk sponsorships</a>
        <a href="/press" class="inline-flex min-h-11 items-center rounded-full border border-white/10 px-5 text-[0.9rem] font-medium text-primary-text/80 hover:text-white">Press kit</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-white/[0.06]">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="grid gap-5 md:grid-cols-3">
        {[
          { t: 'Sponsored note', d: 'One field note with clear sponsor labeling and editorial standards.' },
          { t: 'Resource slot', d: 'Featured tool on Learn — disclosure always visible.' },
          { t: 'Video integration', d: 'Mention or segment on Watch once the channel is live.' },
        ].map((x) => (
          <article class="rounded-[24px] border border-white/[0.06] bg-[#1A232E] p-6">
            <h2 class="text-xl font-semibold text-white">{x.t}</h2>
            <p class="mt-3 text-[0.92rem] leading-[1.65] text-primary-text/65">{x.d}</p>
          </article>
        ))}
      </div>
      <p class="mt-10 text-[0.9rem] text-primary-text/60">Audience: indie iOS engineers, privacy-conscious product people, on-device ML practitioners. Rates and calendar via contact.</p>
    </div>
  </section>
</Layout>
