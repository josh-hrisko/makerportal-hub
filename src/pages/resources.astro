---
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import ButtondownSignup from '../components/ButtondownSignup.astro';
import { affiliateLinks, resolveAffiliateLink } from '../data/affiliate-links';
import { getCollection } from 'astro:content';
import { pillarMeta, fallbackPillar } from '../data/trends';
import type { TrendItem } from '../data/trends';
import { playground } from '../data/playground';

// Fetch the journal entries to compute trending pillars for gear re-ranking (D-017)
// No journal content is rendered on /resources anymore — canonical home is /journal
const journals = await getCollection('journal');
const sortedJournals = journals.sort((a, b) => b.id.localeCompare(a.id));
const latestJournal = sortedJournals[0];

const allTrends: TrendItem[] = latestJournal ? (latestJournal.data.items as TrendItem[]) : [];

const pillarCounts: Record<string, number> = {};
for (const t of allTrends) {
  for (const tag of t.tags ?? []) pillarCounts[tag] = (pillarCounts[tag] ?? 0) + 1;
}
const trendingPillarEntries = Object.entries(pillarCounts).sort((a, b) => b[1] - a[1]);
const trendingPillars = trendingPillarEntries.map(([k]) => k);
const topTrendingPillars = trendingPillars.slice(0, 3);
const trendingPillarSet = new Set(trendingPillars);

const linkTrendScore = (link: { pillars?: string[] }) =>
  (link.pillars ?? []).reduce((sum, p) => sum + (pillarCounts[p] ?? 0), 0);
const linkIsTrending = (link: { pillars?: string[] }) =>
  (link.pillars ?? []).some((p) => trendingPillarSet.has(p));

const gearGroupLabels: Record<string, string> = {
  blexar: 'BLExAR',
  biquadia: 'Biquadia',
  nymic: 'nymic',
  akous: 'akous',
  motionlink: 'MotionLink',
  itria: 'itria',
  studio: 'Studio',
};
const gearGroupOrder = ['blexar', 'biquadia', 'nymic', 'akous', 'motionlink', 'itria', 'studio'];
const baseGearGroups = gearGroupOrder
  .map((key) => ({
    key,
    label: gearGroupLabels[key],
    items: affiliateLinks.filter((link) => {
      const owner = link.relatedTo?.[0];
      if (key === 'studio') return !owner || !gearGroupOrder.slice(0, -1).includes(owner);
      return owner === key || (link.relatedTo?.includes(key) ?? false);
    }),
  }))
  .filter((group) => group.items.length > 0);

const gearGroups = baseGearGroups
  .map((group, originalIdx) => {
    const sortedItems = [...group.items].sort((a, b) => linkTrendScore(b) - linkTrendScore(a));
    const groupScore = sortedItems.reduce((s, l) => s + linkTrendScore(l), 0);
    const trendingItems = sortedItems.filter(linkIsTrending).length;
    return { ...group, items: sortedItems, score: groupScore, trendingItems, originalIdx };
  })
  .sort((a, b) => b.score - a.score || b.trendingItems - a.trendingItems || a.originalIdx - b.originalIdx);

const title = 'Resources — Guides, Playground & Tools | MakerPortal';
const description =
  'On-device AI guides, iOS craft notes, downloadable archives, interactive playground, and 50 curated gear picks with disclosure. Daily Signals Journal re-ranks gear.';

const topics = [
  { title: 'On-device AI', blurb: 'CoreML, ANE latency, quantization, offline indexes, hybrid where needed.' },
  { title: 'Transparent architecture', blurb: 'No dark patterns, App Store labels, local storage, clear cloud disclosure for agentic.' },
  { title: 'SwiftUI craft', blurb: 'Performance, accessibility, one-handed moments.' },
  { title: 'Shipping indie', blurb: 'Release discipline, App Store ops, small teams.' },
];

const tools = [
  { name: 'Apple Developer', href: 'https://developer.apple.com', note: 'Official docs & SDKs' },
  { name: 'Core ML Tools', href: 'https://apple.github.io/coremltools/', note: 'Model conversion' },
  { name: 'Astro', href: 'https://astro.build', note: 'This hub’s static engine' },
];
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Learn · Resources · Topic hubs"
    title="A library that scales."
    lead="Topic-first learning (not format silos): guides, downloads, and tool picks that feed SEO, agents, and affiliate income — without turning the studio into a content farm."
    status="Learn"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blog" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Field notes</a>
        <a href="/shop" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Shop archives</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <h2 class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Topics</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {topics.map((t) => (
          <a href="/blog" class="group rounded-[20px] border border-border bg-card-bg p-5 transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated">
            <h3 class="text-lg font-semibold text-primary-text group-hover:text-primary-cta">{t.title}</h3>
            <p class="mt-2 text-[0.9rem] leading-[1.6] text-muted-text">{t.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Signals Journal lives at /journal — compact bridge (no duplicate feed) */}
  <section class="border-b border-border" aria-labelledby="signals-bridge-title">
    <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
      <div class="flex flex-col gap-4 rounded-[20px] border border-border bg-card-bg p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
        <div>
          <h2 id="signals-bridge-title" class="text-[1.15rem] font-semibold text-primary-text">Signals Journal</h2>
          <p class="mt-1.5 max-w-xl text-[0.9rem] leading-[1.6] text-muted-text">Daily developer signals — auto-published to <span class="font-mono text-[0.8rem]">/journal</span>. Trending pillars re-rank <a href="#gear" class="text-brand-anchor hover:text-primary-text">Gear</a> below.</p>
          {latestJournal && (
            <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">Latest · {latestJournal.id} · {allTrends.length} signals</p>
          )}
        </div>
        <div class="flex shrink-0 flex-wrap gap-2">
          <a href="/journal" class="inline-flex min-h-10 items-center rounded-full bg-primary-text px-5 text-[0.85rem] font-bold text-canvas hover:opacity-90">Open Signals →</a>
          <a href={latestJournal ? `/journal/${latestJournal.id}` : '/journal'} class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-5 text-[0.85rem] font-medium text-muted-text hover:text-primary-text hover:border-[var(--mp-border-strong)]">Latest report</a>
        </div>
      </div>
    </div>
  </section>

  <section id="playground" class="border-b border-border" aria-labelledby="playground-title">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <h2 id="playground-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Playground</h2>
          <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">Interactive tools and toys. Some are grounded in real app code; others are just for the fun of it.</p>
        </div>
        <a href="/playground" class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor">Open Playground →</a>
      </div>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {playground.filter((p) => p.status === 'live').map((entry) => {
          const pillar = entry.pillarHint ? (pillarMeta[entry.pillarHint] ?? fallbackPillar) : null;
          return (
          <a href={`/playground/${entry.slug}`} class="group flex flex-col rounded-[16px] border border-border bg-card-bg p-4 transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated">
            {pillar && (
              <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
                <span class="h-1.5 w-1.5 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>
                {pillar.label} {entry.isGrounded ? '· Lab' : ''}
              </span>
            )}
            <span class="mt-2 text-[0.98rem] font-semibold text-primary-text transition-colors group-hover:text-primary-cta">{entry.title}</span>
            <span class="mt-1 text-[0.8rem] text-muted-text">{entry.tagline}</span>
          </a>
          );
        })}
      </div>
    </div>
  </section>

  <section id="tools" class="border-b border-border" aria-labelledby="tools-title">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <h2 id="tools-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Tools we use</h2>
      <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">
        Curated links. If a listing becomes an affiliate relationship, it will be labeled. See <a href="/privacy#affiliates" class="text-brand-anchor hover:text-primary-text">disclosure</a>.
      </p>
      <ul class="mt-8 divide-y divide-border border-y border-border">
        {tools.map((tool) => (
          <li class="flex flex-wrap items-center justify-between gap-3 py-5">
            <div>
              <a href={tool.href} target="_blank" rel="noopener noreferrer" class="text-[1.05rem] font-semibold text-primary-text hover:text-primary-cta">{tool.name} ↗</a>
              <p class="mt-1 text-[0.85rem] text-muted-text">{tool.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {affiliateLinks.length > 0 && (
    <section id="gear" class="border-b border-border" aria-labelledby="gear-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <h2 id="gear-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Gear</h2>
            <AffiliateDisclosure class="mt-3 max-w-2xl" />
          </div>
          {topTrendingPillars.length > 0 && (
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary-cta align-middle mr-1.5" aria-hidden="true"></span>
              Re-ranked · trending {topTrendingPillars.map((p) => pillarMeta[p]?.label ?? p).join(' · ')}
            </p>
          )}
        </div>
        {gearGroups.map((group) => (
          <details class="group mt-4 first:mt-8" open={group.items.length <= 6}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 rounded-[14px] border border-border bg-elevated/40 px-4 py-3 [&::-webkit-details-marker]:hidden">
              <span class="flex items-center gap-2 font-mono text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-muted-text">
                {group.label} <span class="text-muted-text/70">· {group.items.length}</span>
                {group.score > 0 && (
                  <span class="inline-flex items-center gap-1 rounded-full bg-primary-cta/10 px-2 py-0.5 text-[0.6rem] text-primary-cta">▲ trending</span>
                )}
              </span>
              <span class="text-muted-text transition-transform duration-200 group-open:rotate-180" aria-hidden="true">⌄</span>
            </summary>
            <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {group.items.map((link) => {
                const resolved = resolveAffiliateLink(link);
                const isTrendingItem = linkIsTrending(link);
                const trendingMatchedPillars = (link.pillars ?? []).filter((p) => trendingPillarSet.has(p));
                return (
                  <div class={`flex items-start gap-3 rounded-[14px] border bg-card-bg p-4 ${isTrendingItem ? 'border-primary-cta/20 bg-card-bg' : 'border-border'}`}>
                    {resolved.image && (
                      <img
                        src={resolved.image}
                        alt=""
                        width="48"
                        height="48"
                        loading="lazy"
                        decoding="async"
                        class="size-12 shrink-0 rounded-[8px] border border-border bg-card-bg object-contain p-1"
                      />
                    )}
                    <div class="min-w-0 flex-1">
                      <a href={resolved.url} target="_blank" rel="sponsored noopener noreferrer" class="text-[0.92rem] font-semibold leading-[1.35] text-primary-text hover:text-primary-cta">{resolved.title} ↗</a>
                      <p class="mt-1 text-[0.78rem] leading-[1.5] text-muted-text">{link.note}</p>
                      <div class="mt-2 flex flex-wrap items-center gap-x-2.5 gap-y-1.5">
                        {resolved.price && (
                          <span class="rounded-full border border-border bg-elevated px-2 py-0.5 font-mono text-[0.65rem] text-primary-text">{resolved.price}</span>
                        )}
                        {isTrendingItem && trendingMatchedPillars.length > 0 && (
                          <span class="inline-flex items-center gap-1 rounded-full bg-primary-cta px-2 py-0.5 font-mono text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-white">↗ {trendingMatchedPillars.map((p) => pillarMeta[p]?.label ?? p).join(', ')}</span>
                        )}
                        {(link.pillars ?? []).map((p) => {
                          const pillar = pillarMeta[p] ?? fallbackPillar;
                          const isActive = trendingPillarSet.has(p);
                          return (
                            <span class={`inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.1em] ${isActive ? 'text-primary-text' : 'text-muted-text'}`}>
                              <span class="h-1.5 w-1.5 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>
                              {pillar.label}
                            </span>
                          );
                        })}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

  <section class="border-b border-border bg-elevated/20" aria-labelledby="newsletter-title">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
      <div class="grid gap-6 md:grid-cols-[1.1fr_0.9fr]">
        <div>
          <h2 id="newsletter-title" class="text-[clamp(1.3rem,3vw,1.7rem)] font-[650] tracking-[-0.03em] text-primary-text">Newsletter — privacy-first</h2>
          <p class="mt-3 max-w-xl text-[0.9rem] leading-[1.6] text-muted-text">Buttondown (no tracking pixels, markdown-friendly per D-014). Get Signals re-rank, archive drops, field notes. Free snippet lead magnet.</p>
          <p class="mt-3 font-mono text-[0.62rem] text-muted-text">Free first 100, $9/mo addon · RSS also at /rss.xml</p>
        </div>
        <ButtondownSignup username="" title="Learn — privacy-first" blurb="Signals re-rank + archive drops + field notes. No tracking, unsubscribe anytime." />
      </div>
    </div>
  </section>
</Layout>
