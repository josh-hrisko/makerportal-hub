---
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';

const title = 'Learn — Resources, Guides & Tools | MakerPortal';
const description =
  'On-device AI guides, iOS craft resources, downloadable archives, and curated tools. Affiliate recommendations disclosed.';

const topics = [
  { title: 'On-device AI', blurb: 'CoreML, ANE latency, quantization, offline indexes.' },
  { title: 'Privacy architecture', blurb: 'Zero telemetry patterns, App Store privacy labels, local storage.' },
  { title: 'SwiftUI craft', blurb: 'Performance, accessibility, one-handed moments.' },
  { title: 'Shipping indie', blurb: 'Release discipline, App Store ops, small teams.' },
];

const tools = [
  { name: 'Apple Developer', href: 'https://developer.apple.com', note: 'Official docs & SDKs' },
  { name: 'Core ML Tools', href: 'https://apple.github.io/coremltools/', note: 'Model conversion' },
  { name: 'Astro', href: 'https://astro.build', note: 'This hub’s static engine' },
];
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Learn · Resources · Topic hubs"
    title="A library that scales."
    lead="Topic-first learning (not format silos): guides, downloads, and tool picks that feed SEO, agents, and affiliate income — without turning the studio into a content farm."
    status="Library scaffold"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blog" class="inline-flex min-h-11 items-center rounded-full bg-white px-5 text-[0.9rem] font-bold text-canvas hover:bg-primary-text">Field notes</a>
        <a href="/shop" class="inline-flex min-h-11 items-center rounded-full border border-white/10 px-5 text-[0.9rem] font-medium text-primary-text/80 hover:text-white">Shop archives</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-white/[0.06]">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <h2 class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-white">Topics</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {topics.map((t) => (
          <a href="/blog" class="group rounded-[20px] border border-white/[0.06] bg-white/[0.02] p-5 transition-colors hover:border-white/10 hover:bg-white/[0.04]">
            <h3 class="text-lg font-semibold text-white group-hover:text-primary-cta">{t.title}</h3>
            <p class="mt-2 text-[0.9rem] leading-[1.6] text-primary-text/60">{t.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="tools" class="border-b border-white/[0.06]" aria-labelledby="tools-title">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <h2 id="tools-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-white">Tools we use</h2>
      <p class="mt-3 max-w-2xl text-[0.95rem] text-primary-text/60">
        Curated links. If a listing becomes an affiliate relationship, it will be labeled. See <a href="/privacy#affiliates" class="text-brand-anchor hover:text-white">disclosure</a>.
      </p>
      <ul class="mt-8 divide-y divide-white/[0.06] border-y border-white/[0.06]">
        {tools.map((tool) => (
          <li class="flex flex-wrap items-center justify-between gap-3 py-5">
            <div>
              <a href={tool.href} target="_blank" rel="noopener noreferrer" class="text-[1.05rem] font-semibold text-white hover:text-primary-cta">{tool.name} ↗</a>
              <p class="mt-1 text-[0.85rem] text-muted-text/70">{tool.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
