---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import { pillarMeta, fallbackPillar, sourceLabels } from '../../data/trends';
import type { TrendItem, TrendSource } from '../../data/trends';

export async function getStaticPaths() {
  const journals = await getCollection('journal');
  // Sort ascending for prev/next calc consistency
  const sorted = journals.sort((a,b) => a.id.localeCompare(b.id));
  return sorted.map((entry, idx) => ({
    params: { date: entry.id },
    props: { 
      entry,
      prevDate: idx > 0 ? sorted[idx-1].id : null,
      nextDate: idx < sorted.length - 1 ? sorted[idx+1].id : null,
      allEntries: sorted,
    },
  }));
}

const { entry, prevDate, nextDate } = Astro.props;
const dateStr = entry.id;
const items = entry.data.items as TrendItem[];
const generatedAt = entry.data.generatedAt;

const trending = [...items].sort((a, b) => b.score - a.score);
const [featuredSignal, ...restSignals] = trending;

const pillarOf = (item: { tags: string[] }) => pillarMeta[item.tags[0]] ?? fallbackPillar;
const signalBars = (score: number) => Math.max(1, Math.min(5, Math.round(score / 3)));

const timeAgo = (iso: string) => {
  const days = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 864e5));
  return days === 0 ? 'today' : `${days}d ago`;
};

const formattedDate = new Date(dateStr + 'T12:00:00Z').toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});

const genDate = new Date(generatedAt);
const genFormatted = genDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZoneName: 'short',
});

const title = `Signals Report — ${formattedDate} | MakerPortal`;
const description = `Daily developer trends and public discussion signals for ${formattedDate}: ${items.length} signals across on-device AI, iOS craft, DSP. Score-weighted, source-corroborated.`;

// Pillar distribution for filter bar
const pillarCounts = {} as any;
for (const t of items) for (const tag of (t as any).tags ?? []) pillarCounts[tag] = (pillarCounts[tag] ?? 0) + 1;
const pillarEntries = Object.entries(pillarCounts).sort((a: any,b: any) => (b[1] as number)-(a[1] as number));

// Source distribution for filter bar
const sourceCounts = {} as any;
for (const t of items) {
  const sources = (t.sources ?? [t.source]) as string[];
  for (const src of sources) {
    sourceCounts[src] = (sourceCounts[src] ?? 0) + 1;
  }
}
const sourceEntries = Object.entries(sourceCounts).sort((a: any, b: any) => (b[1] as number) - (a[1] as number));
const uniqueSources = [...new Set(items.flatMap((i: any) => i.sources ?? [i.source]))];
---

<Layout title={title} description={description}>
  <HubShell
    kicker={`Library · Signals Journal · ${dateStr}`}
    title={formattedDate}
    lead={`Captured ${genFormatted} — ${items.length} signals across ${pillarEntries.length} pillars, ${uniqueSources.length} source networks. Scores weighted by keyword hits, artifact bonus, and cross-source corroboration.`}
    status="Journal"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-2">
        <a href="/journal" class="inline-flex min-h-11 items-center gap-1.5 rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor">
          <span aria-hidden="true">←</span> Journal index
        </a>
        <a href="/resources#gear" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Trending gear →</a>
      </div>
      <div class="mt-6 flex flex-wrap items-center gap-2">
        {prevDate ? (
          <a href={`/journal/${prevDate}`} class="inline-flex min-h-8 items-center gap-1 rounded-full border border-border bg-card-bg px-3 text-[0.75rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">
            ← {prevDate}
          </a>
        ) : <span class="inline-flex min-h-8 items-center rounded-full border border-dashed border-border px-3 text-[0.75rem] text-muted-text/60">No earlier scan</span>}
        {nextDate ? (
          <a href={`/journal/${nextDate}`} class="inline-flex min-h-8 items-center gap-1 rounded-full border border-border bg-card-bg px-3 text-[0.75rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">
            {nextDate} →
          </a>
        ) : <span class="inline-flex min-h-8 items-center rounded-full border border-dashed border-border px-3 text-[0.75rem] text-muted-text/60">Latest day →</span>}
        <span class="ml-2 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">{items.length} signals · generated {genFormatted}</span>
      </div>
    </Fragment>
  </HubShell>

  {/* Combined filter bar — client-side filter (no framework) */}
  {(pillarEntries.length > 0 || sourceEntries.length > 0) && (
    <div class="sticky top-[3.875rem] z-30 border-b border-border bg-canvas/95 backdrop-blur-sm">
      <div class="mx-auto max-w-[88rem] px-5 py-3 sm:px-8 lg:px-10">
        <div class="flex flex-wrap items-center justify-between gap-y-3 gap-x-6">
          {/* Pillars */}
          {pillarEntries.length > 0 && (
            <div class="flex flex-wrap items-center gap-2" role="group" aria-label="Filter by topic pillar">
              <span class="mr-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Pillar:</span>
              <button data-filter="all" aria-pressed="true" class="filter-pill active inline-flex items-center gap-1.5 rounded-full border bg-primary-text border-primary-text px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-canvas focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">All · {items.length}</button>
              {pillarEntries.map(([tag, count]) => {
                const meta = pillarMeta[tag] ?? fallbackPillar;
                return (
                  <button data-filter={tag} aria-pressed="false" class="filter-pill inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-3 py-1 text-[0.7rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor focus-visible:ring-offset-2 focus-visible:ring-offset-canvas" data-color={meta.color}>
                    <span class="size-1.5 rounded-full" style={`background:${meta.color}`} aria-hidden="true"></span>
                    {meta.label} · {count}
                  </button>
                );
              })}
            </div>
          )}

          {/* Sources */}
          {sourceEntries.length > 0 && (
            <div class="flex flex-wrap items-center gap-2" role="group" aria-label="Filter by source network">
              <span class="mr-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Source:</span>
              <button data-source-filter="all" aria-pressed="true" class="source-pill active inline-flex items-center gap-1.5 rounded-full border bg-primary-text border-primary-text px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-canvas focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">All</button>
              {sourceEntries.map(([src, count]) => {
                const label = sourceLabels[src as TrendSource] ?? src;
                return (
                  <button data-source-filter={src} aria-pressed="false" class="source-pill inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-3 py-1 text-[0.7rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">
                    {label} · {count}
                  </button>
                );
              })}
            </div>
          )}

          {/* Clear filters + live result count — revealed by JS when any filter is active */}
          <div class="flex items-center gap-2.5">
            <span id="filter-count" role="status" aria-live="polite" class="font-mono text-[0.62rem] uppercase tracking-[0.1em] text-muted-text"></span>
            <button
              id="clear-filters"
              type="button"
              hidden
              class="inline-flex items-center gap-1 rounded-full border border-dashed border-border px-3 py-1 font-mono text-[0.62rem] uppercase tracking-[0.1em] text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor"
            >
              <span aria-hidden="true">✕</span> Clear
            </button>
          </div>
        </div>
      </div>
    </div>
  )}

  {trending.length > 0 && featuredSignal ? (
    <section class="border-b border-border bg-canvas">
      <div class="mx-auto max-w-[88rem] px-5 py-10 sm:px-8 sm:py-14 lg:px-10">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <h2 class="text-[clamp(1.3rem,2.8vw,1.7rem)] font-[650] tracking-[-0.04em] text-primary-text">Daily digest</h2>
            <p class="mt-2 max-w-2xl text-[0.9rem] leading-[1.6] text-muted-text">
              Top signal featured — scores combine keyword relevance (×3 per hit), artifact bonus (+3 for GitHub/arXiv/papers), corroboration (+3 per extra source), and capped engagement (+0–4). Remaining signals grid below, filterable by pillar.
            </p>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="mr-1.5 inline-block h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
              Scan {dateStr}
            </span>
            <span class="font-mono text-[0.6rem] text-muted-text">{items.length} total</span>
          </div>
        </div>

        {/* Featured */}
        <a
          href={featuredSignal.url}
          target="_blank"
          rel="noopener noreferrer"
          class="journal-featured-reveal group mt-8 grid overflow-hidden rounded-[24px] border border-border bg-card-bg shadow-[0_8px_30px_-16px_rgba(0,0,0,0.2)] transition-all hover:border-[var(--mp-border-strong)] hover:shadow-[0_20px_50px_-18px_rgba(0,0,0,0.25)] hover:-translate-y-[1px] md:grid-cols-[1.15fr_1fr]"
          data-tags={featuredSignal.tags.join(' ')}
          data-sources={(featuredSignal.sources ?? [featuredSignal.source]).join(' ')}
        >
          <div class="relative aspect-[16/10] overflow-hidden md:aspect-auto md:min-h-[18rem]">
            {featuredSignal.image ? (
              <img
                src={featuredSignal.image}
                alt={featuredSignal.title}
                width="720"
                height="480"
                loading="eager"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              />
            ) : (
              <div
                class="absolute inset-0 flex items-center justify-center"
                style={`background: radial-gradient(120% 120% at 20% 20%, color-mix(in srgb, ${pillarOf(featuredSignal).color} 22%, transparent), transparent 50%), linear-gradient(135deg, color-mix(in srgb, ${pillarOf(featuredSignal).color} 14%, var(--mp-card-bg)), var(--mp-card-bg));`}
                aria-hidden="true"
              >
                <span class="rounded-full border border-border bg-canvas/80 px-3 py-1 font-mono text-[0.7rem] uppercase tracking-[0.2em] backdrop-blur" style={`color:${pillarOf(featuredSignal).color};`}>◉ {pillarOf(featuredSignal).label}</span>
              </div>
            )}
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
          </div>
          <div class="flex flex-col justify-between gap-6 p-6 sm:p-8">
            <div>
              <p class="flex flex-wrap items-center gap-2 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-muted-text">
                <span class="inline-flex items-center rounded-full bg-primary-cta px-2 py-0.5 text-[0.6rem] font-bold text-white">Top signal · Score {featuredSignal.score}</span>
                <span>{(featuredSignal.sources ?? [featuredSignal.source]).map((s) => sourceLabels[s]).join(' + ')}</span>
                <span>· {timeAgo(featuredSignal.publishedAt)}</span>
              </p>
              <h3 class="mt-4 text-[clamp(1.2rem,2.6vw,1.6rem)] font-semibold leading-[1.3] tracking-[-0.02em] text-primary-text group-hover:text-primary-cta">{featuredSignal.title}</h3>
              {featuredSignal.author && <p class="mt-2 font-mono text-[0.65rem] text-muted-text">by {featuredSignal.author}</p>}
            </div>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
              <span class="inline-flex items-center gap-2 rounded-full border border-border bg-canvas px-3 py-1 font-mono text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">
                <span class="h-2 w-2 rounded-full" style={`background:${pillarOf(featuredSignal).color};`} aria-hidden="true"></span>
                {pillarOf(featuredSignal).label}
              </span>
              {featuredSignal.domain && <span class="rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.6rem] text-muted-text">{featuredSignal.domain}</span>}
              <span class="ml-auto inline-flex items-end gap-[3px]" role="img" aria-label={`Signal strength ${signalBars(featuredSignal.score)} of 5`}>
                {[1, 2, 3, 4, 5].map((n) => (
                  <span class="signal-bar signal-bar-animate w-[4px] rounded-sm transition-colors" style={`height:${4 + n * 2}px; background:${n <= signalBars(featuredSignal.score) ? pillarOf(featuredSignal).color : 'var(--mp-border)'};`} aria-hidden="true"></span>
                ))}
              </span>
            </div>
          </div>
        </a>

        {/* Grid */}
        <ul id="signal-grid" class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {restSignals.map((item) => {
            const pillar = pillarOf(item);
            return (
              <li class="signal-card journal-card-reveal" data-tags={item.tags.join(' ')} data-sources={(item.sources ?? [item.source]).join(' ')}>
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex h-full flex-col overflow-hidden rounded-[20px] border border-border bg-card-bg transition-all hover:border-[var(--mp-border-strong)] hover:bg-elevated hover:shadow-[0_12px_30px_-14px_rgba(0,0,0,0.2)] hover:-translate-y-[1px]"
                >
                  <div class="relative aspect-[16/9] overflow-hidden bg-canvas">
                    {item.image ? (
                      <img
                        src={item.image}
                        alt={item.title}
                        width="640"
                        height="360"
                        loading="lazy"
                        decoding="async"
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                      />
                    ) : (
                      <div
                        class="absolute inset-0 flex items-center justify-center"
                        style={`background: linear-gradient(135deg, color-mix(in srgb, ${pillar.color} 12%, var(--mp-card-bg)), var(--mp-card-bg));`}
                        aria-hidden="true"
                      >
                        <span class="rounded-full border border-border bg-canvas/70 px-2.5 py-1 font-mono text-[0.62rem] uppercase tracking-[0.18em] backdrop-blur" style={`color:${pillar.color};`}>◉ {pillar.label}</span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col justify-between gap-4 p-5">
                    <div>
                      <p class="flex flex-wrap items-center gap-1.5 font-mono text-[0.58rem] uppercase tracking-[0.12em] text-muted-text">
                        <span>{(item.sources ?? [item.source]).map((s) => sourceLabels[s]).join(' + ')}</span>
                        <span class="opacity-50">·</span>
                        <span>{timeAgo(item.publishedAt)}</span>
                        <span
                          class="ml-auto inline-flex cursor-help items-center rounded-full bg-elevated border border-border px-1.5 py-0.5 text-[0.55rem]"
                          title={`Score ${item.score} — keyword hits ×3 · artifact +3 · corroboration ×3 · engagement capped 0–4 · recency +8…−3`}
                          aria-label={`Signal score ${item.score}. Weighted by keyword relevance, artifact bonus, corroboration, capped engagement, and recency.`}
                        >{item.score}</span>
                      </p>
                      <h3 class="mt-2.5 line-clamp-3 text-[0.95rem] font-medium leading-[1.5] text-primary-text group-hover:text-primary-cta">{item.title}</h3>
                    </div>
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1.5">
                      <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.1em] text-muted-text">
                        <span class="h-1.5 w-1.5 rounded-full" style={`background:${pillar.color};`} aria-hidden="true"></span>
                        {pillar.label}
                      </span>
                      {item.domain && <span class="rounded-full border border-border bg-elevated px-2 py-0.5 font-mono text-[0.6rem] text-muted-text">{item.domain}</span>}
                      <span class="ml-auto inline-flex items-end gap-[2.5px]" role="img" aria-label={`Signal ${signalBars(item.score)} of 5`}>
                        {[1, 2, 3, 4, 5].map((n) => (
                          <span class="signal-bar signal-bar-animate w-[3px] rounded-sm" style={`height:${3 + n * 2}px; background:${n <= signalBars(item.score) ? pillar.color : 'var(--mp-border)'};`} aria-hidden="true"></span>
                        ))}
                      </span>
                    </div>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>

        <div class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-border pt-8">
          <div class="flex gap-2">
            {prevDate ? <a href={`/journal/${prevDate}`} class="inline-flex min-h-10 items-center rounded-full border border-border bg-card-bg px-4 text-[0.85rem] font-medium text-primary-text hover:border-[var(--mp-border-strong)]">← {prevDate}</a> : null}
            {nextDate ? <a href={`/journal/${nextDate}`} class="inline-flex min-h-10 items-center rounded-full border border-border bg-card-bg px-4 text-[0.85rem] font-medium text-primary-text hover:border-[var(--mp-border-strong)]">{nextDate} →</a> : null}
          </div>
          <a href="/journal" class="inline-flex min-h-10 items-center rounded-full bg-primary-text px-5 text-[0.85rem] font-bold text-canvas hover:opacity-90">Back to all scans →</a>
        </div>
      </div>
    </section>
  ) : (
    <section class="border-b border-border bg-canvas py-24 text-center">
      <p class="text-muted-text">No signals captured for this day.</p>
      <div class="mt-6 flex justify-center gap-2">
        {prevDate && <a href={`/journal/${prevDate}`} class="rounded-full border border-border px-4 py-2 text-sm">← {prevDate}</a>}
        <a href="/journal" class="rounded-full bg-primary-text px-4 py-2 text-sm text-canvas">Journal</a>
        {nextDate && <a href={`/journal/${nextDate}`} class="rounded-full border border-border px-4 py-2 text-sm">{nextDate} →</a>}
      </div>
    </section>
  )}

  <script>
    // Pillar and Source filter — light vanilla JS, no framework.
    // State persists in the URL hash (shareable) + localStorage (sticky across days).
    const pillarPills = document.querySelectorAll('.filter-pill');
    const sourcePills = document.querySelectorAll('.source-pill');
    const featured = document.querySelector('a[data-tags].group') as HTMLElement | null;
    const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement | null;
    const STORAGE_KEY = 'journal:filters';

    let activePillar = 'all';
    let activeSource = 'all';

    function setPillarActive(filter: string) {
      pillarPills.forEach(p => {
        const isActive = p.getAttribute('data-filter') === filter;
        p.classList.toggle('active', isActive);
        p.setAttribute('aria-pressed', String(isActive));
        if (isActive) {
          p.classList.add('bg-primary-text','border-primary-text','text-canvas');
          p.classList.remove('bg-card-bg','border-border','text-muted-text');
        } else {
          p.classList.remove('bg-primary-text','border-primary-text','text-canvas');
          p.classList.add('bg-card-bg','border-border','text-muted-text');
        }
      });
    }

    function setSourceActive(filter: string) {
      sourcePills.forEach(p => {
        const isActive = p.getAttribute('data-source-filter') === filter;
        p.classList.toggle('active', isActive);
        p.setAttribute('aria-pressed', String(isActive));
        if (isActive) {
          p.classList.add('bg-primary-text','border-primary-text','text-canvas');
          p.classList.remove('bg-card-bg','border-border','text-muted-text');
        } else {
          p.classList.remove('bg-primary-text','border-primary-text','text-canvas');
          p.classList.add('bg-card-bg','border-border','text-muted-text');
        }
      });
    }

    function matches(el: HTMLElement) {
      const tags = (el.getAttribute('data-tags') || '').split(' ');
      const sources = (el.getAttribute('data-sources') || '').split(' ');
      return (activePillar === 'all' || tags.includes(activePillar)) &&
             (activeSource === 'all' || sources.includes(activeSource));
    }

    function updateFilters() {
      let visible = 0;
      document.querySelectorAll('.signal-card').forEach(card => {
        const show = matches(card as HTMLElement);
        (card as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (featured) {
        const showFeatured = matches(featured);
        featured.style.display = showFeatured ? '' : 'none';
        if (showFeatured) visible++;
      }

      const anyActive = activePillar !== 'all' || activeSource !== 'all';
      if (clearBtn) clearBtn.hidden = !anyActive;
      const countEl = document.getElementById('filter-count');
      if (countEl) countEl.textContent = anyActive ? `${visible} shown` : '';
    }

    function persist() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ pillar: activePillar, source: activeSource }));
      } catch {}
      const params = new URLSearchParams();
      if (activePillar !== 'all') params.set('pillar', activePillar);
      if (activeSource !== 'all') params.set('source', activeSource);
      const hash = params.toString();
      history.replaceState(null, '', hash ? `#${hash}` : location.pathname + location.search);
    }

    function apply(pillar: string, source: string, save = true) {
      // Ignore persisted values that don't exist on this day
      activePillar = [...pillarPills].some(p => p.getAttribute('data-filter') === pillar) ? pillar : 'all';
      activeSource = [...sourcePills].some(p => p.getAttribute('data-source-filter') === source) ? source : 'all';
      setPillarActive(activePillar);
      setSourceActive(activeSource);
      updateFilters();
      if (save) persist();
    }

    function restore() {
      // URL hash wins (shareable link), then localStorage (sticky preference)
      const params = new URLSearchParams(location.hash.slice(1));
      let pillar = params.get('pillar');
      let source = params.get('source');
      if (!pillar && !source) {
        try {
          const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
          if (saved) { pillar = saved.pillar ?? null; source = saved.source ?? null; }
        } catch {}
      }
      apply(pillar ?? 'all', source ?? 'all', false);
    }

    pillarPills.forEach(pill => {
      pill.addEventListener('click', () => apply(pill.getAttribute('data-filter') || 'all', activeSource));
    });
    sourcePills.forEach(pill => {
      pill.addEventListener('click', () => apply(activePillar, pill.getAttribute('data-source-filter') || 'all'));
    });
    clearBtn?.addEventListener('click', () => apply('all', 'all'));

    restore();
  </script>

  <style>
    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Layout>
