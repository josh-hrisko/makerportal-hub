---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import { pillarMeta, fallbackPillar, sourceLabels } from '../../data/trends';
import type { TrendItem } from '../../data/trends';

const journals = await getCollection('journal');
// Sort journal entries by date (id) descending
const sortedJournals = journals.sort((a, b) => b.id.localeCompare(a.id));

const title = 'Signals Journal — Daily Trend Backlog | MakerPortal';
const description =
  'Persistent historical backlog of daily scans tracking public discussion on on-device AI, iOS platform craft, and DSP.';

const formatDate = (dateStr: string) => {
  return new Date(dateStr + 'T12:00:00Z').toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
};

const pillarOf = (tag: string) => pillarMeta[tag] ?? fallbackPillar;
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Learn · Signals Journal · Archive"
    title="Daily Signals Archive"
    lead="A persistent chronological backlog of automated scans tracking on-device AI, iOS platform craft, and DSP. Ephemeral trends, saved for permanent analysis."
    status="Journal"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/resources" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Resource hub</a>
        <a href="/blog" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Field notes</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border bg-canvas">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      {sortedJournals.length === 0 ? (
        <div class="rounded-[24px] border border-border bg-card-bg p-8 text-center">
          <p class="text-lg text-muted-text">No journal entries found. The daily scanning pipeline will populate this archive soon.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-10">
          {sortedJournals.map((entry) => {
            const dateStr = entry.id;
            const formattedDate = formatDate(dateStr);
            const items = entry.data.items as TrendItem[];
            // Sort to get top 3 signals for preview
            const topThree = [...items].sort((a, b) => b.score - a.score).slice(0, 3);
            
            // Gather all unique tags in this daily run
            const uniqueTags = [...new Set(items.flatMap(item => item.tags ?? []))].slice(0, 5);

            return (
              <article class="surface-card group overflow-hidden rounded-[24px] border border-border bg-card-bg p-6 transition-all hover:border-[var(--mp-border-strong)] hover:bg-elevated sm:p-8">
                <div class="flex flex-col gap-6 lg:flex-row lg:justify-between lg:items-start">
                  
                  {/* Left: Metadata & summary */}
                  <div class="flex-1">
                    <p class="font-mono text-[0.65rem] uppercase tracking-[0.14em] text-primary-cta">
                      {dateStr}
                    </p>
                    <h2 class="mt-2 text-2xl font-bold tracking-tight text-primary-text group-hover:text-primary-cta">
                      <a href={`/journal/${dateStr}`}>{formattedDate}</a>
                    </h2>
                    <p class="mt-2 text-[0.875rem] text-muted-text">
                      Tracked {items.length} signals across developer circles.
                    </p>
                    
                    {/* Tags row */}
                    {uniqueTags.length > 0 && (
                      <div class="mt-4 flex flex-wrap gap-2">
                        {uniqueTags.map(tag => {
                          const p = pillarOf(tag);
                          return (
                            <span 
                              class="inline-flex items-center gap-1.5 rounded-full border border-border bg-canvas px-2.5 py-0.5 font-mono text-[0.6rem] uppercase tracking-wider text-muted-text"
                            >
                              <span class="h-1.5 w-1.5 rounded-full" style={`background: ${p.color};`} />
                              {p.label}
                            </span>
                          );
                        })}
                      </div>
                    )}
                    
                    <div class="mt-6">
                      <a 
                        href={`/journal/${dateStr}`} 
                        class="inline-flex min-h-9 items-center rounded-full bg-elevated border border-border px-4 text-[0.8rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor"
                      >
                        View full daily report ({items.length} signals) →
                      </a>
                    </div>
                  </div>

                  {/* Right: Top 3 signals inline list */}
                  <div class="w-full border-t border-border pt-6 lg:w-[32rem] lg:border-t-0 lg:pt-0 lg:border-l lg:pl-8">
                    <h3 class="font-mono text-[0.65rem] uppercase tracking-[0.14em] text-muted-text mb-4">
                      Top Signals for this day
                    </h3>
                    <ul class="flex flex-col gap-4">
                      {topThree.map(item => (
                        <li class="flex items-start justify-between gap-4">
                          <div class="min-w-0">
                            <a 
                              href={item.url} 
                              target="_blank" 
                              rel="noopener noreferrer" 
                              class="text-[0.9rem] font-medium leading-[1.4] text-primary-text hover:text-primary-cta truncate block"
                            >
                              {item.title}
                            </a>
                            <span class="font-mono text-[0.58rem] text-muted-text uppercase tracking-wider">
                              {item.domain} · {(item.sources ?? [item.source]).map(s => sourceLabels[s]).join(' + ')}
                            </span>
                          </div>
                          <span class="flex-shrink-0 font-mono text-[0.7rem] bg-canvas border border-border px-2 py-0.5 rounded text-muted-text">
                            Score: {item.score}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </div>

                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Layout>
