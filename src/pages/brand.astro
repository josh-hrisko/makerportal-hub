            </div>
            <div class="rounded-2xl border border-muted-text/10 bg-canvas p-4">
              <div class="size-8 rounded-full bg-[#5C6E7A]"></div>
              <p class="mt-3 font-mono text-[0.68rem] text-white">Muted #5C6E7A</p>
            </div>
          </div>
        </div>

        <!-- Guidelines Summary -->
        <div>
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.2em] text-muted-text">Layout Specs</p>
          <div class="mt-6 rounded-2xl border border-muted-text/10 bg-canvas p-6 space-y-4 text-sm text-muted-text">
            <div>
              <span class="font-bold text-white block">Clearspace</span>
              A boundary of 0.5H (half height) must be kept clear around all wordmarks.
            </div>
            <div>
              <span class="font-bold text-white block">Minimum Sizes</span>
              16px for favicon, 32px height for wordmark legibility.
            </div>
            <div>
              <span class="font-bold text-white block">Mid-Card Dot & Lockup</span>
              <div class="mt-2 flex items-center gap-4">
                <BrandLogo variant="mp" size="sm" />
                <span class="text-xs">Three per-card crimson dots converge to the center period — the lockup dot slides from the wordmark into the icon core.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
