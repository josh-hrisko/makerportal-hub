---
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';
import AppSwitcher from '../components/AppSwitcher.astro';
import { apps } from '../data/apps';
import { legacyBridgeNote } from '../data/app-nav';

const title = 'About — MakerPortal Studio';
const description = `Independent San Francisco studio building ${apps.length} iOS apps — on-device ML where possible, agentic DSP with transparent cloud for AuraLinter. CoreML, Metal, ANE, LangGraph. No dark patterns.`;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://www.makerportal.ai/about' },
  ],
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>
  </Fragment>

  <HubShell
    kicker="Studio · San Francisco · est. 2023"
    title="Software with a point of view."
    lead="MakerPortal is an independent studio engineering iOS & iPadOS apps — on-device first where possible, agentic DSP with transparent cloud where needed. Small surface area. Craft over clutter."
    status="Studio"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/team" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Meet the team</a>
        <a href="/apps" class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-medium text-primary-text/80 hover:text-primary-text">App matrix ({apps.length}) →</a>
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-medium text-primary-text/80 hover:text-primary-text">Contact</a>
      </div>
    </Fragment>
  </HubShell>

  <!-- Studio ethos -->
  <section class="border-b border-border">
    <div class="mx-auto grid max-w-[88rem] gap-12 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[1.1fr_0.9fr] lg:px-10">
      <div>
        <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-[650] tracking-[-0.04em] text-primary-text">Studio</h2>
        <p class="mt-4 text-[0.98rem] leading-[1.75] text-muted-text">
          Independent software for people who care about latency and craft. Based in San Francisco; distribution worldwide. Now <strong class="font-semibold text-primary-text">{apps.length} apps</strong> live across <code class="rounded bg-elevated px-1.5 py-0.5 font-mono text-[0.8rem]">*.makerportal.ai</code> and legacy <code class="rounded bg-elevated px-1.5 py-0.5 font-mono text-[0.8rem]">makersportal.com/apps</code> — transparent migration, no hidden catalog.
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {[
            { k: `${apps.length} apps`, v: 'Live catalog' },
            { k: 'SF • Worldwide', v: 'Studio HQ' },
            { k: 'No dark patterns', v: 'Transparent' },
          ].map((s) => (
            <div class="rounded-[14px] border border-border bg-elevated/60 px-4 py-3">
              <div class="text-[0.95rem] font-semibold text-primary-text">{s.k}</div>
              <div class="mt-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">{s.v}</div>
            </div>
          ))}
        </div>
        <ul class="mt-8 flex flex-wrap gap-2 font-mono text-[0.68rem] uppercase tracking-[0.12em] text-muted-text">
          <li><a class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-3 py-1.5 hover:text-primary-text" href="https://github.com/makerportal" rel="me" target="_blank">GitHub ↗</a></li>
          <li><a class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-3 py-1.5 hover:text-primary-text" href="https://x.com/MakerPortal" rel="me" target="_blank">X ↗</a></li>
          <li><a class="inline-flex items-center gap-1 rounded-full border border-border bg-elevated px-3 py-1.5 hover:text-primary-text" href="https://makersportal.com" rel="me">Journal ↗</a></li>
        </ul>
      </div>
      <div>
        <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-[650] tracking-[-0.04em] text-primary-text">Principles</h2>
        <ol class="mt-4 space-y-5 text-[0.95rem] leading-[1.7] text-muted-text">
          <li class="flex gap-3">
            <span class="mt-1 size-1.5 shrink-0 rounded-full bg-primary-cta"></span>
            <span><strong class="text-primary-text">On-device first.</strong> Inference stays local. No cloud tax for intelligence features — ANE, CoreML, Metal, ONNX, llama.cpp.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 size-1.5 shrink-0 rounded-full bg-brand-anchor"></span>
            <span><strong class="text-primary-text">Ship small.</strong> Narrow products, strong opinions, deliberate releases. Agentic DSP, vocal engines, generative audio — each does one job well.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 size-1.5 shrink-0 rounded-full bg-emerald-500"></span>
            <span><strong class="text-primary-text">Human media.</strong> Notes, video, and tools that teach the craft — not surveillance growth hacks. Transparent bridge for legacy apps.</span>
          </li>
        </ol>
        <div class="mt-8 rounded-[14px] border border-border bg-elevated/60 px-4 py-3 text-[0.85rem] leading-[1.6] text-muted-text">
          <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-primary-text">Legacy bridge</span> — {legacyBridgeNote.message}
          <div class="mt-2">
            <a href={legacyBridgeNote.journalUrl} rel="noopener" class="font-medium text-brand-anchor hover:text-primary-text">Visit makersportal.com/apps ↗</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- App matrix bridge — frontier card -->
  <section class="border-b border-border bg-elevated/30">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="section-kicker">Application matrix / {String(apps.length).padStart(2,'0')} live</p>
          <h2 class="mt-3 text-[clamp(1.5rem,3vw,2rem)] font-[650] tracking-[-0.04em] text-primary-text">From DSP lab to BLE bridge — one studio.</h2>
          <p class="mt-3 max-w-xl text-[0.95rem] leading-[1.65] text-muted-text">New titles live on <code class="rounded bg-card-bg px-1.5 py-0.5 font-mono text-[0.8rem]">*.makerportal.ai</code>, legacy on <code class="rounded bg-card-bg px-1.5 py-0.5 font-mono text-[0.8rem]">makersportal.com/apps</code>. Same craft-first stack, transparent about cloud where used.</p>
        </div>
        <a href="/apps" class="inline-flex min-h-10 w-fit items-center gap-1.5 text-[0.875rem] font-medium text-brand-anchor hover:text-primary-text">Full matrix →</a>
      </div>

      <div class="mt-8">
        <AppSwitcher limit={11} showLegacyBadge title={`All ${apps.length} products`} />
      </div>
    </div>
  </section>

  <!-- Quick nav to pillars -->
  <section class="border-b border-border">
    <div class="mx-auto flex max-w-[88rem] flex-col gap-6 px-5 py-12 sm:flex-row sm:items-center sm:justify-between sm:px-8 lg:px-10">
      <div class="flex flex-wrap gap-3">
        <a href="/team" class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-4 text-[0.875rem] font-medium text-muted-text hover:text-primary-text">Team →</a>
        <a href="/blog" class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-4 text-[0.875rem] font-medium text-muted-text hover:text-primary-text">Field notes →</a>
        <a href="/contact" class="inline-flex min-h-10 items-center rounded-full bg-primary-text px-4 text-[0.875rem] font-bold text-canvas hover:opacity-90">Contact studio →</a>
      </div>
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">San Francisco · Remote • 11 live • Transparent • SF • Worldwide</p>
    </div>
  </section>
</Layout>
