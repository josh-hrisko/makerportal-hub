---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import AppCard from '../components/AppCard.astro';
import Layout from '../layouts/Layout.astro';
import { apps } from '../data/apps';
import BrandLogo from '../components/BrandLogo.astro';

const pageTitle = 'MakerPortal — iOS Studio | On-Device AI & Agentic DSP';
const pageDescription = 'San Francisco studio engineering iOS & iPadOS apps — on-device ML where possible, transparent hybrid for agentic DSP (AuraLinter). CoreML, Metal, ANE, LangGraph, no dark patterns.';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const directorySchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://www.makerportal.ai/#directory',
  name: 'MakerPortal Application Matrix — On-Device AI Apps for iOS',
  description: pageDescription,
  url: 'https://www.makerportal.ai',
  isPartOf: { '@id': 'https://www.makerportal.ai/#website' },
  about: {
    '@type': 'Thing',
    name: 'On-Device Machine Learning & Privacy-First Software',
    description: 'Apple Silicon native applications using CoreML, Neural Engine, Metal Performance Shaders, with zero data collection'
  },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: apps.length,
    itemListElement: apps.map((app, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'SoftwareApplication',
        '@id': `${app.url}#app`,
        name: app.title,
        description: app.description,
        applicationCategory: app.category,
        operatingSystem: app.platform,
        url: app.url,
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD', availability: 'https://schema.org/InStock' },
        featureList: app.techBadges.join(', '),
        publisher: { '@id': 'https://makersportal.com/#organization' },
        author: { '@id': 'https://makersportal.com/#organization' },
      },
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Why on-device AI instead of cloud?', acceptedAnswer: { '@type': 'Answer', text: 'On-device inference via Apple Neural Engine delivers 4-8ms latency vs 200-800ms cloud roundtrip, zero data leaves your device, and works offline. We use CoreML FP16 quantized models, Metal Performance Shaders, and vector embedding indexes that live entirely on iPhone/iPad.' } },
    { '@type': 'Question', name: 'What makes MakerPortal different from other iOS studios?', acceptedAnswer: { '@type': 'Answer', text: 'Small surface area, zero telemetry, Apple Silicon native from day one. No committees, no cloud dependencies, one deliberate release at a time. Built in San Francisco with craft over clutter.' } },
    { '@type': 'Question', name: 'Which apps are currently available?', acceptedAnswer: { '@type': 'Answer', text: apps.map(a => `${a.title}: ${a.tagline}`).join('; ') } },
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(directorySchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <link rel="preload" as="image" href={apps[0].iconSet.w128.src} imagesrcset={`${apps[0].iconSet.w64.src} 64w, ${apps[0].iconSet.w128.src} 128w`} />
  </Fragment>

  <!-- Hero – Frontier 2026: Spatial depth + text reveal + view transitions.
       Light mode: border-token, elevated from-token (not hardcoded #1A232E),
       hero ink = primary-text which flips dark↔light. Primary CTA button uses
       primary-text / canvas so it stays visible on both card and canvas. -->
  <section class="hero-grid relative isolate overflow-hidden border-b border-border bg-gradient-to-b from-elevated/40 to-canvas" aria-labelledby="hero-title">
    <!-- CLS fix: top offset uses vh (viewport-relative) instead of % (parent-relative) so web-font swap reflow of the
         hero heading cannot change this element's computed position — eliminates the 0.667 CLS regression. -->
    <!-- Soft auras via radial-gradient only (no filter:blur) — huge CSS blurs
         on ATF are a major iOS Safari paint cost and LCP render-delay driver. -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-20 bg-[radial-gradient(56rem_40rem_at_48%_-10vh,color-mix(in_srgb,var(--mp-cta)_9%,transparent),transparent_60%),radial-gradient(38rem_28rem_at_32%_12vh,color-mix(in_srgb,var(--mp-anchor)_10%,transparent),transparent_55%)]"></div>
    <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[radial-gradient(120%_70%_at_50%_0%,color-mix(in_srgb,var(--mp-text)_3%,transparent),transparent_60%)]"></div>
    
    <div class="mx-auto grid min-h-[calc(100svh-5rem)] max-w-[88rem] items-center gap-12 px-5 py-20 sm:px-8 lg:grid-cols-[1.08fr_0.92fr] lg:gap-6 lg:px-10 lg:py-24">
      <div class="relative z-10 max-w-[46rem] hero-fade-scroll">
        <div class="mb-7 flex flex-wrap items-center gap-2.5">
          <p class="group inline-flex items-center gap-2 rounded-full border border-primary-cta/20 bg-primary-cta/[0.10] px-3.5 py-1.5 font-mono text-[0.64rem] font-semibold uppercase tracking-[0.18em] text-primary-cta transition-colors hover:border-primary-cta/30">
            <span aria-hidden="true" class="signal-dot size-1.5 rounded-full bg-primary-cta"></span>
            Studio transmission • SF • 2026
          </p>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.66rem] font-medium uppercase tracking-[0.12em] text-muted-text">
            <span class="size-1 rounded-full bg-emerald-400"></span> Shipping
          </span>
        </div>

        <!-- No opacity-from-0 hero animation: LCP text must paint immediately.
             Underline still draws; motion-sensitive users get reduced-motion CSS. -->
        <h1 id="hero-title" class="text-balance text-[clamp(3.2rem,7.5vw,7.2rem)] font-[700] leading-[0.88] tracking-[-0.07em] text-primary-text">
          <span class="block">Software with</span>
          <span class="block">a point of <span class="relative inline-block text-primary-cta">view<span aria-hidden="true" class="absolute inset-x-0 bottom-[0.03em] h-[2px] origin-left scale-x-0 animate-[underline-draw_0.6s_0.35s_cubic-bezier(0.16,1,0.3,1)_forwards] bg-gradient-to-r from-primary-cta/0 via-primary-cta to-primary-cta/0"></span></span>.</span>
        </h1>
        
        <p class="mt-7 max-w-[34rem] text-pretty text-[1.05rem] leading-[1.75] text-muted-text sm:text-[1.15rem] sm:leading-[1.8]">
          Independent studio engineering <strong class="font-semibold text-primary-text">iOS & iPadOS</strong> apps — on-device ML where possible, agentic DSP with transparent cloud — <span class="text-brand-anchor font-medium">CoreML, Metal, ANE, LangGraph</span>. Crafted in San Francisco, shipped worldwide.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a href="/apps" class="group inline-flex min-h-11 items-center gap-2.5 rounded-full bg-primary-text px-5 text-[0.925rem] font-bold tracking-[-0.01em] text-canvas shadow-[0_4px_20px_rgba(0,0,0,0.12)] transition-[transform,background-color,box-shadow] duration-300 hover:scale-[1.02] hover:opacity-90">
            Enter app matrix
            <span aria-hidden="true" class="grid size-5 place-items-center rounded-full bg-canvas/70 text-primary-text transition-transform group-hover:translate-x-0.5">→</span>
          </a>
          <a href="/blog" class="group inline-flex min-h-11 items-center gap-1.5 rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium tracking-[-0.01em] text-muted-text transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated hover:text-primary-text">
            Field notes <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
          </a>
          <span class="hidden sm:inline-flex items-center gap-2 pl-3 font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text/70">
            <span class="h-px w-6 bg-border"></span> {String(apps.length).padStart(2,'0')} apps • {posts.length} notes • Transparent
          </span>
        </div>

        <!-- Micro-trust row – frontier social proof (cap 6 icons to avoid crowding with 11 live) -->
        <div class="mt-10 flex flex-wrap items-center gap-4 border-t border-border pt-6 text-[0.8rem] text-muted-text">
          <div class="flex -space-x-2">
            {apps.slice(0,6).map((app) => (
              <span class="grid size-7 place-items-center rounded-full border-2 border-canvas bg-card-bg shadow-sm">
                <Image src={app.iconSet.w64} alt="" width={20} height={20} class="size-5 rounded-full object-contain" loading="lazy" decoding="async" />
              </span>
            ))}
            {apps.length > 6 && (
              <span class="grid size-7 place-items-center rounded-full border-2 border-canvas bg-elevated text-[0.6rem] font-semibold text-muted-text">+{apps.length-6}</span>
            )}
          </div>
          <span class="leading-[1.4]">Trusted for <em class="not-italic text-primary-text/90 font-medium">craft-first</em> workflows — {apps.length} apps, on-device first, transparent where cloud is needed.</span>
        </div>
      </div>

      <!-- Orbit Visual – fixed CLS via contain + fixed size, optimized images.
           Light mode: orbit lines use border-border (visible on paper), center node bg-card-bg,
           orbit apps bg-card-bg with border-border + shadow token so they lift off canvas. -->
      <div class="relative mx-auto w-full max-w-[32rem] lg:mr-0 lg:max-w-[36rem]" role="group" aria-label={`${apps.length} applications in orbit — featured`}>
        <div class="orbit-stage relative mx-auto aspect-square w-full max-w-[min(100%,36rem)] overflow-visible">
          <div aria-hidden="true" class="orbit-line orbit-line-1 absolute inset-[9%] rounded-full border border-border"></div>
          <div aria-hidden="true" class="orbit-line orbit-line-2 absolute inset-[24%] rounded-full border border-dashed border-border"></div>
          
          <!-- Center node – card surface, brand border, no lens flare (glow removed 2026-07-13). Previously had blue 0 0 40px rgba glow that competed with App Grid. -->
          <div class="absolute inset-[35%] grid place-items-center rounded-full border border-border bg-card-bg shadow-sm">
            <div class="absolute inset-px rounded-full bg-gradient-to-b from-[color-mix(in_srgb,var(--mp-text)_6%,transparent)] to-transparent pointer-events-none"></div>
            <div class="relative text-center">
              <span class="mx-auto block size-12 sm:size-14 drop-shadow-lg" aria-hidden="true">
                <BrandLogo variant="icon" pulseOnView class="h-full w-full" />
              </span>
              <span class="mt-2 block font-mono text-[0.5rem] font-semibold uppercase tracking-[0.2em] text-muted-text">Build / Learn / Ship</span>
            </div>
          </div>

          <!-- Orbit apps – limited to 4 featured to keep CSS positions valid; all 11 live in grid below -->
          {apps.filter((a) => a.featured || ['AuraLinter','Biquadia','Thumb-Dash','Notiary'].includes(a.title)).slice(0,4).map((app, index) => (
            <a href={app.url} target="_blank" rel="noopener noreferrer" class={`orbit-app orbit-app-${index + 1} absolute grid size-[4.25rem] place-items-center rounded-[16px] border border-border bg-card-bg shadow-[0_8px_24px_rgba(0,0,0,0.14)] transition-[transform,border-color,box-shadow] duration-500 hover:scale-110 hover:border-brand-anchor/40 hover:shadow-[0_12px_32px_rgba(0,0,0,0.18)] focus-visible:scale-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-anchor sm:size-[4.75rem]`} aria-label={`Open ${app.title} — ${app.tagline}`}>
              <Image src={app.iconSet.w64} alt={`${app.title} icon`} width={52} height={52} densities={[1,2]} loading={index < 2 ? 'eager' : 'lazy'} decoding="async" class="size-[2.85rem] rounded-[12px] object-contain transition-transform duration-500 hover:rotate-[-3deg]" />
            </a>
          ))}

          <div aria-hidden="true" class="absolute bottom-[10%] left-[14%] hidden rounded-full border border-border bg-card-bg px-3 py-2 shadow-xl sm:flex">
            <span class="font-mono text-[0.55rem] uppercase tracking-[0.16em] text-muted-text">System</span>
            <span class="ml-2 inline-flex items-center gap-1.5 text-[0.75rem] font-semibold text-primary-text"><span class="signal-dot size-1.5 rounded-full bg-emerald-400"></span>{apps.length} live • ANE</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ticker – theme-aware elevated surface + canvas gradient fade -->
  <div class="relative overflow-hidden border-y border-border bg-elevated py-3.5">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,var(--mp-canvas)_0%,transparent_8%,transparent_92%,var(--mp-canvas)_100%)] z-10"></div>
    <p class="sr-only">Studio principles: on-device first, no committee software, useful on day one, craft over clutter, and one release at a time.</p>
    <div class="ticker-track flex w-max items-center whitespace-nowrap font-mono text-[0.66rem] font-bold uppercase tracking-[0.18em] text-muted-text motion-reduce:animate-none">
      {[0, 1].map(() => (
        <span aria-hidden="true" class="flex items-center">
          <span class="mx-6 inline-flex items-center gap-2"><span class="size-1 rounded-full bg-primary-cta"></span> On-device first</span><span class="text-muted-text/40">/</span>
          <span class="mx-6 inline-flex items-center gap-2"><span class="size-1 rounded-full bg-brand-anchor"></span> Agentic DSP</span><span class="text-muted-text/40">/</span>
          <span class="mx-6 inline-flex items-center gap-2"><span class="size-1 rounded-full bg-emerald-400"></span> Apple Silicon Native</span><span class="text-muted-text/40">/</span>
          <span class="mx-6 inline-flex items-center gap-2"><span class="size-1 rounded-full bg-violet-400"></span> Transparent • No dark patterns</span><span class="text-muted-text/40">/</span>
          <span class="mx-6">One deliberate release at a time</span><span class="text-primary-cta">✦</span>
        </span>
      ))}
    </div>
  </div>

  <!-- Apps Grid – semantic tokens, light visible borders + elevated meta -->
  <section id="apps" aria-labelledby="apps-title" class="scroll-mt-[5.5rem] border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
      <div class="grid gap-6 border-b border-border pb-10 md:grid-cols-[1.1fr_0.9fr] md:items-end">
        <div>
          <p class="section-kicker">Application matrix / {String(apps.length).padStart(2, '0')} live • On-device first • Hybrid where needed</p>
          <h2 id="apps-title" class="mt-4 max-w-3xl text-balance text-[clamp(2.4rem,5vw,3.75rem)] font-[650] leading-[0.92] tracking-[-0.05em] text-primary-text">Different problems.<br /><span class="text-muted-text">The same craft-first intelligence.</span></h2>
        </div>
        <div class="max-w-xl md:justify-self-end md:text-right">
          <p class="text-[0.95rem] leading-[1.7] text-muted-text">Most apps run natively on-device. AuraLinter uses transparent cloud for agentic DSP where needed — audio uploads with clear retention, SSE streaming, compiler-verified kernels. The studio is the connective craft.</p>
          <div class="mt-4 flex flex-wrap gap-1.5 md:justify-end">
            <span class="rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.66rem] font-medium uppercase tracking-[0.1em] text-muted-text">iOS 17+ • iPadOS 17+</span>
            <span class="rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[0.66rem] font-medium uppercase tracking-[0.1em] text-muted-text">Swift • Metal • CoreML</span>
          </div>
        </div>
      </div>

      <div class="mt-8 grid items-stretch gap-5 sm:gap-6 lg:gap-7 md:grid-cols-2">
        {apps.map((app) => (
          <AppCard {...app} class="md:col-span-1" />
        ))}
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-between gap-4 rounded-[20px] border border-border bg-elevated/60 px-5 py-4">
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.14em] text-muted-text">Products live on <strong class="text-primary-text">subdomains</strong> • Hub is the catalog • <strong class="text-primary-text">~9KB</strong> icons • No trackers</p>
        <div class="flex flex-wrap items-center gap-4">
          <a href="/apps" class="inline-flex items-center gap-1.5 text-[0.8rem] font-medium text-brand-anchor hover:text-primary-text">Full matrix →</a>
          <a href="https://github.com/makerportal" target="_blank" rel="me noopener noreferrer" class="inline-flex items-center gap-1.5 text-[0.8rem] font-medium text-muted-text hover:text-primary-text">Open source ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Dashboard – tokenized, light gets card surfaces -->
  <section class="relative border-b border-border bg-elevated/40" aria-labelledby="tech-title">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_60%_at_70%_40%,color-mix(in_srgb,var(--mp-anchor)_6%,transparent),transparent_60%)]"></div>
    <div class="mx-auto max-w-[88rem] px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="section-kicker">On-device infrastructure • Privacy architecture</p>
          <h2 id="tech-title" class="mt-4 text-balance text-[clamp(2rem,4vw,3rem)] font-[650] leading-[0.95] tracking-[-0.04em] text-primary-text">Engineered for Apple Silicon. No cloud tax.</h2>
          <p class="mt-5 text-[0.98rem] leading-[1.7] text-muted-text">
            We reject bloated cloud integrations. Every app is built natively using Swift, Metal shaders, and CoreML, utilizing the ANE hardware acceleration already in your pocket. Your data never leaves your device.
          </p>
          
          <ul class="mt-7 space-y-3 font-mono text-[0.76rem] leading-[1.5] text-muted-text">
            {[
              ['ANE 16-Core', '16-Core Neural Engine acceleration • 4.2ms median inference'],
              ['Local Vectors', 'Zero-latency vector embedding index • 28MB offline'],
              ['Private by Design', 'Private processing • No analytics SDKs • No cookies for AI features'],
            ].map(([k,v]) => (
              <li class="flex gap-3 rounded-xl border border-border bg-card-bg px-3 py-2.5">
                <span aria-hidden="true" class="mt-0.5 flex size-5 shrink-0 items-center justify-center rounded-full bg-emerald-500/15 text-emerald-600">✓</span>
                <span><strong class="text-primary-text font-semibold">{k}:</strong> {v}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 grid grid-cols-3 gap-3 text-center">
            {[{k:'<8ms', v:'P95 latency'}, {k:'0', v:'servers'}, {k:'100%', v:'offline capable'}].map((s) => (
              <div class="rounded-xl border border-border bg-card-bg px-3 py-3">
                <div class="text-lg font-bold tracking-tight text-primary-text">{s.k}</div>
                <div class="mt-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">{s.v}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="surface-card group relative animate-on-scroll rounded-[20px] border bg-card-bg p-5 font-mono text-[0.72rem] leading-[1.6] sm:p-6">
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
          <div class="flex items-center justify-between border-b border-border pb-3.5">
            <div class="flex items-center gap-1.5">
              <span class="size-3 rounded-full bg-[#FF5F56] shadow-[0_0_8px_rgba(255,95,86,0.4)]"></span>
              <span class="size-3 rounded-full bg-[#FFBD2E] shadow-[0_0_8px_rgba(255,189,46,0.4)]"></span>
              <span class="size-3 rounded-full bg-[#27C93F] shadow-[0_0_8px_rgba(39,201,63,0.4)]"></span>
            </div>
            <span class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">local-inference-monitor • v2.6 • ANE</span>
          </div>

          <div class="mt-5 space-y-4">
            {[
              { app:'AURALINTER • AGENTIC DSP', engine:'LangGraph + clang++ Verified + SSE', latency:'4 agents • ACTIVE', color:'text-primary-cta' },
              { app:'NYMIC • VOCAL ENGINE', engine:'kNN-VC • WavLM-Large • ONNX Runtime', latency:'22ms • READY', color:'text-amber-300' },
              { app:'BIQUADIA • SPECTRAL ENHANCER', engine:'CoreML FP16 Quantized • ANE', latency:'4.2ms • ACTIVE', color:'text-brand-anchor' },
              { app:'ITRIA • OFFLINE LLM', engine:'llama.cpp + Metal GPU • Local models', latency:'IDLE • Metal', color:'text-violet-300' },
            ].map((row) => (
              <div class="rounded-lg border border-border bg-canvas/70 px-3 py-2.5">
                <p class="font-semibold tracking-[-0.01em] text-primary-text">{row.app}</p>
                <div class="mt-1 flex flex-wrap items-center justify-between gap-2 text-muted-text">
                  <span>{row.engine}</span><span class:list={['font-semibold', row.color]}>{row.latency}</span>
                </div>
              </div>
            ))}
            <div class="flex items-center gap-2 pt-2 text-muted-text">
              <span class="text-brand-anchor">~</span><span class="text-primary-cta">❯</span><span class="inline-block h-3 w-1.5 animate-pulse bg-muted-text/60"></span><span class="font-mono text-[0.65rem]">11 live • privacy-first • no phoning home • legacy bridge → *.makerportal.ai</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Operating Principles – tokenized -->
  <section aria-labelledby="operating-title" class="relative overflow-hidden border-b border-border bg-canvas/40">
    <div aria-hidden="true" class="absolute -right-32 top-1/2 hidden size-[28rem] -translate-y-1/2 rounded-full border border-border lg:block"></div>
    <div class="mx-auto grid max-w-[88rem] gap-12 px-5 py-20 sm:px-8 sm:py-28 lg:grid-cols-[0.8fr_1.2fr] lg:px-10">
      <div class="lg:sticky lg:top-28 lg:self-start">
        <p class="section-kicker">Operating system • Studio ethos</p>
        <h2 id="operating-title" class="mt-4 text-balance text-[clamp(2rem,4vw,2.8rem)] font-[650] leading-[0.95] tracking-[-0.05em] text-primary-text">A studio built for momentum, not meetings.</h2>
        <p class="mt-5 max-w-md text-[0.95rem] leading-[1.7] text-muted-text">Small surface area. Direct feedback from real hands. Enough rigor to last, enough speed to stay alive. Craft over clutter.</p>
        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-border bg-elevated px-3 py-1.5 font-mono text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">
          <span class="size-1 rounded-full bg-muted-text/60"></span> est. 2023 • San Francisco
        </div>
      </div>

      <ol class="divide-y divide-border border-y border-border" role="list">
        {[
          { n:'01', k:'NOTICE', title:'Start with friction.', desc:'Find the repeated annoyance, the expert workflow, or the tiny moment everyone else decided was too small to deserve software. Thats where leverage lives.', c:'text-primary-cta' },
          { n:'02', k:'REDUCE', title:'Cut until the idea becomes obvious.', desc:'The best version is rarely the biggest. It is the one whose purpose survives every subtraction. Ship half the features, twice the craft.', c:'text-brand-anchor' },
          { n:'03', k:'SHIP', title:'Put it in real hands.', desc:'A shipped product teaches more than a perfect prototype. Release, listen, refine, repeat. Telemetry is conversation, not surveillance.', c:'text-muted-text' },
        ].map((step) => (
          <li class="group grid gap-4 py-7 sm:grid-cols-[5.5rem_1fr] sm:py-8">
            <span class:list={['font-mono text-[0.72rem] font-bold tracking-[0.12em]', step.c]}>{step.n} / {step.k}</span>
            <div><h3 class="text-[1.35rem] font-semibold tracking-[-0.02em] text-primary-text transition-colors">{step.title}</h3><p class="mt-2 max-w-[38rem] text-[0.95rem] leading-[1.7] text-muted-text">{step.desc}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Blog – semantic tokens -->
  <section aria-labelledby="notes-title" class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="section-kicker">Field notes • Building in public • on-device AI journal</p>
          <h2 id="notes-title" class="mt-4 text-[clamp(2rem,4vw,2.75rem)] font-[650] tracking-[-0.05em] text-primary-text">Thinking in public.</h2>
          <p class="mt-3 max-w-xl text-[0.95rem] leading-[1.6] text-muted-text">Short notes from inside the build — CoreML experiments, SwiftUI edge cases, Metal shader tricks, and the tiny decisions that make privacy-first software feel fast.</p>
        </div>
        <a href="/blog" class="group inline-flex min-h-10 w-fit items-center gap-1.5 rounded-full border border-border bg-elevated px-4 text-[0.875rem] font-medium text-brand-anchor transition-all hover:border-brand-anchor/30 hover:bg-brand-anchor/10">All field notes <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span></a>
      </div>

      <div class="mt-10 grid divide-y divide-border border-y border-border md:grid-cols-3 md:divide-x md:divide-y-0">
        {posts.map((post, index) => (
          <article class="group relative flex flex-col py-7 md:px-7 md:first:pl-0 md:last:pr-0">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Note {String(index + 1).padStart(2, '0')} • {post.data.readingTime} • {post.data.publishedAt.toLocaleDateString('en-US',{month:'short',day:'numeric'})}</p>
            <h3 class="mt-6 line-clamp-3 text-[1.35rem] font-semibold leading-[1.15] tracking-[-0.02em] text-primary-text transition-colors group-hover:text-primary-cta">{post.data.title}</h3>
            <p class="mt-3 line-clamp-3 text-[0.9rem] leading-[1.6] text-muted-text">{post.data.description}</p>
            <a href={`/blog/${post.id}`} aria-label={`Read: ${post.data.title}`} class="mt-auto inline-flex min-h-10 items-center pt-6 text-[0.875rem] font-semibold text-primary-text before:absolute before:inset-0 hover:text-primary-cta focus-visible:outline-none">Read note <span aria-hidden="true" class="ml-1.5 transition-transform group-hover:translate-x-1">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA – tokenized, light card distinct -->
  <section aria-labelledby="closing-title" class="relative isolate overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[radial-gradient(90%_70%_at_50%_120%,color-mix(in_srgb,var(--mp-cta)_12%,transparent),transparent_60%),radial-gradient(60%_50%_at_20%_30%,color-mix(in_srgb,var(--mp-anchor)_8%,transparent),transparent_60%)]"></div>
    <div class="mx-auto max-w-[88rem] px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
      <div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div>
          <p class="section-kicker">Next release is already moving • Agentic-first • Privacy-first</p>
          <h2 id="closing-title" class="mt-5 text-balance text-[clamp(2.8rem,6vw,5.5rem)] font-[750] leading-[0.9] tracking-[-0.06em] text-primary-text">Make the<br />thing you<br />wish existed.</h2>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact" class="group inline-flex min-h-11 items-center gap-2 rounded-full bg-primary-text px-5 text-[0.9rem] font-bold tracking-[-0.01em] text-canvas shadow-[0_4px_16px_rgba(0,0,0,0.10)] transition-all hover:scale-[1.02] hover:opacity-90">Get in touch <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span></a>
            <a href="/apps" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text transition-colors hover:border-[var(--mp-border-strong)] hover:text-primary-text">App matrix</a>
            <a href="https://makersportal.com" rel="me noopener" target="_blank" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text transition-colors hover:border-[var(--mp-border-strong)] hover:text-primary-text">Studio journal ↗</a>
          </div>
          <div class="mt-8 flex flex-wrap items-center gap-3 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-muted-text">
            <span class="inline-flex items-center gap-1.5"><span class="size-1 rounded-full bg-emerald-500"></span> No cookies for app functionality</span>
            <span class="hidden sm:inline h-3 w-px bg-border"></span>
            <span class="hidden sm:inline">llms.txt • sitemap • RSS • Open Graph</span>
          </div>
        </div>
        <aside class="surface-card rounded-[28px] border bg-card-bg p-7 sm:p-8">
          <p class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-primary-cta">Directory</p>
          <ul class="mt-5 space-y-3 text-[0.95rem]">
            <li><a href="/apps" class="group flex items-center justify-between rounded-xl border border-transparent px-3 py-2.5 text-muted-text transition-colors hover:border-border hover:bg-elevated hover:text-primary-text"><span>Application matrix</span><span aria-hidden="true" class="text-muted-text/60 transition-transform group-hover:translate-x-0.5">→</span></a></li>
            <li><a href="/blog" class="group flex items-center justify-between rounded-xl border border-transparent px-3 py-2.5 text-muted-text transition-colors hover:border-border hover:bg-elevated hover:text-primary-text"><span>Field notes</span><span aria-hidden="true" class="text-muted-text/60 transition-transform group-hover:translate-x-0.5">→</span></a></li>
            <li><a href="/contact" class="group flex items-center justify-between rounded-xl border border-transparent px-3 py-2.5 text-muted-text transition-colors hover:border-border hover:bg-elevated hover:text-primary-text"><span>Contact studio</span><span aria-hidden="true" class="text-muted-text/60 transition-transform group-hover:translate-x-0.5">→</span></a></li>
          </ul>
          <p class="mt-6 border-t border-border pt-5 font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Products · <span class="text-muted-text">*.makerportal.ai</span></p>
        </aside>
      </div>
    </div>
  </section>
</Layout>
