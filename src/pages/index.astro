---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import AppCard from '../components/AppCard.astro';
import Layout from '../layouts/Layout.astro';
import { apps } from '../data/apps';

const pageTitle = 'MakerPortal — Independent AI & iOS Software Studio';
const pageDescription = 'Building focused, privacy-first applications utilizing local neural networks, real-time DSP, and on-device machine learning.';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const directorySchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://www.makerportal.ai/#directory',
  name: 'MakerPortal Application Directory',
  description: pageDescription,
  url: 'https://www.makerportal.ai',
  isPartOf: { '@id': 'https://www.makerportal.ai/#website' },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: apps.length,
    itemListElement: apps.map((app, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'SoftwareApplication',
        name: app.title,
        description: app.description,
        url: app.url,
        applicationCategory: app.category,
        operatingSystem: app.platform,
        publisher: { '@id': 'https://makersportal.com/#organization' },
      },
    })),
  },
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(directorySchema)}></script>
  </Fragment>

  <!-- Hero Section -->
  <section class="hero-grid relative isolate overflow-hidden border-b border-muted-text/15" aria-labelledby="hero-title">
    <div aria-hidden="true" class="hero-aura absolute left-1/2 top-0 -z-20 h-[42rem] w-[58rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-cta/[0.06] blur-[150px]"></div>
    <div aria-hidden="true" class="hero-aura absolute left-1/3 top-12 -z-20 h-[30rem] w-[40rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-anchor/[0.1] blur-[130px]"></div>
    
    <div class="mx-auto grid min-h-[calc(100svh-4.75rem)] max-w-[88rem] items-center gap-14 px-5 py-20 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8 lg:px-10 lg:py-24">
      <div class="relative z-10 max-w-4xl">
        <div class="mb-8 flex flex-wrap items-center gap-3">
          <p class="inline-flex items-center gap-2 rounded-full border border-primary-cta/25 bg-primary-cta/[0.07] px-3 py-1.5 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-primary-cta animate-pulse">
            <span aria-hidden="true" class="signal-dot size-1.5 rounded-full bg-primary-cta"></span>
            Studio transmission / 2026
          </p>
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text">Los Angeles · Worldwide</span>
        </div>

        <h1 id="hero-title" class="text-balance text-[clamp(3.6rem,8vw,7.6rem)] font-semibold leading-[0.87] tracking-[-0.072em] text-white">
          Software with<br />a point of <span class="relative whitespace-nowrap text-primary-cta">view<span aria-hidden="true" class="absolute -right-4 top-0 size-2 rounded-full bg-brand-anchor animate-bounce"></span></span>.
        </h1>
        <p class="mt-9 max-w-2xl text-pretty text-lg leading-8 text-primary-text/90 sm:text-xl sm:leading-9">
          MakerPortal is an independent studio engineering iOS & iPadOS apps powered by private, on-device intelligence and high-performance neural computing.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="#apps" class="inline-flex min-h-12 items-center gap-3 rounded-full bg-primary-cta px-5 text-sm font-bold text-white transition duration-300 hover:scale-[1.02] hover:bg-primary-cta/90 shadow-md shadow-primary-cta/20 hover:shadow-primary-cta/35 motion-reduce:transition-none">
            Enter the app matrix
            <span aria-hidden="true">↓</span>
          </a>
          <a href="/blog" class="inline-flex min-h-12 items-center rounded-full border border-muted-text/30 px-5 text-sm font-semibold text-primary-text transition-colors hover:border-brand-anchor hover:text-brand-anchor hover:bg-brand-anchor/10">Read field notes</a>
        </div>
      </div>

      <!-- Hero Visual (Orbit Stage) -->
      <div class="relative mx-auto w-full max-w-[36rem] lg:mr-0" role="group" aria-label={`${apps.length} applications orbiting the MakerPortal studio`}>
        <div class="orbit-stage relative aspect-square">
          <div aria-hidden="true" class="orbit-line orbit-line-1 absolute inset-[8%] rounded-full border border-muted-text/15"></div>
          <div aria-hidden="true" class="orbit-line orbit-line-2 absolute inset-[23%] rounded-full border border-dashed border-muted-text/20"></div>
          <div class="absolute inset-[34%] grid place-items-center rounded-full border border-brand-anchor/35 bg-card-bg shadow-[0_0_90px_rgba(50,108,136,0.15)]">
            <div class="text-center">
              <span class="block text-4xl font-black tracking-[-0.08em] text-primary-cta sm:text-5xl">MP</span>
              <span class="mt-1 block font-mono text-[0.52rem] uppercase tracking-[0.2em] text-muted-text">Build / Learn / Ship</span>
            </div>
          </div>

          {apps.map((app, index) => (
            <a href={app.url} target="_blank" rel="noopener noreferrer" class={`orbit-app orbit-app-${index + 1} absolute grid size-[4.5rem] place-items-center rounded-2xl border border-muted-text/20 bg-card-bg shadow-2xl transition-transform hover:scale-110 hover:border-brand-anchor/50 focus:scale-110 motion-reduce:transition-none sm:size-20`} aria-label={`Open ${app.title} in a new tab`}>
              <Image src={app.icon} alt={`${app.title} application icon`} width={52} height={52} class="size-[3.25rem] rounded-xl transition duration-300 hover:rotate-3" />
            </a>
          ))}

          <div aria-hidden="true" class="absolute bottom-[12%] left-[17%] rounded-full border border-muted-text/20 bg-canvas/80 px-3 py-2 backdrop-blur-sm shadow-lg">
            <span class="font-mono text-[0.58rem] uppercase tracking-[0.17em] text-muted-text">System status</span>
            <span class="ml-2 inline-flex items-center gap-1.5 text-xs font-semibold text-white"><span class="signal-dot size-1.5 rounded-full bg-primary-cta"></span>Shipping</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat Ticker -->
  <div class="ticker overflow-hidden border-b border-muted-text/15 bg-card-bg py-4 text-primary-text">
    <p class="sr-only">Studio principles: on-device first, no committee software, useful on day one, craft over clutter, and one release at a time.</p>
    <div class="ticker-track flex w-max items-center whitespace-nowrap font-mono text-[0.67rem] font-bold uppercase tracking-[0.2em] motion-reduce:animate-none">
      {[0, 1].map(() => (
        <span aria-hidden="true" class="flex items-center">
          <span class="mx-7">On-device neural processing</span><span class="text-primary-cta">✦</span>
          <span class="mx-7">No cloud dependencies</span><span class="text-brand-anchor">✦</span>
          <span class="mx-7">Apple Silicon Native</span><span class="text-primary-cta">✦</span>
          <span class="mx-7">Zero Telemetry Privacy</span><span class="text-brand-anchor">✦</span>
          <span class="mx-7">One deliberate release at a time</span><span class="text-primary-cta">✦</span>
        </span>
      ))}
    </div>
  </div>

  <!-- Apps Grid -->
  <section id="apps" aria-labelledby="apps-title" class="scroll-mt-6 border-b border-muted-text/15">
    <div class="mx-auto max-w-[88rem] px-5 py-24 sm:px-8 sm:py-32 lg:px-10">
      <div class="grid gap-8 border-b border-muted-text/20 pb-10 md:grid-cols-[1fr_0.7fr] md:items-end">
        <div>
          <p class="section-kicker">Application matrix / {String(apps.length).padStart(2, '0')}</p>
          <h2 id="apps-title" class="mt-4 max-w-3xl text-balance text-4xl font-semibold leading-[0.96] tracking-[-0.05em] text-white sm:text-6xl">Different problems.<br /><span class="text-muted-text">The same local intelligence.</span></h2>
        </div>
        <p class="max-w-xl text-base leading-7 text-muted-text md:justify-self-end md:text-right">Every application runs natively on-device, leveraging local neural engines to protect privacy and eliminate latency. The studio is the craft connecting them.</p>
      </div>

      <div class="mt-8 grid items-stretch gap-5 md:grid-cols-2 lg:grid-cols-3">
        {apps.map((app) => <AppCard {...app} />)}
      </div>
    </div>
  </section>

  <!-- Technical Dashboard Section -->
  <section class="border-b border-muted-text/15 bg-canvas/30" aria-labelledby="tech-title">
    <div class="mx-auto max-w-[88rem] px-5 py-24 sm:px-8 sm:py-32 lg:px-10">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-center">
        <div>
          <p class="section-kicker">ON-DEVICE INFRASTRUCTURE</p>
          <h2 id="tech-title" class="mt-4 text-balance text-4xl font-semibold leading-tight tracking-[-0.04em] text-white sm:text-5xl">Engineered for Apple Silicon.</h2>
          <p class="mt-6 text-base leading-7 text-muted-text">
            We reject the trend of bloated cloud integrations. Our applications are built natively using Swift, Metal shaders, and CoreML, utilizing the hardware acceleration of your Apple device.
          </p>
          
          <ul class="mt-8 space-y-4 font-mono text-xs text-primary-text/90">
            <li class="flex items-center gap-3">
              <span aria-hidden="true" class="flex size-5 items-center justify-center rounded-full bg-primary-cta/15 text-primary-cta">✓</span>
              <span>16-Core Neural Engine (ANE) acceleration</span>
            </li>
            <li class="flex items-center gap-3">
              <span aria-hidden="true" class="flex size-5 items-center justify-center rounded-full bg-brand-anchor/15 text-brand-anchor">✓</span>
              <span>Zero-latency local vector embedding index</span>
            </li>
            <li class="flex items-center gap-3">
              <span aria-hidden="true" class="flex size-5 items-center justify-center rounded-full bg-primary-cta/15 text-primary-cta">✓</span>
              <span>Private processing: your data never leaves your device</span>
            </li>
          </ul>
        </div>

        <!-- Simulated Tech Terminal -->
        <div class="rounded-2xl border border-muted-text/25 bg-card-bg p-5 shadow-2xl font-mono text-xs sm:p-7">
          <div class="flex items-center justify-between border-b border-muted-text/20 pb-4">
            <div class="flex items-center gap-2">
              <span class="size-3 rounded-full bg-[#CE445D]/70"></span>
              <span class="size-3 rounded-full bg-[#326C88]/70"></span>
              <span class="size-3 rounded-full bg-[#5C6E7A]/70"></span>
            </div>
            <span class="text-[0.68rem] tracking-wider text-muted-text uppercase">local-inference-monitor // v2.6</span>
          </div>

          <div class="mt-6 space-y-4 text-muted-text">
            <div>
              <p class="text-white">// BIQUADIA SPECTRAL ENHANCER MODEL</p>
              <div class="mt-1 flex items-center justify-between">
                <span>Model Engine: CoreML (FP16 Quantized)</span>
                <span class="text-primary-cta">ACTIVE</span>
              </div>
              <div class="mt-1 flex items-center justify-between">
                <span>Hardware Target: Apple Neural Engine (ANE)</span>
                <span>Latency: 4.2ms</span>
              </div>
            </div>

            <div class="border-t border-muted-text/10 pt-4">
              <p class="text-white">// NOTIARY SEMANTIC EMBEDDINGS</p>
              <div class="mt-1 flex items-center justify-between">
                <span>Model Engine: MiniLM-L6-v2 Vectorizer</span>
                <span class="text-brand-anchor">IDLE</span>
              </div>
              <div class="mt-1 flex items-center justify-between">
                <span>Hardware Target: CoreML (Local CPU/GPU)</span>
                <span>Dim: 384 / Index: 28MB</span>
              </div>
            </div>

            <div class="border-t border-muted-text/10 pt-4">
              <p class="text-white">// POPCLOSET VISION CLASSIFIER</p>
              <div class="mt-1 flex items-center justify-between">
                <span>Model Engine: MobileNetV4 Outfit Parser</span>
                <span class="text-muted-text">READY</span>
              </div>
              <div class="mt-1 flex items-center justify-between">
                <span>Hardware Target: Metal Performance Shaders</span>
                <span>Latency: 8.5ms</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Operating Principles -->
  <section aria-labelledby="operating-title" class="relative overflow-hidden border-b border-muted-text/15 bg-canvas/40">
    <div aria-hidden="true" class="absolute -right-48 top-1/2 size-[38rem] -translate-y-1/2 rounded-full border border-muted-text/10"></div>
    <div class="mx-auto grid max-w-[88rem] gap-16 px-5 py-24 sm:px-8 sm:py-32 lg:grid-cols-[0.8fr_1.2fr] lg:px-10">
      <div>
        <p class="section-kicker">Operating system</p>
        <h2 id="operating-title" class="mt-4 text-balance text-4xl font-semibold leading-none tracking-[-0.05em] text-white sm:text-5xl">A studio built for momentum.</h2>
        <p class="mt-6 max-w-md leading-7 text-muted-text">Small surface area. Direct feedback. Enough rigor to last, enough speed to stay alive.</p>
      </div>

      <ol class="divide-y divide-muted-text/20 border-y border-muted-text/20">
        <li class="group grid gap-4 py-7 sm:grid-cols-[5rem_1fr] sm:py-9">
          <span class="font-mono text-xs text-primary-cta">01 / NOTICE</span>
          <div><h3 class="text-2xl font-semibold tracking-tight text-white">Start with friction.</h3><p class="mt-2 max-w-2xl leading-7 text-muted-text">Find the repeated annoyance, the expert workflow, or the tiny moment everyone else decided was too small.</p></div>
        </li>
        <li class="group grid gap-4 py-7 sm:grid-cols-[5rem_1fr] sm:py-9">
          <span class="font-mono text-xs text-brand-anchor">02 / REDUCE</span>
          <div><h3 class="text-2xl font-semibold tracking-tight text-white">Cut until the idea becomes obvious.</h3><p class="mt-2 max-w-2xl leading-7 text-muted-text">The best version is rarely the biggest. It is the one whose purpose survives every subtraction.</p></div>
        </li>
        <li class="group grid gap-4 py-7 sm:grid-cols-[5rem_1fr] sm:py-9">
          <span class="font-mono text-xs text-muted-text">03 / SHIP</span>
          <div><h3 class="text-2xl font-semibold tracking-tight text-white">Put it in real hands.</h3><p class="mt-2 max-w-2xl leading-7 text-muted-text">A shipped product teaches more than a perfect prototype. Release, listen, refine, repeat.</p></div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Blog/Field Notes Section -->
  <section aria-labelledby="notes-title" class="border-b border-muted-text/15">
    <div class="mx-auto max-w-[88rem] px-5 py-24 sm:px-8 sm:py-32 lg:px-10">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="section-kicker">Field notes / from inside the build</p>
          <h2 id="notes-title" class="mt-4 text-4xl font-semibold tracking-[-0.05em] text-white sm:text-5xl">Thinking in public.</h2>
        </div>
        <a href="/blog" class="inline-flex min-h-11 w-fit items-center gap-2 text-sm font-semibold text-brand-anchor hover:text-primary-cta transition-colors duration-200">All field notes <span aria-hidden="true">→</span></a>
      </div>

      <div class="mt-12 grid border-t border-muted-text/25 md:grid-cols-3">
        {posts.map((post, index) => (
          <article class="group relative border-b border-muted-text/20 py-8 md:border-b-0 md:border-r md:border-muted-text/20 md:px-7 md:first:pl-0 md:last:border-r-0 md:last:pr-0">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text">Note {String(index + 1).padStart(2, '0')} · {post.data.readingTime}</p>
            <h3 class="mt-8 text-2xl font-semibold leading-tight tracking-[-0.035em] text-white transition-colors group-hover:text-primary-cta">{post.data.title}</h3>
            <p class="mt-4 text-sm leading-6 text-muted-text">{post.data.description}</p>
            <a href={`/blog/${post.id}`} class="mt-8 inline-flex min-h-11 items-center text-sm font-semibold text-white before:absolute before:inset-0">Read note <span aria-hidden="true" class="ml-2 transition-transform group-hover:translate-x-1">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing Call To Action -->
  <section aria-labelledby="closing-title" class="relative isolate overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_110%,rgba(206,68,93,0.12),transparent_45%)]"></div>
    <div class="mx-auto max-w-[88rem] px-5 py-28 text-center sm:px-8 sm:py-40 lg:px-10">
      <p class="section-kicker">The next release is already moving</p>
      <h2 id="closing-title" class="mx-auto mt-5 max-w-5xl text-balance text-5xl font-semibold leading-[0.92] tracking-[-0.06em] text-white sm:text-7xl lg:text-8xl">Make the thing<br />you wish existed.</h2>
      <a href="https://makersportal.com" rel="me" class="mt-10 inline-flex min-h-12 items-center gap-3 rounded-full bg-primary-cta px-6 text-sm font-bold text-white transition duration-300 hover:scale-[1.02] hover:bg-primary-cta/90 shadow-md shadow-primary-cta/20 hover:shadow-primary-cta/35 motion-reduce:transition-none">Follow the studio journal <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</Layout>

