  }

  #modes-table tbody td {
    padding: 0.35rem 0.75rem;
    white-space: nowrap;
  }
  tr.row-axial {
    background: hsla(120, 40%, 50%, 0.06);
  }
  tr.row-tangential {
    background: hsla(40, 80%, 55%, 0.06);
  }
  tr.row-oblique {
    background: hsla(280, 40%, 50%, 0.06);
  }
  tr.row-highlight {
    box-shadow: inset 3px 0 0 var(--mp-cta);
  }
</style>

<script>
  import { roomModes, schroederFrequency, modePressure, speedOfSound } from '../../lib/acoustics.ts';

  interface RoomMode {
    nx: number;
    ny: number;
    nz: number;
    freq: number;
    type: 'axial' | 'tangential' | 'oblique';
  }

  function initRoomModes() {
    const root = document.getElementById('room-lx');
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const lxInput = document.getElementById('room-lx') as HTMLInputElement;
    const lyInput = document.getElementById('room-ly') as HTMLInputElement;
    const lzInput = document.getElementById('room-lz') as HTMLInputElement;
    const tempInput = document.getElementById('room-temp') as HTMLInputElement;
    const maxFreqInput = document.getElementById('max-freq') as HTMLInputElement;
    const listenerX = document.getElementById('listener-x') as HTMLInputElement;
    const listenerY = document.getElementById('listener-y') as HTMLInputElement;
    const listenerZ = document.getElementById('listener-z') as HTMLInputElement;
    const sourceX = document.getElementById('source-x') as HTMLInputElement;
    const sourceY = document.getElementById('source-y') as HTMLInputElement;
    const sourceZ = document.getElementById('source-z') as HTMLInputElement;
    const modeSelect = document.getElementById('mode-select') as HTMLSelectElement;
    const gridResSlider = document.getElementById('grid-res-slider') as HTMLInputElement;
    const gridResReadout = document.getElementById('grid-res-readout')!;
    const sliceZReadout = document.getElementById('slice-z-readout')!;
    const mapModeLabel = document.getElementById('map-mode-label')!;
    const tableNote = document.getElementById('table-note')!;
    const modesTbody = document.getElementById('modes-tbody')!;
    const pressureSvg = document.getElementById('pressure-svg')!;
    const lxReadout = document.getElementById('lx-readout')!;
    const lyReadout = document.getElementById('ly-readout')!;
    const lzReadout = document.getElementById('lz-readout')!;
    const tempReadout = document.getElementById('temp-readout')!;
    const maxfreqReadout = document.getElementById('maxfreq-readout')!;
    const listenerXReadout = document.getElementById('listener-x-readout')!;
    const listenerYReadout = document.getElementById('listener-y-readout')!;
    const listenerZReadout = document.getElementById('listener-z-readout')!;
    const sourceXReadout = document.getElementById('source-x-readout')!;
    const sourceYReadout = document.getElementById('source-y-readout')!;
    const sourceZReadout = document.getElementById('source-z-readout')!;
    const metricVolume = document.getElementById('metric-volume')!;
    const metricSA = document.getElementById('metric-sa')!;
    const metricEdges = document.getElementById('metric-edges')!;
    const metricC = document.getElementById('metric-c')!;
    const metricSchroeder = document.getElementById('metric-schroeder')!;
    const metricTotal = document.getElementById('metric-total')!;
    const metricAxial = document.getElementById('metric-axial')!;
    const metricTangential = document.getElementById('metric-tangential')!;
    const metricOblique = document.getElementById('metric-oblique')!;

    const MAX_TABLE_ROWS = 200;
    let modes: RoomMode[] = [];
    

    function readParams(): { Lx: number; Ly: number; Lz: number; tempC: number; maxFreq: number; listener: [number, number, number]; source: [number, number, number] } {
      const Lx = parseFloat(lxInput.value) || 5;
      const Ly = parseFloat(lyInput.value) || 4;
      const Lz = parseFloat(lzInput.value) || 2.8;
      const tempC = parseFloat(tempInput.value) || 20;
      const maxFreq = parseFloat(maxFreqInput.value) || 400;
      const lx = Math.min(Lx, parseFloat(listenerX.value) ?? Lx / 2);
      const ly = Math.min(Ly, parseFloat(listenerY.value) ?? Ly / 2);
      const lz = Math.min(Lz, parseFloat(listenerZ.value) ?? 1.2);
      const sx = Math.min(Lx, parseFloat(sourceX.value) ?? Lx * 0.25);
      const sy = Math.min(Ly, parseFloat(sourceY.value) ?? Ly * 0.25);
      const sz = Math.min(Lz, parseFloat(sourceZ.value) ?? Lz * 0.25);
      return { Lx, Ly, Lz, tempC, maxFreq, listener: [lx, ly, lz], source: [sx, sy, sz] };
    }

    function updateReadouts(p: ReturnType<typeof readParams>) {
      lxReadout.textContent = p.Lx.toFixed(1);
      lyReadout.textContent = p.Ly.toFixed(1);
      lzReadout.textContent = p.Lz.toFixed(2);
      tempReadout.textContent = String(p.tempC);
      maxfreqReadout.textContent = String(p.maxFreq);
      listenerXReadout.textContent = p.listener[0].toFixed(2);
      listenerYReadout.textContent = p.listener[1].toFixed(2);
      listenerZReadout.textContent = p.listener[2].toFixed(2);
      sourceXReadout.textContent = p.source[0].toFixed(2);
      sourceYReadout.textContent = p.source[1].toFixed(2);
      sourceZReadout.textContent = p.source[2].toFixed(2);
      sliceZReadout.textContent = p.listener[2].toFixed(2);

      listenerX.max = String(p.Lx);
      listenerY.max = String(p.Ly);
      listenerZ.max = String(p.Lz);
      sourceX.max = String(p.Lx);
      sourceY.max = String(p.Ly);
      sourceZ.max = String(p.Lz);
    }

    function clampVal(v: number, max: number) { return Math.min(max, Math.max(0, v)); }

    function recalculate() {
      const p = readParams();
      updateReadouts(p);

      const c = speedOfSound(p.tempC);
      const V = p.Lx * p.Ly * p.Lz;
      const S = 2 * (p.Lx * p.Ly + p.Lx * p.Lz + p.Ly * p.Lz);
      const totalEdge = 4 * (p.Lx + p.Ly + p.Lz);
      const avgAlpha = 0.15;
      const A = S * avgAlpha;
      const T60 = 0.161 * V / A;
      const fSchroeder = schroederFrequency(V, T60);

      modes = roomModes(p.Lx, p.Ly, p.Lz, c, p.maxFreq);

      const countAxial = modes.filter((m) => m.type === 'axial').length;
      const countTangential = modes.filter((m) => m.type === 'tangential').length;
      const countOblique = modes.filter((m) => m.type === 'oblique').length;

      metricVolume.textContent = `${V.toFixed(1)} m³`;
      metricSA.textContent = `${S.toFixed(1)} m²`;
      metricEdges.textContent = `${totalEdge.toFixed(1)} m`;
      metricC.textContent = `${c.toFixed(0)} m/s`;
      metricSchroeder.textContent = `${fSchroeder.toFixed(1)} Hz`;
      metricTotal.textContent = String(modes.length);
      metricAxial.textContent = String(countAxial);
      metricTangential.textContent = String(countTangential);
      metricOblique.textContent = String(countOblique);

      buildTable(p);
      buildModeDropdown();
      drawPressureMap(p);
    }

    function buildTable(p: ReturnType<typeof readParams>) {
      const [lx, ly, lz] = p.listener;
      const truncated = modes.length > MAX_TABLE_ROWS;
      const shown = truncated ? modes.slice(0, MAX_TABLE_ROWS) : modes;

      tableNote.textContent = truncated
        ? `Showing first ${MAX_TABLE_ROWS} of ${modes.length} modes (sorted by frequency). Increase max frequency to see more.`
        : `Showing all ${modes.length} modes sorted by frequency.`;

      const rows = shown.map((m, i) => {
        const pressure = modePressure(lx, ly, lz, p.Lx, p.Ly, p.Lz, m.nx, m.ny, m.nz);
        const highlightCls = Math.abs(pressure) > 0.5 ? ' row-highlight' : '';
        return `<tr class="row-${m.type}${highlightCls}">
          <td>${i + 1}</td>
          <td>${m.nx}</td>
          <td>${m.ny}</td>
          <td>${m.nz}</td>
          <td>${m.freq.toFixed(1)}</td>
          <td>${m.type}</td>
          <td>${pressure.toFixed(3)}</td>
        </tr>`;
      });

      if (truncated) {
        rows.push(`<tr class="text-muted-text text-[0.65rem]"><td colspan="7" class="px-3 py-2">… ${modes.length - MAX_TABLE_ROWS} more modes truncated (max ${MAX_TABLE_ROWS} rows shown).</td></tr>`);
      }

      modesTbody.innerHTML = rows.join('');
    }

    function buildModeDropdown() {
      const currentVal = modeSelect.value;
      modeSelect.innerHTML = modes.map((m, i) => {
        const label = `#${i + 1} — (${m.nx},${m.ny},${m.nz}) — ${m.freq.toFixed(1)} Hz [${m.type}]`;
        return `<option value="${i}">${label}</option>`;
      }).join('');
      if (modes.length > 0) {
        const prevIdx = parseInt(currentVal, 10);
        if (!isNaN(prevIdx) && prevIdx < modes.length) {
          modeSelect.value = String(prevIdx);
        } else {
          modeSelect.value = '0';
        }
      }
    }

    function drawPressureMap(p: ReturnType<typeof readParams>) {
      const idx = parseInt(modeSelect.value, 10);
      if (isNaN(idx) || idx < 0 || idx >= modes.length) {
        pressureSvg.innerHTML = '';
        mapModeLabel.textContent = 'Select a mode to display';
        return;
      }
      const mode = modes[idx];
      mapModeLabel.textContent = `Mode (${mode.nx},${mode.ny},${mode.nz}) — ${mode.freq.toFixed(1)} Hz — ${mode.type}`;

      const gridRes = parseInt(gridResSlider.value, 10) || 40;
      const svgW = 640;
      const svgH = 520;
      const margin = { top: 10, right: 120, bottom: 10, left: 10 };
      const plotW = svgW - margin.left - margin.right;
      const plotH = svgH - margin.top - margin.bottom;
      const scale = Math.min(plotW / p.Lx, plotH / p.Ly);
      const roomW = p.Lx * scale;
      const roomH = p.Ly * scale;
      const offX = margin.left + (plotW - roomW) / 2;
      const offY = margin.top + (plotH - roomH) / 2;

      const listenerZVal = p.listener[2];
      const cellW = roomW / gridRes;
      const cellH = roomH / gridRes;

      function pressureColor(val: number): string {
        const abs = Math.abs(val);
        const s = (abs * 100).toFixed(0);
        const l = (100 - abs * 35).toFixed(0);
        const h = val >= 0 ? 0 : 240;
        return `hsl(${h}, ${s}%, ${l}%)`;
      }

      const cells: string[] = [];
      for (let j = 0; j < gridRes; j++) {
        const y = (j + 0.5) * p.Ly / gridRes;
        for (let i = 0; i < gridRes; i++) {
          const x = (i + 0.5) * p.Lx / gridRes;
          const pr = modePressure(x, y, listenerZVal, p.Lx, p.Ly, p.Lz, mode.nx, mode.ny, mode.nz);
          const fill = pressureColor(pr);
          const sx = (offX + i * cellW).toFixed(2);
          const sy = (offY + j * cellH).toFixed(2);
          cells.push(`<rect x="${sx}" y="${sy}" width="${cellW.toFixed(2)}" height="${cellH.toFixed(2)}" fill="${fill}" stroke="rgba(255,255,255,0.04)" stroke-width="0.5"/>`);
        }
      }

      const roomRect = `<rect x="${offX.toFixed(2)}" y="${offY.toFixed(2)}" width="${roomW.toFixed(2)}" height="${roomH.toFixed(2)}" fill="none" stroke="var(--mp-border-strong)" stroke-width="2" rx="2"/>`;

      const lxScaled = offX + (p.listener[0] / p.Lx) * roomW;
      const lyScaled = offY + (p.listener[1] / p.Ly) * roomH;
      const sxScaled = offX + (p.source[0] / p.Lx) * roomW;
      const syScaled = offY + (p.source[1] / p.Ly) * roomH;

      const listenerDot = `<circle cx="${lxScaled.toFixed(2)}" cy="${lyScaled.toFixed(2)}" r="5" fill="none" stroke="var(--mp-text)" stroke-width="2"/><circle cx="${lxScaled.toFixed(2)}" cy="${lyScaled.toFixed(2)}" r="2" fill="var(--mp-text)"/>`;
      const sourceDot = `<circle cx="${sxScaled.toFixed(2)}" cy="${syScaled.toFixed(2)}" r="5" fill="none" stroke="var(--mp-cta)" stroke-width="2"/><circle cx="${sxScaled.toFixed(2)}" cy="${syScaled.toFixed(2)}" r="2" fill="var(--mp-cta)"/>`;

      const labelX = offX + roomW + 18;
      const cbX = offX + roomW + 30;
      const cbTop = offY;
      const cbH = roomH;
      const cbW = 16;

      const colorbarGradient = (() => {
        const id = 'cb-grad';
        const stops = [];
        for (let s = 0; s <= 20; s++) {
          const t = s / 20;
          const val = 1 - 2 * t;
          const v = (t * 100).toFixed(1);
          stops.push(`<stop offset="${v}%" stop-color="${pressureColor(val)}"/>`);
        }
        return `<defs><linearGradient id="${id}" x1="0" y1="1" x2="0" y2="0">${stops.join('')}</linearGradient></defs>
        <rect x="${cbX}" y="${cbTop.toFixed(2)}" width="${cbW}" height="${cbH.toFixed(2)}" fill="url(#${id})" rx="2"/>
        <text x="${cbX + cbW + 8}" y="${cbTop + 8}" fill="var(--mp-text)" font-size="11" font-family="ui-monospace, monospace">+1</text>
        <text x="${cbX + cbW + 8}" y="${cbTop + cbH - 4}" fill="var(--mp-text)" font-size="11" font-family="ui-monospace, monospace">−1</text>
        <text x="${cbX + cbW + 8}" y="${cbTop + cbH/2 + 4}" fill="var(--mp-text)" font-size="11" font-family="ui-monospace, monospace">0</text>`;
      })();

      const legendItems = [
        `<circle cx="${labelX + 8}" cy="${offY + roomH + 32}" r="4" fill="none" stroke="var(--mp-text)" stroke-width="1.5"/><text x="${labelX + 20}" y="${offY + roomH + 36}" fill="var(--mp-muted)" font-size="10" font-family="ui-monospace, monospace">Listener</text>`,
        `<circle cx="${labelX + 8}" cy="${offY + roomH + 52}" r="4" fill="none" stroke="var(--mp-cta)" stroke-width="1.5"/><text x="${labelX + 20}" y="${offY + roomH + 56}" fill="var(--mp-muted)" font-size="10" font-family="ui-monospace, monospace">Source</text>`,
        `<rect x="${labelX + 2}" y="${offY + roomH + 64}" width="12" height="12" fill="hsl(0, 100%, 65%)" rx="1"/><text x="${labelX + 20}" y="${offY + roomH + 74}" fill="var(--mp-muted)" font-size="10" font-family="ui-monospace, monospace">+ pressure</text>`,
        `<rect x="${labelX + 2}" y="${offY + roomH + 84}" width="12" height="12" fill="hsl(240, 100%, 65%)" rx="1"/><text x="${labelX + 20}" y="${offY + roomH + 94}" fill="var(--mp-muted)" font-size="10" font-family="ui-monospace, monospace">− pressure</text>`,
      ];

      const dimLabels = [
        `<text x="${offX + roomW/2}" y="${offY + roomH + 18}" fill="var(--mp-muted)" font-size="10" font-family="ui-monospace, monospace" text-anchor="middle">L<sub>x</sub> = ${p.Lx.toFixed(1)} m</text>`,
        `<text x="${offX - 8}" y="${offY + roomH/2}" fill="var(--mp-muted)" font-size="10" font-family="ui-monospace, monospace" text-anchor="end" transform="rotate(-90, ${offX - 8}, ${offY + roomH/2})">L<sub>y</sub> = ${p.Ly.toFixed(1)} m</text>`,
      ];

      pressureSvg.innerHTML = cells.join('') + colorbarGradient + roomRect + listenerDot + sourceDot + legendItems.join('') + dimLabels.join('');
    }

    function handleInput() {
      const p = readParams();
      const clampedLx = clampVal(parseFloat(listenerX.value) || p.Lx / 2, p.Lx);
      const clampedLy = clampVal(parseFloat(listenerY.value) || p.Ly / 2, p.Ly);
      const clampedLz = clampVal(parseFloat(listenerZ.value) || 1.2, p.Lz);
      const clampedSx = clampVal(parseFloat(sourceX.value) || p.Lx * 0.25, p.Lx);
      const clampedSy = clampVal(parseFloat(sourceY.value) || p.Ly * 0.25, p.Ly);
      const clampedSz = clampVal(parseFloat(sourceZ.value) || p.Lz * 0.25, p.Lz);
      listenerX.value = clampedLx.toFixed(2);
      listenerY.value = clampedLy.toFixed(2);
      listenerZ.value = clampedLz.toFixed(2);
      sourceX.value    = clampedSx.toFixed(2);
      sourceY.value    = clampedSy.toFixed(2);
      sourceZ.value    = clampedSz.toFixed(2);
      recalculate();
    }

    for (const el of [lxInput, lyInput, lzInput, tempInput, maxFreqInput, listenerX, listenerY, listenerZ, sourceX, sourceY, sourceZ]) {
      el.addEventListener('input', handleInput);
    }
    modeSelect.addEventListener('change', () => {
      const p = readParams();
      drawPressureMap(p);
    });
    gridResSlider.addEventListener('input', () => {
      gridResReadout.textContent = gridResSlider.value;
      const p = readParams();
      drawPressureMap(p);
    });

    handleInput();
  }

  document.addEventListener('astro:page-load', initRoomModes);
  initRoomModes();
</script>
