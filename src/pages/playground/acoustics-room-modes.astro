  .control-label select {
    grid-column: 1 / -1;
    width: 100%;
  }
  .metric-card,
  .math-card {
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--mp-elevated) 48%, transparent);
    padding: 0.85rem;
  }
  .metric-card dt,
  .math-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
