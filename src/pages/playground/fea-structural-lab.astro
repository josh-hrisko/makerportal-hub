@keyframes feashake{10%,90%{transform:translate(-1px,0)}20%,80%{transform:translate(2px,1px)}30%,50%,70%{transform:translate(-3px,-1px)}40%,60%{transform:translate(3px,2px)}}
</style>

<script>
// @ts-nocheck
function initFEA(){
  const meshCanvas=document.getElementById('mesh-canvas');
  const stressCanvas=document.getElementById('stress-canvas');
  const deformCanvas=document.getElementById('deform-canvas');
  if(!meshCanvas || meshCanvas.dataset.init) return;
  meshCanvas.dataset.init='1';
  const ctxMesh=meshCanvas.getContext('2d');
  const ctxStress=stressCanvas.getContext('2d');
  const ctxDeform=deformCanvas.getContext('2d');
  function setupHiDPI(c, ctx){
    const dpr=Math.min(window.devicePixelRatio||1,2);
    const Wc=c.width, Hc=c.height;
    c.width=Wc*dpr; c.height=Hc*dpr; c.style.width=Wc+'px'; c.style.height=Hc+'px';
    ctx.setTransform(dpr,0,0,dpr,0,0);
    return {W:Wc, H:Hc};
  }
  const dM=setupHiDPI(meshCanvas,ctxMesh);
  const dS=setupHiDPI(stressCanvas,ctxStress);
  const dD=setupHiDPI(deformCanvas,ctxDeform);

  // UI refs
  const selGeom=document.getElementById('sel-geom');
  const selPreset=document.getElementById('sel-preset');
  const slRes=document.getElementById('sl-res'), outRes=document.getElementById('out-res');
  const slThk=document.getElementById('sl-thk'), outThk=document.getElementById('out-thk');
  const slScale=document.getElementById('sl-scale'), outScale=document.getElementById('out-scale');
  const slLoad=document.getElementById('sl-load'), outLoad=document.getElementById('out-load');
  const slAng=document.getElementById('sl-ang'), outAng=document.getElementById('out-ang');
  const slAsec=document.getElementById('sl-Asec'), outAsec=document.getElementById('out-Asec');
  const inL=document.getElementById('in-L'), inH=document.getElementById('in-H');
  const inE=document.getElementById('in-E'), inNu=document.getElementById('in-nu'), inYield=document.getElementById('in-yield');
  const chkDisp=document.getElementById('chk-disp'), chkAudio=document.getElementById('chk-audio');
  const chkVec=document.getElementById('chk-vec'), chkWire=document.getElementById('chk-wire');
  const btnSolve=document.getElementById('btn-solve'), btnResetView=document.getElementById('btn-reset-view');
  const statusEl=document.getElementById('fea-status');
  const readK=document.getElementById('read-K'), readMesh=document.getElementById('read-mesh'), readUmax=document.getElementById('read-umax'), readSmax=document.getElementById('read-smax'), readUtil=document.getElementById('read-util'), readTime=document.getElementById('read-time');
  const flashOverlay=document.getElementById('flash-overlay'), viewportWrap=document.getElementById('viewport-wrap'), yieldBadge=document.getElementById('yield-badge');

  function updLabels(){
    outRes.textContent=slRes.value; outThk.textContent=Number(slThk.value).toFixed(1);
    outScale.textContent=slScale.value; outLoad.textContent=slLoad.value;
    outAng.textContent=slAng.value+'°'; outAsec.textContent=slAsec.value;
  }
  [slRes,slThk,slScale,slLoad,slAng,slAsec].forEach(el=>el.addEventListener('input',updLabels)); updLabels();

  const presets={
    PLA:{E:2.8, nu:0.33, y:50},
    ALU:{E:69, nu:0.33, y:240},
    STEEL:{E:200, nu:0.30, y:350},
  };
  selPreset.addEventListener('change',()=>{
    const p=presets[selPreset.value];
    if(p){ inE.value=p.E; inNu.value=p.nu; inYield.value=p.y; triggerSolve(); }
  });

  // Material helpers
  function getMat(){
    const E_GPa=parseFloat(inE.value)||69, nu=parseFloat(inNu.value)||0.33, sy_MPa=parseFloat(inYield.value)||240;
    return {E:E_GPa*1e9, nu, sy:sy_MPa*1e6, E_GPa, sy_MPa};
  }

  // Mesh generation
  function buildCantilever(nx, ny, Lmm, Hmm){
    const L=Lmm/1000, H=Hmm/1000;
    const nodes=[]; // {x,y,origX,origY}
    const nodeId=(ix,iy)=>iy*(nx+1)+ix;
    for(let iy=0; iy<=ny; iy++){
      const y= (iy/ny -0.5)*H;
      for(let ix=0; ix<=nx; ix++){
        const x= (ix/nx)*L;
        nodes.push({x,y,origX:x,origY:y, id:nodeId(ix,iy), fix: x<1e-9});
      }
    }
    const tris=[];
    for(let iy=0; iy<ny; iy++){
      for(let ix=0; ix<nx; ix++){
        const n0=nodeId(ix,iy), n1=nodeId(ix+1,iy), n2=nodeId(ix+1,iy+1), n3=nodeId(ix,iy+1);
        tris.push({n:[n0,n1,n3], type:'tri'});
        tris.push({n:[n1,n2,n3], type:'tri'});
      }
    }
    // load nodes: right edge middle
    const loadNodes=[];
    for(let iy=0; iy<=ny; iy++){
      const ix=nx;
      if(Math.abs( (iy/ny -0.5)*H ) < H*0.25 + 1e-6){
        loadNodes.push(nodeId(ix,iy));
      }
    }
    if(loadNodes.length===0) loadNodes.push(nodeId(nx,Math.floor(ny/2)));
    return {nodes, tris, loadNodes, L, H};
  }
  function buildPlateWithHole(nx, ny, Lmm, Hmm){
    const L=Lmm/1000, H=Hmm/1000;
    const R= 0.22* Math.min(L,H); // hole radius
    const cx=L*0.5, cy=0;
    const nodes=[];
    const nodeId=(ix,iy)=>iy*(nx+1)+ix;
    for(let iy=0; iy<=ny; iy++){
      const y=(iy/ny -0.5)*H;
      for(let ix=0; ix<=nx; ix++){
        const x=(ix/nx)*L;
        nodes.push({x,y,origX:x,origY:y, id:nodeId(ix,iy), fix:x<1e-9, holeInside:Math.hypot(x-cx,y-cy)<R*0.98});
      }
    }
    const tris=[];
    for(let iy=0; iy<ny; iy++){
      for(let ix=0; ix<nx; ix++){
        const n0=nodeId(ix,iy), n1=nodeId(ix+1,iy), n2=nodeId(ix+1,iy+1), n3=nodeId(ix,iy+1);
        const c1x=(nodes[n0].x+nodes[n1].x+nodes[n3].x)/3, c1y=(nodes[n0].y+nodes[n1].y+nodes[n3].y)/3;
        const c2x=(nodes[n1].x+nodes[n2].x+nodes[n3].x)/3, c2y=(nodes[n1].y+nodes[n2].y+nodes[n3].y)/3;
        if(Math.hypot(c1x-cx,c1y-cy) > R) tris.push({n:[n0,n1,n3], type:'tri'});
        if(Math.hypot(c2x-cx,c2y-cy) > R) tris.push({n:[n1,n2,n3], type:'tri'});
      }
    }
    const loadNodes=[];
    for(let iy=0; iy<=ny; iy++){
      const id=nodeId(nx,iy);
      if(!nodes[id].holeInside) loadNodes.push(id);
    }
    return {nodes, tris, loadNodes, L, H, hole:{cx,cy,R}};
  }
  function buildTruss(nxSeg, Lmm, Hmm){
    // simple warren truss: bottom chord length L, height H, nxSeg bays
    const L=Lmm/1000, H=Hmm/1000;
    const nodes=[];
    const bottom=[]; const top=[];
    for(let i=0;i<=nxSeg;i++){
      const x=(i/nxSeg)*L;
      bottom.push(nodes.length); nodes.push({x,y:-H/2,origX:x,origY:-H/2,id:nodes.length,fix:i===0||i===nxSeg});
      if(i<nxSeg){
        // top nodes offset half bay for warren? Use straight top chord with top count = nxSeg +1 for simplicity but with diagonal
        // We'll create top nodes at mid-bay? Simpler: top chord nodes at same x as bottom but y=+H/2 except triangular caps.
      }
    }
    // top chord nodes (nxSeg+1) at y=H/2
    const topStart=nodes.length;
    for(let i=0;i<=nxSeg;i++){
      const x=(i/nxSeg)*L;
      top.push(nodes.length); nodes.push({x,y:H/2,origX:x,origY:H/2,id:nodes.length,fix:false});
    }
    const bars=[];
    // bottom chord
    for(let i=0;i<nxSeg;i++) bars.push({n:[bottom[i], bottom[i+1]], type:'bar'});
    // top chord
    for(let i=0;i<nxSeg;i++) bars.push({n:[top[i], top[i+1]], type:'bar'});
    // verticals
    for(let i=0;i<=nxSeg;i++) bars.push({n:[bottom[i], top[i]], type:'bar'});
    // diagonals warren
    for(let i=0;i<nxSeg;i++){
      bars.push({n:[bottom[i], top[i+1]], type:'bar'});
      if(i<nxSeg-0) bars.push({n:[top[i], bottom[i+1]], type:'bar'});
    }
    // load at top middle
    const mid=Math.floor(nxSeg/2);
    const loadNodes=[top[mid]];
    // fix bottom ends fully (already)
    nodes.forEach(nd=>{ nd.isBottomFix = bottom.includes(nd.id); });
    return {nodes, tris:bars, loadNodes, L, H, bottom, top};
  }

  // Math helpers
  function transpose(M){ const r=M.length, c=M[0].length; const T=Array(c).fill(0).map(()=>Array(r)); for(let i=0;i<r;i++) for(let j=0;j<c;j++) T[j][i]=M[i][j]; return T; }
  function mul(A,B){
    const r=A.length, k=A[0].length, c=B[0].length;
    const C=Array(r).fill(0).map(()=>Array(c).fill(0));
    for(let i=0;i<r;i++) for(let j=0;j<c;j++){ let s=0; for(let t=0;t<k;t++) s+=A[i][t]*B[t][j]; C[i][j]=s; }
    return C;
  }
  function mulScalar(A,s){ return A.map(row=>row.map(v=>v*s)); }

  function cstKe(x1,y1,x2,y2,x3,y3, E, nu, t){
    const det=(x2-x1)*(y3-y1)-(x3-x1)*(y2-y1);
    const A=0.5*Math.abs(det)+1e-12;
    if(Math.abs(det)<1e-12) return {Ke:Array(6).fill(0).map(()=>Array(6).fill(0)), B:null, D:null, A};
    const b1=y2-y3, b2=y3-y1, b3=y1-y2;
    const c1=x3-x2, c2=x1-x3, c3=x2-x1;
    const inv2A=1/(2*A);
    const B=[
      [b1*inv2A, 0,        b2*inv2A, 0,        b3*inv2A, 0       ],
      [0,        c1*inv2A, 0,        c2*inv2A, 0,        c3*inv2A],
      [c1*inv2A, b1*inv2A, c2*inv2A, b2*inv2A, c3*inv2A, b3*inv2A]
    ];
    const eFac=E/(1-nu*nu);
    const D=[[eFac, eFac*nu, 0],[eFac*nu, eFac, 0],[0,0,eFac*(1-nu)/2]];
    const Bt=transpose(B);
    const DB=mul(D,B);
    const BtDB=mul(Bt,DB);
    const Ke=mulScalar(BtDB, t*A);
    return {Ke,B,D,A,det};
  }
  function barKe(x1,y1,x2,y2,E,Asec){
    const dx=x2-x1, dy=y2-y1, L=Math.hypot(dx,dy)||1e-9;
    const cx=dx/L, cy=dy/L;
    const k=E*Asec/L;
    const Ke=[
      [ k*cx*cx,  k*cx*cy, -k*cx*cx, -k*cx*cy],
      [ k*cx*cy,  k*cy*cy, -k*cx*cy, -k*cy*cy],
      [-k*cx*cx, -k*cx*cy,  k*cx*cx,  k*cx*cy],
      [-k*cx*cy, -k*cy*cy,  k*cx*cy,  k*cy*cy]
    ];
    return {Ke, L, cx, cy};
  }
  function solveLinear(K,F){
    const n=F.length;
    const A=K.map(r=>r.slice());
    const b=F.slice();
    for(let i=0;i<n;i++){
      let maxRow=i, maxV=Math.abs(A[i][i]);
      for(let r=i+1;r<n;r++) if(Math.abs(A[r][i])>maxV){maxV=Math.abs(A[r][i]); maxRow=r;}
      if(maxV<1e-12) continue;
      if(maxRow!==i){ const tmp=A[i]; A[i]=A[maxRow]; A[maxRow]=tmp; const tb=b[i]; b[i]=b[maxRow]; b[maxRow]=tb; }
      const piv=A[i][i];
      for(let r=i+1;r<n;r++){
        const f=A[r][i]/piv;
        if(Math.abs(f)<1e-14) continue;
        for(let c=i;c<n;c++) A[r][c]-=f*A[i][c];
        b[r]-=f*b[i];
      }
    }
    const x=new Array(n).fill(0);
    for(let i=n-1;i>=0;i--){
      let s=b[i];
      for(let j=i+1;j<n;j++) s-=A[i][j]*x[j];
      x[i]= Math.abs(A[i][i])<1e-12 ? 0 : s/A[i][i];
    }
    return x;
  }

  // Solver wrapper
  let lastResult=null; // {nodes, elems, U, stresses, maxU, maxS}
  function assembleAndSolve(){
    const t0=performance.now();
    const nx=parseInt(slRes.value,10);
    const ny=Math.max(2, Math.round(nx*0.45));
    const Lmm=parseFloat(inL.value)||120;
    const Hmm=parseFloat(inH.value)||30;
    const tmm=parseFloat(slThk.value)||6;
    const t=tmm/1000;
    const Fmag=parseFloat(slLoad.value)||500;
    const angDeg=parseFloat(slAng.value)||-90;
    const ang=angDeg*Math.PI/180;
    const Asecmm2=parseFloat(slAsec.value)||25;
    const Asec=Asecmm2*1e-6;
    const mat=getMat();
    const geom=selGeom.value;

    let mesh;
    if(geom==='cantilever') mesh=buildCantilever(nx,ny,Lmm,Hmm);
    else if(geom==='plate-hole') mesh=buildPlateWithHole(nx,ny,Lmm,Hmm);
    else mesh=buildTruss(nx,Lmm,Hmm);

    const nodes=mesh.nodes;
    const elems=mesh.tris;
    const N=nodes.length;
    const ndof=2*N;
    // global K dense
    let K=Array(ndof).fill(0).map(()=>Array(ndof).fill(0));
    const elemData=[]; // per elem store B,D etc for stress

    for(let ei=0; ei<elems.length; ei++){
      const el=elems[ei];
      if(el.type==='tri'){
        const n0=nodes[el.n[0]], n1=nodes[el.n[1]], n2=nodes[el.n[2]];
        if(n0.holeInside||n1.holeInside||n2.holeInside) continue;
        const {Ke,B,D,A:Ar,det}=cstKe(n0.x,n0.y,n1.x,n1.y,n2.x,n2.y, mat.E, mat.nu, t);
        const map=[el.n[0]*2, el.n[0]*2+1, el.n[1]*2, el.n[1]*2+1, el.n[2]*2, el.n[2]*2+1];
        for(let a=0;a<6;a++) for(let b=0;b<6;b++) K[map[a]][map[b]]+=Ke[a][b];
        elemData.push({type:'tri', n:el.n.slice(), B,D, A:Ar, det});
      } else {
        const n0=nodes[el.n[0]], n1=nodes[el.n[1]];
        const {Ke,L,cx,cy}=barKe(n0.x,n0.y,n1.x,n1.y, mat.E, Asec);
        const map=[el.n[0]*2, el.n[0]*2+1, el.n[1]*2, el.n[1]*2+1];
        for(let a=0;a<4;a++) for(let b=0;b<4;b++) K[map[a]][map[b]]+=Ke[a][b];
        elemData.push({type:'bar', n:el.n.slice(), L,cx,cy, Asec});
      }
    }
    // Force vector
    const Fvec=Array(ndof).fill(0);
    const loadNodes=mesh.loadNodes||[];
    const nLoad=loadNodes.length||1;
    const fxPer=Fmag*Math.cos(ang)/nLoad;
    const fyPer=Fmag*Math.sin(ang)/nLoad;
    loadNodes.forEach(id=>{
      Fvec[id*2]+=fxPer;
      Fvec[id*2+1]+=fyPer;
    });

    // fixed DOFs
    const fixed=new Set();
    nodes.forEach(nd=>{
      if(nd.fix || nd.isBottomFix){
        fixed.add(nd.id*2); fixed.add(nd.id*2+1);
      } else if(geom!=='truss' && nd.origX<1e-9){
        // for cantilever & plate, left edge clamp
        fixed.add(nd.id*2); fixed.add(nd.id*2+1);
      }
    });
    // truss: also bottom fixes already, but we want only two bottom nodes fully fixed, others free; our buildTruss marks two bottom nodes fix.
    if(geom==='truss'){
      // clear then add only two nodes fixed
      fixed.clear();
      (mesh.bottom||[]).forEach((_,idx,arr)=>{
        if(idx===0||idx===arr.length-1){
          const nid=mesh.bottom[idx];
          fixed.add(nid*2); fixed.add(nid*2+1);
        }
      });
    }

    const free=[]; const freeMap=new Map();
    for(let i=0;i<ndof;i++) if(!fixed.has(i)){ freeMap.set(i, free.length); free.push(i); }

    const nFree=free.length;
    const Kff=Array(nFree).fill(0).map(()=>Array(nFree).fill(0));
    const Ff=Array(nFree).fill(0);
    for(let i=0;i<nFree;i++){
      const gi=free[i];
      Ff[i]=Fvec[gi];
      for(let j=0;j<nFree;j++){
        const gj=free[j];
        Kff[i][j]=K[gi][gj];
      }
    }
    const uf = nFree>0 ? solveLinear(Kff,Ff) : [];
    const U=Array(ndof).fill(0);
    for(let i=0;i<nFree;i++) U[free[i]]=uf[i];

    // stresses
    const stresses=[]; let maxS=0, maxU=0;
    for(let i=0;i<N;i++){
      const ux=U[i*2], uy=U[i*2+1];
      const um=Math.hypot(ux,uy); if(um>maxU) maxU=um;
    }
    elemData.forEach(ed=>{
      if(ed.type==='tri'){
        const ue=[
          U[ed.n[0]*2], U[ed.n[0]*2+1],
          U[ed.n[1]*2], U[ed.n[1]*2+1],
          U[ed.n[2]*2], U[ed.n[2]*2+1]
        ];
        // eps = B*ue
        const eps=[0,0,0];
        for(let r=0;r<3;r++){ let s=0; for(let c=0;c<6;c++) s+=ed.B[r][c]*ue[c]; eps[r]=s; }
        const sx=ed.D[0][0]*eps[0]+ed.D[0][1]*eps[1];
        const sy=ed.D[1][0]*eps[0]+ed.D[1][1]*eps[1];
        const txy=ed.D[2][2]*eps[2];
        const vm=Math.sqrt(sx*sx - sx*sy + sy*sy + 3*txy*txy);
        stresses.push({vm,sx,sy,txy,type:'tri'});
        if(vm>maxS) maxS=vm;
      } else {
        const u0x=U[ed.n[0]*2], u0y=U[ed.n[0]*2+1], u1x=U[ed.n[1]*2], u1y=U[ed.n[1]*2+1];
        const dux=u1x-u0x, duy=u1y-u0y;
        const elong=dux*ed.cx + duy*ed.cy;
        const strain=elong/ed.L;
        const sigma=mat.E*strain;
        const vm=Math.abs(sigma);
        stresses.push({vm,sx:sigma,sy:0,txy:0,type:'bar', strain});
        if(vm>maxS) maxS=vm;
      }
    });

    const t1=performance.now();
    return {nodes,elems:elemData,origElems:elems, U, stresses, maxU, maxS, Ksize:ndof, nNodes:N, nElems:elems.length, time:t1-t0, L:mesh.L, H:mesh.H, hole:mesh.hole, loadNodes, mat};
  }

  // Colors: HSL 240->0 mapping
  function stressToColor(norm){
    norm=Math.max(0,Math.min(1,norm));
    // pow for emphasis
    const nPow=Math.pow(norm,0.85);
    const hue=240*(1-nPow); // 240 blue to 0 red
    // slightly desat low
    const sat= 85 + 15*nPow;
    const lig= 50 + (norm>0.5? -10*norm : 10*(1-norm));
    return `hsl(${hue.toFixed(1)} ${sat}% ${lig}%)`;
  }

  // Drawing transforms: map physical coords to canvas
  function getBounds(res){
    // use L,H from result, pad
    const margin=18;
    const Wp=res.W||200, Hp=res.H||200;
    const L=res.L||0.12, H=res.H||0.03;
    // choose scale to fit beam centered
    const scale = Math.min((Wp-margin*2)/ (L*1.25), (Hp-margin*2)/(H*1.6));
    const ox = margin + 8;
    const oy = Hp/2;
    return {scale, ox, oy};
  }
  function worldToCanvas(x,y, bounds){
    // y inverted: + up = - screen
    return {cx: bounds.ox + x*bounds.scale, cy: bounds.oy - y*bounds.scale};
  }

  function drawMesh(res){
    const ctx=ctxMesh; const {W,H}=dM;
    ctx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    if(!res) return;
    const b=getBounds({W,H,L:res.L,H:res.H});
    // hole circle for plate
    if(res.hole){
      const cc=worldToCanvas(res.hole.cx,res.hole.cy,b);
      const r=res.hole.R*b.scale;
      ctx.fillStyle='rgba(255,255,255,0.06)'; ctx.beginPath(); ctx.arc(cc.cx,cc.cy,r,0,Math.PI*2); ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.12)'; ctx.stroke();
    }
    // draw tris wire
    ctx.lineWidth=1;
    res.origElems.forEach(el=>{
      if(el.type==='tri'){
        const n0=res.nodes[el.n[0]], n1=res.nodes[el.n[1]], n2=res.nodes[el.n[2]];
        if(n0.holeInside||n1.holeInside||n2.holeInside) return;
        const p0=worldToCanvas(n0.x,n0.y,b), p1=worldToCanvas(n1.x,n1.y,b), p2=worldToCanvas(n2.x,n2.y,b);
        ctx.strokeStyle='rgba(255,255,255,0.18)';
        ctx.beginPath(); ctx.moveTo(p0.cx,p0.cy); ctx.lineTo(p1.cx,p1.cy); ctx.lineTo(p2.cx,p2.cy); ctx.closePath(); ctx.stroke();
      } else {
        const n0=res.nodes[el.n[0]], n1=res.nodes[el.n[1]];
        const p0=worldToCanvas(n0.x,n0.y,b), p1=worldToCanvas(n1.x,n1.y,b);
        ctx.strokeStyle='rgba(180,210,255,0.45)'; ctx.lineWidth=1.2; ctx.beginPath(); ctx.moveTo(p0.cx,p0.cy); ctx.lineTo(p1.cx,p1.cy); ctx.stroke(); ctx.lineWidth=1;
      }
    });
    // nodes: fixed squares
    res.nodes.forEach(nd=>{
      if(nd.holeInside) return;
      const p=worldToCanvas(nd.x,nd.y,b);
      const isFix= (res.nodes[nd.id].fix || (nd.isBottomFix && (nd.id===res.nodes[0].id || true))) && (nd.fix||nd.isBottomFix);
      // draw small dot
      if(nd.fix){
        ctx.fillStyle='#f07a94'; ctx.fillRect(p.cx-3,p.cy-3,6,6);
      } else if(nd.isBottomFix){
        // handled fixed set still
      } else {
        ctx.fillStyle='rgba(255,255,255,0.55)'; ctx.beginPath(); ctx.arc(p.cx,p.cy,1.6,0,Math.PI*2); ctx.fill();
      }
    });
    // load arrows
    (res.loadNodes||[]).forEach(id=>{
      const nd=res.nodes[id];
      const p=worldToCanvas(nd.x,nd.y,b);
      const ang=parseFloat(slAng.value)*Math.PI/180;
      const len=18;
      ctx.strokeStyle='#4ade80'; ctx.lineWidth=1.8;
      ctx.beginPath(); ctx.moveTo(p.cx,p.cy); ctx.lineTo(p.cx+Math.cos(ang)*len, p.cy - Math.sin(ang)*len); ctx.stroke();
      // arrow head
      const ahx=p.cx+Math.cos(ang)*len, ahy=p.cy - Math.sin(ang)*len;
      ctx.fillStyle='#4ade80'; ctx.beginPath(); ctx.arc(ahx,ahy,2.5,0,Math.PI*2); ctx.fill();
    });
  }

  function drawStress(res){
    const ctx=ctxStress; const {W,H}=dS;
    ctx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    if(!res) return;
    const b=getBounds({W,H,L:res.L,H:res.H});
    const maxS=res.maxS||1e6;
    // draw each elem filled by stress color
    res.elems.forEach((ed, idx)=>{
      const vm=res.stresses[idx]?.vm||0;
      const norm = maxS>1e-9 ? vm/maxS : 0;
      ctx.fillStyle=stressToColor(norm);
      if(ed.type==='tri'){
        const n0=res.nodes[ed.n[0]], n1=res.nodes[ed.n[1]], n2=res.nodes[ed.n[2]];
        const p0=worldToCanvas(n0.x,n0.y,b), p1=worldToCanvas(n1.x,n1.y,b), p2=worldToCanvas(n2.x,n2.y,b);
        ctx.beginPath(); ctx.moveTo(p0.cx,p0.cy); ctx.lineTo(p1.cx,p1.cy); ctx.lineTo(p2.cx,p2.cy); ctx.closePath(); ctx.fill();
        // outline subtly
        if(norm>0.9){ ctx.strokeStyle='rgba(255,40,40,0.8)'; ctx.lineWidth=1.2; ctx.stroke();}
      } else {
        const n0=res.nodes[ed.n[0]], n1=res.nodes[ed.n[1]];
        const p0=worldToCanvas(n0.x,n0.y,b), p1=worldToCanvas(n1.x,n1.y,b);
        ctx.strokeStyle=stressToColor(norm); ctx.lineWidth= 2 + norm*5;
        ctx.beginPath(); ctx.moveTo(p0.cx,p0.cy); ctx.lineTo(p1.cx,p1.cy); ctx.stroke();
      }
    });
    // fixed indicators faint
    res.nodes.forEach(nd=>{
      if(nd.holeInside) return;
      if(nd.fix){ const p=worldToCanvas(nd.x,nd.y,b); ctx.fillStyle='rgba(240,122,148,0.9)'; ctx.fillRect(p.cx-2,p.cy-2,4,4); }
    });
    if(res.hole){
      const cc=worldToCanvas(res.hole.cx,res.hole.cy,b); const r=res.hole.R*b.scale;
      ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cc.cx,cc.cy,r,0,Math.PI*2); ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.28)'; ctx.beginPath(); ctx.arc(cc.cx,cc.cy,r,0,Math.PI*2); ctx.stroke();
    }
  }

  function drawDeform(res){
    const ctx=ctxDeform; const {W,H}=dD;
    ctx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    if(!res) return;
    const b=getBounds({W,H,L:res.L,H:res.H});
    const scaleU = chkDisp.checked ? parseFloat(slScale.value)||80 : 0;
    const maxS=res.maxS||1;
    const showVec=chkVec.checked;
    const showWire=chkWire.checked;

    // deformed positions
    function defPos(nd){
      const ux=res.U[nd.id*2], uy=res.U[nd.id*2+1];
      return {x: nd.x + ux*scaleU, y: nd.y + uy*scaleU, ux, uy};
    }

    res.elems.forEach((ed, idx)=>{
      const vm=res.stresses[idx]?.vm||0;
      const norm= maxS>1e-9 ? vm/maxS : 0;
      const col=stressToColor(norm);
      if(ed.type==='tri'){
        const n0=res.nodes[ed.n[0]], n1=res.nodes[ed.n[1]], n2=res.nodes[ed.n[2]];
        const d0=defPos(n0), d1=defPos(n1), d2=defPos(n2);
        const p0=worldToCanvas(d0.x,d0.y,b), p1=worldToCanvas(d1.x,d1.y,b), p2=worldToCanvas(d2.x,d2.y,b);
        ctx.fillStyle=col; ctx.globalAlpha=0.85; ctx.beginPath(); ctx.moveTo(p0.cx,p0.cy); ctx.lineTo(p1.cx,p1.cy); ctx.lineTo(p2.cx,p2.cy); ctx.closePath(); ctx.fill(); ctx.globalAlpha=1;
        if(showWire){ ctx.strokeStyle='rgba(255,255,255,0.18)'; ctx.lineWidth=0.6; ctx.stroke();}
      } else {
        const n0=res.nodes[ed.n[0]], n1=res.nodes[ed.n[1]];
        const d0=defPos(n0), d1=defPos(n1);
        const p0=worldToCanvas(d0.x,d0.y,b), p1=worldToCanvas(d1.x,d1.y,b);
        ctx.strokeStyle=col; ctx.lineWidth=1.5 + norm*3; ctx.beginPath(); ctx.moveTo(p0.cx,p0.cy); ctx.lineTo(p1.cx,p1.cy); ctx.stroke();
      }
    });
    if(showVec){
      res.nodes.forEach(nd=>{
        if(nd.holeInside) return;
        if(nd.fix) return;
        const d=defPos(nd);
        const pOrig=worldToCanvas(nd.x,nd.y,b);
        const pDef=worldToCanvas(d.x,d.y,b);
        const mag=Math.hypot(d.ux,d.uy);
        if(mag<1e-9) return;
        const lenScale=0.9; // vector arrow length already via deformation? we draw small vector of displacement direction scaled
        // For readability, draw arrow from original to deformed with opacity
        // Alternatively draw displacement vector at def pos
        ctx.strokeStyle='rgba(110,230,150,0.85)'; ctx.lineWidth=1;
        ctx.beginPath(); ctx.moveTo(pOrig.cx,pOrig.cy); ctx.lineTo(pDef.cx,pDef.cy); ctx.stroke();
        // dot at deformed
        ctx.fillStyle='rgba(110,230,150,0.9)'; ctx.beginPath(); ctx.arc(pDef.cx,pDef.cy,1.2,0,Math.PI*2); ctx.fill();
      });
    }
    // fixed and hole
    if(res.hole){
      // hole also moves? For simplicity keep at original but with small deformation based on near nodes? ignore
      const cc=worldToCanvas(res.hole.cx,res.hole.cy,b); const r=res.hole.R*b.scale*0.96;
      ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cc.cx,cc.cy,r,0,Math.PI*2); ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.25)'; ctx.beginPath(); ctx.arc(cc.cx,cc.cy,r,0,Math.PI*2); ctx.stroke();
    }
    // load arrow at deformed tip
    (res.loadNodes||[]).forEach(id=>{
      const nd=res.nodes[id]; const d=defPos(nd);
      const p=worldToCanvas(d.x,d.y,b);
      const ang=parseFloat(slAng.value)*Math.PI/180;
      ctx.strokeStyle='#4ade80'; ctx.lineWidth=1.6;
      const len=16; ctx.beginPath(); ctx.moveTo(p.cx,p.cy); ctx.lineTo(p.cx+Math.cos(ang)*len, p.cy - Math.sin(ang)*len); ctx.stroke();
    });
  }

  // Audio
  let audioCtx=null;
  function ensureAudio(){
    if(audioCtx) return audioCtx;
    audioCtx=new (window.AudioContext||window.webkitAudioContext)();
    return audioCtx;
  }
  function playCreak(intensity){
    if(!chkAudio.checked) return;
    const ctx=ensureAudio(); ctx.resume();
    const dur=0.18;
    const buf=ctx.createBuffer(1, Math.floor(ctx.sampleRate*dur), ctx.sampleRate);
    const ch=buf.getChannelData(0);
    for(let i=0;i<ch.length;i++){
      // pink-ish: integrate white
      ch[i]=(Math.random()*2-1)* (1 - i/ch.length*0.5);
    }
    const src=ctx.createBufferSource(); src.buffer=buf;
    const bp1=ctx.createBiquadFilter(); bp1.type='bandpass'; bp1.frequency.value=1100 + intensity*500; bp1.Q.value=7;
    const bp2=ctx.createBiquadFilter(); bp2.type='bandpass'; bp2.frequency.value=2200 + intensity*300; bp2.Q.value=4.5;
    const gain=ctx.createGain(); gain.gain.value=0.0001;
    const mixGain=ctx.createGain(); mixGain.gain.value=0.7;
    src.connect(bp1); bp1.connect(bp2); bp2.connect(gain); gain.connect(mixGain); mixGain.connect(ctx.destination);
    const now=ctx.currentTime;
    gain.gain.setValueAtTime(0.0001, now);
    gain.gain.linearRampToValueAtTime(intensity*0.34, now+0.01);
    gain.gain.exponentialRampToValueAtTime(0.0001, now+dur);
    src.start(now); src.stop(now+dur+0.02);
  }
  function playFracture(){
    if(!chkAudio.checked) return;
    const ctx=ensureAudio(); ctx.resume();
    const dur=0.35;
    const buf=ctx.createBuffer(1, Math.floor(ctx.sampleRate*0.085), ctx.sampleRate);
    const ch=buf.getChannelData(0);
    for(let i=0;i<ch.length;i++) ch[i]=(Math.random()*2-1)*Math.pow(1-i/ch.length,2.2);
    const src=ctx.createBufferSource(); src.buffer=buf;
    const hp=ctx.createBiquadFilter(); hp.type='highpass'; hp.frequency.value=2800; hp.Q.value=1.2;
    const gain=ctx.createGain(); gain.gain.value=0.0001;
    src.connect(hp); hp.connect(gain); gain.connect(ctx.destination);
    const now=ctx.currentTime;
    gain.gain.setValueAtTime(0.0001, now);
    gain.gain.linearRampToValueAtTime(0.85, now+0.004);
    gain.gain.exponentialRampToValueAtTime(0.0001, now+0.16);
    src.start(now);
    // chirp down
    const osc=ctx.createOscillator(); osc.type='triangle';
    const oscGain=ctx.createGain(); oscGain.gain.value=0.0001;
    const lp=ctx.createBiquadFilter(); lp.type='lowpass'; lp.frequency.value=2400;
    osc.connect(lp); lp.connect(oscGain); oscGain.connect(ctx.destination);
    osc.frequency.setValueAtTime(1400, now);
    osc.frequency.exponentialRampToValueAtTime(60, now+0.28);
    oscGain.gain.setValueAtTime(0.0001, now);
    oscGain.gain.linearRampToValueAtTime(0.5, now+0.01);
    oscGain.gain.exponentialRampToValueAtTime(0.0001, now+0.35);
    osc.start(now); osc.stop(now+0.36);
  }
  let creakTimer=0; let lastFracture=false;

  function triggerSolve(){
    const res=assembleAndSolve();
    lastResult=res;
    drawMesh(res); drawStress(res); drawDeform(res);
    // status
    readK.textContent=res.Ksize+' × '+res.Ksize;
    readMesh.textContent=res.nNodes+' / '+res.nElems;
    readUmax.textContent=(res.maxU*1000).toFixed(3)+' mm';
    readSmax.textContent=(res.maxS/1e6).toFixed(2)+' MPa';
    const mat=res.mat;
    const util=res.maxS/ (mat.sy||1e6);
    readUtil.textContent=(util*100).toFixed(1)+'%';
    readTime.textContent=res.time.toFixed(1)+' ms';
    statusEl.textContent = util>1 ? 'FRACTURE' : util>0.85 ? 'YIELD NEAR' : 'solved';
    statusEl.style.color = util>1 ? '#ef4444' : util>0.75 ? '#f59e0b' : 'var(--mp-muted)';

    // yield badge + flash + audio
    const isFracture = util >= 1.0;
    if(isFracture){
      yieldBadge.classList.remove('hidden');
      if(!lastFracture){
        // flash
        flashOverlay.classList.remove('active'); void flashOverlay.offsetWidth; flashOverlay.classList.add('active');
        viewportWrap.classList.remove('shake'); void viewportWrap.offsetWidth; viewportWrap.classList.add('shake');
        playFracture();
        setTimeout(()=>{ viewportWrap.classList.remove('shake'); }, 400);
        setTimeout(()=>{ flashOverlay.classList.remove('active'); }, 500);
      }
    } else {
      yieldBadge.classList.add('hidden');
      // creaks when util high
      if(util>0.65){
        const prob = (util-0.65)*2.2; // 0..~0.77
        creakTimer += 0.016; // approx caller loop? we call only on solve though - so trigger probabilistic
        if(Math.random()<prob*0.45){
          playCreak(util);
        }
      }
    }
    lastFracture=isFracture;
  }

  // Events
  btnSolve.addEventListener('click', triggerSolve);
  selGeom.addEventListener('change', triggerSolve);
  slRes.addEventListener('change', triggerSolve);
  slThk.addEventListener('change', triggerSolve);
  inL.addEventListener('change', triggerSolve);
  inH.addEventListener('change', triggerSolve);
  slLoad.addEventListener('change', triggerSolve);
  slAng.addEventListener('change', ()=>{
    updLabels();
    if(lastResult) { drawMesh(lastResult); drawDeform(lastResult); }
  });
  slAng.addEventListener('input', ()=>{
    updLabels();
    if(lastResult){ drawMesh(lastResult); drawDeform(lastResult); }
  });
  slAsec.addEventListener('change', triggerSolve);
  inE.addEventListener('change', ()=>{ selPreset.value='CUSTOM'; triggerSolve(); });
  inNu.addEventListener('change', triggerSolve);
  inYield.addEventListener('change', triggerSolve);
  slScale.addEventListener('input', ()=>{ updLabels(); if(lastResult) drawDeform(lastResult); });
  chkDisp.addEventListener('change', ()=>{ if(lastResult) drawDeform(lastResult); });
  chkVec.addEventListener('change', ()=>{ if(lastResult) drawDeform(lastResult); });
  chkWire.addEventListener('change', ()=>{ if(lastResult) drawDeform(lastResult); });
  btnResetView.addEventListener('click', ()=>{
    slScale.value='80'; slAng.value='-90'; slLoad.value='500'; updLabels(); triggerSolve();
  });

  // initial solve
  triggerSolve();

  // rudimentary continuous creak check via interval when stressed but not re-solving
  let creakInterval=setInterval(()=>{
    if(!lastResult) return;
    const util= lastResult.maxS / (lastResult.mat.sy||1e6);
    if(util>=1 || util<0.66) return;
    if(Math.random()< 0.04 + (util-0.66)*0.25){ playCreak(util); }
  }, 320);

  document.addEventListener('astro:before-swap',()=>{
    clearInterval(creakInterval);
    try{audioCtx?.close();}catch{}
  },{once:true});
}
document.addEventListener('astro:page-load', initFEA);
initFEA();
</script>
</Layout>
