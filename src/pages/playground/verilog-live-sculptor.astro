    <FabOrderPanel simulator="verilog-live-sculptor" exportLabel="Export Verilog + PCB carrier notes" description="Export your live Verilog with LUT/slack header + notes for MicroMod carrier PCB. Order carrier on PCBWay Shared Project (10% PCB+SMT) or JLCPCB Brand Advocate path when live." />

    <section class="border-b border-border" aria-labelledby="faq-title">
