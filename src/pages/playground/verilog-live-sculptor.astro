<style>
.pill-btn{border-radius:9999px;border:1px solid var(--mp-border);background:var(--mp-elevated);padding:0.38rem 0.9rem;font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.07em;color:var(--mp-muted);transition:all 0.15s}
.pill-btn.is-active{background:color-mix(in srgb,var(--mp-cta) 14%,var(--mp-elevated));border-color:var(--mp-cta);color:var(--mp-text)}
.pill-btn:hover{border-color:var(--mp-border-strong);color:var(--mp-text)}
.control-label{display:grid;grid-template-columns:1fr auto;gap:0.25rem 0.75rem;align-items:center;font-family:var(--font-mono);font-size:0.68rem;color:var(--mp-muted)}
.control-label input[type=range]{grid-column:1/-1}
.tool-input{display:block;width:100%;border-radius:10px;border:1px solid var(--mp-border);background:var(--mp-canvas);padding:0.35rem 0.5rem;font-size:0.82rem;color:var(--mp-text)}
.math-card{border:1px solid var(--mp-border);border-radius:14px;background:color-mix(in srgb,var(--mp-elevated) 48%,transparent);padding:0.9rem 1rem}
.math-label{font-family:var(--font-mono);font-size:0.6rem;text-transform:uppercase;letter-spacing:0.11em;color:var(--mp-muted)}
.tool-code{font-family:var(--font-mono);font-size:0.78em;background:color-mix(in srgb,var(--mp-elevated) 70%,transparent);border:1px solid var(--mp-border);padding:0.08em 0.35em;border-radius:5px}
.line-clamp-2{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.line-clamp-3{display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
@keyframes violPulse{0%,100%{background:color-mix(in srgb,#ef4444 8%,var(--mp-card-bg))}50%{background:color-mix(in srgb,#ef4444 22%,var(--mp-card-bg))}}
.violating{animation:violPulse 0.32s ease-in-out infinite;border-color:color-mix(in srgb,#ef4444 40%,var(--mp-border)) !important}
</style>

<script>
// @ts-nocheck
function initVLS(){
  const floorC=document.getElementById('floor-canvas');
  if(!floorC || floorC.dataset.init) return;
  floorC.dataset.init='true';
  const timingC=document.getElementById('timing-canvas');
  const fCtx=floorC.getContext('2d');
  const tCtx=timingC.getContext('2d');
  const dpr=Math.min(devicePixelRatio||1,2);
  [floorC,timingC].forEach(c=>{
    const W=c.width,H=c.height; c.width=W*dpr; c.height=H*dpr; c.style.width=W+'px'; c.style.height=H+'px'; c.getContext('2d').scale(dpr,dpr);
  });

  const codeEl=document.getElementById('vl-code');
  const exSel=document.getElementById('ex-select');
  const slClk=document.getElementById('sl-clk'), slRoute=document.getElementById('sl-route'), slJitter=document.getElementById('sl-jitter');
  const outClk=document.getElementById('out-clk'), outRoute=document.getElementById('out-route'), outJitter=document.getElementById('out-jitter');
  const roLut=document.getElementById('ro-lut'), roReg=document.getElementById('ro-reg'), roDsp=document.getElementById('ro-dsp');
  const roMod=document.getElementById('ro-mod'), roLines=document.getElementById('ro-lines'), roLv=document.getElementById('ro-lv');
  const roArr=document.getElementById('ro-arr'), roReq=document.getElementById('ro-req'), roSlack=document.getElementById('ro-slack'), roHslack=document.getElementById('ro-hslack'), roFmax=document.getElementById('ro-fmax'), roUtil=document.getElementById('ro-util');
  const pathList=document.getElementById('path-list'), violBadge=document.getElementById('viol-badge'), floorStatus=document.getElementById('floor-status');
  const btnRoute=document.getElementById('btn-route'), btnAudio=document.getElementById('btn-audio'), btnClear=document.getElementById('btn-clear');
  const timingCard=document.getElementById('timing-card'), slackFill=document.getElementById('slack-fill');

  const examples={
    counter: `module counter8 (
  input wire clk, rstn,
  input wire en,
  output reg [7:0] count,
  output wire overflow
);
  assign overflow = (count==8'hFF) & en;
  wire [7:0] next = count + 1;

  always @(posedge clk or negedge rstn) begin
    if(!rstn) count <= 8'h00;
    else if(en) count <= next;
  end
endmodule`,
    alu: `module alu8 (
  input  [7:0] a,b,
  input  [2:0] op,
  output reg [7:0] y,
  output reg zero
);
  wire [7:0] add = a + b;
  wire [7:0] sub = a - b;
  wire [7:0] andv = a & b;
  wire [7:0] orv  = a | b;
  wire [7:0] xorv = a ^ b;
  wire [15:0] mul = a * b;

  always @(*) begin
    case(op)
      3'd0: y = add;
      3'd1: y = sub;
      3'd2: y = andv;
      3'd3: y = orv;
      3'd4: y = xorv;
      3'd5: y = mul[7:0];
      default: y = 8'h00;
    endcase
    zero = (y==0);
  end
endmodule`,
    pipeline: `module mac_pipe (
  input clk, rst,
  input signed [7:0] a,b,c,
  output reg signed [15:0] y
);
  reg signed [7:0] a_r, b_r;
  reg signed [15:0] prod;
  wire signed [15:0] mul = a_r * b_r;
  wire signed [15:0] acc = prod + c;

  always @(posedge clk) begin
    if(rst) begin
      a_r <= 0; b_r <= 0;
      prod <= 0; y <= 0;
    end else begin
      a_r <= a;
      b_r <= b;
      prod <= mul;
      y <= acc;
    end
  end
endmodule`,
    pwm: `module pwm_gen #(
  parameter RES=8
)(
  input clk, rstn,
  input [RES-1:0] duty,
  output reg pwm_out
);
  reg [RES-1:0] cnt;
  assign tick = (cnt==0);

  always @(posedge clk or negedge rstn) begin
    if(!rstn) cnt <= 0;
    else cnt <= cnt + 1;
  end
  always @(*) begin
    pwm_out = (cnt < duty);
  end
endmodule`,
    fsm: `module traffic_fsm (
  input clk, rst,
  input car_ns, car_ew,
  output reg [1:0] light_ns, light_ew
);
  typedef enum {S_NS_GREEN, S_NS_YEL, S_EW_GREEN, S_EW_YEL} state_t;
  state_t state, nxt;
  reg [3:0] timer;
  wire timeout = (timer==0);
  assign green_ns = (state==S_NS_GREEN);
  assign green_ew = (state==S_EW_GREEN);

  always @(posedge clk) begin
    if(rst) begin state <= S_NS_GREEN; timer <= 10; end
    else begin
      if(timeout) state <= nxt;
      timer <= timeout ? 10 : timer-1;
    end
  end
  always @(*) begin
    case(state)
      S_NS_GREEN: nxt = car_ew ? S_NS_YEL : S_NS_GREEN;
      S_NS_YEL:   nxt = S_EW_GREEN;
      S_EW_GREEN: nxt = car_ns ? S_EW_YEL : S_EW_GREEN;
      S_EW_YEL:   nxt = S_NS_GREEN;
      default: nxt = S_NS_GREEN;
    endcase
    light_ns = (state==S_NS_GREEN)?2'd2:(state==S_NS_YEL)?2'd1:2'd0;
    light_ew = (state==S_EW_GREEN)?2'd2:(state==S_EW_YEL)?2'd1:2'd0;
  end
endmodule`
  };

  function loadEx(key){
    const src=examples[key];
    if(!src) return;
    codeEl.value=src;
    compute(true);
  }
  exSel.addEventListener('change',()=>loadEx(exSel.value));
  // init
  codeEl.value=examples.counter;

  function updOut(){
    outClk.textContent=parseFloat(slClk.value).toFixed(1);
    outRoute.textContent=parseFloat(slRoute.value).toFixed(2);
    outJitter.textContent=parseFloat(slJitter.value).toFixed(2);
  }
  [slClk,slRoute,slJitter].forEach(el=>el.addEventListener('input',()=>{updOut(); compute(false);} ));
  updOut();

  // audio
  let audioCtx=null, masterGain=null, oscs=[], oscGains=[], lfo=null, audioOn=false, closureTimer=0;
  function ensureAudio(){
    if(audioCtx) return audioCtx;
    audioCtx=new (window.AudioContext||window.webkitAudioContext)();
    masterGain=audioCtx.createGain(); masterGain.gain.value=0; masterGain.connect(audioCtx.destination);
    // 3 harmonic oscillators for major triad 220, 275, 330 (4:5:6 of 55Hz*4)
    const freqs=[220, 275, 330];
    freqs.forEach((f,i)=>{
      const o=audioCtx.createOscillator(); o.type='sine'; o.frequency.value=f;
      const g=audioCtx.createGain(); g.gain.value=0;
      const filt=audioCtx.createBiquadFilter(); filt.type='lowpass'; filt.frequency.value=1200 + i*300;
      o.connect(filt); filt.connect(g); g.connect(masterGain);
      o.start();
      oscs.push(o); oscGains.push(g);
    });
    // subtle detune shimmer via slow LFO on gain
    return audioCtx;
  }
  function setClosureTone(closed, slackPos){
    if(!audioOn) return;
    const ctx=ensureAudio(); ctx.resume();
    const now=ctx.currentTime;
    if(closed){
      closureTimer=1.0;
      masterGain.gain.cancelScheduledValues(now);
      masterGain.gain.linearRampToValueAtTime(Math.min(0.14, 0.05+slackPos*0.02), now+0.15);
      oscs.forEach((_,i)=>{
        const target = 0.04 + i*0.01 + slackPos*0.003;
        oscGains[i].gain.cancelScheduledValues(now);
        oscGains[i].gain.linearRampToValueAtTime(target, now+0.2 + i*0.05);
      });
    } else {
      masterGain.gain.cancelScheduledValues(now);
      masterGain.gain.linearRampToValueAtTime(0, now+0.25);
      oscGains.forEach(g=>{
        g.gain.cancelScheduledValues(now);
        g.gain.linearRampToValueAtTime(0, now+0.2);
      });
    }
  }
  btnAudio.addEventListener('click',()=>{
    audioOn=!audioOn; btnAudio.classList.toggle('is-active',audioOn);
    btnAudio.textContent=audioOn?'🔇 Muted':'🔊 Timing Chime';
    if(audioOn){ ensureAudio(); audioCtx.resume(); }
    else { if(masterGain){ try{masterGain.gain.value=0;}catch{} } }
    compute(false);
  });
  btnClear.addEventListener('click',()=>{ codeEl.value=''; compute(true); });

  function parseVerilog(src, clkPeriod, spread, jitter){
    const noComments=src.replace(/\/\/.*$/gm,'').replace(/\/\*[\s\S]*?\*\//g,'');
    const modules=[...noComments.matchAll(/module\s+(\w+)/g)].map(m=>m[1]);
    const assigns=(noComments.match(/^\s*assign\s+/gm)||[]).length;
    const alwaysPosRaw=(noComments.match(/always\s*@\s*\(\s*posedge/gi)||[]).length + (noComments.match(/always_ff\s*@/gi)||[]).length;
    const alwaysComb=(noComments.match(/always\s*@\s*\(\s*\*/g)||[]).length + (noComments.match(/always_comb/gi)||[]).length + (noComments.match(/always @\(\*\)/g)||[]).length;
    const ops=(noComments.match(/[&|^]/g)||[]).length;
    const tildes=(noComments.match(/~/g)||[]).length;
    const addSub=(noComments.match(/(?<![=!<>])\+(?!\+)|(?<![=!<>])-(?!-)/g)||[]).length;
    // isolate * not ** and not commented
    const starMatches=noComments.match(/(?<!\*)\*(?!\*)/g);
    const dspCount=starMatches?starMatches.length:0;
    const nbMatches=[...noComments.matchAll(/<=\s*[^;]+;/g)];
    const nb=nbMatches.length || (noComments.match(/<=/g)||[]).length;
    const bram=(noComments.match(/reg\s*\[[^\]]+\]\s*\w+\s*\[[^\]]+\]/g)||[]).length + (noComments.match(/\bBRAM|\bRAMB|mem\[|memory/gi)||[]).length;
    // LUT estimation
    let lut = assigns*1;
    lut += Math.ceil(ops*0.35) + Math.ceil(tildes*0.5);
    lut += Math.ceil(addSub*0.55);
    lut += alwaysComb*2;
    // heuristic for case/mux
    const muxes=(noComments.match(/\bcase\b|\b\?\s*:/g)||[]).length;
    lut += muxes*1;
    if(lut===0 && (noComments.trim().length>10)) lut=1;
    let regs = nb>0 ? nb : alwaysPosRaw*2;
    // logic levels
    const logicLevels = Math.max(1, Math.ceil(Math.log2(Math.max(1,lut))*1.2 + assigns*0.15 + muxes*0.25));
    const tLut=0.35, tRoute=0.12+spread*0.45, tDsp=1.15, tCq=0.18, tSetup=0.08;
    const tHold=0.05;
    const arrival = tCq + logicLevels*(tLut+tRoute) + dspCount*tDsp + bram*0.9;
    const arrivalMin = arrival*0.22;
    const required = clkPeriod - tSetup - jitter;
    const slack = required - arrival;
    const holdSlack = arrivalMin - tHold;
    const fmax = 1000/(arrival + tSetup); // MHz if arrival ns
    const paths=[
      {name:'crit comb', delay:arrival, levels:logicLevels},
      {name:'to first reg', delay:arrival*0.62, levels:Math.max(1,Math.floor(logicLevels*0.6))},
      {name: dspCount>0 ? 'DSP chain' : 'mux chain', delay: dspCount>0? (tCq + tDsp + logicLevels*0.3*(tLut+tRoute)) : arrival*0.48, levels: dspCount>0?2:Math.floor(logicLevels*0.5)}
    ];
    return {modules, assigns, alwaysPos:alwaysPosRaw, alwaysComb, lut, regs, dsps:dspCount, brams:bram, lines:noComments.split('\n').length, logicLevels, arrival, arrivalMin, required, slack, holdSlack, fmax, paths};
  }

  let animIdx=0, animTotal=0, animHandle=0;
  let lastData=null;

  function drawFloor(data, animProgress){
    const W=720,H=520;
    fCtx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    fCtx.fillStyle=bg; fCtx.fillRect(0,0,W,H);
    // grid
    const cols=14, rows=14;
    const pad=18, cellW=(W-pad*2)/cols, cellH=(H-pad*2)/rows, gap=2;
    // clock spine
    fCtx.fillStyle='rgba(96,165,250,0.10)'; fCtx.fillRect(pad + 6*cellW, pad, cellW*2, H-pad*2);
    fCtx.fillStyle='rgba(96,165,250,0.28)'; fCtx.fillRect(pad+6*cellW+cellW*0.45, pad, 2, H-pad*2);
    // congestion heat if high spread
    const spread=parseFloat(slRoute.value)||0;
    if(spread>0.6){
      fCtx.fillStyle=`rgba(251,146,60,${(spread-0.6)*0.18})`;
      fCtx.fillRect(pad,pad,W-pad*2,H-pad*2);
    }
    const totalLUT=data.lut, totalDSP=data.dsps, totalBRAM=data.brams, totalReg=data.regs;
    const litCount=Math.min(totalLUT, cols*rows);
    const progress=animProgress!=null?animProgress:1;
    const litNow=Math.floor(litCount*progress);
    // place pattern: serpentine
    let placed=0;
    let dspPlaced=0, bramPlaced=0;
    // precompute positions for LUTs
    for(let r=0;r<rows;r++){
      for(let c=0;c<cols;c++){
        const x=pad + c*cellW + gap, y=pad + r*cellH + gap;
        const cw=cellW-gap*2, ch=cellH-gap*2;
        const idx=r*cols + (r%2? cols-1-c : c);
        const isLit = idx < litNow;
        const depth = (idx % Math.max(1,data.logicLevels)) / Math.max(1,data.logicLevels-1||1);
        if(!isLit){
          fCtx.fillStyle='rgba(255,255,255,0.06)'; fCtx.strokeStyle='rgba(255,255,255,0.06)'; fCtx.lineWidth=1;
          fCtx.beginPath(); fCtx.roundRect(x,y,cw,ch,4); fCtx.fill(); fCtx.stroke();
        } else {
          // LUT glow
          const alpha=0.55 + depth*0.45;
          const g=`rgba(${163+depth*40}, ${230-depth*30}, ${Math.floor(53+depth*20)}, ${alpha})`;
          fCtx.fillStyle=g; fCtx.shadowColor=g; fCtx.shadowBlur=8*alpha;
          fCtx.beginPath(); fCtx.roundRect(x,y,cw,ch,5); fCtx.fill(); fCtx.shadowBlur=0;
          // reg dot
          if(placed < totalReg){
            fCtx.fillStyle='#60a5fa';
            fCtx.beginPath(); fCtx.arc(x+cw-6, y+6, 3.2,0,Math.PI*2); fCtx.fill();
          }
          placed++;
        }
        // DSP tiles at bottom rows
        if(r>=rows-2 && dspPlaced<totalDSP){
          const isDspLit = dspPlaced < totalDSP*progress;
          if(isDspLit){
            fCtx.fillStyle='rgba(251,146,60,0.92)'; fCtx.beginPath(); fCtx.roundRect(x, y- (rows-2)*cellH*0 + (r-(rows-2))*cellH*0.1 , cw*1.8, ch*1.8,6); fCtx.fill();
          }
          dspPlaced++;
        }
      }
    }
    // BRAM bars on right edge
    for(let i=0;i<data.brams;i++){
      const visible=i < data.brams*progress;
      if(!visible) continue;
      const x=pad + (cols-1.6)*cellW, y=pad + 2*cellH + i*3.2*cellH;
      fCtx.fillStyle='rgba(192,132,252,0.92)'; fCtx.beginPath(); fCtx.roundRect(x,y,cellW*1.2,cellH*2.6,6); fCtx.fill();
    }
    fCtx.fillStyle='#e8eef6aa'; fCtx.font='10px ui-monospace'; fCtx.fillText(`${litNow}/${cols*rows} LUT slots lit • ${totalReg} reg • ${totalDSP} DSP • ${totalBRAM} BRAM`, pad, H-6);
  }

  function drawTiming(data){
    const W=820,H=300;
    tCtx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    tCtx.fillStyle=bg; tCtx.fillRect(0,0,W,H);
    const clk=parseFloat(slClk.value)||8;
    const jitter=parseFloat(slJitter.value)||0.08;
    const arrival=data.arrival, arrivalMin=data.arrivalMin, required=data.required, slack=data.slack, holdSlack=data.holdSlack;
    const padL=56, padR=20, padT=30, padB=44;
    const plotW=W-padL-padR, plotH=H-padT-padB;
    const pxPerNs= plotW / (clk*1.35);
    const yClk=padT + 18, yData=padT+85, yHold=padT+145, ySlack=padT+200;
    // grid per ns
    tCtx.strokeStyle='rgba(255,255,255,0.06)'; tCtx.lineWidth=1;
    for(let ns=0; ns<=clk*1.35; ns+=1){
      const x=padL + ns*pxPerNs;
      tCtx.beginPath(); tCtx.moveTo(x,padT); tCtx.lineTo(x,H-padB); tCtx.stroke();
      tCtx.fillStyle='rgba(255,255,255,0.28)'; tCtx.font='9px ui-monospace'; tCtx.fillText(ns.toFixed(0)+'ns', x-8, H-padB+12);
    }
    // clock waveform
    const drawSquareWave=(y, amp)=>{
      tCtx.beginPath(); tCtx.strokeStyle='#e8eef6'; tCtx.lineWidth=2;
      const periodW=clk*pxPerNs;
      const steps=[padL, padL+periodW*0.5, padL+periodW*0.5, padL+periodW];
      let x=padL, curY=y - amp/2;
      tCtx.moveTo(x,curY);
      tCtx.lineTo(padL+periodW*0.5,curY);
      tCtx.lineTo(padL+periodW*0.5, y+amp/2);
      tCtx.lineTo(padL+periodW, y+amp/2);
      // next edge
      tCtx.lineTo(padL+periodW, y-amp/2);
      tCtx.lineTo(padL+periodW*1.35, y-amp/2);
      tCtx.stroke();
      // jitter shade
      if(jitter>0){
        tCtx.fillStyle='rgba(96,165,250,0.12)';
        tCtx.fillRect(padL+periodW - jitter*pxPerNs, y-amp/2, jitter*2*pxPerNs, amp);
      }
    };
    drawSquareWave(yClk, 28);
    tCtx.fillStyle='#e8eef6'; tCtx.font='10px ui-monospace'; tCtx.fillText('CLK', 8, yClk+3);
    // data arrival marker
    const xArr=padL + arrival*pxPerNs;
    tCtx.strokeStyle= slack>=0 ? '#a3e635' : '#ef4444'; tCtx.lineWidth=2.5;
    tCtx.beginPath(); tCtx.moveTo(xArr, yData-16); tCtx.lineTo(xArr, yData+16); tCtx.stroke();
    tCtx.fillStyle=slack>=0?'#a3e635':'#ef4444';
    tCtx.beginPath(); tCtx.moveTo(xArr, yData-14); tCtx.lineTo(xArr-6, yData-22); tCtx.lineTo(xArr+6, yData-22); tCtx.closePath(); tCtx.fill();
    tCtx.font='11px ui-monospace'; tCtx.fillText(`T_arr ${arrival.toFixed(2)}ns`, xArr+6, yData-20);
    // data line ramp
    tCtx.strokeStyle='#facc15aa'; tCtx.lineWidth=1.5; tCtx.setLineDash([5,4]);
    tCtx.beginPath(); tCtx.moveTo(padL, yData); tCtx.lineTo(xArr, yData); tCtx.stroke(); tCtx.setLineDash([]);
    // required edge
    const xReq=padL + required*pxPerNs;
    tCtx.strokeStyle='#60a5fa'; tCtx.lineWidth=1.5; tCtx.setLineDash([3,3]);
    tCtx.beginPath(); tCtx.moveTo(xReq, padT); tCtx.lineTo(xReq, H-padB); tCtx.stroke(); tCtx.setLineDash([]);
    tCtx.fillStyle='#60a5fa'; tCtx.font='10px ui-monospace'; tCtx.fillText(`T_req ${required.toFixed(2)}ns`, xReq+4, yData+28);
    // setup window shading
    if(slack<0){
      tCtx.fillStyle=`rgba(239,68,68,${0.18 + Math.abs(Math.sin(Date.now()/140))*0.18})`;
      tCtx.fillRect(Math.min(xArr,xReq), yData-12, Math.abs(xReq-xArr), 24);
    } else {
      tCtx.fillStyle='rgba(163,230,53,0.12)';
      tCtx.fillRect(xArr, yData-12, Math.max(2,xReq-xArr), 24);
    }
    // hold lane
    const xHoldMin=padL + arrivalMin*pxPerNs;
    tCtx.strokeStyle= holdSlack>=0 ? '#22d3ee' : '#ef4444'; tCtx.lineWidth=2;
    tCtx.beginPath(); tCtx.moveTo(padL, yHold); tCtx.lineTo(xHoldMin, yHold); tCtx.stroke();
    tCtx.fillStyle=holdSlack>=0?'#22d3ee':'#ef4444'; tCtx.beginPath(); tCtx.arc(xHoldMin, yHold,4,0,Math.PI*2); tCtx.fill();
    tCtx.fillStyle='#e8eef6aa'; tCtx.font='10px ui-monospace'; tCtx.fillText(`T_arr_min ${arrivalMin.toFixed(2)}ns`, xHoldMin+6, yHold-8);
    tCtx.fillText('HOLD', 8, yHold+3);
    // hold violation mark 0.05ns
    const xHoldReq=padL + 0.05*pxPerNs;
    tCtx.strokeStyle='rgba(239,68,68,0.6)'; tCtx.beginPath(); tCtx.moveTo(xHoldReq, yHold-12); tCtx.lineTo(xHoldReq, yHold+12); tCtx.stroke();
    // slack bar textual area
    tCtx.fillStyle='#e8eef6'; tCtx.font='12px ui-monospace';
    const slackTxt = slack>=0 ? `✓ Setup slack +${slack.toFixed(3)}ns closes` : `✗ Setup slack ${slack.toFixed(3)}ns VIOLATION`;
    tCtx.fillStyle=slack>=0?'#a3e635':'#ef4444'; tCtx.fillText(slackTxt, padL, ySlack);
    tCtx.fillStyle=holdSlack>=0?'#22d3ee':'#ef4444';
    tCtx.fillText(holdSlack>=0?`✓ Hold +${holdSlack.toFixed(3)}ns`:`✗ Hold ${holdSlack.toFixed(3)}ns VIOLATION`, padL+260, ySlack);
    // Fmax
    tCtx.fillStyle='#e8eef6aa'; tCtx.font='10px ui-monospace';
    tCtx.fillText(`Fmax≈${data.fmax.toFixed(1)}MHz  T_clk=${clk.toFixed(1)}ns`, padL, ySlack+18);
  }

  function compute(animate){
    const src=codeEl.value;
    const clk=parseFloat(slClk.value)||8;
    const spread=parseFloat(slRoute.value)||0.4;
    const jitter=parseFloat(slJitter.value)||0.08;
    const data=parseVerilog(src, clk, spread, jitter);
    lastData=data;
    roLut.textContent=data.lut.toString();
    roReg.textContent=data.regs.toString();
    roDsp.textContent=`${data.dsps} / ${data.brams}`;
    roMod.textContent=data.modules.length? data.modules.join(', '): '—';
    roLines.textContent=data.lines.toString();
    roLv.textContent=data.logicLevels.toString();
    roArr.textContent=data.arrival.toFixed(3)+' ns';
    roReq.textContent=data.required.toFixed(3)+' ns';
    roSlack.textContent=data.slack.toFixed(3)+' ns';
    roHslack.textContent=data.holdSlack.toFixed(3)+' ns';
    roFmax.textContent=data.fmax.toFixed(1);
    const util=(data.lut/196*100); roUtil.textContent=util.toFixed(1)+'%'+(util>100?' OVERFLOW':'');
    roSlack.style.color=data.slack>=0?'#a3e635':'#ef4444';
    roHslack.style.color=data.holdSlack>=0?'#22d3ee':'#ef4444';
    // paths
    pathList.innerHTML='';
    data.paths.forEach(p=>{
      const li=document.createElement('li');
      li.textContent=`${p.name}: ${p.delay.toFixed(2)}ns • ${p.levels} levels`;
      pathList.appendChild(li);
    });
    // viol badge
    const viol = data.slack<0 || data.holdSlack<0;
    violBadge.style.display= viol ? 'inline-flex' : 'none';
    violBadge.classList.toggle('violating', false);
    if(viol){
      timingCard.classList.toggle('violating', data.slack<0);
      floorStatus.textContent= data.slack<0? `✗ SETUP ${data.slack.toFixed(2)}ns` : `✗ HOLD ${data.holdSlack.toFixed(2)}ns`;
      floorStatus.style.color='#ef4444';
    } else {
      timingCard.classList.remove('violating');
      floorStatus.textContent=`✓ TIMING CLOSED +${data.slack.toFixed(2)}ns`;
      floorStatus.style.color='#a3e635';
    }
    // slack fill bar
    const slackPct=Math.max(0, Math.min(100, ((data.slack+2)/ (clk))*100));
    slackFill.style.width= slackPct.toFixed(1)+'%';
    slackFill.style.background= data.slack>=0 ? 'linear-gradient(90deg,#22c55e,#a3e635)' : 'linear-gradient(90deg,#ef4444,#f97316)';

    // audio
    setClosureTone(data.slack>=0 && data.holdSlack>=0, data.slack);

    if(animate){
      // animate PnR
      animIdx=0; animTotal=data.lut+data.dsps+data.brams;
      if(animHandle) cancelAnimationFrame(animHandle);
      function step(){
        animIdx+= Math.max(1, Math.ceil(animTotal/28));
        const prog=Math.min(1, animIdx/ Math.max(1,animTotal));
        drawFloor(data, prog);
        if(prog<1) animHandle=requestAnimationFrame(step);
        else drawFloor(data,1);
      }
      step();
    } else {
      drawFloor(data,1);
    }
    drawTiming(data);
  }

  codeEl.addEventListener('input',()=>compute(false));
  btnRoute.addEventListener('click',()=>compute(true));

  compute(true);

  // ExportGate — Verilog RTL + timing report
  try {
    const reg = () => {
      if (window.MPExportGate) {
        window.MPExportGate.register('verilog-live-sculptor', () => {
          const src = codeEl ? codeEl.value : '// no rtl yet\n';
          const clk = parseFloat(slClk?.value || '8');
          const slack = lastData ? lastData.slack.toFixed(3) : '—';
          const hSlack = lastData ? lastData.holdSlack.toFixed(3) : '—';
          const lut = lastData ? lastData.lut : 0;
          const regs = lastData ? lastData.regs : 0;
          const dsp = lastData ? lastData.dsps : 0;
          const bram = lastData ? lastData.brams : 0;
          let header = `// Export ${new Date().toISOString()} — verilog-live-sculptor\n`;
          header += `// Timing: T_clk=${clk}ns Slack_setup=${slack}ns Hold=${hSlack}ns\n`;
          header += `// Utilization: LUTs=${lut} Regs=${regs} DSP=${dsp} BRAM=${bram}\n`;
          header += `// Target: Digilent Arty A7-35T (XC7A35T) + SparkFun MicroMod Main Board Single\n`;
          header += `// Generated by makerportal.ai/playground/verilog-live-sculptor — clean after email unlock\n`;
          header += `// For PCB carrier: place Arty headers + MicroMod M.2 via PCBWay Shared Project; keep 100Ω diff pairs\n\n`;
          return header + src;
        });
      }
    };
    reg();
    document.addEventListener('astro:page-load', reg);
  } catch {}

  let raf=0;
  function liveLoop(){
    raf=requestAnimationFrame(liveLoop);
    if(lastData){
      // subtle flicker for violation pulse
      if(lastData.slack<0 || lastData.holdSlack<0){
        drawTiming(lastData);
      }
    }
  }
  liveLoop();

  document.addEventListener('astro:before-swap',()=>{
    cancelAnimationFrame(raf); if(animHandle) cancelAnimationFrame(animHandle);
    try{audioCtx?.close();}catch{}
  },{once:true});
}
document.addEventListener('astro:page-load', initVLS);
initVLS();
</script>
</Layout>
