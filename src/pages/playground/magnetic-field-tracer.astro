<script>
// @ts-nocheck
import { buildLoop, buildWire, fieldAt, traceFieldLine, compileSegments, compiledFieldAt, MU0 } from '../../lib/emfields.ts';

function initFieldTracer() {
  const canvas = document.getElementById('field-canvas');
  if (!canvas || canvas.dataset.init) return;
  canvas.dataset.init = 'true';
  const ctx = canvas.getContext('2d', { alpha: false });

  let heatCanvas = document.createElement('canvas');
  heatCanvas.width = canvas.width; heatCanvas.height = canvas.height;
  let heatCtx = heatCanvas.getContext('2d');
  
  let lineCanvas = document.createElement('canvas');
  lineCanvas.width = canvas.width; lineCanvas.height = canvas.height;
  let lineCtx = lineCanvas.getContext('2d');

  let colors = {};
  function readColors() {
    const s = getComputedStyle(document.documentElement);
    const g = (n, f) => s.getPropertyValue(n).trim() || f;
    colors = {
      canvas: g('--mp-canvas', '#0f141c'), text: g('--mp-text', '#e8eef6'),
      muted: g('--mp-muted', '#a8b9cc'), border: g('--mp-border', 'rgba(255,255,255,0.1)'),
      cta: g('--mp-cta', '#f07a94'), anchor: g('--mp-anchor', '#71b9e3'),
    };
  }
  readColors();

  const R = 0.1;
  const VIEW = 0.34;
  const nSeg = 96;

  let preset = 'single';
  let current = 100;
  let geom = 1.0;
  let nSeeds = 14;
  let showHeat = true;
  let showFlow = true;

  let segments = [];
  let compiledSegments = null;
  let heatmapCell = 5;
  let glyphs = [];
  let lines = [];
  let bMax = 1;
  let dashPhase = 0;
  let flowRafId = null;
  let destroyed = false;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const el = {
    cur: document.getElementById('cur-slider'), curOut: document.getElementById('cur-out'),
    geom: document.getElementById('geom-slider'), geomOut: document.getElementById('geom-out'),
    geomLabel: document.getElementById('geom-label'),
    seed: document.getElementById('seed-slider'), seedOut: document.getElementById('seed-out'),
    sceneNote: document.getElementById('scene-note'),
  };

  function buildScene() {
    segments = []; glyphs = [];
    const zAxis = [0, 0, 1];
    const addLoop = (zc, cur) => {
      segments.push(...buildLoop([0, 0, zc], R, zAxis, cur, nSeg));
      glyphs.push({ x: R, z: zc, into: cur > 0 });
      glyphs.push({ x: -R, z: zc, into: cur < 0 });
    };
    const seeds = [];
    const eqSeeds = (zc, rmin, rmax, n, sign = 1) => {
      for (let k = 0; k < n; k++) {
        const r = rmin + (rmax - rmin) * (k / (n - 1));
        seeds.push([sign * r, 0, zc]);
      }
    };

    if (preset === 'single') {
      addLoop(0, current);
      el.geomLabel.textContent = 'Loop radius scale';
      el.sceneNote.textContent = 'single current loop · axis vertical';
      eqSeeds(0, 0.16 * R, 2.6 * R, Math.ceil(nSeeds / 2));
      eqSeeds(0, 0.16 * R, 2.6 * R, Math.floor(nSeeds / 2), -1);
    } else if (preset === 'helmholtz') {
      const sep = geom * R;
      addLoop(-sep / 2, current); addLoop(sep / 2, current);
      el.geomLabel.textContent = 'Coil separation';
      el.sceneNote.textContent = 'Helmholtz pair · uniform core at s = R';
      eqSeeds(0, 0.14 * R, 2.4 * R, Math.ceil(nSeeds / 2));
      eqSeeds(0, 0.14 * R, 2.4 * R, Math.floor(nSeeds / 2), -1);
    } else if (preset === 'bottle') {
      const sep = geom * R;
      addLoop(-sep / 2, current); addLoop(sep / 2, -current);
      el.geomLabel.textContent = 'Coil separation';
      el.sceneNote.textContent = 'anti-Helmholtz "magnetic bottle" · field pinches at both ends';
      eqSeeds(-sep / 2, 0.2 * R, 1.8 * R, Math.ceil(nSeeds / 2));
      eqSeeds(-sep / 2, 0.2 * R, 1.8 * R, Math.floor(nSeeds / 2), -1);
    } else if (preset === 'solenoid') {
      const turns = Math.max(3, Math.round(2 + geom * 3));
      const h = 3.2 * R;
      for (let t = 0; t < turns; t++) {
        const zc = -h / 2 + (h * t) / (turns - 1);
        addLoop(zc, current);
      }
      el.geomLabel.textContent = 'Turns (aspect)';
      el.geomOut.textContent = `${turns} turns`;
      el.sceneNote.textContent = `solenoid · ${turns} turns · confined interior field`;
      eqSeeds(0, 0.12 * R, 0.85 * R, Math.ceil(nSeeds / 2));
      eqSeeds(0, 1.25 * R, 2.6 * R, Math.floor(nSeeds / 2));
    } else if (preset === 'antiparallel') {
      const d = geom * R;
      const Lw = 4;
      segments.push(buildWire([d, -Lw, 0], [d, Lw, 0], current));
      segments.push(buildWire([-d, -Lw, 0], [-d, Lw, 0], -current));
      glyphs.push({ x: d, z: 0, into: false });
      glyphs.push({ x: -d, z: 0, into: true });
      el.geomLabel.textContent = 'Wire separation';
      el.sceneNote.textContent = 'two anti-parallel wires · field encircles each';
      const rings = Math.max(3, Math.floor(nSeeds / 4));
      for (const cx of [d, -d]) for (let k = 0; k < rings; k++) {
        const rr = 0.25 * R + k * 0.4 * R;
        seeds.push([cx + rr, 0, 0]);
      }
    } else if (preset === 'dipole') {
      const sep = geom * R;
      segments = []; glyphs = [];
      addLoop(-sep / 2, current); addLoop(sep / 2, current);
      el.geomLabel.textContent = 'Loop separation';
      el.geomOut.textContent = `${geom.toFixed(2)} R`;
      el.sceneNote.textContent = 'coaxial loop pair ≈ bar-magnet dipole';
      eqSeeds(0, 0.18 * R, 2.8 * R, Math.ceil(nSeeds / 2));
      eqSeeds(0, 0.18 * R, 2.8 * R, Math.floor(nSeeds / 2), -1);
    }

    compiledSegments = compileSegments(segments);
    traceAll(seeds);
    computeBMax();
    rebuildCachedLayers();
  }

  function rebuildCachedLayers() {
    drawHeatmapToCache();
    drawLinesToCache();
  }

  function traceAll(seeds) {
    lines = [];
    const opt = { step: 0.005, maxSteps: 1100, minField: MU0 * 1e-4, bound: VIEW * 1.7 };
    for (const s of seeds) {
      const fwd = traceFieldLine(compiledSegments, s, opt);
      const bwd = traceFieldLine(compiledSegments, s, { ...opt, reverse: true });
      const pts = bwd.points.slice(1).reverse().concat(fwd.points);
      const b = bwd.bValues.slice(1).reverse().concat(fwd.bValues);
      if (pts.length < 4) continue;
      lines.push({ pts: pts.map((p) => [p[0], p[2]]), b });
    }
  }

  function computeBMax() {
    bMax = 1e-9;
    for (const ln of lines) for (const v of ln.b) if (v < 1e30) bMax = Math.max(bMax, v);
    const all = [];
    for (const ln of lines) for (const v of ln.b) all.push(v);
    all.sort((a, b) => a - b);
    if (all.length) bMax = all[Math.floor(all.length * 0.92)] || bMax;
  }

  function mapX(x) { return (canvas.width / 2) + (x / VIEW) * (canvas.width / 2 - 20); }
  function mapZ(z) { return (canvas.height / 2) - (z / VIEW) * (canvas.height / 2 - 20); }
  function invX(px) { return ((px - canvas.width / 2) / (canvas.width / 2 - 20)) * VIEW; }
  function invZ(py) { return -((py - canvas.height / 2) / (canvas.height / 2 - 20)) * VIEW; }

  function rgb(c) {
    const m = c.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
    if (m) return [parseInt(m[1], 16), parseInt(m[2], 16), parseInt(m[3], 16)];
    const g = c.match(/(\d+)/g); return g ? g.slice(0, 3).map(Number) : [113, 185, 227];
  }

  function drawHeatmapToCache() {
    const W = heatCanvas.width, H = heatCanvas.height;
    heatCtx.clearRect(0, 0, W, H);
    if (!showHeat) return;
    
    const startT = performance.now();
    const cell = heatmapCell;
    const cold = rgb(colors.anchor), hot = rgb(colors.cta);
    for (let py = 0; py < H; py += cell) {
      for (let px = 0; px < W; px += cell) {
        const x = invX(px + cell / 2), z = invZ(py + cell / 2);
        const f = compiledFieldAt(compiledSegments, [x, 0, z]);
        const b = Math.hypot(f[0], f[1], f[2]);
        let t = Math.log10(1 + b / bMax) / Math.log10(2);
        t = Math.max(0, Math.min(1, t));
        if (t < 0.02) continue;
        const r = cold[0] + (hot[0] - cold[0]) * t;
        const g = cold[1] + (hot[1] - cold[1]) * t;
        const bl = cold[2] + (hot[2] - cold[2]) * t;
        heatCtx.fillStyle = `rgba(${r | 0},${g | 0},${bl | 0},${0.16 * t})`;
        heatCtx.fillRect(px, py, cell, cell);
      }
    }
    const endT = performance.now();
    if (endT - startT > 8 && heatmapCell < 12) {
      heatmapCell = heatmapCell === 5 ? 8 : 12;
    }
  }
  
  function drawLinesToCache() {
    const W = lineCanvas.width, H = lineCanvas.height;
    lineCtx.clearRect(0, 0, W, H);
    
    lineCtx.strokeStyle = colors.border; lineCtx.lineWidth = 1; lineCtx.globalAlpha = 0.6;
    lineCtx.beginPath(); lineCtx.moveTo(mapX(0), 0); lineCtx.lineTo(mapX(0), H); lineCtx.stroke();
    lineCtx.globalAlpha = 1;

    const cold = rgb(colors.anchor), hot = rgb(colors.cta);
    const buckets = new Array(32).fill(null).map(() => new Path2D());
    
    for (const ln of lines) {
      const p = ln.pts;
      for (let i = 1; i < p.length; i++) {
        let t = Math.log10(1 + ln.b[i] / bMax) / Math.log10(2);
        t = Math.max(0, Math.min(1, t));
        const bIdx = Math.floor(t * 31);
        buckets[bIdx].moveTo(mapX(p[i - 1][0]), mapZ(p[i - 1][1]));
        buckets[bIdx].lineTo(mapX(p[i][0]), mapZ(p[i][1]));
      }
    }
    
    lineCtx.globalAlpha = 0.85;
    lineCtx.lineWidth = 1.4;
    for (let i = 0; i < 32; i++) {
      const t = i / 31;
      const r = cold[0] + (hot[0] - cold[0]) * t;
      const g = cold[1] + (hot[1] - cold[1]) * t;
      const bl = cold[2] + (hot[2] - cold[2]) * t;
      lineCtx.strokeStyle = `rgb(${r | 0},${g | 0},${bl | 0})`;
      lineCtx.stroke(buckets[i]);
    }
    lineCtx.globalAlpha = 1;
  }

  function draw() {
    const W = canvas.width, H = canvas.height;
    ctx.fillStyle = colors.canvas; ctx.fillRect(0, 0, W, H);

    if (showHeat) ctx.drawImage(heatCanvas, 0, 0);
    ctx.drawImage(lineCanvas, 0, 0);

    if (showFlow) {
      ctx.strokeStyle = colors.text; ctx.globalAlpha = 0.28; ctx.lineWidth = 1.6;
      ctx.setLineDash([2, 16]); ctx.lineDashOffset = -dashPhase;
      for (const ln of lines) {
        const p = ln.pts;
        ctx.beginPath();
        for (let i = 0; i < p.length; i++) { const X = mapX(p[i][0]), Y = mapZ(p[i][1]); if (i === 0) ctx.moveTo(X, Y); else ctx.lineTo(X, Y); }
        ctx.stroke();
      }
      ctx.setLineDash([]); ctx.lineDashOffset = 0; ctx.globalAlpha = 1;
    }

    for (const gl of glyphs) {
      const cx = mapX(gl.x), cy = mapZ(gl.z), rr = 7;
      ctx.beginPath(); ctx.arc(cx, cy, rr, 0, Math.PI * 2);
      ctx.fillStyle = colors.canvas; ctx.fill();
      ctx.strokeStyle = colors.text; ctx.lineWidth = 1.5; ctx.stroke();
      ctx.strokeStyle = colors.text; ctx.lineWidth = 1.4;
      if (gl.into) {
        ctx.beginPath(); ctx.moveTo(cx - rr * 0.6, cy - rr * 0.6); ctx.lineTo(cx + rr * 0.6, cy + rr * 0.6);
        ctx.moveTo(cx + rr * 0.6, cy - rr * 0.6); ctx.lineTo(cx - rr * 0.6, cy + rr * 0.6); ctx.stroke();
      } else {
        ctx.beginPath(); ctx.arc(cx, cy, 1.8, 0, Math.PI * 2); ctx.fillStyle = colors.text; ctx.fill();
      }
    }
  }

  let isVisible = true;

  function startFlowLoop() {
    if (destroyed || !showFlow || reduceMotion) return;
    if (flowRafId) return;
    function tick() {
      if (destroyed || !showFlow || !isVisible || document.hidden) { flowRafId = null; return; }
      dashPhase = (dashPhase + 0.6) % 18; draw();
      flowRafId = requestAnimationFrame(tick);
    }
    flowRafId = requestAnimationFrame(tick);
  }

  function stopFlowLoop() {
    if (flowRafId) { cancelAnimationFrame(flowRafId); flowRafId = null; }
  }

  function updateFlowState() {
    if (showFlow && isVisible && !document.hidden && !reduceMotion) {
      startFlowLoop();
    } else {
      stopFlowLoop();
    }
  }

  const io = new IntersectionObserver((entries) => {
    isVisible = entries[0].isIntersecting && !document.hidden;
    updateFlowState();
  });
  io.observe(canvas);

  function handleVisibilityChange() {
    updateFlowState();
  }
  document.addEventListener('visibilitychange', handleVisibilityChange);

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const px = (e.clientX - rect.left) * (canvas.width / rect.width);
    const py = (e.clientY - rect.top) * (canvas.height / rect.height);
    const x = invX(px), z = invZ(py);
    const f = compiledFieldAt(compiledSegments, [x, 0, z]);
    const b = Math.hypot(f[0], f[1], f[2]);
    const uT = b * 1e6;
    document.getElementById('cur-B').textContent =
      uT > 1000 ? `${(uT / 1000).toFixed(2)} mT` : `${uT.toFixed(1)} µT`;
    const ang = Math.atan2(f[2], f[0]) * 180 / Math.PI;
    document.getElementById('cur-dir').textContent = `${ang.toFixed(0)}°`;
  });

  el.cur.addEventListener('input', () => { current = parseFloat(el.cur.value); el.curOut.textContent = current; buildScene(); draw(); });
  el.geom.addEventListener('input', () => {
    geom = parseFloat(el.geom.value);
    if (preset !== 'solenoid') el.geomOut.textContent = `${geom.toFixed(2)} R`;
    buildScene(); draw();
  });
  el.seed.addEventListener('input', () => { nSeeds = parseInt(el.seed.value, 10); el.seedOut.textContent = nSeeds; buildScene(); draw(); });

  document.querySelectorAll('[data-preset]').forEach((b) =>
    b.addEventListener('click', () => {
      preset = b.dataset.preset;
      if (preset !== 'solenoid') el.geomOut.textContent = `${geom.toFixed(2)} R`;
      document.querySelectorAll('[data-preset]').forEach((x) => x.classList.toggle('is-active', x === b));
      buildScene(); draw();
    }));

  const heatBtn = document.getElementById('heat-btn');
  heatBtn.addEventListener('click', () => { showHeat = !showHeat; heatBtn.classList.toggle('is-active', showHeat); draw(); });
  const flowBtn = document.getElementById('flow-btn');
  flowBtn.addEventListener('click', () => { showFlow = !showFlow; flowBtn.classList.toggle('is-active', showFlow); updateFlowState(); if (!showFlow) draw(); });

  const themeObserver = new MutationObserver(() => { readColors(); rebuildCachedLayers(); draw(); });
  themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  document.addEventListener('astro:before-swap', () => { 
    destroyed = true; 
    stopFlowLoop();
    themeObserver.disconnect(); 
    io.disconnect();
    document.removeEventListener('visibilitychange', handleVisibilityChange);
  }, { once: true });

  buildScene();
  draw();
  updateFlowState();
}

document.addEventListener('astro:page-load', initFieldTracer);
initFieldTracer();
</script>
