<script is:inline define:vars={{ weatherCities: weatherData.cities, satelliteTle: { line1: satelliteData.line1, line2: satelliteData.line2 } }}>
  window.__globeData = { weatherCities, satelliteTle };
</script>

<script>
  // @ts-nocheck
  import * as d3 from 'd3-geo';

  interface Pt { x: number; y: number; }
  interface LandFeature { type: 'Feature'; geometry: { type: 'Polygon' | 'MultiPolygon'; coordinates: any } }

  function initGlobe() {
    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.initialized === 'true') return;
    canvas.dataset.initialized = 'true';

    const ctx = canvas.getContext('2d')!;
    const W = canvas.width;
    const H = canvas.height;
    const R = W * 0.46;
    const CX = W / 2;
    const CY = H / 2;

    const globeData = (window as unknown as { __globeData: { weatherCities: WeatherCity[]; satelliteTle: { line1: string; line2: string } } }).__globeData;

    interface WeatherCity { name: string; lat: number; lon: number; tempC: number; weatherCode: number; windKph: number; humidity: number; observedAt: string; }

    function deg2rad(d: number) { return (d * Math.PI) / 180; }
    function rad2deg(r: number) { return (r * 180) / Math.PI; }

    function resolveColor(varName: string, fallback: string): string {
      const v = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
      return v || fallback;
    }
    let colors = {
      text: resolveColor('--mp-text', '#16202e'),
      muted: resolveColor('--mp-muted', '#4a5d6f'),
      border: resolveColor('--mp-border-strong', 'rgba(22,32,46,0.22)'),
      cta: resolveColor('--mp-cta', '#b8324f'),
      elevated: resolveColor('--mp-elevated', '#e8dfd1'),
      card: resolveColor('--mp-card', '#ffffff'),
    };
    let shadeThemeRevision = 0;
    const themeObserver = new MutationObserver(() => {
      colors = {
        text: resolveColor('--mp-text', '#16202e'),
        muted: resolveColor('--mp-muted', '#4a5d6f'),
        border: resolveColor('--mp-border-strong', 'rgba(22,32,46,0.22)'),
        cta: resolveColor('--mp-cta', '#b8324f'),
        elevated: resolveColor('--mp-elevated', '#e8dfd1'),
        card: resolveColor('--mp-card', '#ffffff'),
      };
      shadeThemeRevision++;
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // =====================================================================
    // d3-geo projection
    // =====================================================================
    let lambda0 = -20; // current spin (longitude of center), degrees
    const phi0 = 18;   // fixed tilt, degrees
    
    // For visibility tests in night shade logic
    const sinPhi0 = Math.sin(deg2rad(phi0));
    const cosPhi0 = Math.cos(deg2rad(phi0));

    const projection = d3.geoOrthographic()
      .scale(R)
      .translate([CX, CY])
      .clipAngle(90)
      .precision(0.1);

    const path = d3.geoPath(projection, ctx);
    const graticuleGenerator = d3.geoGraticule().step([30, 30]);

    // =====================================================================
    // Real astronomy: subsolar point + terminator great circle
    // =====================================================================
    function subsolarPoint(date: Date): { decl: number; lon: number } {
      const jd = date.getTime() / 86400000 + 2440587.5;
      const T = (jd - 2451545.0) / 36525;
      const meanLon = ((280.46646 + T * (36000.76983 + 0.0003032 * T)) % 360 + 360) % 360;
      const meanAnomaly = deg2rad(((357.52911 + T * (35999.05029 - 0.0001537 * T)) % 360 + 360) % 360);
      const equationOfCenter =
        Math.sin(meanAnomaly) * (1.914602 - T * (0.004817 + 0.000014 * T)) +
        Math.sin(2 * meanAnomaly) * (0.019993 - 0.000101 * T) +
        Math.sin(3 * meanAnomaly) * 0.000289;
      const omega = deg2rad(125.04 - 1934.136 * T);
      const apparentLon = deg2rad(meanLon + equationOfCenter - 0.00569 - 0.00478 * Math.sin(omega));
      const obliquity0 = 23 + (26 + (21.448 - T * (46.815 + T * (0.00059 - 0.001813 * T))) / 60) / 60;
      const obliquity = deg2rad(obliquity0 + 0.00256 * Math.cos(omega));
      const rightAscension = Math.atan2(Math.cos(obliquity) * Math.sin(apparentLon), Math.cos(apparentLon));
      const decl = rad2deg(Math.asin(Math.sin(obliquity) * Math.sin(apparentLon)));

      const gmst = 280.46061837 + 360.98564736629 * (jd - 2451545.0) + 0.000387933 * T * T - (T * T * T) / 38710000;
      const longitudeRaw = rad2deg(rightAscension) - gmst;
      const lon = ((longitudeRaw + 180) % 360 + 360) % 360 - 180;
      return { decl, lon };
    }

    function toVec3(latDeg: number, lonDeg: number): [number, number, number] {
      const phi = deg2rad(latDeg), lam = deg2rad(lonDeg);
      return [Math.cos(phi) * Math.cos(lam), Math.cos(phi) * Math.sin(lam), Math.sin(phi)];
    }
    function cross(a: number[], b: number[]): [number, number, number] {
      return [a[1] * b[2] - a[2] * b[1], a[2] * b[0] - a[0] * b[2], a[0] * b[1] - a[1] * b[0]];
    }
    function normalize(a: number[]): [number, number, number] {
      const m = Math.hypot(a[0], a[1], a[2]);
      return [a[0] / m, a[1] / m, a[2] / m];
    }
    function toLatLon(v: number[]): { lat: number; lon: number } {
      return { lat: rad2deg(Math.asin(Math.max(-1, Math.min(1, v[2])))), lon: rad2deg(Math.atan2(v[1], v[0])) };
    }

    function terminatorLatLon(decl: number, ssLon: number): { lat: number; lon: number }[] {
      const s = toVec3(decl, ssLon);
      const ref: [number, number, number] = Math.abs(s[2]) < 0.9 ? [0, 0, 1] : [0, 1, 0];
      const u = normalize(cross(ref, s));
      const v = normalize(cross(s, u));
      const points: { lat: number; lon: number }[] = [];
      for (let i = 0; i <= 180; i++) {
        const t = deg2rad(i * 2);
        const p = [
          Math.cos(t) * u[0] + Math.sin(t) * v[0],
          Math.cos(t) * u[1] + Math.sin(t) * v[1],
          Math.cos(t) * u[2] + Math.sin(t) * v[2],
        ];
        points.push(toLatLon(p));
      }
      return points;
    }

    const SHADE_SIZE = 256;
    const nightShadeCanvas = document.createElement('canvas');
    nightShadeCanvas.width = SHADE_SIZE;
    nightShadeCanvas.height = SHADE_SIZE;
    const nightShadeCtx = nightShadeCanvas.getContext('2d')!;
    let lastShadeLambda = Number.NaN;
    let lastShadeSolarMinute = -1;
    let renderedThemeRevision = -1;

    function longitudeDelta(a: number, b: number): number {
      return Math.abs(((a - b + 540) % 360) - 180);
    }

    function updateNightShade(date: Date, decl: number, ssLon: number) {
      const solarMinute = Math.floor(date.getTime() / 60000);
      const needsUpdate =
        !Number.isFinite(lastShadeLambda) ||
        longitudeDelta(lambda0, lastShadeLambda) >= 0.2 ||
        solarMinute !== lastShadeSolarMinute ||
        renderedThemeRevision !== shadeThemeRevision;
      if (!needsUpdate) return;

      const sun = toVec3(decl, ssLon);
      const centerLon = deg2rad(lambda0);
      const east: [number, number, number] = [-Math.sin(centerLon), Math.cos(centerLon), 0];
      const up: [number, number, number] = [
        -sinPhi0 * Math.cos(centerLon),
        -sinPhi0 * Math.sin(centerLon),
        cosPhi0,
      ];
      const view: [number, number, number] = [
        cosPhi0 * Math.cos(centerLon),
        cosPhi0 * Math.sin(centerLon),
        sinPhi0,
      ];
      const sunEast = sun[0] * east[0] + sun[1] * east[1] + sun[2] * east[2];
      const sunUp = sun[0] * up[0] + sun[1] * up[1] + sun[2] * up[2];
      const sunView = sun[0] * view[0] + sun[1] * view[1] + sun[2] * view[2];
      const darkTheme = document.documentElement.dataset.theme === 'dark';
      const nightRgb = darkTheme ? [0, 5, 14] : [9, 24, 47];
      const image = nightShadeCtx.createImageData(SHADE_SIZE, SHADE_SIZE);

      for (let py = 0; py < SHADE_SIZE; py++) {
        const sy = 1 - ((py + 0.5) / SHADE_SIZE) * 2;
        for (let px = 0; px < SHADE_SIZE; px++) {
          const sx = ((px + 0.5) / SHADE_SIZE) * 2 - 1;
          const radial2 = sx * sx + sy * sy;
          if (radial2 > 1) continue;
          const towardViewer = Math.sqrt(Math.max(0, 1 - radial2));
          const solarDot = sx * sunEast + sy * sunUp + towardViewer * sunView;
          if (solarDot >= 0) continue;
          const i = (py * SHADE_SIZE + px) * 4;
          image.data[i] = nightRgb[0];
          image.data[i + 1] = nightRgb[1];
          image.data[i + 2] = nightRgb[2];
          image.data[i + 3] = Math.round((darkTheme ? 0.48 : 0.44) * 255 + Math.min(1, -solarDot) * 42);
        }
      }
      nightShadeCtx.putImageData(image, 0, 0);
      lastShadeLambda = lambda0;
      lastShadeSolarMinute = solarMinute;
      renderedThemeRevision = shadeThemeRevision;
    }

    function drawNightShade(date: Date, decl: number, ssLon: number) {
      updateNightShade(date, decl, ssLon);
      ctx.drawImage(nightShadeCanvas, CX - R, CY - R, R * 2, R * 2);
    }

    // =====================================================================
    // Simplified two-body ISS propagation from real TLE
    // =====================================================================
    const GM = 398600.4418;
    const EARTH_RADIUS_KM = 6378.137;

    function parseTle(line1: string, line2: string) {
      const epochStr = line1.substring(18, 32).trim();
      const yy = parseInt(epochStr.substring(0, 2), 10);
      const year = yy < 57 ? 2000 + yy : 1900 + yy;
      const dayOfYear = parseFloat(epochStr.substring(2));
      const epochMs = Date.UTC(year, 0, 1) + (dayOfYear - 1) * 86400000;
      const inc = parseFloat(line2.substring(8, 16));
      const raan = parseFloat(line2.substring(17, 25));
      const ecc = parseFloat(`0.${line2.substring(26, 33).trim()}`);
      const argp = parseFloat(line2.substring(34, 42));
      const meanAnom0 = parseFloat(line2.substring(43, 51));
      const meanMotion = parseFloat(line2.substring(52, 63));
      const nRadS = (meanMotion * 2 * Math.PI) / 86400;
      const a = Math.cbrt(GM / (nRadS * nRadS));
      return { epochMs, inc, raan, ecc, argp, meanAnom0, nRadS, a };
    }

    function gmstRad(dateMs: number): number {
      const jd = dateMs / 86400000 + 2440587.5;
      const T = (jd - 2451545.0) / 36525;
      let gmst = 280.46061837 + 360.98564736629 * (jd - 2451545.0) + 0.000387933 * T * T - (T * T * T) / 38710000;
      gmst = ((gmst % 360) + 360) % 360;
      return deg2rad(gmst);
    }

    function propagate(elems: ReturnType<typeof parseTle>, dateMs: number) {
      const dtSec = (dateMs - elems.epochMs) / 1000;
      let M = deg2rad(elems.meanAnom0) + elems.nRadS * dtSec;
      M = ((M % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
      let E = M;
      for (let i = 0; i < 15; i++) E -= (E - elems.ecc * Math.sin(E) - M) / (1 - elems.ecc * Math.cos(E));
      const nu = 2 * Math.atan2(Math.sqrt(1 + elems.ecc) * Math.sin(E / 2), Math.sqrt(1 - elems.ecc) * Math.cos(E / 2));
      const r = elems.a * (1 - elems.ecc * Math.cos(E));
      const xOrb = r * Math.cos(nu), yOrb = r * Math.sin(nu);
      const w = deg2rad(elems.argp), inc = deg2rad(elems.inc), om = deg2rad(elems.raan);
      const cw = Math.cos(w), sw = Math.sin(w), ci = Math.cos(inc), si = Math.sin(inc), co = Math.cos(om), so = Math.sin(om);
      const x = (co * cw - so * sw * ci) * xOrb + (-co * sw - so * cw * ci) * yOrb;
      const y = (so * cw + co * sw * ci) * xOrb + (-so * sw + co * cw * ci) * yOrb;
      const z = sw * si * xOrb + cw * si * yOrb;
      const theta = gmstRad(dateMs);
      const xEcef = x * Math.cos(theta) + y * Math.sin(theta);
      const yEcef = -x * Math.sin(theta) + y * Math.cos(theta);
      const zEcef = z;
      const rMag = Math.hypot(xEcef, yEcef, zEcef);
      const lat = rad2deg(Math.asin(zEcef / rMag));
      const lon = rad2deg(Math.atan2(yEcef, xEcef));
      const alt = rMag - EARTH_RADIUS_KM;
      const speedKmS = Math.sqrt(GM * (2 / r - 1 / elems.a));
      return { lat, lon, alt, speedKmS };
    }

    const issElems = parseTle(globeData.satelliteTle.line1, globeData.satelliteTle.line2);

    // =====================================================================
    // Land data
    // =====================================================================
    let land: LandFeature[] = [];
    const landAbortController = new AbortController();
    fetch('/data/world-land-110m.json', { signal: landAbortController.signal })
      .then((r) => {
        if (!r.ok) throw new Error(`Coastline request failed: ${r.status}`);
        return r.json();
      })
      .then((geojson) => { land = geojson.features; })
      .catch((error) => {
        if ((error as Error).name !== 'AbortError') land = [];
      });

    // =====================================================================
    // Mode state
    // =====================================================================
    type Mode = 'daynight' | 'weather' | 'satellite';
    let mode: Mode = 'daynight';

    const modeButtons = document.querySelectorAll<HTMLButtonElement>('.mode-btn');
    const panels: Record<Mode, HTMLElement> = {
      daynight: document.querySelector('[data-panel="daynight"]')!,
      weather: document.querySelector('[data-panel="weather"]')!,
      satellite: document.querySelector('[data-panel="satellite"]')!,
    };

    function setMode(next: Mode) {
      mode = next;
      modeButtons.forEach((b) => b.classList.toggle('is-active', b.dataset.mode === next));
      (Object.keys(panels) as Mode[]).forEach((k) => panels[k].classList.toggle('hidden', k !== next));
      draw();
    }

    modeButtons.forEach((btn) => btn.addEventListener('click', () => setMode(btn.dataset.mode as Mode)));

    // =====================================================================
    // Weather list panel
    // =====================================================================
    const weatherListEl = document.getElementById('weather-list')!;
    weatherListEl.innerHTML = globeData.weatherCities
      .map((c) => `<div class="flex items-center justify-between"><span>${c.name}</span><span class="font-semibold">${Math.round(c.tempC)}°C</span></div>`)
      .join('');

    function tempColor(tempC: number): string {
      const stops: [number, [number, number, number]][] = [
        [-15, [70, 120, 200]],
        [5, [90, 170, 190]],
        [20, [130, 180, 110]],
        [30, [220, 170, 70]],
        [40, [200, 70, 60]],
      ];
      const t = Math.max(stops[0][0], Math.min(stops[stops.length - 1][0], tempC));
      for (let i = 0; i < stops.length - 1; i++) {
        const [t0, c0] = stops[i];
        const [t1, c1] = stops[i + 1];
        if (t >= t0 && t <= t1) {
          const f = (t - t0) / (t1 - t0);
          const r = Math.round(c0[0] + (c1[0] - c0[0]) * f);
          const g = Math.round(c0[1] + (c1[1] - c0[1]) * f);
          const b = Math.round(c0[2] + (c1[2] - c0[2]) * f);
          return `rgb(${r},${g},${b})`;
        }
      }
      return 'rgb(150,150,150)';
    }

    const issTrail: Pt[] = [];
    let issTrailTimestamp = -1;
    const issLatEl = document.getElementById('iss-lat')!;
    const issLonEl = document.getElementById('iss-lon')!;
    const issAltEl = document.getElementById('iss-alt')!;
    const issSpeedEl = document.getElementById('iss-speed')!;
    const earthUtcEl = document.getElementById('earth-utc')!;
    const subsolarPointEl = document.getElementById('subsolar-point')!;

    let autoRotate = true;
    const animationToggle = document.getElementById('animation-toggle') as HTMLButtonElement;
    animationToggle.addEventListener('click', () => {
      autoRotate = !autoRotate;
      animationToggle.textContent = autoRotate ? 'Pause rotation' : 'Play rotation';
      animationToggle.setAttribute('aria-pressed', String(autoRotate));
    });

    let renderWireframe = true;
    const styleToggle = document.getElementById('style-toggle') as HTMLButtonElement;
    styleToggle.textContent = 'Wireframe';
    styleToggle.classList.add('is-active');

    styleToggle.addEventListener('click', () => {
      renderWireframe = !renderWireframe;
      styleToggle.textContent = renderWireframe ? 'Wireframe' : 'Filled';
      styleToggle.classList.toggle('is-active', renderWireframe);
      draw();
    });

    // =====================================================================
    // Main draw loop
    // =====================================================================
    function draw() {
      // Update projection rotation
      projection.rotate([-lambda0, -phi0, 0]);

      ctx.clearRect(0, 0, CX * 2, CY * 2);

      ctx.save();
      // Clip to globe circle for background and shading
      ctx.beginPath();
      ctx.arc(CX, CY, R, 0, Math.PI * 2);
      ctx.clip();

      // Background
      ctx.beginPath();
      ctx.arc(CX, CY, R, 0, Math.PI * 2);
      ctx.fillStyle = colors.elevated;
      ctx.fill();
      ctx.strokeStyle = colors.border;
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.restore();

      ctx.save();
      // Graticule
      ctx.beginPath();
      path(graticuleGenerator());
      ctx.strokeStyle = colors.border;
      ctx.globalAlpha = 0.35;
      ctx.lineWidth = 0.6;
      ctx.stroke();
      ctx.globalAlpha = 1;

      const now = new Date();
      const { decl, lon: ssLon } = subsolarPoint(now);
      earthUtcEl.textContent = now.toISOString().replace('T', ' ').replace(/\.\d{3}Z$/, ' UTC');
      subsolarPointEl.textContent = `${Math.abs(decl).toFixed(2)}°${decl >= 0 ? 'N' : 'S'}, ${Math.abs(ssLon).toFixed(2)}°${ssLon >= 0 ? 'E' : 'W'}`;

      // Land
      for (const feature of land) {
        ctx.beginPath();
        path(feature as any);
        if (renderWireframe) {
          ctx.strokeStyle = colors.text;
          ctx.lineWidth = 1;
          ctx.globalAlpha = mode === 'daynight' ? 0.72 : 0.4;
          ctx.stroke();
        } else {
          ctx.fillStyle = colors.text;
          ctx.globalAlpha = mode === 'daynight' ? 0.82 : 0.55;
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }

      ctx.save();
      ctx.beginPath();
      ctx.arc(CX, CY, R, 0, Math.PI * 2);
      ctx.clip();
      if (mode === 'daynight') drawNightShade(now, decl, ssLon);
      ctx.restore();

      // Terminator line
      if (mode === 'daynight') {
        const termPts = terminatorLatLon(decl, ssLon);
        const termLine = {
          type: 'LineString',
          coordinates: termPts.map((p) => [p.lon, p.lat]),
        };
        ctx.beginPath();
        path(termLine as any);
        ctx.strokeStyle = colors.cta;
        ctx.lineWidth = 1.5;
        ctx.globalAlpha = 0.8;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }

      // Weather cities
      if (mode === 'weather') {
        for (const city of globeData.weatherCities) {
          const point = { type: 'Point', coordinates: [city.lon, city.lat] };
          path.pointRadius(5);
          ctx.beginPath();
          path(point as any);
          ctx.fillStyle = tempColor(city.tempC);
          ctx.fill();
          ctx.lineWidth = 1;
          ctx.strokeStyle = colors.card;
          ctx.stroke();
        }
      }

      // ISS
      if (mode === 'satellite') {
        const nowMs = Date.now();
        const posNow = propagate(issElems, nowMs);
        const currentSecond = Math.floor(nowMs / 1000);
        if (currentSecond !== issTrailTimestamp) {
          issTrail.length = 0;
          for (let offsetSeconds = -25 * 60; offsetSeconds <= 0; offsetSeconds += 30) {
            const trailPos = propagate(issElems, nowMs + offsetSeconds * 1000);
            issTrail.push({ x: trailPos.lat, y: trailPos.lon });
          }
          issTrailTimestamp = currentSecond;
        }

        // Draw trail
        const trailLine = {
          type: 'LineString',
          coordinates: issTrail.map((t) => [t.y, t.x]),
        };
        ctx.beginPath();
        path(trailLine as any);
        ctx.strokeStyle = colors.cta;
        ctx.lineWidth = 2;
        ctx.globalAlpha = 0.7;
        ctx.stroke();
        ctx.globalAlpha = 1;

        // Draw ISS
        const point = { type: 'Point', coordinates: [posNow.lon, posNow.lat] };
        path.pointRadius(5);
        ctx.beginPath();
        path(point as any);
        ctx.fillStyle = colors.cta;
        ctx.fill();

        issLatEl.textContent = `${posNow.lat.toFixed(2)}°`;
        issLonEl.textContent = `${posNow.lon.toFixed(2)}°`;
        issAltEl.textContent = `${posNow.alt.toFixed(0)} km`;
        issSpeedEl.textContent = `${posNow.speedKmS.toFixed(2)} km/s`;
      }
      ctx.restore();
    }

    // =====================================================================
    // Drag interaction
    // =====================================================================
    let isDragging = false;
    let dragStartX = 0;
    let lambdaAtDragStart = 0;

    canvas.addEventListener('pointerdown', (e) => {
      isDragging = true;
      dragStartX = e.clientX;
      lambdaAtDragStart = lambda0;
      canvas.setPointerCapture(e.pointerId);
    });
    canvas.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - dragStartX;
      lambda0 = lambdaAtDragStart - dx * 0.3;
    });

    function endDrag() {
      isDragging = false;
    }

    canvas.addEventListener('pointerup', endDrag);
    canvas.addEventListener('pointercancel', endDrag);
    canvas.addEventListener('lostpointercapture', endDrag);
    window.addEventListener('blur', endDrag);

    const AUTO_ROTATION_DEG_PER_SECOND = 2.4;
    let lastFrameTime = performance.now();
    let animationFrameId = 0;
    let destroyed = false;

    function loop(frameTime: number) {
      if (destroyed) return;
      const deltaSeconds = Math.min(0.05, Math.max(0, frameTime - lastFrameTime) / 1000);
      lastFrameTime = frameTime;
      if (!isVisible) {
        animationFrameId = requestAnimationFrame(loop);
        return;
      }
      if (!isDragging && autoRotate) {
        lambda0 = ((lambda0 + AUTO_ROTATION_DEG_PER_SECOND * deltaSeconds + 540) % 360) - 180;
      }
      draw();
      animationFrameId = requestAnimationFrame(loop);
    }
    draw();
    animationFrameId = requestAnimationFrame(loop);

    let isVisible = true;
    const io = new IntersectionObserver((entries) => {
      isVisible = entries[0].isIntersecting && !document.hidden;
    });
    io.observe(canvas);

    function handleVisibilityChange() {
      lastFrameTime = performance.now();
      isVisible = !document.hidden;
    }
    document.addEventListener('visibilitychange', handleVisibilityChange);

    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = btn.dataset.copyTarget;
        const codeEl = targetId ? document.getElementById(targetId) : null;
        if (!codeEl) return;
        try {
          await navigator.clipboard.writeText(codeEl.textContent ?? '');
          const original = btn.textContent;
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = original; }, 1500);
        } catch {}
      });
    });

    document.addEventListener('astro:before-swap', () => {
      destroyed = true;
      cancelAnimationFrame(animationFrameId);
      landAbortController.abort();
      themeObserver.disconnect();
      io.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
      window.removeEventListener('blur', endDrag);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initGlobe);
  initGlobe();
</script>
