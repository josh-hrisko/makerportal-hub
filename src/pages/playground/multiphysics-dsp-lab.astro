---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';
import Math from '../../components/Math.astro';

const title = 'Audio & Acoustics Toolbox — Engineering tools for sound, DSP & loudspeakers | MakerPortal';
const description = 'Serious engineering tools for audio, acoustics, DSP, and loudspeaker design: room modes, pole-zero filters, enclosure alignment, driver nonlinearity, thermal compression, cone breakup, and fast acoustic calculators.';
const canonical = new URL('/playground/multiphysics-dsp-lab', Astro.site);

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Audio & Acoustics Toolbox', item: canonical.toString() },
  ],
};

const tools = [
  {
    slug: 'acoustic-calculators',
    title: 'Acoustic Calculators',
    tagline: 'Wavelength, SPL, RT60, delay — the numbers you reach for daily',
    description: 'Bench-ready math: wavelength, SPL summation, RT60 Sabine vs Eyring, critical distance, port tuning, Helmholtz resonance, speed of sound vs temperature. No fluff — just formulas turned into sliders.',
    emoji: '📐',
  },
  {
    slug: 'acoustics-room-modes',
    title: 'Room Mode Analyzer',
    tagline: 'Where bass piles up and why your room lies',
    description: 'Rectangular eigenfrequencies, axial/tangential sorting, Schroeder frequency, pressure anti-nodes. Modal density collapses below Schroeder — you hear the room, not the speaker.',
    emoji: '🏠',
  },
  {
    slug: 'pole-zero-explorer',
    title: 'Pole-Zero Filter Explorer',
    tagline: 'Drag poles, hear the math bite',
    description: 'Z-plane is destiny: poles inside unit circle stable. Drag pairs → magnitude, phase, group-delay. RBJ export, Web Audio audition.',
    emoji: '🎛️',
  },
  {
    slug: 'loudspeaker-enclosure-designer',
    title: 'Loudspeaker Enclosure Designer',
    tagline: 'Box as spring, port as mass — Thiele-Small alignment',
    description: 'Compliance ratio sets Qtc and fc. Butterworth 0.707, Bessel 0.577. QB3/SBB4/SC4 via Small 1973. Hoffman Iron Law: small, deep, loud — pick two.',
    emoji: '🔊',
  },
  {
    slug: 'loudspeaker-nonlinearity-lab',
    title: 'Driver Nonlinearity Lab',
    tagline: 'Bl(x), Kms(x), Le(x) — why sine out ≠ sine in',
    description: 'Motor force, suspension stiffness, inductance modulation. Even vs odd harmonics from Taylor expansion, THD, Klippel-style visualization.',
    emoji: '⚡',
  },
  {
    slug: 'voice-coil-thermal-compression',
    title: 'Voice-Coil Thermal Compression',
    tagline: 'Power in, heat stays, SPL sags',
    description: 'Thermal RC: coil tau vs magnet tau. Resistance rises with temperature, current falls, SPL compresses. Copper turns into a limiter.',
    emoji: '🌡️',
  },
  {
    slug: 'cone-breakup',
    title: 'Cone Breakup Explorer',
    tagline: 'Piston to chaos — bending waves win',
    description: 'Bending stiffness, dispersive wave speed, modal patterns with Bessel functions, breakup scales with sqrt(E/ρ)/diameter.',
    emoji: '📢',
  },
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>
  </Fragment>

  <PlaygroundShell
    title="Audio & Acoustics Toolbox"
    lead="Seven instruments for when air, electricity, and mechanics have to agree. Each is a bench, not a demo — built to make invisible physics visible: how a box stiffens a resonance, how a coil leaves a gap, how a cone forgets it is a piston, how a room piles bass into corners, how heat turns into compression, how a pole-zero pair sings."
    pillarHint="dsp-audio"
  >
    <section class="border-b border-border" aria-labelledby="tools-title">
      <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 sm:py-16 lg:px-10">
        <h2 id="tools-title" class="text-[clamp(1.35rem,3vw,1.7rem)] font-[650] tracking-[-0.03em] text-primary-text">Choose a tool</h2>
        <p class="mt-2 max-w-2xl text-[0.92rem] leading-[1.6] text-muted-text">
          Each tool opens as its own page with shareable URLs, focused controls, and detailed method notes. Nothing runs in the background — open only what you need.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {tools.map((tool) => (
            <a
              href={`/playground/${tool.slug}`}
              class="group flex flex-col rounded-[20px] border border-border bg-card-bg p-5 transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated"
            >
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-[1.05rem] font-semibold leading-tight text-primary-text transition-colors group-hover:text-primary-cta">{tool.title}</h3>
                <span class="shrink-0 text-xl" aria-hidden="true">{tool.emoji}</span>
              </div>
              <p class="mt-1.5 text-[0.82rem] leading-[1.45] text-muted-text">{tool.tagline}</p>
              <p class="mt-2 text-[0.76rem] leading-[1.5] text-muted-text/75">{tool.description}</p>
              <span class="mt-3 inline-flex items-center gap-1 font-mono text-[0.65rem] uppercase tracking-[0.08em] text-primary-cta">
                Open tool <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="philosophy-title">
      <div class="mx-auto max-w-[70rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="philosophy-title" class="text-[clamp(1.45rem,3vw,1.85rem)] font-[680] tracking-[-0.03em] text-primary-text">Frontier instruments, not demos</h2>
        <p class="mt-3 max-w-3xl text-[0.95rem] leading-[1.7] text-muted-text">
          Loudspeaker design is multiphysics. Electrical current makes force, force fights suspension and air load, cone bends, room stores energy, copper heats and fights back. This toolbox splits that chain into seven focused benches where you can turn one knob and see consequence instantly — no background simulation, no hidden state.
        </p>

        <div class="mt-8 grid gap-5 md:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/30 p-5">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.11em] text-muted-text">Electrical ↔ Mechanical</p>
            <p class="mt-2 text-[0.9rem] font-[600] tracking-[-0.02em] text-primary-text">Pole-Zero + Nonlinearity Lab</p>
            <div class="mt-2 text-[0.82rem] leading-[1.6] text-muted-text space-y-3">
              <p>Every filter is a pole-zero placement: <Math math="H(z)=\frac{\prod(1-q_k z^{-1})}{\prod(1-p_k z^{-1})}" /></p>
              <p>Drag a pair, magnitude and group-delay tilt. Then meet the motor: <Math math="Bl(x)" /> droop clips force, <Math math="K_{ms}(x)" /> cubes displacement, <Math math="Le(x)" /> modulates current. Taylor <Math math="a_2x^2 \to 2f" />, <Math math="a_3x^3 \to 3f" />. One bench shows linear dream, the next why it fails at power.</p>
            </div>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/30 p-5">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.11em] text-muted-text">Volume ↔ Mass</p>
            <p class="mt-2 text-[0.9rem] font-[600] tracking-[-0.02em] text-primary-text">Enclosure Designer + Acoustic Calculators</p>
            <div class="mt-2 text-[0.82rem] leading-[1.6] text-muted-text space-y-3">
              <p>Thiele-Small: two springs, one mass. Compliance <Math math="\alpha=\frac{V_{as}}{V_b}" /> sets <Math math="Q_{tc}=Q_{ts}\sqrt{1+\alpha}" /> and <Math math="f_c=f_s\sqrt{1+\alpha}" />. Vented adds Helmholtz <Math math="f_b" />.</p>
              <p>Hoffman <Math math="\eta_0 V_b f_3^3 = const" /> → small / deep / loud — pick two. Calculators give <Math math="\lambda=c/f" />, Sabine <Math math="T_{60}=0.161V/A" />, port <Math math="L_p=\frac{c^2S_p}{4\pi^2f_b^2V_b}-0.732r_p" />.</p>
            </div>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/30 p-5">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.11em] text-muted-text">Piston ↔ Breakup</p>
            <p class="mt-2 text-[0.9rem] font-[600] tracking-[-0.02em] text-primary-text">Cone Breakup Explorer + Waveguide Designer</p>
            <div class="mt-2 text-[0.82rem] leading-[1.6] text-muted-text space-y-3">
              <p>Low <Math math="ka" /> → piston. Bending stiffness <Math math="B=\frac{Et^3}{12(1-\nu^2)}" /> sets <Math math="c_b=\left(\frac{B}{\rho h}\right)^{1/4}\sqrt{\omega}" />.</p>
              <p>Modes <Math math="w_{mn}\propto J_m(\alpha_{mn}r/R)\cos m\theta" />. Breakup <Math math="f_{breakup}\propto\frac{\sqrt{E/\rho}}{D}" />. Waveguide mouth <Math math="ka" /> must hold pattern: OSWG <Math math="S=S_0(1+(x/a)^2)" /> CD, exponential <Math math="S=S_0e^{mx}" /> beams.</p>
            </div>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/30 p-5">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.11em] text-muted-text">Energy storage</p>
            <p class="mt-2 text-[0.9rem] font-[600] tracking-[-0.02em] text-primary-text">Room Modes + Thermal Compression</p>
            <div class="mt-2 text-[0.82rem] leading-[1.6] text-muted-text space-y-3">
              <p>Room <Math math="f_{modes}=\frac{c}{2}\sqrt{(n_x/L_x)^2+(n_y/L_y)^2+(n_z/L_z)^2}" />. Below Schroeder <Math math="f_s=2000\sqrt{T_{60}/V}" /> modes isolated — you hear room.</p>
              <p>Thermal: <Math math="R_e(T)=R_{e0}(1+\alpha_{cu}\Delta T)" />, drop <Math math="10\log_{10}(R_{e0}/R_e)" />. Heat is final compressor.</p>
            </div>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/50 p-5 md:col-span-2">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.11em] text-muted-text">How to use — 3 rules</p>
            <div class="mt-3 grid gap-4 sm:grid-cols-3 text-[0.82rem] leading-[1.6] text-muted-text">
              <div>
                <p class="font-semibold text-primary-text">1. Start frozen.</p>
                <p class="mt-1">Each tool opens at a known-good state. Watch 5 seconds. See default <Math math="f_b" />, <Math math="Q_{tc}" />, coherence, <Math math="Bl(x)" /> bell.</p>
              </div>
              <div>
                <p class="font-semibold text-primary-text">2. One knob, one effect.</p>
                <p class="mt-1">Move <Math math="D" /> and <Math math="f_{breakup}\propto1/D" />. Change <Math math="V_b" /> and <Math math="\alpha" /> shifts <Math math="f_c" />. Add <Math math="\beta" /> and 2nd harmonic rises. Causal chain is lesson.</p>
              </div>
              <div>
                <p class="font-semibold text-primary-text">3. Read the bottom.</p>
                <p class="mt-1">Every tool has 4–5 frontier notes: hook, intuition, math, playbook, honesty. Honesty tells where model stops — no FEA, no BEM, no Klippel rig. That boundary is part of instrument.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </PlaygroundShell>
</Layout>
