.line-clamp-3{display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
</style>

<script>
// @ts-nocheck
function initSLAM(){
  const slamCanvas = document.getElementById('slam-canvas');
  if(!slamCanvas || slamCanvas.dataset.init) return;
  slamCanvas.dataset.init='true';
  const cloudCanvas = document.getElementById('cloud-canvas');
  const bowCanvas = document.getElementById('bow-canvas');
  const sCtx = slamCanvas.getContext('2d');
  const cCtx = cloudCanvas.getContext('2d');
  const bCtx = bowCanvas.getContext('2d');
  const dpr = Math.min(window.devicePixelRatio||1,2);
  [[slamCanvas,960,540],[cloudCanvas,560,300],[bowCanvas,320,120]].forEach(([c,W0,H0])=>{
    const W=W0,H=H0; c.width=W*dpr; c.height=H*dpr; c.style.width=W+'px'; c.style.height=H+'px'; c.getContext('2d').scale(dpr,dpr);
  });
  const W=960,H=540, CW=560,CH=300;

  // UI
  const slMotion=document.getElementById('sl-motion'), slObs=document.getElementById('sl-obs'), slFeat=document.getElementById('sl-feat');
  const slV=document.getElementById('sl-v'), slWrpm=document.getElementById('sl-w'), slRange=document.getElementById('sl-range');
  const outMotion=document.getElementById('out-motion'), outObs=document.getElementById('out-obs'), outFeat=document.getElementById('out-feat');
  const outV=document.getElementById('out-v'), outW=document.getElementById('out-w'), outRange=document.getElementById('out-range');
  const chkLoop=document.getElementById('chk-loop'), chkAudio=document.getElementById('chk-audio'), chkTrue=document.getElementById('chk-true');
  const btnPlay=document.getElementById('btn-play'), btnReset=document.getElementById('btn-reset');
  const roTrue=document.getElementById('ro-true'), roEst=document.getElementById('ro-est'), roATE=document.getElementById('ro-ate'), roCov=document.getElementById('ro-cov');
  const roVis=document.getElementById('ro-vis'), roLoopC=document.getElementById('ro-loop'), roMap=document.getElementById('ro-map');
  const roBow=document.getElementById('ro-bow'), barBow=document.getElementById('bar-bow'), loopFlash=document.getElementById('loop-flash');
  const roLoopDist=document.getElementById('ro-loopdist'), roDrift=document.getElementById('ro-drift'), roFov=document.getElementById('ro-fov'), roTime=document.getElementById('ro-time');
  const flashOverlay=document.getElementById('flash-overlay');

  function updOut(){
    outMotion.textContent=slMotion.value; outObs.textContent=slObs.value; outFeat.textContent=slFeat.value;
    outV.textContent=slV.value; outW.textContent=slWrpm.value; outRange.textContent=slRange.value;
  }
  [slMotion,slObs,slFeat,slV,slWrpm,slRange].forEach(el=>el.addEventListener('input',updOut));
  updOut();

  // Utils
  function rand(){ return Math.random(); }
  function randn(){
    let u=0,v=0; while(u===0) u=Math.random(); while(v===0) v=Math.random();
    return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);
  }
  function wrap(a){ return Math.atan2(Math.sin(a),Math.cos(a)); }

  // Audio
  let audioCtx=null, masterGain=null;
  function ensureAudio(){
    if(audioCtx) return audioCtx;
    audioCtx=new (window.AudioContext||window.webkitAudioContext)();
    masterGain=audioCtx.createGain(); masterGain.gain.value=0.28; masterGain.connect(audioCtx.destination);
    return audioCtx;
  }
  function playSnap(relX, relY, drift){
    if(!chkAudio.checked) return;
    const ctx=ensureAudio(); ctx.resume();
    const panner=ctx.createPanner(); panner.panningModel='HRTF'; panner.distanceModel='inverse';
    const azimuth=Math.atan2(relY,relX); // left-right
    const dist=Math.sqrt(relX*relX+relY*relY)+1;
    panner.positionX.value=Math.sin(azimuth)*2;
    panner.positionY.value=0;
    panner.positionZ.value=-Math.cos(azimuth)*2;
    const comp=ctx.createDynamicsCompressor(); comp.threshold.value=-18; comp.ratio.value=8;
    panner.connect(comp); comp.connect(masterGain);
    const t=ctx.currentTime;
    // dual oscillator
    [[880,0.22,0.25],[2640,0.14,0.18]].forEach(([freq,g,dec])=>{
      const o=ctx.createOscillator(); o.type='sine'; o.frequency.value=freq;
      const gn=ctx.createGain(); gn.gain.setValueAtTime(0,t); gn.gain.linearRampToValueAtTime(g*(0.7+drift*0.2),t+0.01); gn.gain.exponentialRampToValueAtTime(0.001, t+dec);
      o.connect(gn); gn.connect(panner); o.start(t); o.stop(t+dec+0.05);
    });
    // noise burst
    const bufferSize=Math.floor(ctx.sampleRate*0.12);
    const buf=ctx.createBuffer(1,bufferSize,ctx.sampleRate);
    const ch=buf.getChannelData(0);
    for(let i=0;i<bufferSize;i++){
      const env=Math.exp(-i/(bufferSize*0.22));
      ch[i]=(Math.random()*2-1)*env*0.6;
    }
    const src=ctx.createBufferSource(); src.buffer=buf;
    const bp=ctx.createBiquadFilter(); bp.type='bandpass'; bp.frequency.value=3400+drift*800; bp.Q.value=0.8;
    const gN=ctx.createGain(); gN.gain.setValueAtTime(0.32,t); gN.gain.exponentialRampToValueAtTime(0.001,t+0.18);
    src.connect(bp); bp.connect(gN); gN.connect(panner); src.start(t); src.stop(t+0.16);
  }

  // World
  let truePose={x:0,y:0,th:0};
  let odomPose={x:0,y:0,th:0}; // dead reckoning only
  let mu=[]; // state
  let P=[]; // covariance matrix
  let seen=[]; // bool per landmark
  let landmarks=[]; // true {x,y,z,wrd}
  let trails={true:[], est:[], odom:[]};
  let keyframes=[]; // {mu:[x,y,th], true:[x,y], bow: array 32, ids:[]}
  let loopCount=0, flashTimer=0, time=0;
  let isPlaying=true;
  let bowCurr=new Array(32).fill(0);

  function initWorld(){
    const N=parseInt(slFeat.value);
    landmarks=[];
    for(let i=0;i<N;i++){
      const angle=rand()*Math.PI*2;
      const radius=2.5+rand()*9.5;
      // bias to make loop more feature rich near loop path
      let x=radius*Math.cos(angle)+(rand()-0.5)*1.5;
      let y=radius*Math.sin(angle)+(rand()-0.5)*1.5;
      // avoid very close to origin too many
      if(Math.hypot(x,y)<1.2){ x+= (x>=0?1.2:-1.2); y+= (y>=0?1.2:-1.2); }
      const z=0.3+rand()*2.1 + (rand()>0.7? rand()*0.8:0);
      const bowWord=Math.floor(rand()*32);
      landmarks.push({x,y,z,bow:bowWord, id:i});
    }
    const D=3+2*N;
    mu=new Array(D).fill(0);
    mu[0]=0; mu[1]=0; mu[2]=0;
    P=new Array(D);
    for(let i=0;i<D;i++){ P[i]=new Array(D).fill(0); }
    for(let i=0;i<3;i++) P[i][i]=0.01;
    for(let i=3;i<D;i++) P[i][i]=800; // large unknown
    seen=new Array(N).fill(false);
    truePose={x:0,y:0,th:0};
    odomPose={x:0,y:0,th:0};
    trails={true:[], est:[], odom:[]};
    keyframes=[];
    bowCurr=new Array(32).fill(0);
    loopCount=0; flashTimer=0; time=0;
    roLoopC.textContent='0';
    loopFlash.textContent='';
  }

  function predict(v,w,dt,sigmaM){
    const th=mu[2];
    const vNoisy=v + randn()*sigmaM;
    const wNoisy=w + randn()*sigmaM*0.45;
    // true moves with clean
    truePose.x += v*dt*Math.cos(truePose.th);
    truePose.y += v*dt*Math.sin(truePose.th);
    truePose.th = wrap(truePose.th + w*dt);
    // odom drift only
    odomPose.x += vNoisy*dt*Math.cos(odomPose.th);
    odomPose.y += vNoisy*dt*Math.sin(odomPose.th);
    odomPose.th = wrap(odomPose.th + wNoisy*dt);

    // EKF mu robot
    mu[0] += vNoisy*dt*Math.cos(th);
    mu[1] += vNoisy*dt*Math.sin(th);
    mu[2] = wrap(mu[2] + wNoisy*dt);

    // G matrix 3x3
    const G00=1, G01=0, G02=-vNoisy*dt*Math.sin(th);
    const G10=0, G11=1, G12= vNoisy*dt*Math.cos(th);
    const G20=0, G21=0, G22=1;
    // P_rr = G P_rr G^T + Q
    const qv=sigmaM*sigmaM*0.8; const qw=sigmaM*sigmaM*0.3;
    // extract Prr
    const Prr=[[P[0][0],P[0][1],P[0][2]],[P[1][0],P[1][1],P[1][2]],[P[2][0],P[2][1],P[2][2]]];
    // GP = G*Prr
    const GP=[
      [G00*Prr[0][0]+G01*Prr[1][0]+G02*Prr[2][0], G00*Prr[0][1]+G01*Prr[1][1]+G02*Prr[2][1], G00*Prr[0][2]+G01*Prr[1][2]+G02*Prr[2][2]],
      [G10*Prr[0][0]+G11*Prr[1][0]+G12*Prr[2][0], G10*Prr[0][1]+G11*Prr[1][1]+G12*Prr[2][1], G10*Prr[0][2]+G11*Prr[1][2]+G12*Prr[2][2]],
      [G20*Prr[0][0]+G21*Prr[1][0]+G22*Prr[2][0], G20*Prr[0][1]+G21*Prr[1][1]+G22*Prr[2][1], G20*Prr[0][2]+G21*Prr[1][2]+G22*Prr[2][2]]
    ];
    // GPGT = GP * G^T : GT = [[1,0,0],[0,1,0],[G02,G12,1]]
    const GPGT=[
      [GP[0][0]*G00 + GP[0][1]*G01 + GP[0][2]*G02, GP[0][0]*G10 + GP[0][1]*G11 + GP[0][2]*G12, GP[0][0]*G20 + GP[0][1]*G21 + GP[0][2]*G22],
      [GP[1][0]*G00 + GP[1][1]*G01 + GP[1][2]*G02, GP[1][0]*G10 + GP[1][1]*G11 + GP[1][2]*G12, GP[1][0]*G20 + GP[1][1]*G21 + GP[1][2]*G22],
      [GP[2][0]*G00 + GP[2][1]*G01 + GP[2][2]*G02, GP[2][0]*G10 + GP[2][1]*G11 + GP[2][2]*G12, GP[2][0]*G20 + GP[2][1]*G21 + GP[2][2]*G22]
    ];
    GPGT[0][0]+=qv; GPGT[1][1]+=qv; GPGT[2][2]+=qw;
    // copy back
    for(let i=0;i<3;i++) for(let j=0;j<3;j++) P[i][j]=GPGT[i][j];
    // P_rm = G P_rm for all landmark columns
    const N=(mu.length-3)/2;
    for(let k=0;k<N;k++){
      const cx=3+k*2, cy=cx+1;
      const p0x=P[0][cx], p0y=P[0][cy], p1x=P[1][cx], p1y=P[1][cy], p2x=P[2][cx], p2y=P[2][cy];
      // actually need full matrix multiplication for rows 0,1,2 vs all? Simplified: G * P_rm where P_rm is 3x2N matrix (top rows)
      // new P0 = G00*P0+G01*P1+G02*P2
      const np0x = G00*p0x + G01*p1x + G02*p2x;
      const np0y = G00*p0y + G01*p1y + G02*p2y;
      const np1x = G10*p0x + G11*p1x + G12*p2x;
      const np1y = G10*p0y + G11*p1y + G12*p2y;
      const np2x = G20*p0x + G21*p1x + G22*p2x;
      const np2y = G20*p0y + G21*p1y + G22*p2y;
      P[0][cx]=np0x; P[0][cy]=np0y;
      P[1][cx]=np1x; P[1][cy]=np1y;
      P[2][cx]=np2x; P[2][cy]=np2y;
      // symmetric lower
      P[cx][0]=np0x; P[cy][0]=np0y;
      P[cx][1]=np1x; P[cy][1]=np1y;
      P[cx][2]=np2x; P[cy][2]=np2y;
    }
  }

  function observe(sigmaO, maxRange){
    const rx=mu[0], ry=mu[1], rt=mu[2];
    const trueRx=truePose.x, trueRy=truePose.y, trueRt=truePose.th;
    const visible=[];
    bowCurr=new Array(32).fill(0);
    for(let i=0;i<landmarks.length;i++){
      const lm=landmarks[i];
      const dxT=lm.x-trueRx, dyT=lm.y-trueRy;
      const rT=Math.hypot(dxT,dyT);
      const bearT=wrap(Math.atan2(dyT,dxT)-trueRt);
      if(rT>maxRange) continue;
      if(Math.abs(bearT)>1.65) continue; // 95 deg
      // measurement
      const rMeas=rT + randn()*sigmaO;
      const bearMeas=wrap(bearT + randn()*sigmaO*0.55);
      // init if never seen
      const lix=3+i*2;
      if(!seen[i]){
        // first observation triangulation
        mu[lix]=rx + rMeas*Math.cos(rt+bearMeas);
        mu[lix+1]=ry + rMeas*Math.sin(rt+bearMeas);
        P[lix][lix]=1.5; P[lix+1][lix+1]=1.5;
        // rough cross correlation from robot?
        seen[i]=true;
      }
      visible.push({id:i, r:rMeas, bear:bearMeas, rT, bearT, dx: mu[lix]-rx, dy: mu[lix+1]-ry });
      bowCurr[lm.bow]+=1;
    }
    // sequential update per visible
    for(let v of visible){
      const lix=3+v.id*2;
      if(!seen[v.id]) continue;
      const dx=mu[lix]-mu[0], dy=mu[lix+1]-mu[1];
      const q=dx*dx+dy*dy;
      if(q<1e-6) continue;
      const r=Math.sqrt(q);
      const predBear=wrap(Math.atan2(dy,dx)-mu[2]);
      // measurement prediction
      // Jacobians
      // H_r 2x3
      const dr_dx=-dx/r, dr_dy=-dy/r, dr_dt=0;
      const dphi_dx= dy/q, dphi_dy= -dx/q, dphi_dt= -1;
      const dr_dmx= dx/r, dr_dmy= dy/r;
      const dphi_dmx= -dy/q, dphi_dmy= dx/q;
      const idx=[0,1,2,lix,lix+1];
      const Hsmall=[
        [dr_dx, dr_dy, dr_dt, dr_dmx, dr_dmy],
        [dphi_dx, dphi_dy, dphi_dt, dphi_dmx, dphi_dmy]
      ];
      // P_sub 5x5
      const Psub=[];
      for(let a=0;a<5;a++){ Psub[a]=[]; for(let b=0;b<5;b++){ Psub[a][b]=P[idx[a]][idx[b]]; } }
      // S = H Psub H^T + R
      let S00=0,S01=0,S10=0,S11=0;
      for(let a=0;a<5;a++) for(let b=0;b<5;b++){
        const pab=Psub[a][b];
        S00+=Hsmall[0][a]*pab*Hsmall[0][b];
        S01+=Hsmall[0][a]*pab*Hsmall[1][b];
        S10+=Hsmall[1][a]*pab*Hsmall[0][b];
        S11+=Hsmall[1][a]*pab*Hsmall[1][b];
      }
      const Rr=sigmaO*sigmaO;
      const Rb=(sigmaO*0.55)*(sigmaO*0.55);
      S00+=Rr; S11+=Rb;
      const det=S00*S11 - S01*S10;
      if(Math.abs(det)<1e-9) continue;
      const invDet=1/det;
      const Sinv=[[S11*invDet, -S01*invDet],[-S10*invDet, S00*invDet]];
      // P_HT = P[:,idx] * H^T => D x2
      const D=mu.length;
      const PHT=new Array(D);
      for(let i=0;i<D;i++){ PHT[i]=[0,0]; }
      for(let i=0;i<D;i++){
        let sum0=0,sum1=0;
        for(let k=0;k<5;k++){
          const Pik=P[i][idx[k]];
          sum0+=Pik*Hsmall[0][k];
          sum1+=Pik*Hsmall[1][k];
        }
        PHT[i][0]=sum0; PHT[i][1]=sum1;
      }
      // K = PHT * S_inv => D x2
      const K=new Array(D);
      for(let i=0;i<D;i++){
        K[i]=[
          PHT[i][0]*Sinv[0][0] + PHT[i][1]*Sinv[1][0],
          PHT[i][0]*Sinv[0][1] + PHT[i][1]*Sinv[1][1]
        ];
      }
      // innovation
      const innov0=v.r - r;
      const innov1=wrap(v.bear - predBear);
      // mu update
      for(let i=0;i<D;i++){
        mu[i] += K[i][0]*innov0 + K[i][1]*innov1;
      }
      mu[2]=wrap(mu[2]);
      // P update P = P - K * PHT^T
      // P[i][j] -= K[i][0]*PHT[j][0] + K[i][1]*PHT[j][1]
      for(let i=0;i<D;i++){
        for(let j=0;j<D;j++){
          P[i][j] -= K[i][0]*PHT[j][0] + K[i][1]*PHT[j][1];
        }
      }
      // enforce symmetry a bit
      for(let i=0;i<D;i++) for(let j=i+1;j<D;j++){
        const avg=(P[i][j]+P[j][i])*0.5;
        P[i][j]=avg; P[j][i]=avg;
      }
    }
    // normalize bow histogram
    const norm=Math.hypot(...bowCurr)||1;
    const bowNorm=bowCurr.map(v=>v/norm);
    return {visible, bowNorm};
  }

  function manageKeyframes(bowNorm, visible){
    const lastKf=keyframes[keyframes.length-1];
    const moved= lastKf ? Math.hypot(mu[0]-lastKf.mu[0], mu[1]-lastKf.mu[1]) : 10;
    const rot=Math.abs(wrap(mu[2]- (lastKf?lastKf.mu[2]:0)));
    if(!lastKf || moved>1.1 || rot>0.32){
      keyframes.push({
        mu:[mu[0],mu[1],mu[2]],
        true:[truePose.x,truePose.y,truePose.th],
        bow: bowNorm.slice(),
        ids: visible.map(v=>v.id),
        t: time
      });
      if(keyframes.length>90) keyframes.shift();
    }
  }

  function checkLoopClosure(bowNorm){
    if(!chkLoop.checked) return {sim:0, trigger:false, matched:null};
    if(keyframes.length<12) return {sim:0, trigger:false, matched:null};
    if(time<12) return {sim:0, trigger:false, matched:null};
    const totalDist=Math.hypot(...trails.true.reduce((acc,_,i,a)=>{ if(i===0) return [0,0]; const d=Math.hypot(a[i].x-a[i-1].x, a[i].y-a[i-1].y); acc[0]+=d; return acc; },[0,0]))||0;
    // rough total distance from trail length
    const traveled=trails.true.length*0.06*parseFloat(slV.value); // approx
    if(traveled<12) return {sim:0, trigger:false, matched:null};

    // compare current bow vs old keyframes not recent (exclude last 8)
    let bestSim=-1, bestIdx=-1;
    for(let i=0;i<keyframes.length-8;i++){
      const kf=keyframes[i];
      let dot=0, n1=0,n2=0;
      for(let b=0;b<32;b++){ dot+=kf.bow[b]*bowNorm[b]; n1+=kf.bow[b]*kf.bow[b]; n2+=bowNorm[b]*bowNorm[b]; }
      const sim=n1>0&&n2>0? dot/(Math.sqrt(n1)*Math.sqrt(n2)):0;
      // metric proximity: estimated pos close to old kf true proximity plus drift
      const distEst=Math.hypot(mu[0]-kf.mu[0], mu[1]-kf.mu[1]);
      const distTrue=Math.hypot(truePose.x-kf.true[0], truePose.y-kf.true[1]);
      // we want small distTrue but maybe larger distEst if drifted => good loop candidate
      if(distTrue<2.2 && sim>bestSim){
        bestSim=sim; bestIdx=i;
      }
    }
    if(bestIdx>=0 && bestSim>0.72){
      const kf=keyframes[bestIdx];
      const drift=Math.hypot(mu[0]-kf.mu[0], mu[1]-kf.mu[1]);
      if(drift>0.85){
        // trigger
        return {sim:bestSim, trigger:true, matched:kf, drift};
      }
      return {sim:bestSim, trigger:false, matched:kf, drift};
    }
    return {sim: bestSim>0?bestSim:0, trigger:false, matched:null};
  }

  function applyLoopClosure(matched, drift){
    const dx=matched.mu[0]-mu[0];
    const dy=matched.mu[1]-mu[1];
    const dth=wrap(matched.mu[2]-mu[2]);
    const gain=0.85;
    // snap robot
    mu[0]+=dx*gain; mu[1]+=dy*gain; mu[2]=wrap(mu[2]+dth*gain);
    // snap landmarks that were shared: those visible now and in matched ids
    const sharedSet=new Set(matched.ids);
    for(let vId of sharedSet){
      const lix=3+vId*2;
      // shift landmark proportionally
      mu[lix]+=dx*gain*0.7;
      mu[lix+1]+=dy*gain*0.7;
    }
    // covariance shrinkage
    const D=mu.length;
    for(let i=0;i<3;i++) for(let j=0;j<3;j++) P[i][j]*=0.28;
    // cross terms shrink
    const N=(D-3)/2;
    for(let k=0;k<N;k++){
      const cx=3+k*2, cy=cx+1;
      P[0][cx]*=0.7; P[0][cy]*=0.7; P[1][cx]*=0.7; P[1][cy]*=0.7; P[2][cx]*=0.7; P[2][cy]*=0.7;
      P[cx][0]*=0.7; P[cy][0]*=0.7; P[cx][1]*=0.7; P[cy][1]*=0.7; P[cx][2]*=0.7; P[cy][2]*=0.7;
    }
    // for snapped landmarks also reduce their covariance
    for(let id of sharedSet){
      const lix=3+id*2;
      P[lix][lix]*=0.55; P[lix+1][lix+1]*=0.55;
    }
    loopCount++;
    flashTimer=0.85;
    loopFlash.textContent=`LOOP CLOSURE #${loopCount} Δ=${drift.toFixed(2)}m`;
    setTimeout(()=>{ if(flashTimer<0.1) loopFlash.textContent=''; }, 2200);
    // audio
    playSnap(dx,dy,drift);
  }

  // Drawing helpers
  function worldToScreen(x,y){
    const scale=22;
    return {sx: W/2 + x*scale, sy: H/2 - y*scale, scale};
  }
  function drawEllipse(ctx, cx, cy, cov00, cov01, cov11, color, lineW=1){
    const a=cov00, b=cov01, c=cov11;
    const trace=a+c; const det=a*c - b*b;
    const temp=Math.sqrt(Math.max(0, (a-c)*(a-c)/4 + b*b));
    const l1=trace/2 + temp; const l2=trace/2 - temp;
    if(l1<=0||l2<=0) return;
    const angle = Math.abs(b)<1e-9 ? 0 : 0.5*Math.atan2(2*b, a-c);
    const chi=2.447; // 95%
    const rx=Math.sqrt(l1)*chi, ry=Math.sqrt(l2)*chi;
    ctx.save(); ctx.translate(cx,cy); ctx.rotate(angle);
    ctx.strokeStyle=color; ctx.lineWidth=lineW;
    ctx.beginPath(); ctx.ellipse(0,0, rx*22, ry*22, 0,0,Math.PI*2); ctx.stroke();
    ctx.restore();
  }

  let raf=0;
  let lastT=performance.now();
  function loop(now){
    raf=requestAnimationFrame(loop);
    const dtFrame=Math.min(0.05, (now-lastT)/1000); lastT=now;
    if(!isPlaying) { draw(); return; }
    const sigmaM=parseFloat(slMotion.value);
    const sigmaO=parseFloat(slObs.value);
    const maxRange=parseFloat(slRange.value);
    const v=parseFloat(slV.value);
    const w=parseFloat(slWrpm.value);
    const dtSim=0.05;
    // integrate maybe multiple steps per frame for stability
    const steps=2;
    let lastVisible=[], lastBow=[];
    for(let s=0;s<steps;s++){
      predict(v,w,dtSim,sigmaM);
      const obs=observe(sigmaO, maxRange);
      lastVisible=obs.visible; lastBow=obs.bowNorm;
      manageKeyframes(obs.bowNorm, obs.visible);
      time+=dtSim;
    }
    // trail push
    trails.true.push({x:truePose.x, y:truePose.y});
    trails.est.push({x:mu[0], y:mu[1]});
    trails.odom.push({x:odomPose.x, y:odomPose.y});
    if(trails.true.length>800){ trails.true.shift(); trails.est.shift(); trails.odom.shift(); }

    const loopInfo=checkLoopClosure(lastBow);
    if(loopInfo.trigger && loopInfo.matched){
      applyLoopClosure(loopInfo.matched, loopInfo.drift);
    }

    // update bow bar
    roBow.textContent=loopInfo.sim.toFixed(2);
    barBow.style.width=Math.min(100, Math.max(4, loopInfo.sim*100))+'%';
    barBow.style.background=loopInfo.trigger? '#4ade80' : (loopInfo.sim>0.5? '#f07a94':'var(--mp-cta)');

    // readouts
    roTrue.textContent=`${truePose.x.toFixed(2)},${truePose.y.toFixed(2)},${(truePose.th*57.3).toFixed(0)}°`;
    roEst.textContent=`${mu[0].toFixed(2)},${mu[1].toFixed(2)},${(mu[2]*57.3).toFixed(0)}°`;
    const ate = Math.hypot(truePose.x-mu[0], truePose.y-mu[1]);
    // RMSE over trail
    let sum=0,len=trails.true.length;
    for(let i=0;i<len;i++){ const dx=trails.true[i].x-trails.est[i].x, dy=trails.true[i].y-trails.est[i].y; sum+=dx*dx+dy*dy; }
    const rmse=Math.sqrt(sum/Math.max(1,len));
    roATE.textContent=rmse.toFixed(3)+' m (inst '+ate.toFixed(2)+')';
    const trP=P[0][0]+P[1][1]+P[2][2];
    roCov.textContent=trP.toFixed(3);
    roVis.textContent=`${lastVisible.length} / ${landmarks.length}`;
    roMap.textContent=`${seen.filter(Boolean).length}`;
    roLoopDist.textContent= loopInfo.matched ? Math.hypot(truePose.x-loopInfo.matched.true[0], truePose.y-loopInfo.matched.true[1]).toFixed(2) : '—';
    roDrift.textContent= loopInfo.drift!==undefined? loopInfo.drift.toFixed(2)+' m':'—';
    roFov.textContent=`${lastVisible.length}`;
    roTime.textContent=time.toFixed(1);

    if(flashTimer>0){ flashTimer-=dtFrame; flashOverlay.style.opacity=(flashTimer*0.8).toString(); if(flashTimer<=0){ flashOverlay.style.opacity='0'; } }

    draw(lastVisible, loopInfo);
  }

  function draw(visible=[], loopInfo=null){
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    sCtx.fillStyle=bg; sCtx.fillRect(0,0,W,H);
    // grid
    sCtx.strokeStyle='rgba(255,255,255,0.05)'; sCtx.lineWidth=1;
    for(let gx=-24; gx<=24; gx+=2){
      const p1=worldToScreen(gx,-14), p2=worldToScreen(gx,14);
      sCtx.beginPath(); sCtx.moveTo(p1.sx,p1.sy); sCtx.lineTo(p2.sx,p2.sy); sCtx.stroke();
    }
    for(let gy=-14; gy<=14; gy+=2){
      const p1=worldToScreen(-14,gy), p2=worldToScreen(14,gy);
      sCtx.beginPath(); sCtx.moveTo(p1.sx,p1.sy); sCtx.lineTo(p2.sx,p2.sy); sCtx.stroke();
    }
    // landmarks true
    if(chkTrue.checked){
      sCtx.fillStyle='#8da0b8aa';
      for(let lm of landmarks){
        const ps=worldToScreen(lm.x,lm.y);
        sCtx.beginPath(); sCtx.arc(ps.sx,ps.sy, 1.8,0,Math.PI*2); sCtx.fill();
      }
    }
    // landmarks estimated + ellipses
    for(let i=0;i<landmarks.length;i++){
      if(!seen[i]) continue;
      const lix=3+i*2;
      const ex=mu[lix], ey=mu[lix+1];
      const ps=worldToScreen(ex,ey);
      // ellipse from P
      const c00=P[lix][lix], c01=P[lix][lix+1]||P[lix+1][lix], c11=P[lix+1][lix+1];
      drawEllipse(sCtx, ps.sx, ps.sy, c00,c01,c11, 'rgba(240,122,148,0.28)', 0.8);
      // dot
      sCtx.fillStyle='#ff9b6e';
      sCtx.beginPath(); sCtx.arc(ps.sx,ps.sy, 3,0,Math.PI*2); sCtx.fill();
      sCtx.strokeStyle='rgba(255,255,255,0.6)'; sCtx.lineWidth=0.5; sCtx.stroke();
    }
    // robot ellipse
    const rps=worldToScreen(mu[0],mu[1]);
    const pr00=P[0][0], pr01=P[0][1], pr11=P[1][1];
    drawEllipse(sCtx, rps.sx, rps.sy, pr00,pr01,pr11, '#71b9e3', 1.2);
    // trails
    function drawTrail(arr,color,lineW,dash=null){
      if(arr.length<2) return;
      sCtx.beginPath(); sCtx.strokeStyle=color; sCtx.lineWidth=lineW; if(dash) sCtx.setLineDash(dash);
      for(let i=0;i<arr.length;i++){
        const p=worldToScreen(arr[i].x, arr[i].y);
        if(i===0) sCtx.moveTo(p.sx,p.sy); else sCtx.lineTo(p.sx,p.sy);
      }
      sCtx.stroke(); sCtx.setLineDash([]);
    }
    drawTrail(trails.true,'#60a5fa88',1.5);
    drawTrail(trails.odom,'#9aa0a6aa',1,[6,5]);
    drawTrail(trails.est,'#f07a94',2);
    // observation lines
    if(visible && visible.length){
      sCtx.strokeStyle='rgba(113,185,227,0.22)'; sCtx.lineWidth=0.8;
      const rp=worldToScreen(mu[0],mu[1]);
      for(let v of visible){
        const lix=3+v.id*2;
        const ep=worldToScreen(mu[lix], mu[lix+1]);
        sCtx.beginPath(); sCtx.moveTo(rp.sx,rp.sy); sCtx.lineTo(ep.sx,ep.sy); sCtx.stroke();
      }
    }
    // loop edge
    if(loopInfo && loopInfo.matched){
      const mf=loopInfo.matched;
      const p1=worldToScreen(mu[0],mu[1]);
      const p2=worldToScreen(mf.mu[0], mf.mu[1]);
      sCtx.strokeStyle= loopInfo.trigger ? '#4ade80' : 'rgba(74,222,128,0.25)';
      sCtx.lineWidth= loopInfo.trigger? 3 :1;
      sCtx.beginPath(); sCtx.moveTo(p1.sx,p1.sy); sCtx.lineTo(p2.sx,p2.sy); sCtx.stroke();
      // flash circle at match
      if(loopInfo.trigger || flashTimer>0){
        sCtx.fillStyle=`rgba(74,222,128,${Math.min(0.5,flashTimer)})`;
        sCtx.beginPath(); sCtx.arc(p2.sx,p2.sy, 10+flashTimer*10,0,Math.PI*2); sCtx.fill();
      }
    }
    // robot triangle
    sCtx.save(); sCtx.translate(rps.sx, rps.sy); sCtx.rotate(-mu[2]); // canvas y flipped? we used -y mapping, adjust
    // because world y up => screen y down, rotation inverse
    // Our worldToScreen uses -y, so angle should be -theta for screen? use -mu[2]
    sCtx.fillStyle='#e8eef6'; sCtx.strokeStyle='#0f141c'; sCtx.lineWidth=1;
    sCtx.beginPath(); sCtx.moveTo(10,0); sCtx.lineTo(-7,5); sCtx.lineTo(-7,-5); sCtx.closePath(); sCtx.fill(); sCtx.stroke();
    sCtx.restore();
    // origin start marker
    const o=worldToScreen(0,0);
    sCtx.strokeStyle='#4ade80aa'; sCtx.setLineDash([3,3]); sCtx.beginPath(); sCtx.arc(o.sx,o.sy,8,0,Math.PI*2); sCtx.stroke(); sCtx.setLineDash([]);
    sCtx.fillStyle='#e8eef6'; sCtx.font='10px ui-monospace'; sCtx.fillText(`x=${mu[0].toFixed(1)} y=${mu[1].toFixed(1)} ATE=${Math.hypot(truePose.x-mu[0],truePose.y-mu[1]).toFixed(2)}m`, 8, H-8);

    // cloud canvas
    cCtx.fillStyle=bg; cCtx.fillRect(0,0,CW,CH);
    cCtx.strokeStyle='rgba(255,255,255,0.06)'; cCtx.beginPath(); cCtx.moveTo(0,CH/2); cCtx.lineTo(CW,CH/2); cCtx.stroke();
    // pinhole projection
    const fx=220, cx=CW/2, cy=CH*0.68;
    const rx=mu[0], ry=mu[1], rt=mu[2];
    const points=[];
    for(let i=0;i<landmarks.length;i++){
      if(!seen[i]) continue;
      const lix=3+i*2;
      const ex=mu[lix], ey=mu[lix+1];
      const dx=ex-rx, dy=ey-ry;
      const r=Math.hypot(dx,dy);
      if(r<0.3||r>parseFloat(slRange.value)) continue;
      const bear=wrap(Math.atan2(dy,dx)-rt);
      if(Math.abs(bear)>1.2) continue;
      const depth = r*Math.cos(bear); // forward
      if(depth<0.3) continue;
      const lateral = r*Math.sin(bear);
      const height=landmarks[i].z + randn()*0.06;
      const u = cx + (lateral/depth)*fx;
      const v = cy - (height/depth)*fx*0.9;
      const sz = Math.max(1.2, 7/(depth+0.5));
      points.push({u,v,sz,depth,bow:landmarks[i].bow, id:i});
    }
    points.sort((a,b)=>b.depth-a.depth);
    for(let pt of points){
      const hue = (pt.bow/32)*240;
      cCtx.fillStyle=`hsl(${hue} 70% 65% / ${0.55 + 0.35*Math.max(0,1-pt.depth/10)})`;
      cCtx.beginPath(); cCtx.arc(pt.u, pt.v, pt.sz,0,Math.PI*2); cCtx.fill();
      // vertical line to ground
      cCtx.strokeStyle='rgba(255,255,255,0.10)'; cCtx.lineWidth=0.5;
      cCtx.beginPath(); cCtx.moveTo(pt.u, pt.v); cCtx.lineTo(pt.u, cy); cCtx.stroke();
    }
    cCtx.fillStyle='#e8eef6'; cCtx.font='10px ui-monospace'; cCtx.fillText(`cloud ${points.length} pts`, 8, CH-8);

    // bow canvas
    bCtx.fillStyle=bg; bCtx.fillRect(0,0,320,120);
    bCtx.fillStyle='#1e2633'; bCtx.fillRect(0,0,320,120);
    for(let i=0;i<32;i++){
      const h=bowCurr[i]||0;
      const bh=(h/Math.max(1, Math.max(...bowCurr)))*100;
      const x=i/32*320;
      bCtx.fillStyle= i%2? '#f07a94' : '#71b9e3';
      bCtx.fillRect(x+1, 120-bh, 320/32 -2, bh);
    }
    bCtx.strokeStyle='rgba(255,255,255,0.08)'; bCtx.strokeRect(0.5,0.5,319,119);
  }

  // events
  btnPlay.addEventListener('click',()=>{
    isPlaying=!isPlaying;
    btnPlay.textContent=isPlaying?'⏸ Pause':'▶ Play';
    btnPlay.classList.toggle('is-active', isPlaying);
  });
  btnReset.addEventListener('click',()=>{
    initWorld();
  });
  slFeat.addEventListener('change',()=>{ initWorld(); });
  chkLoop.addEventListener('change',()=>{ if(!chkLoop.checked) loopFlash.textContent='loop disabled'; else loopFlash.textContent=''; });

  initWorld();
  loop(performance.now());

  // ExportGate — trajectory CSV
  try {
    const reg = () => {
      if (window.MPExportGate) {
        window.MPExportGate.register('slam-odometry-arena', () => {
          // Attempt to use live mu if available
          let csv = `t,x,y,theta,gt_x,gt_y,gt_theta,ate_m,seen_landmarks,loop_trigger,note\n`;
          // Fallback: single snapshot + sim params
          try {
            const now = new Date().toISOString();
            // mu is inside closure, may not be accessible here if minified? Use global fallback
            // We attempt to read from closure via last known pose if available through window
            const poses = window.__MP_SLAM_POSES__ || [];
            if (poses.length) {
              poses.forEach((p,i) => {
                csv += `${i},${p.x.toFixed(3)},${p.y.toFixed(3)},${p.theta.toFixed(4)},${(p.gt_x ?? '').toString()},${(p.gt_y ?? '').toString()},${(p.gt_theta ?? '').toString()},${(p.ate ?? '').toString()},${p.seen ?? ''},${p.loop?'1':'0'},${p.note||''}\n`;
              });
            } else {
              csv += `0,${mu?mu[0].toFixed(3):'0'},${mu?mu[1].toFixed(3):'0'},${mu?mu[2].toFixed(4):'0'},${truePose?truePose.x.toFixed(3):''},${truePose?truePose.y.toFixed(3):''},${truePose?truePose.theta.toFixed(4):''},${truePose && mu ? Math.hypot(truePose.x-mu[0],truePose.y-mu[1]).toFixed(3):''},${landmarks?landmarks.length:''},${loopInfo&&loopInfo.trigger?'1':'0'},export ${now}\n`;
              csv += `# Fallback: poses array not buffered — integrate __MP_SLAM_POSES__ pushing in loop for full history\n`;
            }
          } catch (e) {
            csv += `0,0,0,0,,,,\n# error ${e}\n`;
          }
          csv += `# Generated ${new Date().toISOString()} by makerportal.ai/playground/slam-odometry-arena\n`;
          csv += `# Suggest: RealSense D455 + ZED-F9P RTK (SparkFun Originals) for ground truth capture\n`;
          return csv;
        });
      }
    };
    reg();
    document.addEventListener('astro:page-load', reg);

    // Buffer poses into global for richer exports
    try {
      window.__MP_SLAM_POSES__ = window.__MP_SLAM_POSES__ || [];
      const origLoop = loop;
      // Monkey patch: push pose each frame via separate ticker
      setInterval(() => {
        try {
          if (!mu || !truePose) return;
          const arr = window.__MP_SLAM_POSES__;
          if (arr.length > 600) arr.shift();
          arr.push({
            x: mu[0], y: mu[1], theta: mu[2],
            gt_x: truePose.x, gt_y: truePose.y, gt_theta: truePose.theta,
            ate: Math.hypot(truePose.x-mu[0], truePose.y-mu[1]),
            seen: landmarks ? landmarks.filter((_,i)=>seen[i]).length : 0,
            loop: !!(loopInfo && loopInfo.trigger),
            note: ''
          });
        } catch {}
      }, 250);
    } catch {}
  } catch {}

  document.addEventListener('astro:before-swap',()=>{ cancelAnimationFrame(raf); try{audioCtx?.close();}catch{} },{once:true});
}
document.addEventListener('astro:page-load', initSLAM);
initSLAM();
</script>
</Layout>
