---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';

const title = 'Voice-Coil Thermal Compression — Heat, Resistance & SPL Sag | MakerPortal';
const description =
  'Interactive lumped thermal RC model of voice-coil heating. Simulate copper TCR, power compression, and SPL sag with configurable cooling architectures and real-time charts.';
const canonical = new URL('/playground/voice-coil-thermal-compression', Astro.site);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Voice-Coil Thermal Compression', item: canonical.toString() },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  </Fragment>

  <PlaygroundShell
    title="Voice-Coil Thermal Compression"
    lead="A lumped thermal RC model of voice-coil heating under continuous drive. Dial in power, cooling architecture, and copper TCR — watch temperature, resistance rise, SPL sag, and the steady-state destination in real time."
    pillarHint="dsp-audio"
    isGrounded={false}
  >
    <section class="border-b border-border" aria-labelledby="simulation-title">
      <div class="mx-auto max-w-[76rem] px-5 py-12 sm:px-8 lg:px-10">

        <!-- Controls Card -->
        <div class="rounded-[20px] border border-border bg-card-bg p-5 sm:p-6">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <h2 id="simulation-title" class="text-[1.05rem] font-[650] tracking-[-0.02em]">Thermal Controls</h2>
            <div class="flex flex-wrap gap-2">
              <button type="button" class="sim-btn is-active" id="run-toggle" aria-pressed="true">Pause</button>
              <button type="button" class="sim-btn" id="reset-btn">Reset to ambient</button>
            </div>
          </div>

          <div class="mt-5 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Input power -->
            <label class="control-label" for="power-slider">
              <span>Input power <span class="eyebrow">Continuous RMS (W)</span></span>
              <output id="power-readout">150</output>
              <input type="range" id="power-slider" min="1" max="1000" step="1" value="150" />
            </label>

            <!-- Re at 20°C -->
            <label class="control-label" for="re-slider">
              <span>Re at 20&deg;C <span class="eyebrow">Voice-coil DC resistance (&Omega;)</span></span>
              <output id="re-readout">6.2</output>
              <input type="range" id="re-slider" min="1" max="32" step="0.1" value="6.2" />
            </label>

            <!-- Tamb -->
            <label class="control-label" for="tamb-slider">
              <span>Tamb <span class="eyebrow">Ambient temperature (&deg;C)</span></span>
              <output id="tamb-readout">20</output>
              <input type="range" id="tamb-slider" min="0" max="50" step="0.5" value="20" />
            </label>

            <!-- Time acceleration -->
            <label class="control-label" for="accel-slider">
              <span>Time acceleration <span class="eyebrow">Simulation speed</span></span>
              <output id="accel-readout">8&times;</output>
              <input type="range" id="accel-slider" min="1" max="40" step="1" value="8" />
            </label>
          </div>

          <!-- Cooling Architecture -->
          <div class="mt-5">
            <span class="eyebrow mb-2 block">Cooling architecture presets</span>
            <div class="flex flex-wrap gap-2" aria-label="Cooling architecture presets">
              <button type="button" class="preset-btn is-active" data-preset="standard">Standard basket</button>
              <button type="button" class="preset-btn" data-preset="vented">Vented pole-piece</button>
              <button type="button" class="preset-btn" data-preset="ferrofluid">Ferrofluid</button>
              <button type="button" class="preset-btn" data-preset="custom">Custom</button>
            </div>
          </div>

          <!-- Thermal parameters for custom -->
          <div class="mt-4 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-3" id="thermal-params-group">
            <label class="control-label" for="rth-slider">
              <span>Rth_v <span class="eyebrow">Coil-to-magnet Rth (K/W)</span></span>
              <output id="rth-readout">1.5</output>
              <input type="range" id="rth-slider" min="0.1" max="10" step="0.05" value="1.5" />
            </label>
            <label class="control-label" for="cth-slider">
              <span>Cth_v <span class="eyebrow">Coil thermal cap (J/K)</span></span>
              <output id="cth-readout">15</output>
              <input type="range" id="cth-slider" min="0.5" max="50" step="0.1" value="15" />
            </label>
            <label class="control-label" for="alpha-slider">
              <span>&alpha; <span class="eyebrow">Copper TCR (1/K) &mdash; default 0.00393</span></span>
              <output id="alpha-readout">0.00393</output>
              <input type="range" id="alpha-slider" min="0.001" max="0.006" step="0.00001" value="0.00393" />
            </label>
          </div>
        </div>

        <!-- Results Dashboard -->
        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-7" id="results-grid">
          <!-- Coil temperature — large, prominent card -->
          <div class="metric-card sm:col-span-1 lg:col-span-1" id="temp-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Coil temp</dt>
            <dd id="res-temp" class="mt-1 text-[clamp(1.4rem,3vw,2rem)] font-[700] leading-[1.05] tracking-[-0.03em] temp-safe">20.0&deg;C</dd>
            <p class="text-[0.6rem] text-muted-text">&deg;C</p>
          </div>
          <div class="metric-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Re</dt>
            <dd id="res-re" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.02em]">6.20</dd>
            <p class="text-[0.6rem] text-muted-text">&Omega;</p>
          </div>
          <div class="metric-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Current</dt>
            <dd id="res-current" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.02em]">4.92</dd>
            <p class="text-[0.6rem] text-muted-text">A RMS</p>
          </div>
          <div class="metric-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Elect. power</dt>
            <dd id="res-power" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.02em]">150</dd>
            <p class="text-[0.6rem] text-muted-text">W</p>
          </div>
          <div class="metric-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">SPL compression</dt>
            <dd id="res-spl" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.02em]">0.00</dd>
            <p class="text-[0.6rem] text-muted-text">dB</p>
          </div>
          <div class="metric-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Coil tau</dt>
            <dd id="res-tau" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.02em]">22.5</dd>
            <p class="text-[0.6rem] text-muted-text">&tau; (s)</p>
          </div>
          <div class="metric-card">
            <dt class="text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">Steady-state T</dt>
            <dd id="res-tss" class="mt-1 text-[1.05rem] font-[650] tracking-[-0.02em]">395</dd>
            <p class="text-[0.6rem] text-muted-text">&deg;C</p>
          </div>
        </div>

        <!-- Warning callout -->
        <div id="temp-warning" class="mt-4 hidden rounded-[14px] border border-[#d4523a]/40 bg-[#d4523a]/8 px-4 py-3 text-[0.82rem] font-semibold text-[#d4523a]">
          Coil temperature exceeds 200&deg;C &mdash; adhesive failure risk. Reduce power or improve cooling.
        </div>

        <!-- Time-History Canvas -->
        <div class="mt-6 canvas-card">
          <div class="canvas-label-row">
            <span>Time history &mdash; Temperature &amp; SPL compression</span>
            <span id="time-readout">0.0 s simulated</span>
          </div>
          <canvas id="time-canvas" width="900" height="480" aria-label="Time-history plot: temperature and SPL compression over the last 60 simulated seconds"></canvas>
        </div>

        <!-- Thermal Gradient SVG -->
        <div class="mt-5 rounded-[20px] border border-border bg-card-bg p-5 sm:p-6">
          <h3 class="font-semibold">Motor cross-section &amp; thermal gradient</h3>
          <div class="mt-4 flex justify-center">
            <svg id="motor-svg" viewBox="0 0 500 260" class="w-full max-w-[500px] h-auto" xmlns="http://www.w3.org/2000/svg" aria-label="Simplified loudspeaker motor cross-section with thermal gradient visualization">
              <!-- Magnet structure (outer gray ring) -->
              <rect x="50" y="30" width="400" height="200" rx="16" fill="var(--mp-elevated)" stroke="var(--mp-border)" stroke-width="1.5" />
              <!-- Pole piece (darker inner rectangle) -->
              <rect x="130" y="55" width="240" height="150" rx="10" fill="color-mix(in srgb, var(--mp-elevated) 70%, #000 30%)" stroke="var(--mp-border)" stroke-width="1" />
              <!-- Top plate -->
              <rect x="100" y="45" width="300" height="28" rx="6" fill="color-mix(in srgb, var(--mp-elevated) 60%, #000 40%)" stroke="var(--mp-border)" stroke-width="1" />
              <!-- Bottom plate -->
              <rect x="100" y="187" width="300" height="28" rx="6" fill="color-mix(in srgb, var(--mp-elevated) 60%, #000 40%)" stroke="var(--mp-border)" stroke-width="1" />
              <!-- Voice coil gap (left and right gaps between pole piece and magnet) -->
              <!-- Left voice coil -->
              <rect id="coil-left" x="120" y="72" width="12" height="116" rx="3" fill="#d4784a" stroke="#b85a2e" stroke-width="0.8" />
              <!-- Right voice coil -->
              <rect id="coil-right" x="368" y="72" width="12" height="116" rx="3" fill="#d4784a" stroke="#b85a2e" stroke-width="0.8" />
              <!-- Heat flow arrows group -->
              <g id="heat-arrows" stroke="#e8945a" stroke-width="1.8" fill="none" stroke-linecap="round">
                <!-- Left side arrows -->
                <line x1="132" y1="90" x2="155" y2="90" />
                <polygon points="155,86 163,90 155,94" fill="#e8945a" stroke="none" />
                <line x1="132" y1="130" x2="160" y2="130" />
                <polygon points="160,126 168,130 160,134" fill="#e8945a" stroke="none" />
                <line x1="132" y1="170" x2="155" y2="170" />
                <polygon points="155,166 163,170 155,174" fill="#e8945a" stroke="none" />
                <!-- Right side arrows -->
                <line x1="368" y1="90" x2="345" y2="90" />
                <polygon points="345,86 337,90 345,94" fill="#e8945a" stroke="none" />
                <line x1="368" y1="130" x2="340" y2="130" />
                <polygon points="340,126 332,130 340,134" fill="#e8945a" stroke="none" />
                <line x1="368" y1="170" x2="345" y2="170" />
                <polygon points="345,166 337,170 345,174" fill="#e8945a" stroke="none" />
              </g>
              <!-- Labels -->
              <text id="label-ambient" x="250" y="22" fill="var(--mp-muted)" font-family="var(--font-mono)" font-size="10" text-anchor="middle">Ambient: 20&deg;C</text>
              <text id="label-coil" x="250" y="245" fill="var(--mp-text)" font-family="var(--font-mono)" font-size="10" text-anchor="middle">Coil: 20&deg;C</text>
              <text id="label-magnet" x="250" y="258" fill="var(--mp-muted)" font-family="var(--font-mono)" font-size="9" text-anchor="middle">Magnet structure: 20&deg;C</text>
            </svg>
          </div>
        </div>

        <!-- Power Sweep Canvas -->
        <div class="mt-5 canvas-card">
          <div class="canvas-label-row">
            <span>Power sweep &mdash; Steady-state temperature vs. input power</span>
            <span>
              <button type="button" id="show-all-curves-btn" class="sim-btn !text-[0.55rem] !py-0.5 !px-2">Show all architectures</button>
            </span>
          </div>
          <canvas id="sweep-canvas" width="560" height="320" aria-label="Steady-state temperature vs input power curve"></canvas>
        </div>

      </div>
    </section>

    <section aria-labelledby="hook-title" class="border-b border-border bg-elevated/20">
      <div class="mx-auto max-w-[66rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
        <div class="max-w-[44rem]">
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-cta">Essence</p>
          <h2 id="hook-title" class="mt-3 text-[clamp(1.6rem,3.5vw,2.4rem)] font-[700] leading-[0.95] tracking-[-0.05em] text-primary-text">Your speaker gets quieter the longer you punish it. That's copper doing math.</h2>
          <div class="mt-6 space-y-5 text-[1.02rem] leading-[1.75] text-muted-text">
            <p>
              Set $P_&#123;in&#125; = 150$ W, walk away, come back five minutes later. The amp still reads 150 W on the dial, but the cone is moving less. You lost 2 dB. Not to the amp, not to the air — to heat.
            </p>
            <p>
              Every $I^2 R$ watt that doesn't become sound becomes temperature inside a few grams of copper wire. Copper's resistance climbs about $0.39\%$ per degree — $\alpha = 0.00393$ $K^&#123;-1&#125;$ — so as it heats, it draws less current from the same voltage. Less current means less $Bl \cdot I$ force, so less SPL. The system quietly negotiates itself down. Engineers call it power compression, and in live sound it eats headroom for breakfast.
            </p>
            <p>
              Past $200°C$ the glue that holds the coil to the former softens. Past $300°C$ you smell it. This simulation lets you watch that negotiation in real time: temperature, resistance, current, electrical power, SPL sag, all coupled. No hidden knobs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="intuition-title" class="border-b border-border">
      <div class="mx-auto max-w-[66rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
          <div>
            <h2 id="intuition-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">The intuition — heat has mass and insulation</h2>
            <div class="mt-5 space-y-4 text-[0.95rem] leading-[1.75] text-muted-text">
              <p>
                If you've seen an electrical RC circuit, you already know the thermal one. Temperature is voltage, heat flow is current, thermal resistance $R_&#123;th&#125;$ is how hard it is to push heat out, thermal capacitance $C_&#123;th&#125;$ is how much heat you must dump in to raise the temperature one degree.
              </p>
              <p>
                Map it: the coil dumps $P_e$ watts into $C_&#123;th\_v&#125;$, the small fast can — $10$ to $15$ $J/K$ in the code. It leaks to the magnet through $R_&#123;th\_v&#125;$. The magnet is the big slow can, $C_&#123;th\_m&#125; = 250$ $J/K$, barely warming at first, then storing that heat for minutes. It leaks to ambient through $R_&#123;th\_m&#125;$. Two cans, two time constants:
              </p>
              <div class="rounded-[14px] border border-border bg-card-bg p-5 font-mono text-[0.78rem] leading-[1.7] text-primary-text">
                $\tau_v = R_&#123;th\_v&#125; C_&#123;th\_v&#125;$ — coil, seconds<br/>
                $\tau_m = R_&#123;th\_m&#125; C_&#123;th\_m&#125;$ — magnet, minutes<br/>
                <span class="text-muted-text">e.g. standard preset: $\tau_v \approx 22.5$ s, $\tau_m \approx 250$ s</span>
              </div>
              <p>
                Now add copper's twist. $R_e(T) = R_&#123;e0&#125;(1+\alpha(T-20))$. As $T_v$ climbs, $R_e$ climbs. The amp is modeled as constant-voltage — $V_&#123;in&#125;^2 = P_&#123;input&#125; R_&#123;e0&#125;$ — so actual electrical power $P_e = V_&#123;in&#125;^2 / R_e(T)$ <em>drops</em> as it heats. That's a stabilizing negative feedback on temperature, but a direct hit to SPL. You trade loudness for survival.
              </p>
              <ul class="list-disc pl-5 space-y-2 marker:text-muted-text/60">
                <li>Hot coil $\to$ higher $R_e$ $\to$ lower $I = V_&#123;in&#125;/R_e$ $\to$ lower $BlI$.</li>
                <li>Lower $I$ $\to$ slightly less heating, so temperature asymptotes rather than running away.</li>
                <li>But $SPL_&#123;comp&#125; = -20\log_&#123;10&#125;(R_e/R_&#123;e0&#125;)$ keeps sliding negative — you hear it as compression.</li>
              </ul>
              <p>
                Short bursts mostly charge $C_&#123;th\_v&#125;$. Long, heavy drive also charges $C_&#123;th\_m&#125;$, and that magnet won't cool quickly when you stop. That is why a speaker can sound fine for one song and dull for the next, even at the same meter reading.
              </p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="math-card !bg-card-bg">
              <p class="math-label">Think of it like</p>
              <p class="mt-3 text-[0.92rem] leading-[1.6] text-primary-text">Two buckets connected by a slow pipe. You pour water (power) into the small top bucket (coil). It drains through a narrow hose ($R_&#123;th\_v&#125;$) into a huge bottom tank (magnet). The top bucket's water level is temperature. Now imagine the faucet gets stingier as the top bucket fills — higher water level pinches the inlet. Level stabilizes, but flow out the $BlI$ tap drops. That's compression.</p>
            </div>
            <div class="math-card">
              <p class="math-label">Where architecture matters</p>
              <p class="mt-2 font-mono text-[0.82rem] leading-[1.6] text-primary-text">Standard basket: $R_&#123;th\_v&#125; \approx 1.5$ K/W, sluggish cooling<br/>Vented pole: $R_&#123;th\_v&#125; \approx 0.8$, much better exhaust<br/>Ferrofluid: $R_&#123;th\_v&#125; \approx 0.4$, fluid bridges the gap</p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">Same $C_&#123;th\_v&#125;$ range ($10$–$15$ J/K) but cutting $R_&#123;th\_v&#125;$ by 3× cuts $\tau_v$ and the final temperature almost proportionally. Check the lower plot — curves separate hard at high power.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="math-title" class="border-b border-border bg-elevated/20">
      <div class="mx-auto max-w-[72rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
        <h2 id="math-title" class="text-[clamp(1.6rem,3.5vw,2.2rem)] font-[700] tracking-[-0.05em] text-primary-text">The math — from copper physics to code</h2>

        <div class="mt-10 grid gap-12 lg:grid-cols-[1.15fr_0.85fr]">
          <div class="space-y-8">
            <div>
              <h3 class="text-[1.05rem] font-semibold tracking-[-0.02em] text-primary-text">1. Copper doesn't keep its resistance</h3>
              <div class="mt-3 space-y-4 text-[0.92rem] leading-[1.7] text-muted-text">
                <p>The base fact of this whole sim is linear TCR:</p>
                <div class="rounded-[14px] border border-border bg-card-bg p-5 font-mono text-[0.82rem] leading-[1.8] text-primary-text">
                  $$ R_e(T) = R_&#123;e0&#125;\,[1 + \alpha\,(T - 20)] $$
                  $$ \alpha = 0.00393\,K^&#123;-1&#125; \text&#123; (copper, code &#125;ALPHA\_CU\text&#123;)&#125; $$
                </div>
                <p>At $150°C$, $R_e \approx 1.51 \times R_&#123;e0&#125;$. A nominal $6.2\,\Omega$ coil is now $9.4\,\Omega$. The amp hasn't changed. Ohm's law has.</p>
              </div>
            </div>

            <div>
              <h3 class="text-[1.05rem] font-semibold tracking-[-0.02em] text-primary-text">2. Constant-voltage amp model</h3>
              <div class="mt-3 space-y-4 text-[0.92rem] leading-[1.7] text-muted-text">
                <p>The slider says "Input power" in RMS watts. That value is interpreted as power into a cold coil. Code stores it as $P_&#123;input&#125;$ and defines the drive voltage once:</p>
                <div class="rounded-[14px] border border-border bg-card-bg p-5 font-mono text-[0.82rem] leading-[1.8] text-primary-text">
                  $$ V_&#123;in&#125;^2 = P_&#123;input&#125;\,R_&#123;e0&#125; $$
                  $$ P_e(T_v) = \frac&#123;V_&#123;in&#125;^2&#125;&#123;R_e(T_v)&#125; = \frac&#123;P_&#123;input&#125;R_&#123;e0&#125;&#125;&#123;R_e(T_v)&#125; $$
                  $$ I(T_v) = \frac&#123;V_&#123;in&#125;&#125;&#123;R_e(T_v)&#125; $$
                </div>
                <p>So $P_e$ falls as the coil heats. If you wanted a constant-power source, you'd hold $P_e$ fixed and temperature would climb faster. Real amps behave closer to constant-voltage into a resistive load, so this is the honest choice for SPL loss.</p>
              </div>
            </div>

            <div>
              <h3 class="text-[1.05rem] font-semibold tracking-[-0.02em] text-primary-text">3. Two coupled thermal ODEs</h3>
              <div class="mt-3 space-y-4 text-[0.92rem] leading-[1.7] text-muted-text">
                <p>This is the lumped ladder the code actually integrates with explicit Euler every $PHYSICS\_DT = 0.02$ s:</p>
                <div class="rounded-[14px] border border-border bg-card-bg p-5 font-mono text-[0.76rem] leading-[1.75] text-primary-text">
                  $$ \begin&#123;aligned&#125; \frac&#123;dT_v&#125;&#123;dt&#125; &= \frac&#123;P_e(T_v) - \frac&#123;T_v - T_m&#125;&#123;R_&#123;th\_v&#125;&#125;&#125;&#123;C_&#123;th\_v&#125;&#125; \\ \frac&#123;dT_m&#125;&#123;dt&#125; &= \frac&#123;\frac&#123;T_v - T_m&#125;&#123;R_&#123;th\_v&#125;&#125; - \frac&#123;T_m - T_&#123;amb&#125;&#125;&#123;R_&#123;th\_m&#125;&#125;&#125;&#123;C_&#123;th\_m&#125;&#125; \end&#123;aligned&#125; $$
                </div>
                <p>
                  Inside <code>stepPhysics()</code>, <code>heatFlowVC_to_Mag = (T_coil - T_mag)/Rth_v</code> and <code>heatFlowMag_to_Amb = (T_mag - Tamb)/Rth_m</code>. The update is <code>T_coil += dT_coil</code> with <code>dT_coil = (Pe - flow)/Cth_v * dt</code>. That is exactly the math above.
                </p>
                <p>
                  The rolling chart keeps $WINDOW\_SECONDS = 60$ simulated seconds, sampling about $30$ Hz, with <code>MAX_BUFFER = 1800</code> points. Time reads as simulated seconds, not wall-clock — accelerated by the slider up to $40\times$, safely stepping with an accumulator and a $200$-iteration cap per frame.
                </p>
              </div>
            </div>

            <div>
              <h3 class="text-[1.05rem] font-semibold tracking-[-0.02em] text-primary-text">4. SPL compression from lost current</h3>
              <div class="mt-3 space-y-4 text-[0.92rem] leading-[1.7] text-muted-text">
                <p>Force is $Bl \cdot I$. If $Bl$ held constant, $F \propto I \propto 1/R_e$. Sound pressure is proportional to force, so:</p>
                <div class="rounded-[14px] border border-border bg-card-bg p-5 font-mono text-[0.82rem] leading-[1.7] text-primary-text">
                  $$ \Delta L = -20\,\log_&#123;10&#125;\!\left(\frac&#123;R_e(T_v)&#125;&#123;R_&#123;e0&#125;&#125;\right)\;[\text&#123;dB&#125;] $$
                </div>
                <p>At $1.5\times R_&#123;e0&#125;$, that's $-3.5$ dB — you need $2.2\times$ electrical power to make up what heat stole. The top canvas draws this alongside temperature, so you see compression lag temperature slightly — it tracks $R_e$, which tracks $T_v$.</p>
              </div>
            </div>

            <div>
              <h3 class="text-[1.05rem] font-semibold tracking-[-0.02em] text-primary-text">5. Where it settles — steady-state solve</h3>
              <div class="mt-3 space-y-4 text-[0.92rem] leading-[1.7] text-muted-text">
                <p>Set derivatives to zero. Heat in equals heat out through the series $R_&#123;th&#125;$:</p>
                <div class="rounded-[14px] border border-border bg-card-bg p-5 font-mono text-[0.82rem] leading-[1.7] text-primary-text">
                  $$ \frac&#123;V_&#123;in&#125;^2&#125;&#123;R_&#123;e0&#125;[1+\alpha(T_&#123;ss&#125;-20)]&#125; = \frac&#123;T_&#123;ss&#125;-T_&#123;amb&#125;&#125;&#123;R_&#123;th\_v&#125;+R_&#123;th\_m&#125;&#125; $$
                </div>
                <p>
                  That's implicit in $T_&#123;ss&#125;$ because $R_e$ depends on it. Code function <code>steadyStateTemp(P_input, Re0, Tamb, alpha, Rth_v, Rth_m)</code> Newton-iterates $60$ times: residual $r = P_e - (T-T_&#123;amb&#125;)/R_&#123;th&#125;$, derivative $dr/dT = dP_e/dT - 1/R_&#123;th&#125;$, $T \gets T - r/(dr/dT)$. Initial guess ignores TCR: $T_&#123;guess&#125; = T_&#123;amb&#125; + P_&#123;input&#125;R_&#123;th&#125;$. Result shows as the dashed $T_&#123;ss&#125;$ line and the "Steady-state T" badge. The power-sweep canvas uses the same solver at $100$ power points up to $2\times P_&#123;input&#125;$.
                </p>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <div class="math-card !bg-card-bg">
              <p class="math-label">State vector</p>
              <p class="mt-2 font-mono text-[0.84rem] text-primary-text">$$\mathbf&#123;x&#125; = [T_v, T_m]^&#123;\top&#125;$$</p>
              <p class="mt-3 text-[0.78rem] leading-[1.6] text-muted-text">Two states, two time scales. Code keeps them as <code>T_coil</code> and <code>T_mag</code>, plus <code>simulatedTime</code>. No hidden integrators pulling tricks.</p>
            </div>
            <div class="math-card !bg-card-bg">
              <p class="math-label">Variables you actually touch</p>
              <p class="mt-2 font-mono text-[0.78rem] leading-[1.7] text-primary-text">$R_&#123;th\_v&#125;$ coil-to-magnet K/W — slider $rth\_v$<br/>$C_&#123;th\_v&#125;$ coil J/K — slider $cth\_v$<br/>$R_&#123;th\_m&#125;$, $C_&#123;th\_m&#125;$ magnet side — preset only<br/>$\alpha$ copper TCR — slider, default $0.00393$<br/>$P_&#123;input&#125;$, $R_&#123;e0&#125;$, $T_&#123;amb&#125;$ direct controls<br/>$PHYSICS\_DT=0.02$, $WINDOW\_SECONDS=60$</p>
            </div>
            <div class="math-card">
              <p class="math-label">Time constant decoded</p>
              <p class="mt-2 font-mono text-[0.78rem] leading-[1.7] text-primary-text">$$\tau = R_&#123;th&#125;C_&#123;th&#125;\;[s]$$</p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">After one $\tau$, the step response reaches $63\%$. Standard basket: $\tau_v=1.5\times15=22.5$ s. You see it on the top plot — knee around $20$–$30$ s. Ferrofluid slashes $R_&#123;th\_v&#125;$ to $0.4$, so $\tau_v \approx 4$ s and $T_&#123;ss&#125;$ drops dramatically, but $C_&#123;th\_v&#125;$ also $10$ J/K in that preset, keeping it responsive.</p>
            </div>
            <div class="math-card">
              <p class="math-label">Integrator honesty</p>
              <p class="mt-2 text-[0.78rem] leading-[1.6] text-muted-text">Forward Euler, fixed $0.02$ s, is stable here because thermal times are seconds, not microseconds. The accumulator pattern decouples sim time from frame rate, and time acceleration is a multiplier on elapsed wall time. No implicit solver, no artificial damping — what you see is the ODE, stepped honestly.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="play-title" class="border-b border-border">
      <div class="mx-auto max-w-[66rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="play-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Playbook — what to push, what to watch</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <div class="space-y-6">
            <div>
              <h3 class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-cta">Start here</h3>
              <p class="mt-2 text-[0.92rem] leading-[1.7] text-muted-text"><strong class="text-primary-text">150 W, Standard basket, 20°C.</strong> The default. Hit Play — coil climbs toward $\sim 150$–$200°C$ depending on $R_&#123;e0&#125;$, SPL sags about $-1$ to $-2$ dB over $60$ s. Watch $\tau_v$: time readout shows the early rise is steep, then bends as magnet warms. That's $C_&#123;th\_m&#125;$ waking up.</p>
            </div>
            <div>
              <h3 class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-cta">Crank it</h3>
              <p class="mt-2 text-[0.92rem] leading-[1.7] text-muted-text"><strong class="text-primary-text">1000 W.</strong> Same cooling, $5\times$ heat. $T_&#123;ss&#125;$ in the code's Newton solver jumps beyond $400°C$ — well past the $200°C$ adhesive warning. Current drops from $\sim 10$ A to $\sim 6$ A, electrical power actually falls as it heats. You asked for 1000 W, you get $\sim 600$ W hot. The red banner is not theatrical.</p>
              <p class="mt-3 text-[0.92rem] leading-[1.7] text-muted-text"><strong class="text-primary-text">Swap to Ferrofluid.</strong> Same 1000 W now settles near $180$–$220°C$, SPL sag about half. The power-sweep chart shows why: the orange-red curve (your current architecture) pulls down to green when you click that preset. Ferrofluid bridges the $0.2$ mm gap with liquid that conducts heat — $R_&#123;th\_v&#125; = 0.4$ vs $1.5$. Physics you can buy.</p>
            </div>
            <div>
              <h3 class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-cta">Find the constants</h3>
              <p class="mt-2 text-[0.92rem] leading-[1.7] text-muted-text"><strong class="text-primary-text">Measure $\tau$.</strong> Pause at ambient, hit Play, time how long to get $63\%$ of $T_&#123;ss&#125;-T_&#123;amb&#125;$. That's $\tau$ — compare to $R_&#123;th\_v&#125;C_&#123;th\_v&#125;$ badge. Now lower $C_&#123;th\_v&#125;$ to $0.5$ J/K (custom). Rise becomes near-instant — you removed thermal inertia. Raise it to $50$ J/K and you get a slow cooker.</p>
              <p class="mt-3 text-[0.92rem] leading-[1.7] text-muted-text"><strong class="text-primary-text">Ambient matters.</strong> Set $T_&#123;amb&#125; = 40°C$ — a summer stage. $T_v$ baseline lifts by $20$ K, $T_&#123;ss&#125;$ lifts by the same plus a little extra because hotter start means higher $R_e$ means a touch less power. Small, but real.</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="rounded-[16px] border border-border bg-card-bg p-5">
              <p class="font-mono text-[0.64rem] uppercase tracking-[0.1em] text-muted-text">Tweaks that matter</p>
              <div class="mt-4 space-y-4 text-[0.88rem] leading-[1.6] text-muted-text">
                <div>
                  <p class="font-semibold text-primary-text">Time acceleration</p>
                  <p>Physics $dt$ stays $PHYSICS\_DT = 0.02$ s — speed just runs more steps per render frame (capped at $200$ per frame). At $40\times$ you watch minutes of thermal drift in seconds. At $1\times$ you can see the sampling — data points every $0.033$ s — and feel how $\tau_m$ really dominates long runs.</p>
                </div>
                <div>
                  <p class="font-semibold text-primary-text">Power sweep + show all architectures</p>
                  <p>Top marker shows current live $T_&#123;coil&#125;$ vs steady-state $T_&#123;ss&#125;$ at $P_&#123;input&#125;$. When they diverge, you're still in transient. Click "Show all architectures" — three dashed curves use $PRESETS$ directly: standard $1.5/1.0$, vented $0.8/0.4$, ferrofluid $0.4/0.3$ for $R_&#123;th\_v&#125;/R_&#123;th\_m&#125;$. Slope at low power is $R_&#123;th\_v&#125;+R_&#123;th\_m&#125;$: linear for cold.</p>
                </div>
                <div>
                  <p class="font-semibold text-primary-text">200°C warning</p>
                  <p>At $200°C$ the SVG coil turns orange-red via <code>coilHexColor()</code> and the top plot shades the danger zone. Not arbitrary — most voice-coil adhesives (polyimide) soften around there. The simulation still runs hotter, but reality would have already distorted or seized.</p>
                </div>
              </div>
            </div>
            <div class="math-card">
              <p class="math-label">Where the code lives</p>
              <p class="mt-2 text-[0.78rem] leading-[1.6] text-muted-text"><code>steadyStateTemp()</code> Newton solve, <code>stepPhysics()</code> Euler ladder, <code>renderTimeCanvas()</code> dual stacked plot with $Tamb$ and $Tss$ asymptotes, <code>renderSweepCanvas()</code> pre-computed $100$-point curves. Sampling interval $0.033$ s, $WINDOW_SECONDS=60$ window trim. No magic.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="honesty-title">
      <div class="mx-auto max-w-[62rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="honesty-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Honesty — what this is and isn't</h2>
        <div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-semibold text-primary-text">What is real physics</p>
            <p class="mt-2 text-[0.88rem] leading-[1.65] text-muted-text">Lumped two-time-constant thermal network, copper TCR $\alpha=0.00393$, constant-voltage interpretation $V_&#123;in&#125;^2 = P_&#123;input&#125;R_&#123;e0&#125;$, coupled ODEs as written, Newton solve for steady-state, SPL compression as $-20\log_&#123;10&#125;(R_e/R_&#123;e0&#125;)$. Time constants $\tau=R_&#123;th&#125;C_&#123;th&#125;$ behave exactly as labeled. Numbers track a real 15" woofer within a factor of two.</p>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-semibold text-primary-text">What it simplifies</p>
            <p class="mt-2 text-[0.88rem] leading-[1.65] text-muted-text">Uniform temperature — real coil has hot spots near the gap exit. Constant $R_&#123;th&#125;$, $C_&#123;th&#125;$ — in reality convection scales with $\Delta T$ and gap airflow modulates with excursion. No radiation term $\propto T^4$. No frequency dependence — music is peaky, RMS is a crude average. No eddy-current heating in pole pieces, no $Bl(T)$ drop from magnet demagnetization, no former material or adhesive thermal conductance, no excursion-driven pumping. The model overestimates low-frequency heating and underestimates HF cooling — take it as a clear, teachable bounding case.</p>
          </div>
        </div>
        <p class="mt-8 text-[0.84rem] leading-[1.7] text-muted-text">If you want to push further: make $R_&#123;th\_v&#125;$ a function of $x_&#123;coil&#125;(t)$ to model pumping, add a third node for pole piece with its own $C$, let $Bl = Bl_0[1 - \beta(T_m-20)]$ for ferrite tempco, or drive $P_e(t)$ from a real audio envelope instead of continuous sine. All fit inside the same ladder — more nodes, same idea.</p>
      </div>
    </section>
