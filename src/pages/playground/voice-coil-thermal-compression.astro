<script>
import { setupHiDPI, clearCanvas, drawText, drawLine, drawCircle } from '../../lib/chart-core.ts';

interface Preset {
  label: string;
  rth_v: number;
  cth_v: number;
  rth_m: number;
  cth_m: number;
}

const PRESETS: Record<string, Preset> = {
  standard: { label: 'Standard basket', rth_v: 1.5, cth_v: 15, rth_m: 1.0, cth_m: 250 },
  vented:   { label: 'Vented pole-piece', rth_v: 0.8, cth_v: 12, rth_m: 0.4, cth_m: 250 },
  ferrofluid: { label: 'Ferrofluid', rth_v: 0.4, cth_v: 10, rth_m: 0.3, cth_m: 250 },
};

const ALPHA_CU = 0.00393;
const T_REF = 20;       // reference temperature for Re0 in °C
const WINDOW_SECONDS = 60; // rolling window for time-history plot
const PHYSICS_DT = 0.02;   // fixed physics timestep (seconds)

function clamp(v: number, lo: number, hi: number): number {
  return Math.max(lo, Math.min(hi, v));
}

function tempColorClass(t: number): string {
  if (t < 80) return 'temp-safe';
  if (t < 150) return 'temp-warn';
  if (t < 200) return 'temp-hot';
  return 'temp-danger';
}

function coilHexColor(t: number, tamb: number): string {
  const norm = clamp((t - tamb) / 300, 0, 1);
  if (norm < 0.15) return '#d4784a';
  if (norm < 0.4) {
    const f = (norm - 0.15) / 0.25;
    const r = Math.round(0xd4 + f * (0xe8 - 0xd4));
    const g = Math.round(0x78 + f * (0x6a - 0x78));
    const b = Math.round(0x4a + f * (0x2e - 0x4a));
    return `rgb(${r},${g},${b})`;
  }
  if (norm < 0.7) {
    const f = (norm - 0.4) / 0.3;
    const r = Math.round(0xe8 + f * (0xd4 - 0xe8));
    const g = Math.round(0x6a + f * (0x3a - 0x6a));
    const b = Math.round(0x2e + f * (0x28 - 0x2e));
    return `rgb(${r},${g},${b})`;
  }
  return '#d4523a';
}

// --- Steady-state solver ---
// Solves T_ss from: P_input * Re0 / (Re0 * (1 + α*(T_ss - Tref))) = (T_ss - Tamb) / (Rth_v + Rth_m)
// Iterative Newton-like solver.
function steadyStateTemp(P_input: number, Re0: number, Tamb: number, alpha: number, Rth_v: number, Rth_m: number): number {
  const Rth = Rth_v + Rth_m;
  const VinSq = P_input * Re0;
  let T = Tamb + P_input * Rth; // initial guess (ignoring Re change)
  for (let i = 0; i < 60; i++) {
    const ReT = Re0 * (1 + alpha * (T - T_REF));
    const Pe = VinSq / ReT;
    const residual = Pe - (T - Tamb) / Rth;
    if (Math.abs(residual) < 1e-6) break;
    const dPe_dT = -VinSq * Re0 * alpha / (ReT * ReT);
    const dRes_dT = dPe_dT - 1 / Rth;
    T -= residual / dRes_dT;
  }
  return clamp(T, Tamb, Tamb + 1000);
}

function initVoiceCoilThermal() {
  const timeCanvas = document.getElementById('time-canvas') as HTMLCanvasElement | null;
  const sweepCanvas = document.getElementById('sweep-canvas') as HTMLCanvasElement | null;
  if (!timeCanvas || !sweepCanvas || timeCanvas.dataset.initialized === 'true') return;
  timeCanvas.dataset.initialized = 'true';

  // --- DOM refs ---
  const powerSlider = document.getElementById('power-slider') as HTMLInputElement;
  const reSlider = document.getElementById('re-slider') as HTMLInputElement;
  const tambSlider = document.getElementById('tamb-slider') as HTMLInputElement;
  const accelSlider = document.getElementById('accel-slider') as HTMLInputElement;
  const rthSlider = document.getElementById('rth-slider') as HTMLInputElement;
  const cthSlider = document.getElementById('cth-slider') as HTMLInputElement;
  const alphaSlider = document.getElementById('alpha-slider') as HTMLInputElement;

  const powerReadout = document.getElementById('power-readout')!;
  const reReadout = document.getElementById('re-readout')!;
  const tambReadout = document.getElementById('tamb-readout')!;
  const accelReadout = document.getElementById('accel-readout')!;
  const rthReadout = document.getElementById('rth-readout')!;
  const cthReadout = document.getElementById('cth-readout')!;
  const alphaReadout = document.getElementById('alpha-readout')!;

  const runToggle = document.getElementById('run-toggle') as HTMLButtonElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const showAllCurvesBtn = document.getElementById('show-all-curves-btn') as HTMLButtonElement;

  const resTemp = document.getElementById('res-temp')!;
  const resRe = document.getElementById('res-re')!;
  const resCurrent = document.getElementById('res-current')!;
  const resPower = document.getElementById('res-power')!;
  const resSpl = document.getElementById('res-spl')!;
  const resTau = document.getElementById('res-tau')!;
  const resTss = document.getElementById('res-tss')!;
  const timeReadout = document.getElementById('time-readout')!;
  const tempWarning = document.getElementById('temp-warning')!;
  const coilLeft = document.getElementById('coil-left')!;
  const coilRight = document.getElementById('coil-right')!;
  const labelAmbient = document.getElementById('label-ambient')!;
  const labelCoil = document.getElementById('label-coil')!;
  const labelMagnet = document.getElementById('label-magnet')!;
  const heatArrows = document.getElementById('heat-arrows')!;

  const presetButtons = document.querySelectorAll<HTMLButtonElement>('[data-preset]');

  // --- State ---
  let P_input = 150;
  let Re0 = 6.2;
  let Tamb = 20;
  let timeAccel = 8;
  let alpha = ALPHA_CU;
  let Rth_v = PRESETS.standard.rth_v;
  let Cth_v = PRESETS.standard.cth_v;
  let Rth_m = PRESETS.standard.rth_m;
  let Cth_m = PRESETS.standard.cth_m;
  let activePreset = 'standard';
  let isCustom = false;

  let T_coil = Tamb;          // current coil temperature
  let T_mag = Tamb;           // current magnet temperature
  let simulatedTime = 0;      // accumulated simulated seconds
  let running = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let accumulator = 0;
  let lastFrameTime = performance.now();
  let animationFrameId = 0;
  let destroyed = false;
  let showAllCurves = false;

  // Rolling data buffers for time-history plot
  interface DataPoint {
    t: number;
    T: number;
    spl: number;
  }
  let dataBuffer: DataPoint[] = [];
  const MAX_BUFFER = 1800; // ~30 samples per simulated second * 60 seconds

  // Compute derived values
  function computeDerived(): { VinSq: number; ReT: number; I: number; Pe: number; splComp: number; tau: number; Tss: number } {
    const ReT = Re0 * (1 + alpha * (T_coil - T_REF));
    const VinSq = P_input * Re0;
    const I = Math.sqrt(VinSq) / ReT;  // I = Vin / Re(T)
    const Pe = VinSq / ReT;
    const splComp = -20 * Math.log10(ReT / Re0);
    const tau = Rth_v * Cth_v;
    const Tss = steadyStateTemp(P_input, Re0, Tamb, alpha, Rth_v, Rth_m);
    return { VinSq, ReT, I, Pe, splComp, tau, Tss };
  }

  // --- Physics step ---
  function stepPhysics(dt: number) {
    const ReT = Re0 * (1 + alpha * (T_coil - T_REF));
    const VinSq = P_input * Re0;
    const Pe = VinSq / ReT;
    const heatFlowVC_to_Mag = (T_coil - T_mag) / Rth_v;
    const heatFlowMag_to_Amb = (T_mag - Tamb) / Rth_m;
    const dT_coil = (Pe - heatFlowVC_to_Mag) / Cth_v * dt;
    const dT_mag = (heatFlowVC_to_Mag - heatFlowMag_to_Amb) / Cth_m * dt;
    T_coil += dT_coil;
    T_mag += dT_mag;
    simulatedTime += dt;
    // Store data point every ~0.033 simulated seconds (~30 Hz)
    const lastP = dataBuffer[dataBuffer.length - 1];
    if (!lastP || simulatedTime - lastP.t > 0.033) {
      const ReT2 = Re0 * (1 + alpha * (T_coil - T_REF));
      const splComp2 = -20 * Math.log10(ReT2 / Re0);
      dataBuffer.push({ t: simulatedTime, T: T_coil, spl: splComp2 });
      // Trim to rolling window
      while (dataBuffer.length > 0 && simulatedTime - dataBuffer[0].t > WINDOW_SECONDS) {
        dataBuffer.shift();
      }
      // Limit buffer size
      while (dataBuffer.length > MAX_BUFFER) {
        dataBuffer.shift();
      }
    }
  }

  // --- Update DOM ---
  function updateReadouts() {
    powerReadout.textContent = String(P_input);
    reReadout.textContent = Re0.toFixed(1);
    tambReadout.textContent = String(Tamb);
    accelReadout.innerHTML = timeAccel + '&times;';
    rthReadout.textContent = Rth_v.toFixed(2);
    cthReadout.textContent = Cth_v.toFixed(1);
    alphaReadout.textContent = alpha.toFixed(5);
  }

  function updateSliders() {
    powerSlider.value = String(P_input);
    reSlider.value = String(Re0);
    tambSlider.value = String(Tamb);
    accelSlider.value = String(timeAccel);
    rthSlider.value = String(Rth_v);
    cthSlider.value = String(Cth_v);
    alphaSlider.value = String(alpha);
  }

  function updateResults() {
    const d = computeDerived();
    const colorCls = tempColorClass(T_coil);
    resTemp.className = `mt-1 text-[clamp(1.4rem,3vw,2rem)] font-[700] leading-[1.05] tracking-[-0.03em] ${colorCls}`;
    resTemp.textContent = T_coil.toFixed(1) + '\u00B0C';
    resRe.textContent = d.ReT.toFixed(2);
    resCurrent.textContent = d.I.toFixed(2);
    resPower.textContent = d.Pe.toFixed(1);
    resSpl.textContent = d.splComp.toFixed(2);
    resTau.textContent = d.tau.toFixed(1);
    resTss.textContent = d.Tss.toFixed(0);

    // Warning
    if (T_coil > 200) {
      tempWarning.classList.remove('hidden');
    } else {
      tempWarning.classList.add('hidden');
    }

    // Time readout
    timeReadout.textContent = simulatedTime.toFixed(1) + ' s simulated';
  }

  function updateSVG() {
    const hex = coilHexColor(T_coil, Tamb);
    coilLeft.setAttribute('fill', hex);
    coilRight.setAttribute('fill', hex);

    // Adjust stroke based on temperature
    if (T_coil > 200) {
      coilLeft.setAttribute('stroke', '#a83020');
      coilRight.setAttribute('stroke', '#a83020');
    } else if (T_coil > 100) {
      coilLeft.setAttribute('stroke', '#c05830');
      coilRight.setAttribute('stroke', '#c05830');
    } else {
      coilLeft.setAttribute('stroke', '#b85a2e');
      coilRight.setAttribute('stroke', '#b85a2e');
    }

    // Labels
    labelAmbient.textContent = 'Ambient: ' + Tamb.toFixed(0) + '\u00B0C';
    labelCoil.textContent = 'Coil: ' + T_coil.toFixed(1) + '\u00B0C';
    labelMagnet.textContent = 'Magnet structure: ' + T_mag.toFixed(0) + '\u00B0C';

    // Arrow opacity scales with temperature gradient
    const gradNorm = clamp((T_coil - Tamb) / 200, 0, 1);
    heatArrows.setAttribute('opacity', String(0.25 + gradNorm * 0.75));
  }

  // --- Canvas rendering ---
  function getTheme() {
    const get = (v: string, fallback: string) =>
      (typeof document !== 'undefined' ? getComputedStyle(document.documentElement).getPropertyValue(v).trim() : '') || fallback;
    return {
      canvas: get('--mp-canvas', '#0f141c'),
      text: get('--mp-text', '#e8eef6'),
      muted: get('--mp-muted', '#a8b9cc'),
      border: get('--mp-border', 'rgba(255,255,255,0.08)'),
      gridLine: get('--mp-grid-line', 'rgba(168,185,204,0.028)'),
      cta: get('--mp-cta', '#ce445d'),
    };
  }

  function renderTimeCanvas() {
    if (!timeCanvas) return;
    const rect = timeCanvas.getBoundingClientRect();
    const cw = rect.width;
    const ch = rect.height;
    const ctx = setupHiDPI(timeCanvas, cw, ch);
    const theme = getTheme();
    clearCanvas(ctx, { canvas: theme.canvas, text: theme.text, muted: theme.muted, border: theme.border, gridLine: theme.gridLine, magColor: theme.cta, phaseColor: '#4a7bb8' }, cw, ch);

    if (dataBuffer.length < 2) {
      drawText(ctx, 'Waiting for data…', cw / 2, ch / 2, theme.muted, 12, 'center');
      return;
    }

    const margin = { top: 30, bottom: 34, left: 52, right: 20 };
    const plotH = (ch - margin.top - margin.bottom) / 2 - 4; // two stacked plots
    const tempTop = margin.top;
    const tempBot = tempTop + plotH;
    const splTop = tempBot + 8;
    const splBot = splTop + plotH;
    const plotW = cw - margin.left - margin.right;

    const tMin = dataBuffer[0].t;
    const tMax = dataBuffer[dataBuffer.length - 1].t;
    const paddedTMin = tMax - WINDOW_SECONDS;
    const effectiveTMin = Math.max(tMin, paddedTMin);

    function timeToX(t: number): number {
      return margin.left + ((t - effectiveTMin) / (tMax - effectiveTMin + 0.001)) * plotW;
    }

    // Temperature range
    const temps = dataBuffer.map(d => d.T);
    let tempMin = Tamb - 5;
    let tempMax = Math.max(...temps, Tamb + 5, 250);
    tempMax = Math.ceil(tempMax / 50) * 50 + 25;
    if (tempMax - tempMin < 100) tempMax = tempMin + 100;

    function tempToY(T: number): number {
      return tempBot - ((T - tempMin) / (tempMax - tempMin)) * plotH;
    }

    // SPL range
    const spls = dataBuffer.map(d => d.spl);
    let splMin = Math.min(0, Math.floor(Math.min(...spls)));
    let splMax = 0.5;
    if (splMin > -3) splMin = -3;
    splMin = Math.floor(splMin);

    function splToY(spl: number): number {
      return splBot - ((spl - splMin) / (splMax - splMin)) * plotH;
    }

    // --- Draw temp grid ---
    ctx.strokeStyle = theme.gridLine;
    ctx.lineWidth = 0.5;
    for (let tTemp = Math.ceil(tempMin / 50) * 50; tTemp <= tempMax; tTemp += 50) {
      const y = tempToY(tTemp);
      ctx.beginPath();
      ctx.moveTo(margin.left, y);
      ctx.lineTo(cw - margin.right, y);
      ctx.stroke();
      drawText(ctx, tTemp + '\u00B0', margin.left - 6, y + 3, theme.muted, 8, 'right');
    }

    // Time grid
    for (let t = Math.ceil(effectiveTMin / 10) * 10; t <= tMax; t += 10) {
      if (t < effectiveTMin - 0.1) continue;
      const x = timeToX(t);
      ctx.beginPath();
      ctx.moveTo(x, tempTop);
      ctx.lineTo(x, tempBot);
      ctx.strokeStyle = theme.gridLine;
      ctx.stroke();
      // same grid lines for SPL plot
      ctx.beginPath();
      ctx.moveTo(x, splTop);
      ctx.lineTo(x, splBot);
      ctx.stroke();
      drawText(ctx, t.toFixed(0) + 's', x, splBot + 12, theme.muted, 8, 'center');
    }

    // --- Warning zone shading (above 200°C) ---
    const warnY = tempToY(200);
    if (warnY > tempTop && warnY < tempBot) {
      ctx.fillStyle = 'rgba(212, 82, 58, 0.08)';
      ctx.fillRect(margin.left, tempTop, plotW, warnY - tempTop);
    }

    // --- Tamb reference line ---
    const tambY = tempToY(Tamb);
    ctx.setLineDash([4, 4]);
    drawLine(ctx, margin.left, tambY, cw - margin.right, tambY, theme.muted, 0.8);
    drawText(ctx, 'Tamb=' + Tamb + '\u00B0', cw - margin.right - 4, tambY - 5, theme.muted, 9, 'right');
    ctx.setLineDash([]);

    // --- Steady-state asymptote line ---
    const d = computeDerived();
    const tssY = tempToY(d.Tss);
    ctx.setLineDash([8, 5]);
    drawLine(ctx, margin.left, tssY, cw - margin.right, tssY, theme.muted, 0.6);
    drawText(ctx, 'Tss=' + d.Tss.toFixed(0) + '\u00B0', cw - margin.right - 4, tssY - 5, theme.muted, 8, 'right');
    ctx.setLineDash([]);

    // --- Plot temperature ---
    ctx.beginPath();
    ctx.strokeStyle = theme.cta;
    ctx.lineWidth = 2;
    let firstPoint = true;
    for (const point of dataBuffer) {
      const x = timeToX(point.t);
      const y = tempToY(point.T);
      if (x < margin.left) { firstPoint = true; continue; }
      if (firstPoint) { ctx.moveTo(x, y); firstPoint = false; }
      else ctx.lineTo(x, y);
    }
    ctx.stroke();

    // --- SPL grid ---
    for (let s = splMin; s <= splMax; s += 0.5) {
      const y = splToY(s);
      ctx.beginPath();
      ctx.moveTo(margin.left, y);
      ctx.lineTo(cw - margin.right, y);
      ctx.strokeStyle = s === 0 ? theme.border : theme.gridLine;
      ctx.stroke();
      drawText(ctx, s.toFixed(1), margin.left - 6, y + 3, theme.muted, 8, 'right');
    }

    // --- Plot SPL compression ---
    ctx.beginPath();
    ctx.strokeStyle = '#4a7bb8';
    ctx.lineWidth = 1.8;
    firstPoint = true;
    for (const point of dataBuffer) {
      const x = timeToX(point.t);
      const y = splToY(point.spl);
      if (x < margin.left) { firstPoint = true; continue; }
      if (firstPoint) { ctx.moveTo(x, y); firstPoint = false; }
      else ctx.lineTo(x, y);
    }
    ctx.stroke();

    // --- Axis labels ---
    ctx.fillStyle = theme.muted;
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'center';
    ctx.fillText('Simulated time (s)', cw / 2, splBot + 26);

    ctx.save();
    ctx.translate(13, tempTop + plotH / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('Temperature (\u00B0C)', 0, 0);
    ctx.restore();

    ctx.save();
    ctx.translate(13, splTop + plotH / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('SPL compression (dB)', 0, 0);
    ctx.restore();

    // Plot labels
    drawText(ctx, 'Temp', margin.left + 8, tempTop + 12, theme.cta, 9);
    drawText(ctx, 'SPL sag', margin.left + 8, splTop + 12, '#4a7bb8', 9);

    // Current value indicator dots
    if (dataBuffer.length > 0) {
      const last = dataBuffer[dataBuffer.length - 1];
      const lx = timeToX(last.t);
      drawCircle(ctx, lx, tempToY(last.T), 3.5, theme.cta, theme.canvas, 1.5);
      drawCircle(ctx, lx, splToY(last.spl), 3.5, '#4a7bb8', theme.canvas, 1.5);
    }
  }

  function renderSweepCanvas() {
    if (!sweepCanvas) return;
    const rect = sweepCanvas.getBoundingClientRect();
    const cw = rect.width;
    const ch = rect.height;
    const ctx = setupHiDPI(sweepCanvas, cw, ch);
    const theme = getTheme();
    clearCanvas(ctx, { canvas: theme.canvas, text: theme.text, muted: theme.muted, border: theme.border, gridLine: theme.gridLine, magColor: theme.cta, phaseColor: '#4a7bb8' }, cw, ch);

    const margin = { top: 22, bottom: 30, left: 48, right: 16 };
    const plotW = cw - margin.left - margin.right;
    const plotH = ch - margin.top - margin.bottom;

    const maxPower = P_input * 2;
    const powers: number[] = [];
    const steps = 100;
    for (let i = 0; i <= steps; i++) {
      powers.push((i / steps) * maxPower);
    }

    function powerToX(p: number): number {
      return margin.left + (p / maxPower) * plotW;
    }

    // Compute Y range
    const curves: Record<string, number[]> = {};

    // Current architecture curve
    curves['current'] = powers.map(p => steadyStateTemp(p, Re0, Tamb, alpha, Rth_v, Rth_m));

    if (showAllCurves) {
      curves['standard'] = powers.map(p => steadyStateTemp(p, Re0, Tamb, alpha, PRESETS.standard.rth_v, PRESETS.standard.rth_m));
      curves['vented'] = powers.map(p => steadyStateTemp(p, Re0, Tamb, alpha, PRESETS.vented.rth_v, PRESETS.vented.rth_m));
      curves['ferrofluid'] = powers.map(p => steadyStateTemp(p, Re0, Tamb, alpha, PRESETS.ferrofluid.rth_v, PRESETS.ferrofluid.rth_m));
    }

    const allTemps = Object.values(curves).flat();
    let tempMin = Tamb - 5;
    let tempMax = Math.ceil(Math.max(...allTemps, 100) / 50) * 50 + 25;
    if (tempMax - tempMin < 100) tempMax = tempMin + 100;

    function tempToY(T: number): number {
      return margin.top + plotH - ((T - tempMin) / (tempMax - tempMin)) * plotH;
    }

    // Grid
    ctx.strokeStyle = theme.gridLine;
    ctx.lineWidth = 0.5;
    for (let tTemp = Math.ceil(tempMin / 50) * 50; tTemp <= tempMax; tTemp += 50) {
      const y = tempToY(tTemp);
      ctx.beginPath();
      ctx.moveTo(margin.left, y);
      ctx.lineTo(cw - margin.right, y);
      ctx.stroke();
      drawText(ctx, tTemp + '\u00B0', margin.left - 6, y + 3, theme.muted, 8, 'right');
    }

    for (let p = 0; p <= maxPower; p += Math.max(1, Math.ceil(maxPower / 10))) {
      const x = powerToX(p);
      ctx.beginPath();
      ctx.moveTo(x, margin.top);
      ctx.lineTo(x, margin.top + plotH);
      ctx.stroke();
      drawText(ctx, p + 'W', x, margin.top + plotH + 12, theme.muted, 8, 'center');
    }

    // 200°C danger line
    const dangerY = tempToY(200);
    if (dangerY > margin.top && dangerY < margin.top + plotH) {
      ctx.setLineDash([6, 4]);
      drawLine(ctx, margin.left, dangerY, cw - margin.right, dangerY, '#d4523a', 0.7);
      drawText(ctx, '200\u00B0C', cw - margin.right - 4, dangerY - 5, '#d4523a', 8, 'right');
      ctx.setLineDash([]);
    }

    // Tamb reference
    const tambY = tempToY(Tamb);
    ctx.setLineDash([4, 4]);
    drawLine(ctx, margin.left, tambY, cw - margin.right, tambY, theme.muted, 0.6);
    ctx.setLineDash([]);

    // Plot curves
    // Always draw current architecture curve
    function drawCurve(label: string, temps: number[], color: string, width: number, dash: number[] = []) {
      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = width;
      ctx.setLineDash(dash);
      for (let i = 0; i < powers.length; i++) {
        const x = powerToX(powers[i]);
        const y = tempToY(temps[i]);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.setLineDash([]);
      // Label at end
      const lastX = powerToX(powers[powers.length - 1]);
      const lastY = tempToY(temps[temps.length - 1]);
      drawText(ctx, label, lastX + 3, lastY + 3, color, 8, 'left');
    }

    drawCurve(isCustom ? 'Custom' : PRESETS[activePreset].label, curves['current'], theme.cta, 2.2);

    if (showAllCurves) {
      if (activePreset !== 'standard' || isCustom) drawCurve('Standard', curves['standard']!, theme.muted, 1.2, [5, 3]);
      if (activePreset !== 'vented' || isCustom) drawCurve('Vented', curves['vented']!, '#4a7bb8', 1.2, [5, 3]);
      if (activePreset !== 'ferrofluid' || isCustom) drawCurve('Ferrofluid', curves['ferrofluid']!, '#3ba55c', 1.2, [5, 3]);
    }

    // Current operating point marker
    const currentTss = steadyStateTemp(P_input, Re0, Tamb, alpha, Rth_v, Rth_m);
    const opX = powerToX(P_input);
    const opY = tempToY(currentTss);
    drawCircle(ctx, opX, opY, 5, theme.cta, theme.canvas, 2);
    drawCircle(ctx, opX, opY, 2, theme.text);

    // Current coil temp (may not be at steady state yet)
    const coilY = tempToY(T_coil);
    if (Math.abs(currentTss - T_coil) > 2) {
      drawCircle(ctx, opX, coilY, 4, theme.text, theme.cta, 1.5);
      drawLine(ctx, opX + 6, coilY, opX + 10, coilY, theme.text, 0.8);
      drawText(ctx, T_coil.toFixed(0) + '\u00B0', opX + 12, coilY + 3, theme.text, 8, 'left');
    }

    // Axis labels
    ctx.fillStyle = theme.muted;
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'center';
    ctx.fillText('Input power (W RMS)', cw / 2, ch - 6);

    ctx.save();
    ctx.translate(13, margin.top + plotH / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('Steady-state temperature (\u00B0C)', 0, 0);
    ctx.restore();
  }

  function renderAll() {
    renderTimeCanvas();
    renderSweepCanvas();
  }

  // --- Simulation loop ---
  function renderFrame(frameTime: number) {
    if (destroyed) return;
    const elapsed = Math.min(0.1, Math.max(0, frameTime - lastFrameTime) / 1000);
    lastFrameTime = frameTime;

    if (!isVisible) {
      animationFrameId = requestAnimationFrame(renderFrame);
      return;
    }

    if (running) {
      accumulator += elapsed * timeAccel;
      let safety = 0;
      while (accumulator >= PHYSICS_DT && safety < 200) {
        stepPhysics(PHYSICS_DT);
        accumulator -= PHYSICS_DT;
        safety++;
      }
      if (accumulator > PHYSICS_DT * 3) {
        accumulator = 0;
      }
    }

    updateResults();
    updateSVG();
    renderTimeCanvas();
    renderSweepCanvas();

    animationFrameId = requestAnimationFrame(renderFrame);
  }

  // --- Controls ---
  function setRunning(next: boolean) {
    running = next;
    runToggle.textContent = running ? 'Pause' : 'Play';
    runToggle.classList.toggle('is-active', running);
    runToggle.setAttribute('aria-pressed', String(running));
    lastFrameTime = performance.now();
  }

  function setPreset(key: string) {
    if (key === 'custom') {
      isCustom = true;
      presetButtons.forEach(b => b.classList.toggle('is-active', b.dataset.preset === 'custom'));
      return;
    }
    isCustom = false;
    activePreset = key;
    const preset = PRESETS[key];
    Rth_v = preset.rth_v;
    Cth_v = preset.cth_v;
    Rth_m = preset.rth_m;
    Cth_m = preset.cth_m;
    updateSliders();
    updateReadouts();
    presetButtons.forEach(b => b.classList.toggle('is-active', b.dataset.preset === key));
  }

  function resetSimulation() {
    T_coil = Tamb;
    T_mag = Tamb;
    simulatedTime = 0;
    accumulator = 0;
    dataBuffer = [{ t: 0, T: Tamb, spl: 0 }];
    updateResults();
    updateSVG();
    renderTimeCanvas();
    renderSweepCanvas();
    lastFrameTime = performance.now();
  }

  // --- Event listeners ---
  powerSlider.addEventListener('input', () => {
    P_input = parseFloat(powerSlider.value);
    powerReadout.textContent = String(P_input);
    if (!running) { updateResults(); updateSVG(); renderSweepCanvas(); }
  });

  reSlider.addEventListener('input', () => {
    Re0 = parseFloat(reSlider.value);
    reReadout.textContent = Re0.toFixed(1);
    if (!running) { updateResults(); updateSVG(); renderSweepCanvas(); }
  });

  tambSlider.addEventListener('input', () => {
    Tamb = parseFloat(tambSlider.value);
    tambReadout.textContent = String(Tamb);
    if (!running) {
      T_coil = Math.max(T_coil, Tamb);
      T_mag = Math.max(T_mag, Tamb);
      dataBuffer = [{ t: 0, T: Tamb, spl: 0 }];
      updateResults(); updateSVG(); renderAll();
    }
  });

  accelSlider.addEventListener('input', () => {
    timeAccel = parseFloat(accelSlider.value);
    accelReadout.innerHTML = timeAccel + '&times;';
    lastFrameTime = performance.now();
  });

  rthSlider.addEventListener('input', () => {
    Rth_v = parseFloat(rthSlider.value);
    rthReadout.textContent = Rth_v.toFixed(2);
    if (!isCustom) {
      setPreset('custom');
      updateSliders();
    }
    if (!running) { updateResults(); updateSVG(); renderSweepCanvas(); }
  });

  cthSlider.addEventListener('input', () => {
    Cth_v = parseFloat(cthSlider.value);
    cthReadout.textContent = Cth_v.toFixed(1);
    if (!isCustom) {
      setPreset('custom');
      updateSliders();
    }
    if (!running) { updateResults(); updateSVG(); renderSweepCanvas(); }
  });

  alphaSlider.addEventListener('input', () => {
    alpha = parseFloat(alphaSlider.value);
    alphaReadout.textContent = alpha.toFixed(5);
    if (!running) { updateResults(); updateSVG(); renderSweepCanvas(); }
  });

  presetButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      setPreset(btn.dataset.preset!);
      if (!running) { updateResults(); updateSVG(); renderAll(); }
    });
  });

  runToggle.addEventListener('click', () => setRunning(!running));
  resetBtn.addEventListener('click', resetSimulation);

  showAllCurvesBtn.addEventListener('click', () => {
    showAllCurves = !showAllCurves;
    showAllCurvesBtn.textContent = showAllCurves ? 'Hide architectures' : 'Show all architectures';
    renderSweepCanvas();
  });

  let isVisible = true;
  const io = new IntersectionObserver((entries) => {
    isVisible = entries[0].isIntersecting && !document.hidden;
  });
  io.observe(document.getElementById('time-canvas') || document.body);

  function handleVisibilityChange() {
    lastFrameTime = performance.now();
    isVisible = !document.hidden;
  }
  document.addEventListener('visibilitychange', handleVisibilityChange);

  // --- Kick off ---
  updateReadouts();
  updateSliders();
  // Initial preset button state
  presetButtons.forEach(b => b.classList.toggle('is-active', b.dataset.preset === 'standard'));
  dataBuffer = [{ t: 0, T: Tamb, spl: 0 }];
  setRunning(running);
  updateResults();
  updateSVG();
  renderAll();
  animationFrameId = requestAnimationFrame(renderFrame);

  // --- Cleanup ---
  document.addEventListener('astro:before-swap', () => {
    destroyed = true;
    cancelAnimationFrame(animationFrameId);
    io.disconnect();
    document.removeEventListener('visibilitychange', handleVisibilityChange);
  }, { once: true });
}

document.addEventListener('astro:page-load', initVoiceCoilThermal);
initVoiceCoilThermal();
</script>
