<script>
// @ts-nocheck
function initRtos(){
  const canvas = document.getElementById('rtos-canvas');
  if(!canvas || canvas.dataset.init) return;
  canvas.dataset.init='true';
  const ctx = canvas.getContext('2d');
  const dpr = Math.min(window.devicePixelRatio||1,2);
  const W0 = canvas.width, H0=canvas.height;
  canvas.width=W0*dpr; canvas.height=H0*dpr;
  canvas.style.width=W0+'px'; canvas.style.height=H0+'px';
  ctx.scale(dpr,dpr);
  const W=W0, H=H0;

  // UI refs
  const btnPlay=document.getElementById('btn-play');
  const btnStep=document.getElementById('btn-step');
  const btnReset=document.getElementById('btn-reset');
  const btnAdd=document.getElementById('btn-add');
  const selSched=document.getElementById('sel-sched');
  const inHorizon=document.getElementById('in-horizon');
  const outHorizon=document.getElementById('out-horizon');
  const inSpeed=document.getElementById('in-speed');
  const outSpeed=document.getElementById('out-speed');
  const chkAudio=document.getElementById('chk-audio');
  const tensionInd=document.getElementById('tension-ind');
  const taskTableDiv=document.getElementById('task-table');
  const inIsrPer=document.getElementById('in-isr-per');
  const inIsrC=document.getElementById('in-isr-c');
  const tableBlocking=document.getElementById('blocking-list');
  const timeLabel=document.getElementById('time-label');

  const roU=document.getElementById('ro-u');
  const roBound=document.getElementById('ro-bound');
  const roMiss=document.getElementById('ro-miss');
  const roBlock=document.getElementById('ro-block');
  const roJitter=document.getElementById('ro-jitter');
  const roIdle=document.getElementById('ro-idle');
  const roStatus=document.getElementById('ro-status');
  const ro2U=document.getElementById('ro2-u');
  const ro2Miss=document.getElementById('ro2-miss');
  const ro2Resp=document.getElementById('ro2-resp');

  // state
  let playing=true;
  let speed=2;
  let horizon=240;
  let scheduler='RMS';
  let isrPer=40;
  let isrC=2;
  let tasks=[
    {id:0, name:'T1 Ctrl', T:20, C:4, D:20, prioManual:'', mutex:'M1', csStart:0.2, csDur:0.5, color:'#71b9e3'},
    {id:1, name:'T2 Sens', T:30, C:6, D:30, prioManual:'', mutex:'M1', csStart:0.25, csDur:0.4, color:'#f07a94'},
    {id:2, name:'T3 Log', T:80, C:12, D:80, prioManual:'', mutex:'M2', csStart:0.15, csDur:0.35, color:'#4ade80'},
    {id:3, name:'T4 UI', T:200, C:20, D:200, prioManual:'', mutex:'', csStart:0.2, csDur:0.2, color:'#fbbf24'},
  ];
  const mutexOptions=['','M1','M2','M3'];
  const palette=['#71b9e3','#f07a94','#4ade80','#fbbf24','#a78bfa','#fb7185','#34d399','#f59e0b'];

  let nextId=4;
  let simResult=null;
  let cursor=0;
  let lastFrame=performance.now();
  let accum=0;

  function basePrioOf(td, mode){
    const manual = parseInt(td.prioManual);
    if(!isNaN(manual) && td.prioManual!=='' ){
      const m = Math.max(1,Math.min(99,manual));
      return m*100 + 500; // map 1..99 -> 600..10400 so high overrides auto but still below ISR
    }
    return Math.round(1_000_000 / td.T);
  }

  function simulate(allTasks, horiz, mode, isrP, isrWCET){
    const mutexState=new Map();
    let jobs=[];
    let jid=0;
    const log=new Array(horiz).fill(-1);
    const perTask={};
    allTasks.forEach(t=> perTask[t.id]= new Array(horiz).fill('Idle'));
    perTask[-1]= new Array(horiz).fill('Idle');
    const events=[];
    let totalMiss=0;

    for(let t=0;t<horiz;t++){
      // releases tasks
      allTasks.forEach(td=>{
        if(t % td.T===0){
          const j={
            jobId:jid++, taskId:td.id, release:t, absDeadline:t+td.D,
            executed:0, remaining:td.C, state:'Ready',
            blockedOn:null, holds:new Set(), basePrio:basePrioOf(td,mode),
            effPrio:basePrioOf(td,mode), effDeadline:t+td.D,
            blockedTime:0, firstStart:null, completion:null, missed:false, tdRef:td
          };
          jobs.push(j);
        }
      });
      if(isrP>0 && t % isrP===0){
        const ij={
          jobId:jid++, taskId:-1, release:t, absDeadline:t+isrP,
          executed:0, remaining:isrWCET, state:'Ready', blockedOn:null,
          holds:new Set(), basePrio:1e9, effPrio:1e9, effDeadline:t+isrP,
          blockedTime:0, firstStart:null, completion:null, missed:false, tdRef:null
        };
        jobs.push(ij);
      }

      const active = jobs.filter(j=> j.release<=t && j.remaining>0);

      // release expired CS
      active.forEach(j=>{
        if(j.taskId===-1) return;
        const td = allTasks.find(x=>x.id===j.taskId);
        if(!td || !td.mutex) return;
        const m = td.mutex;
        if(j.holds.has(m)){
          const end = td.csStart + td.csDur;
          if(j.executed >= end*td.C){
            j.holds.delete(m);
            const st=mutexState.get(m);
            if(st && st.holder===j) st.holder=null;
          }
        }
      });

      // try to unblock waiting jobs whose mutex became free (highest prio first)
      // gather per mutex queues arbitration
      for(const [mname, st] of mutexState){
        if(!st.holder && st.queue.length>0){
          // sort queue by eff prio descending for RMS, deadline ascending for EDF
          st.queue.sort((a,b)=>{
            if(mode==='RMS') return b.effPrio - a.effPrio;
            return a.effDeadline - b.effDeadline;
          });
          const nxt = st.queue.shift();
          if(nxt){
            st.holder=nxt;
            nxt.holds.add(mname);
            nxt.blockedOn=null;
            nxt.state='Ready';
          }
        }
      }

      // also check blocked jobs individually if holder null but not in queue iteration above (initial releases)
      active.filter(j=> j.state==='Blocked' && j.blockedOn).forEach(j=>{
        const st = mutexState.get(j.blockedOn);
        if(!st) return;
        if(!st.holder){
          // will be handled next loop, but ensure queue contains it
          if(!st.queue.includes(j)){
            // shouldn't happen
          }
        }
      });

      // new lock attempts
      active.filter(j=> j.state!=='Blocked' && j.remaining>0 && !j.blockedOn).forEach(j=>{
        if(j.taskId===-1) return;
        const td = allTasks.find(x=>x.id===j.taskId);
        if(!td?.mutex) return;
        if(j.holds.has(td.mutex)) return;
        if(j.executed < td.csStart*td.C) return;
        if(j.executed >= (td.csStart+td.csDur)*td.C) return;
        let st = mutexState.get(td.mutex);
        if(!st){ st={holder:null, queue:[]}; mutexState.set(td.mutex, st); }
        if(!st.holder){
          st.holder=j; j.holds.add(td.mutex);
        }else if(st.holder!==j){
          if(!st.queue.includes(j)) st.queue.push(j);
          j.state='Blocked'; j.blockedOn=td.mutex;
          events.push({t, waiter:j.taskId, holder:st.holder.taskId, mutex:td.mutex});
        }
      });

      // inheritance fixpoint
      let changed=true;
      let iter=0;
      while(changed && iter<12){
        changed=false; iter++;
        for(const [mname, st] of mutexState){
          if(!st.holder || st.queue.length===0) continue;
          if(mode==='RMS'){
            let maxWait = st.holder.effPrio;
            let maxJob = null;
            for(const q of st.queue){ if(q.effPrio>maxWait){ maxWait=q.effPrio; maxJob=q; } }
            if(maxWait>st.holder.effPrio){
              st.holder.effPrio=maxWait; changed=true;
            }
          }else{
            let minDead=st.holder.effDeadline;
            for(const q of st.queue){ if(q.effDeadline<minDead) minDead=q.effDeadline; }
            if(minDead < st.holder.effDeadline){ st.holder.effDeadline=minDead; changed=true; }
          }
        }
        // propagate through chain: if holder itself blocked, its new eff should affect its holder
        // loop again covers because holder's boosted eff will be seen by its mutex holder's queue
      }

      // misses
      active.forEach(j=>{
        if(!j.missed && t >= j.absDeadline && j.remaining>0){
          j.missed=true; totalMiss++;
        }
        if(j.state==='Blocked') j.blockedTime++;
      });

      // scheduling
      const cand = active.filter(j=> j.state!=='Blocked');
      if(cand.length>0){
        cand.sort((a,b)=>{
          if(mode==='RMS') return b.effPrio - a.effPrio;
          const d=a.effDeadline - b.effDeadline;
          if(d!==0) return d;
          return b.effPrio - a.effPrio;
        });
        const run=cand[0];
        run.state='Running';
        if(run.firstStart==null) run.firstStart=t;
        cand.slice(1).forEach(j=>{ if(j.state==='Running') j.state='Ready'; if(j.state!=='Blocked') j.state='Ready'; });
        run.executed++; run.remaining--;
        if(run.remaining<=0){
          run.remaining=0; run.state='Done'; run.completion=t+1;
          for(const m of [...run.holds]){
            const st=mutexState.get(m);
            if(st?.holder===run) st.holder=null;
          }
          run.holds.clear();
        }
        log[t]=run.taskId;
      }else{
        log[t]=-1;
      }

      // per task timeline aggregation
      allTasks.forEach(td=>{
        const js = active.filter(j=> j.taskId===td.id);
        let st='Idle';
        if(js.some(j=> j.state==='Running')) st='Running';
        else if(js.some(j=> j.state==='Blocked')) st='Blocked';
        else if(js.some(j=> j.state==='Ready' || j.state==='Done' && j.completion===t+1)) {
          // check if any ready
          if(js.some(j=> j.state==='Ready')) st='Ready';
          else if(js.some(j=> j.state==='Running')) st='Running';
          else if(js.length>0 && js.some(j=> j.state==='Ready' || j.state==='Running' || j.state==='Blocked')) st='Ready';
          else st=js.length? 'Ready':'Idle';
          // more precise: if active includes this task jobs
          // if any Ready else if Blocked else Ready else Idle
          if(js.some(j=> j.state==='Blocked')) st='Blocked';
          if(js.some(j=> j.state==='Running')) st='Running';
          else if(js.some(j=> j.state==='Ready')) st='Ready';
        } else if(js.length>0){
          // if jobs exist but not yet determined, infer
          if(js.every(j=> j.state==='Done')) st='Idle';
          else st='Ready';
        }
        // If multiple jobs overlapping, keep Running > Blocked > Ready
        const states = js.map(j=>j.state);
        if(states.includes('Running')) st='Running';
        else if(states.includes('Blocked')) st='Blocked';
        else if(states.includes('Ready')) st='Ready';
        else if(js.length>0) st='Ready';
        perTask[td.id][t]=st;
      });
      // ISR timeline
      {
        const isrActive = active.filter(j=> j.taskId===-1);
        let st='Idle';
        if(isrActive.some(j=> j.state==='Running')) st='Running';
        else if(isrActive.some(j=> j.state==='Blocked')) st='Blocked';
        else if(isrActive.some(j=> j.state==='Ready')) st='Ready';
        perTask[-1][t]=st;
      }
    }

    const U = allTasks.reduce((s,t)=> s + t.C/t.T, 0);
    const n=allTasks.length ||1;
    const bound = n * (Math.pow(2,1/n)-1);
    const idleCount = log.filter(v=> v===-1).length;
    // jitter and blocking per task
    const taskStats={};
    allTasks.forEach(td=>{
      const js = jobs.filter(j=> j.taskId===td.id && j.completion!=null);
      const responses = js.map(j=> j.completion - j.release);
      const mean = responses.length? responses.reduce((a,b)=>a+b,0)/responses.length : 0;
      const varr = responses.length? Math.sqrt(responses.reduce((s,r)=> s+(r-mean)*(r-mean),0)/responses.length) : 0;
      const worstBlock = Math.max(0,...jobs.filter(j=> j.taskId===td.id).map(j=> j.blockedTime));
      const misses = jobs.filter(j=> j.taskId===td.id && j.missed).length;
      const total = jobs.filter(j=> j.taskId===td.id).length;
      taskStats[td.id]={responses, mean, jitter:varr, worstBlock, misses, total};
    });
    const avgJitter = Object.values(taskStats).reduce((s, st)=> s+st.jitter,0)/ Math.max(1,Object.values(taskStats).length);

    return {log, perTask, jobs, events, U, bound, totalMiss, idleCount, taskStats, avgJitter};
  }

  function renderTaskTable(){
    taskTableDiv.innerHTML='';
    tasks.forEach((td, idx)=>{
      const row=document.createElement('div');
      row.className='task-row';
      row.innerHTML=`
        <div class="flex items-center justify-between gap-2">
          <input data-k="name" data-id="${td.id}" value="${td.name}" class="mini-input !w-[92px] font-semibold" />
          <span class="h-3 w-3 rounded-full border border-border shrink-0" style="background:${td.color}"></span>
          <button data-act="remove" data-id="${td.id}" class="pill-btn !py-1 !px-2 text-[0.6rem]">✕</button>
        </div>
        <div class="mt-2 grid grid-cols-3 gap-2">
          <label class="block"><span class="font-mono text-[0.55rem] uppercase">T ms</span><input data-k="T" data-id="${td.id}" type="number" min="5" max="500" step="1" value="${td.T}" class="mini-input"/></label>
          <label class="block"><span class="font-mono text-[0.55rem] uppercase">C ms</span><input data-k="C" data-id="${td.id}" type="number" min="1" max="100" step="1" value="${td.C}" class="mini-input"/></label>
          <label class="block"><span class="font-mono text-[0.55rem] uppercase">D ms</span><input data-k="D" data-id="${td.id}" type="number" min="1" max="500" step="1" value="${td.D}" class="mini-input"/></label>
        </div>
        <div class="mt-2 grid grid-cols-3 gap-2">
          <label class="block"><span class="font-mono text-[0.55rem] uppercase">Prio manual</span><input data-k="prioManual" data-id="${td.id}" placeholder="auto" value="${td.prioManual}" class="mini-input"/></label>
          <label class="block"><span class="font-mono text-[0.55rem] uppercase">Mutex</span>
            <select data-k="mutex" data-id="${td.id}" class="mini-input">
              ${mutexOptions.map(m=>`<option value="${m}" ${m===td.mutex?'selected':''}>${m||'—'}</option>`).join('')}
            </select>
          </label>
          <label class="block"><span class="font-mono text-[0.55rem] uppercase">Color</span><input data-k="color" data-id="${td.id}" type="color" value="${td.color}" class="mini-input !p-1 !h-7"/></label>
        </div>
      `;
      taskTableDiv.appendChild(row);
    });

    // bind events
    taskTableDiv.querySelectorAll('input, select').forEach(el=>{
      el.addEventListener('change', (e)=>{
        const id=parseInt(el.getAttribute('data-id'));
        const k=el.getAttribute('data-k');
        const td=tasks.find(t=>t.id===id);
        if(!td) return;
        let v=el.value;
        if(['T','C','D'].includes(k)){
          v=parseInt(v)|| td[k];
          if(k==='C' && v>td.T) v=td.T;
        }
        td[k]=v;
        if(k==='T' && td.D>td.T*2) td.D=td.T;
        rerun();
      });
    });
    taskTableDiv.querySelectorAll('button[data-act="remove"]').forEach(b=>{
      b.addEventListener('click', ()=>{
        const id=parseInt(b.getAttribute('data-id'));
        if(tasks.length<=1) return;
        tasks=tasks.filter(t=>t.id!==id);
        rerun();
        renderTaskTable();
      });
    });
  }

  function rerun(){
    try{
      simResult=simulate(tasks, horizon, scheduler, isrPer, isrC);
      updateMetrics();
      renderBlocking();
    }catch(e){
      console.error(e);
      roStatus.textContent='Sim error';
    }
  }

  function updateMetrics(){
    if(!simResult) return;
    const {U, bound, totalMiss, jobs, idleCount, taskStats, avgJitter}=simResult;
    roU.textContent=U.toFixed(3)+(U>1?' ⚠>1':'');
    roBound.textContent=bound.toFixed(3);
    const totalJobs=jobs.length;
    roMiss.textContent=`${totalMiss} / ${totalJobs}`;
    ro2Miss.textContent=`${totalMiss}`;
    ro2U.textContent=U.toFixed(3);
    const worstB = Math.max(0,...Object.values(taskStats).map(s=>s.worstBlock));
    roBlock.textContent=`${worstB} ms`;
    roJitter.textContent=`${avgJitter.toFixed(2)} ms`;
    roIdle.textContent=`${((idleCount/horizon)*100).toFixed(1)}%`;
    const status = U>1 ? 'Overload' : (U>bound ? 'Bound exceed — RTA needed' : (totalMiss>0?'Miss!':'Schedulable'));
    roStatus.textContent=status;
    // response for cursor position task
    const t = Math.min(Math.max(0, Math.floor(cursor)), horizon-1);
    const runningId = simResult.log[t];
    if(runningId!==undefined && runningId!==-1){
      const jobAtT = simResult.jobs.filter(j=> j.taskId===runningId && j.release<=t && (j.completion==null || j.completion>t)).sort((a,b)=> b.release-a.release)[0];
      if(jobAtT){
        const resp = t - jobAtT.release;
        ro2Resp.textContent=`T${runningId} R=${resp}ms (deadline ${jobAtT.absDeadline - jobAtT.release})`;
      }else ro2Resp.textContent='—';
    }else ro2Resp.textContent='Idle';
  }

  function renderBlocking(){
    if(!simResult) return;
    const ev = simResult.events.slice(-20).reverse();
    if(ev.length===0){ tableBlocking.textContent='No blocking — clean DAG'; return; }
    tableBlocking.innerHTML= ev.map(e=>{
      const waiter = e.waiter===-1?'ISR': tasks.find(t=>t.id===e.waiter)?.name || `T${e.waiter}`;
      const holder = e.holder===-1?'ISR': tasks.find(t=>t.id===e.holder)?.name || `T${e.holder}`;
      return `<div class="flex gap-1"><span class="opacity-60">${e.t}ms</span> ${waiter} → ${holder} [${e.mutex}] blocked</div>`;
    }).join('');
  }

  function draw(){
    if(!simResult){ return; }
    const bg = getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim() || '#0f141c';
    ctx.fillStyle=bg;
    ctx.fillRect(0,0,W,H);

    const leftLabel=90;
    const topPad=24;
    const rowH=34;
    const headerH=18;
    const timePx = (W-leftLabel-12)/horizon;
    const rows = tasks.length+2; // + global + ISR
    const neededH = topPad + headerH + rows*rowH + 30;
    // adjust canvas height visually but keep W,H
    // clear and draw time axis
    ctx.fillStyle='rgba(255,255,255,0.05)';
    ctx.font='10px ui-monospace, monospace';
    // time ticks
    ctx.strokeStyle='rgba(255,255,255,0.06)'; ctx.lineWidth=1;
    for(let t=0; t<=horizon; t+=10){
      const x=leftLabel + t*timePx;
      if(t%50===0){
        ctx.beginPath(); ctx.moveTo(x, topPad); ctx.lineTo(x, topPad+headerH+rows*rowH); ctx.stroke();
        ctx.fillStyle='rgba(255,255,255,0.28)';
        ctx.fillText(`${t}`, x-6, topPad+headerH+rows*rowH+12);
        ctx.fillStyle='rgba(255,255,255,0.05)';
      }else if(t%10===0){
        ctx.beginPath(); ctx.moveTo(x, topPad); ctx.lineTo(x, topPad+headerH+rows*rowH); ctx.stroke();
      }
    }

    // global running lane (row 0)
    const allRowY = topPad;
    ctx.fillStyle='rgba(255,255,255,0.6)';
    ctx.font='11px ui-monospace';
    ctx.fillText('CPU', 8, allRowY+headerH+14);
    // draw global running bars
    let curRun=null, segStart=0;
    for(let t=0; t<=horizon; t++){
      const rid = t<horizon? simResult.log[t]: -2;
      if(rid!==curRun){
        if(curRun!==null && curRun!==-1){
          const td = tasks.find(x=>x.id===curRun);
          const color = curRun===-1? '#a78bfa' : (td? td.color : '#888');
          const x0=leftLabel+segStart*timePx;
          const x1=leftLabel+t*timePx;
          ctx.fillStyle=color; ctx.globalAlpha=0.9;
          ctx.fillRect(x0, allRowY+headerH+2, x1-x0, rowH-8);
          ctx.globalAlpha=1;
        }
        curRun=rid; segStart=t;
      }
    }

    // per task rows (+ ISR)
    const rowsData = [{id:-1, label:'ISR', color:'#a78bfa'}].concat(tasks.map(t=>({id:t.id, label:t.name, color:t.color})));
    rowsData.forEach((rd, idx)=>{
      const y = topPad + headerH + (idx+1)*rowH;
      // alternating bg
      ctx.fillStyle= idx%2===0? 'rgba(255,255,255,0.02)' : 'rgba(255,255,255,0.00)';
      ctx.fillRect(0, y, W, rowH);
      // label
      ctx.fillStyle=rd.color;
      ctx.fillRect(8, y+12, 10, 10);
      ctx.fillStyle='rgba(255,255,255,0.75)';
      ctx.font='11px ui-monospace';
      ctx.fillText(rd.label, 24, y+20);

      const timeline = simResult.perTask[rd.id];
      if(!timeline) return;
      let segState=null; let sStart=0;
      for(let t=0; t<=horizon; t++){
        const st = t<horizon? timeline[t] : null;
        if(st!==segState){
          if(segState){
            const x0=leftLabel+sStart*timePx;
            const x1=leftLabel+t*timePx;
            let fill='#222';
            let alpha=0.9;
            if(segState==='Running'){ fill=rd.color; alpha=0.95; }
            else if(segState==='Ready'){ fill='#fbbf24'; alpha=0.42; }
            else if(segState==='Blocked'){ fill='#ef4444'; alpha=0.88; }
            else if(segState==='Idle'){ fill='transparent'; alpha=0; }
            if(alpha>0){
              ctx.fillStyle=fill; ctx.globalAlpha=alpha;
              ctx.fillRect(x0, y+4, Math.max(1,x1-x0), rowH-10);
              ctx.globalAlpha=1;
              // stripe for blocked
              if(segState==='Blocked'){
                ctx.strokeStyle='rgba(0,0,0,0.25)';
                ctx.lineWidth=1;
                for(let xx=x0; xx<x1; xx+=6){
                  ctx.beginPath(); ctx.moveTo(xx, y+6); ctx.lineTo(xx+4, y+rowH-6); ctx.stroke();
                }
              }
            }
            // mutex hold indicator for running segments: check if job holds mutex at that interval
            if(segState==='Running' && rd.id!==-1){
              // find job at sStart
              const mid = Math.floor((sStart+t)/2);
              const job = simResult.jobs.find(j=> j.taskId===rd.id && j.release<=mid && (j.completion==null || j.completion>mid));
              if(job && job.tdRef?.mutex && job.holds.has(job.tdRef.mutex)){
                // actually holds set is final after sim, need approximate: during execution, holds during CS interval
                const cs = job.tdRef;
                const inCS = job.executed>=0 && (mid-job.release) >= cs.csStart*cs.C && (mid-job.release) < (cs.csStart+cs.csDur)*cs.C;
                // simpler show if holds was ever
                if(t-sStart>1){
                  ctx.fillStyle='rgba(0,0,0,0.7)'; ctx.font='8px ui-monospace';
                  ctx.fillText('🔒'+cs.mutex, x0+2, y+12);
                }
              }
            }
          }
          segState=st; sStart=t;
        }
      }
      // deadlines per job vertical dashed
      const jobsForRow = simResult.jobs.filter(j=> j.taskId===rd.id);
      ctx.strokeStyle= rd.id===-1? 'rgba(167,139,250,0.45)' : 'rgba(255,255,255,0.18)';
      ctx.setLineDash([3,4]);
      ctx.lineWidth=1;
      jobsForRow.forEach(j=>{
        if(j.absDeadline<0 || j.absDeadline>horizon) return;
        const x=leftLabel + j.absDeadline*timePx;
        ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(x, y+rowH); ctx.stroke();
        if(j.missed){
          ctx.fillStyle='#ef4444'; ctx.font='12px ui-monospace'; ctx.fillText('✕', x-4, y+rowH-2);
        }
      });
      ctx.setLineDash([]);
    });

    // blocking chain arrows at cursor time
    {
      const t = Math.floor(cursor);
      if(t>=0 && t<horizon){
        const blockedJobs = simResult.jobs.filter(j=> j.blockedOn && j.release<=t && j.remaining>0 && t>=j.release && (j.completion==null || j.completion>t));
        blockedJobs.forEach(bj=>{
          const mutex = bj.blockedOn;
          // find holder active at same t
          const holderJob = simResult.jobs.find(hj=> hj.holds.has(mutex) && hj.release<=t && hj.remaining>0 && hj.taskId!==bj.taskId);
          // Actually after sim, holds cleared; use events more reliable: for current t, find event waiter=bj
          // We'll draw arrow from waiter row to holder row at cursor x
          const waiterIdx = rowsData.findIndex(r=> r.id===bj.taskId);
          const holderIdx = holderJob? rowsData.findIndex(r=> r.id===holderJob.taskId) : -1;
          // fallback use event list
          let hIdx = holderIdx;
          if(hIdx===-1){
            const ev = simResult.events.find(e=> e.t===t && e.waiter===bj.taskId && e.mutex===mutex);
            if(ev) hIdx = rowsData.findIndex(r=> r.id===ev.holder);
          }
          if(waiterIdx>=0 && hIdx>=0){
            const y1 = topPad + headerH + (waiterIdx+1)*rowH + rowH/2;
            const y2 = topPad + headerH + (hIdx+1)*rowH + rowH/2;
            const x = leftLabel + t*timePx;
            ctx.strokeStyle='rgba(239,68,68,0.85)'; ctx.lineWidth=1.2;
            ctx.beginPath(); ctx.moveTo(x, y1); ctx.bezierCurveTo(x+24, y1, x+24, y2, x, y2); ctx.stroke();
            ctx.fillStyle='#ef4444'; ctx.beginPath(); ctx.arc(x, y2, 3, 0, Math.PI*2); ctx.fill();
          }
        });
      }
    }

    // cursor line
    {
      const x = leftLabel + cursor*timePx;
      ctx.strokeStyle='rgba(255,255,255,0.85)'; ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.moveTo(x, topPad); ctx.lineTo(x, topPad+headerH+rows*rowH); ctx.stroke();
      ctx.fillStyle='#fff'; ctx.beginPath(); ctx.arc(x, topPad+headerH+rows*rowH+4, 4, 0, Math.PI*2); ctx.fill();
    }
  }

  // audio dissonance
  let audioCtx=null, osc1=null, osc2=null, gainMaster=null;
  function ensureAudio(){
    if(audioCtx) return audioCtx;
    audioCtx = new (window.AudioContext||window.webkitAudioContext)();
    gainMaster=audioCtx.createGain(); gainMaster.gain.value=0; gainMaster.connect(audioCtx.destination);
    osc1=audioCtx.createOscillator(); osc1.type='sine'; osc1.frequency.value=220;
    const g1=audioCtx.createGain(); g1.gain.value=0.5;
    osc2=audioCtx.createOscillator(); osc2.type='sine'; osc2.frequency.value=330;
    const g2=audioCtx.createGain(); g2.gain.value=0.5;
    const mix=audioCtx.createGain(); mix.gain.value=1;
    osc1.connect(g1); g1.connect(mix);
    osc2.connect(g2); g2.connect(mix);
    mix.connect(gainMaster);
    osc1.start(); osc2.start();
    return audioCtx;
  }
  function updateAudio(){
    if(!chkAudio.checked || !simResult) return;
    const ctx=ensureAudio();
    ctx.resume();
    const totalJobs=simResult.jobs.length||1;
    const missRatio = Math.min(1, simResult.totalMiss/totalJobs);
    const f1=220;
    const f2=330 - missRatio*99; // 330 -> 231
    try{
      osc1.frequency.linearRampToValueAtTime(f1, ctx.currentTime+0.12);
      osc2.frequency.linearRampToValueAtTime(f2, ctx.currentTime+0.12);
      const targetGain = missRatio>0 ? 0.02 + missRatio*0.14 : 0.0;
      gainMaster.gain.linearRampToValueAtTime(targetGain, ctx.currentTime+0.2);
    }catch{}
    tensionInd.textContent=`Tension ${Math.round(missRatio*100)}% (${(Math.abs(f1-f2)).toFixed(1)}Hz beat)`;
    tensionInd.style.color= missRatio>0.3? '#ef4444' : (missRatio>0? '#f59e0b':'var(--mp-cta)');
  }

  // loop animation
  let raf;
  function loop(now){
    raf = requestAnimationFrame(loop);
    const dt = Math.min(0.05, (now-lastFrame)/1000); lastFrame=now;
    if(playing){
      cursor += dt*1000*0.06*speed; // 0.06 converts ms to timeline speed factor
      if(cursor>horizon) cursor=0;
      timeLabel.textContent=`t=${cursor.toFixed(1)} ms`;
      draw();
      if(Math.floor(now/200)%2===0) updateAudio();
    }
  }

  // events
  btnPlay.addEventListener('click', ()=>{
    playing=!playing;
    btnPlay.textContent= playing? '⏸ Pause' : '▶ Play';
    btnPlay.classList.toggle('is-active', playing);
    if(playing) ensureAudio();
  });
  btnStep.addEventListener('click', ()=>{
    cursor = (cursor+5)%horizon;
    timeLabel.textContent=`t=${cursor.toFixed(1)} ms`;
    draw(); updateMetrics();
  });
  btnReset.addEventListener('click', ()=>{
    cursor=0; rerun(); draw();
  });
  btnAdd.addEventListener('click', ()=>{
    const color = palette[tasks.length%palette.length];
    tasks.push({id:nextId++, name:`T${nextId} New`, T:50, C:5, D:50, prioManual:'', mutex:'', csStart:0.2, csDur:0.3, color});
    renderTaskTable(); rerun(); draw();
  });
  selSched.addEventListener('change', e=>{ scheduler=e.target.value; rerun(); });
  inHorizon.addEventListener('input', e=>{
    horizon=parseInt(e.target.value)||240;
    outHorizon.textContent=horizon;
    rerun(); draw();
  });
  inSpeed.addEventListener('input', e=>{
    speed=parseFloat(e.target.value)||2;
    outSpeed.textContent=speed+'×';
  });
  inIsrPer.addEventListener('change', e=>{ isrPer=parseInt(e.target.value)||0; rerun(); });
  inIsrC.addEventListener('change', e=>{ isrC=parseInt(e.target.value)||0; rerun(); });

  // initial
  function initBind(){
    outHorizon.textContent=horizon;
    outSpeed.textContent=speed+'×';
    inHorizon.value=horizon;
    inSpeed.value=speed;
    selSched.value=scheduler;
  }
  initBind();
  renderTaskTable();
  rerun();
  draw();
  loop(performance.now());

  // Register export getter for ExportGate — FreeRTOS-like header
  try {
    const reg = () => {
      if (window.MPExportGate) {
        window.MPExportGate.register('rtos-scheduler', () => {
          const now = new Date().toISOString();
          let out = `/*\n * RTOS Lab Export — ${now}\n * Simulator: rtos-scheduler (RMS=${scheduler==='RMS' ? 'yes' : 'no'}, horizon ${horizon}ms, U=${simResult ? simResult.U.toFixed(3) : '—'})\n * Generated by makerportal.ai\n * Tasks: T=period ms, C=WCET ms, D=deadline ms\n */\n\n`;
          out += `#pragma once\n#include <stdint.h>\n\n`;
          out += `// Task set — ${tasks.length} tasks\n`;
          out += `typedef struct { const char *name; uint32_t T_ms; uint32_t C_ms; uint32_t D_ms; const char *mutex; float csStart; float csDur; } task_def_t;\n\n`;
          out += `static const task_def_t TASKS[] = {\n`;
          tasks.forEach(td => {
            out += `  { .name="${td.name}", .T_ms=${td.T}, .C_ms=${td.C}, .D_ms=${td.D}, .mutex="${td.mutex || ''}", .csStart=${td.csStart.toFixed(2)}f, .csDur=${td.csDur.toFixed(2)}f },\n`;
          });
          out += `};\n#define TASK_COUNT ${tasks.length}\n\n`;
          out += `// Utilization U = Σ C/T = ${simResult ? simResult.U.toFixed(4) : '0'}\n`;
          out += `// Liu & Layland bound for n=${tasks.length} is ${simResult ? simResult.bound.toFixed(4) : '0'}\n`;
          out += `// Deadline misses in last sim: ${simResult ? simResult.totalMiss : 0} / ${simResult ? simResult.jobs.length : 0}\n`;
          out += `// ISR: period ${isrPer}ms C ${isrC}ms\n`;
          out += `// FreeRTOSConfig hints:\n`;
          out += `// #define configMAX_PRIORITIES ${Math.max(5, tasks.length+2)}\n`;
          out += `// #define configTICK_RATE_HZ 1000\n`;
          out += `// Map longest T→lowest prio for RMS; this header is a starting point — tune stack & heap.\n`;
          out += `// Hardware suggestion: SparkFun RedBoard Plus (Original 10%) + Teensy 4.0 + hiletgo logic analyzer\n`;
          return out;
        });
      }
    };
    reg();
    document.addEventListener('astro:page-load', reg);
  } catch {}

  document.addEventListener('astro:before-swap',()=>{
    cancelAnimationFrame(raf);
    try{audioCtx?.close();}catch{}
  },{once:true});
}
document.addEventListener('astro:page-load', initRtos);
initRtos();
</script>
</Layout>
