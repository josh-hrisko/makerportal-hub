<script>
// @ts-nocheck
function initConformalMapping() {
  const canvasEl = document.getElementById('conformal-canvas');
  if (!canvasEl || canvasEl.dataset.init) return;
  canvasEl.dataset.init = 'true';
  const ctx = canvasEl.getContext('2d');

  const presetEl = document.getElementById('preset');
  const exprEl = document.getElementById('expr-input');
  const errorEl = document.getElementById('expr-error');
  const tSlider = document.getElementById('t-slider');
  const tValue = document.getElementById('t-value');
  const radiusSlider = document.getElementById('radius-slider');
  const radiusValue = document.getElementById('radius-value');
  const densitySlider = document.getElementById('density-slider');
  const densityValue = document.getElementById('density-value');
  const animateBtn = document.getElementById('animate-toggle');
  const resetBtn = document.getElementById('reset-btn');
  const poleNote = document.getElementById('pole-note');

  // ---- Complex arithmetic (plain {re, im} objects) ----
  const cAdd = (a, b) => ({ re: a.re + b.re, im: a.im + b.im });
  const cSub = (a, b) => ({ re: a.re - b.re, im: a.im - b.im });
  const cMul = (a, b) => ({ re: a.re * b.re - a.im * b.im, im: a.re * b.im + a.im * b.re });
  const cDiv = (a, b) => {
    const d = b.re * b.re + b.im * b.im;
    return { re: (a.re * b.re + a.im * b.im) / d, im: (a.im * b.re - a.re * b.im) / d };
  };
  const cNeg = (a) => ({ re: -a.re, im: -a.im });
  const cConj = (a) => ({ re: a.re, im: -a.im });
  const cAbsVal = (a) => Math.hypot(a.re, a.im);
  const cArg = (a) => Math.atan2(a.im, a.re);
  const cExp = (a) => { const r = Math.exp(a.re); return { re: r * Math.cos(a.im), im: r * Math.sin(a.im) }; };
  const cLog = (a) => ({ re: Math.log(cAbsVal(a)), im: cArg(a) });
  const cSin = (a) => ({ re: Math.sin(a.re) * Math.cosh(a.im), im: Math.cos(a.re) * Math.sinh(a.im) });
  const cCos = (a) => ({ re: Math.cos(a.re) * Math.cosh(a.im), im: -Math.sin(a.re) * Math.sinh(a.im) });
  const cSqrt = (a) => { const r = Math.sqrt(cAbsVal(a)), th = cArg(a) / 2; return { re: r * Math.cos(th), im: r * Math.sin(th) }; };
  const cPow = (a, b) => {
    if (a.re === 0 && a.im === 0) return { re: 0, im: 0 };
    return cExp(cMul(b, cLog(a)));
  };

  // ---- Safe recursive-descent parser (no eval / new Function anywhere) ----
  function tokenize(src) {
    const tokens = [];
    let i = 0;
    while (i < src.length) {
      const c = src[i];
      if (/\s/.test(c)) { i++; continue; }
      if (/[0-9.]/.test(c)) {
        let j = i;
        while (j < src.length && /[0-9.]/.test(src[j])) j++;
        tokens.push({ type: 'num', value: parseFloat(src.slice(i, j)) });
        i = j;
        continue;
      }
      if (/[a-zA-Z]/.test(c)) {
        let j = i;
        while (j < src.length && /[a-zA-Z]/.test(src[j])) j++;
        tokens.push({ type: 'ident', value: src.slice(i, j) });
        i = j;
        continue;
      }
      if ('+-*/^(),'.includes(c)) { tokens.push({ type: c }); i++; continue; }
      throw new Error(`Unexpected character "${c}"`);
    }
    tokens.push({ type: 'eof' });
    return tokens;
  }

  const FUNCS = { sin: cSin, cos: cCos, tan: (z) => cDiv(cSin(z), cCos(z)), exp: cExp, log: cLog, sqrt: cSqrt, conj: cConj, abs: (z) => ({ re: cAbsVal(z), im: 0 }) };
  const CONSTS = { i: { re: 0, im: 1 }, pi: { re: Math.PI, im: 0 }, e: { re: Math.E, im: 0 } };

  function parseExpression(src) {
    const tokens = tokenize(src);
    let pos = 0;
    const peek = () => tokens[pos];
    const advance = () => tokens[pos++];
    function expect(type) {
      if (peek().type !== type) throw new Error(`Expected "${type}", got "${peek().type}"`);
      return advance();
    }

    // Precedence, loosest to tightest: + - < * / < unary - < ^ (right-assoc, exponent may itself be unary)
    // i.e. -z^2 parses as -(z^2), and z^-2 parses as z^(-2) - matches Python/most calculators, not left-to-right token order.
    function parseExpr() {
      let node = parseTerm();
      while (peek().type === '+' || peek().type === '-') {
        const op = advance().type;
        const rhs = parseTerm();
        node = { type: op === '+' ? 'add' : 'sub', left: node, right: rhs };
      }
      return node;
    }
    function parseTerm() {
      let node = parseUnary();
      while (peek().type === '*' || peek().type === '/') {
        const op = advance().type;
        const rhs = parseUnary();
        node = { type: op === '*' ? 'mul' : 'div', left: node, right: rhs };
      }
      return node;
    }
    function parseUnary() {
      if (peek().type === '-') { advance(); return { type: 'neg', arg: parseUnary() }; }
      if (peek().type === '+') { advance(); return parseUnary(); }
      return parsePow();
    }
    function parsePow() {
      const base = parsePrimary();
      if (peek().type === '^') {
        advance();
        const exp = parseUnary(); // right-associative, and allows a unary-negative exponent
        return { type: 'pow', left: base, right: exp };
      }
      return base;
    }
    function parsePrimary() {
      const tok = peek();
      if (tok.type === 'num') { advance(); return { type: 'num', value: tok.value }; }
      if (tok.type === '(') { advance(); const inner = parseExpr(); expect(')'); return inner; }
      if (tok.type === 'ident') {
        advance();
        const name = tok.value.toLowerCase();
        if (peek().type === '(') {
          advance();
          const arg = parseExpr();
          expect(')');
          if (!FUNCS[name]) throw new Error(`Unknown function "${name}"`);
          return { type: 'call', name, arg };
        }
        if (name === 'z') return { type: 'z' };
        if (CONSTS[name]) return { type: 'const', value: CONSTS[name] };
        throw new Error(`Unknown identifier "${name}"`);
      }
      throw new Error(`Unexpected token "${tok.type}"`);
    }

    const ast = parseExpr();
    expect('eof');
    return ast;
  }

  function evalNode(node, z) {
    switch (node.type) {
      case 'num': return { re: node.value, im: 0 };
      case 'const': return node.value;
      case 'z': return z;
      case 'add': return cAdd(evalNode(node.left, z), evalNode(node.right, z));
      case 'sub': return cSub(evalNode(node.left, z), evalNode(node.right, z));
      case 'mul': return cMul(evalNode(node.left, z), evalNode(node.right, z));
      case 'div': return cDiv(evalNode(node.left, z), evalNode(node.right, z));
      case 'pow': return cPow(evalNode(node.left, z), evalNode(node.right, z));
      case 'neg': return cNeg(evalNode(node.arg, z));
      case 'call': return FUNCS[node.name](evalNode(node.arg, z));
      default: throw new Error(`Bad node type "${node.type}"`);
    }
  }

  // ---- State ----
  let ast = null;
  let t = 0;
  let radius = 2.5;
  let density = 17;
  let animating = false;
  let animFrameId = null;
  let destroyed = false;

  function compile(src) {
    try {
      ast = parseExpression(src);
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
      return true;
    } catch (err) {
      ast = null;
      errorEl.textContent = err instanceof Error ? err.message : 'Could not parse expression.';
      errorEl.classList.remove('hidden');
      return false;
    }
  }

  function draw() {
    if (!ast) return;
    const w = canvasEl.width, h = canvasEl.height;
    ctx.clearRect(0, 0, w, h);

    const viewR = 3.2; // fixed view window in the complex plane, in units
    const scale = Math.min(w, h) / (2 * viewR);
    const cx = w / 2, cy = h / 2;
    const toScreen = (z) => ({ x: cx + z.re * scale, y: cy - z.im * scale });

    // axes
    ctx.strokeStyle = 'rgba(120,120,120,0.35)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, cy); ctx.lineTo(w, cy);
    ctx.moveTo(cx, 0); ctx.lineTo(cx, h);
    ctx.stroke();

    const samples = 90;
    const clampMag = viewR * 2.4; // gap out lines whose mapped point leaves this radius
    let sawGap = false;

    function mapPoint(z) {
      const fz = evalNode(ast, z);
      if (!Number.isFinite(fz.re) || !Number.isFinite(fz.im)) return null;
      const p = { re: (1 - t) * z.re + t * fz.re, im: (1 - t) * z.im + t * fz.im };
      if (Math.hypot(p.re, p.im) > clampMag) return null;
      return p;
    }

    function drawFamily(count, hueBase) {
      for (let k = 0; k < count; k++) {
        const frac = count === 1 ? 0.5 : k / (count - 1);
        const fixed = -radius + frac * 2 * radius;
        const hue = hueBase + frac * 40;
        ctx.strokeStyle = `hsla(${hue}, 65%, 50%, 0.75)`;
        ctx.lineWidth = Math.abs(fixed) < 1e-6 ? 2 : 1.1;
        ctx.beginPath();
        let penDown = false;
        for (let s = 0; s <= samples; s++) {
          const v = -radius + (s / samples) * 2 * radius;
          const z = hueBase === 210 ? { re: v, im: fixed } : { re: fixed, im: v };
          const p = mapPoint(z);
          if (!p) { penDown = false; sawGap = true; continue; }
          const scr = toScreen(p);
          if (!penDown) { ctx.moveTo(scr.x, scr.y); penDown = true; }
          else ctx.lineTo(scr.x, scr.y);
        }
        ctx.stroke();
      }
    }

    drawFamily(density, 210); // horizontal lines (fixed im), blue family
    drawFamily(density, 15);  // vertical lines (fixed re), orange/red family

    poleNote.classList.toggle('hidden', !sawGap);
  }

  function recompute() {
    draw();
  }

  presetEl.addEventListener('change', () => {
    if (presetEl.value === 'custom') { exprEl.focus(); return; }
    exprEl.value = presetEl.value;
    if (compile(exprEl.value)) recompute();
  });
  exprEl.addEventListener('input', () => {
    presetEl.value = 'custom';
    if (compile(exprEl.value)) recompute();
  });

  tSlider.addEventListener('input', () => {
    t = parseFloat(tSlider.value);
    tValue.textContent = t.toFixed(2);
    recompute();
  });
  radiusSlider.addEventListener('input', () => {
    radius = parseFloat(radiusSlider.value);
    radiusValue.textContent = radius.toFixed(1);
    recompute();
  });
  densitySlider.addEventListener('input', () => {
    density = parseInt(densitySlider.value, 10);
    densityValue.textContent = String(density);
    recompute();
  });

  resetBtn.addEventListener('click', () => {
    t = 0; tSlider.value = '0'; tValue.textContent = '0.00';
    setAnimating(false);
    recompute();
  });

  function setAnimating(next) {
    animating = next;
    animateBtn.textContent = animating ? '⏸ Pause' : '▶ Animate';
    animateBtn.classList.toggle('is-active', animating);
    if (animating) {
      let dir = 1;
      const step = () => {
        if (destroyed || !animating) return;
        t += dir * 0.006;
        if (t >= 1) { t = 1; dir = -1; }
        if (t <= 0) { t = 0; dir = 1; }
        tSlider.value = String(t);
        tValue.textContent = t.toFixed(2);
        draw();
        animFrameId = requestAnimationFrame(step);
      };
      animFrameId = requestAnimationFrame(step);
    } else if (animFrameId) {
      cancelAnimationFrame(animFrameId);
      animFrameId = null;
    }
  }

  animateBtn.addEventListener('click', () => setAnimating(!animating));

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  compile(exprEl.value);
  radius = parseFloat(radiusSlider.value);
  density = parseInt(densitySlider.value, 10);
  draw();
  if (!reduceMotion) {
    // start paused by default regardless of motion preference - user opts in via the Animate button
  }

  document.addEventListener('astro:before-swap', () => {
    destroyed = true;
    if (animFrameId) cancelAnimationFrame(animFrameId);
  }, { once: true });

  // Copy button wiring
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.copyTarget;
      const codeEl = targetId ? document.getElementById(targetId) : null;
      if (!codeEl) return;
      try {
        await navigator.clipboard.writeText(codeEl.textContent ?? '');
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {}
    });
  });
}

document.addEventListener('astro:page-load', initConformalMapping);
initConformalMapping();
</script>
