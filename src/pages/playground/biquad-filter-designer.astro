---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';
import { Code } from 'astro:components';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import GearCarousel from '../../components/GearCarousel.astro';
import Math from '../../components/Math.astro';
import { affiliateLinks, resolveAffiliateLink } from '../../data/affiliate-links';

const gear = affiliateLinks
  .filter((link) => link.relatedTo?.includes('biquadia') || link.relatedTo?.includes('biquad-filter-designer'))
  .map(resolveAffiliateLink)
  .sort((a, b) => (a.category === 'Audio interface' ? -1 : b.category === 'Audio interface' ? 1 : 0));

const title = 'Biquad Filter Designer — Hear a cascade, not just see a curve | MakerPortal';
const description = 'Design a cascade of biquad filters with live Web Audio preview, magnitude + phase plots, and exact Direct Form II Transposed code — the real DSP core from Biquadia.';
const canonical = new URL('/playground/biquad-filter-designer', Astro.site);

const df2tJS = `// Direct Form II Transposed — one biquad stage
// y[n] = b0*x[n] + b1*x[n-1] + b2*x[n-2] - a1*y[n-1] - a2*y[n-2]
// State: z1 = b1*x[n-1]+b2*x[n-2]-a1*y[n-1]-a2*y[n-2], z2 = b2*x[n-1]-a2*y[n-1]
function biquadProcess(x, b0,b1,b2,a1,a2, state){
  const y = b0*x + state[0];
  state[0] = b1*x - a1*y + state[1];
  state[1] = b2*x - a2*y;
  return y;
}
// Cascade: for (const stage of cascade) x = biquadProcess(x, ...stage.coeffs, stage.state);`;

const swiftSnippet = `// Swift — same DF2T, stereo-safe
struct Biquad {
  var b0,b1,b2,a1,a2: Double
  var z1: Double = 0, z2: Double = 0
  mutating func process(_ x: Double) -> Double {
    let y = b0 * x + z1
    z1 = b1 * x - a1 * y + z2
    z2 = b2 * x - a2 * y
    return y
  }
}`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Biquad Filter Designer',
  url: canonical.toString(),
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Any',
  description,
  isPartOf: { '@type': 'SoftwareApplication', name: 'Biquadia', url: 'https://biquadia.makerportal.ai' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Biquad Filter Designer', item: canonical.toString() },
  ],
};

const faqs = [
  {
    q: 'Is DF2T better than Direct Form 1?',
    a: 'DF2T uses two state variables per biquad instead of four. Fewer state variables mean less memory and less quantization noise because you only round once per sample instead of twice. The transposed topology also eliminates the feed-forward delay line. The trade-off is that the internal node can clip at high Q if not guarded with saturation — Biquadia clamps z1/z2 after every sample for exactly this reason.',
  },
  {
    q: 'Why do the coefficients change when I switch sample rates?',
    a: 'The RBJ cookbook formulas compute w0 = 2π f0 / Fs. Changing Fs changes w0, which cascades through every cos/sin computation and alpha. A 1 kHz lowpass at 48 kHz and 44.1 kHz needs different b0–a2 to hit the same f0. The frequency response recalculates automatically, but if you are switching rates mid-audio-stream in a real app, you must recompute all coefficients at the new Fs before the next buffer.',
  },
  {
    q: 'Can I implement more than four biquads on a microcontroller?',
    a: 'Yes — on a 180 MHz Cortex-M4 with a CMSIS-DSP biquad cascade, you can run 30–60 biquads at 48 kHz before hitting the real-time deadline. Each DF2T stage costs 5 MACs per sample. At 48 kHz, 60 stages is 14.4 MMAC/s — well within budget. Q format (Q1.31 fixed-point) matters more than stage count. See the MPU9250 field note for Biquadia\'s fixed-point DF2T ARM implementation used on-device.',
  },
  {
    q: 'Why does a high-Q peaking filter ring even after the impulse stops?',
    a: 'High Q means poles are close to the unit circle — near |z| = 1. The impulse response is an exponentially-decaying sinusoid where decay rate = ln(r) per sample. At Q = 10 and f0 = 1 kHz, r ≈ 0.96, so it takes about 100 samples (~2 ms) to decay to 10%. That ringing is not a bug — it is what makes a resonant filter sound like an instrument body or a room mode.',
  },
  {
    q: 'How does Biquadia run hundreds of these on Metal?',
    a: 'Biquadia serializes cascade coefficients into a Metal buffer, then dispatches one compute kernel per audio channel. Each thread processes a DFT block (512–4096 samples), pulling coefficients from the buffer and applying DF2T in an unrolled loop. The GPU\'s SIMD lanes handle stereo pairs in parallel. The same kernel verified via Accelerate vDSP on CPU for bit-exact cross-check. The Metal path adds ~0.3 ms latency at 512-sample blocks.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>

  <PlaygroundShell
    title="Biquad Filter Designer"
    lead="Hear a cascade, not just see a curve. Design 1–4 biquads in series, watch the exact magnitude + phase of the total chain, and preview live on real audio — white noise, oscillator, or mic — using the same DF2T core Biquadia ships."
    pillarHint="dsp-audio"
    isGrounded={true}
    relatedApp="Biquadia"
    relatedAppUrl="https://biquadia.makerportal.ai"
  >
    <section class="border-b border-border" aria-labelledby="designer-title">
      <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 lg:px-10">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <h2 id="designer-title" class="text-[clamp(1.35rem,3vw,1.7rem)] font-[650] tracking-[-0.03em]">Cascade</h2>
          <div class="flex items-center gap-2">
            <button type="button" id="add-stage" class="rounded-full bg-primary-text px-4 py-2 text-[0.78rem] font-bold text-canvas hover:opacity-90">+ Add stage</button>
            <button type="button" id="clear-stages" class="rounded-full border border-border bg-elevated px-4 py-2 text-[0.78rem] font-semibold text-muted-text hover:text-primary-text">Reset to 1 lowpass</button>
            <select id="sample-rate" class="rounded-full border border-border bg-card-bg px-3 py-2 font-mono text-[0.72rem]"><option value="48000">48 kHz</option><option value="44100">44.1 kHz</option></select>
          </div>
        </div>

        <div id="stages" class="mt-8 grid grid-cols-1 gap-5 lg:grid-cols-2"></div>

        <div class="mt-10 rounded-[20px] border border-border bg-card-bg p-5 sm:p-6">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <h3 class="font-semibold">Frequency response (total cascade)</h3>
            <div class="flex items-center gap-2 font-mono text-[0.7rem]">
              <span class="flex items-center gap-1"><span class="inline-block h-2 w-3 rounded-sm bg-[#b8324f]"></span>Mag dB</span>
              <span class="flex items-center gap-1"><span class="inline-block h-2 w-3 rounded-sm bg-[#4a7bb8]"></span>Phase °</span>
              <label class="ml-3 flex items-center gap-1"><input type="checkbox" id="show-phase" checked /> Phase</label>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-1 gap-5 lg:grid-cols-[1.2fr_0.8fr]">
            <div class="overflow-hidden rounded-[14px] border border-border bg-canvas">
              <canvas id="mag-canvas" width="800" height="320" class="block h-[320px] w-full"></canvas>
            </div>
            <div class="rounded-[14px] border border-border bg-canvas p-4 font-mono text-[0.75rem]">
              <p class="font-semibold text-[0.7rem] uppercase tracking-[0.1em] text-muted-text">Current chain coefficients (normalized, a0=1)</p>
              <pre id="coeff-out" class="mt-3 max-h-[280px] overflow-auto whitespace-pre-wrap text-[0.72rem] leading-[1.5]"></pre>
            </div>
          </div>
        </div>

        <div class="mt-10 rounded-[20px] border border-border bg-card-bg p-5 sm:p-6">
          <h3 class="font-semibold">Live audio preview — Biquadia-style</h3>
          <p class="mt-1 max-w-2xl text-[0.82rem] leading-[1.5] text-muted-text">Uses Web Audio <code>IIRFilterNode</code> with the exact coefficients above. Pick a source, hit play, toggle bypass to hear the chain.</p>
          <div class="mt-5 flex flex-wrap items-center gap-3">
            <select id="source-type" class="rounded-full border border-border bg-canvas px-3 py-2 font-mono text-[0.75rem]">
              <option value="white">White noise</option>
              <option value="pink">Pink noise</option>
              <option value="sine">Sine oscillator (440 Hz)</option>
              <option value="sweep">Sine sweep (20–20k, 8s)</option>
            </select>
            <button id="audio-play" class="rounded-full bg-primary-text px-5 py-2 text-[0.85rem] font-bold text-canvas">Play</button>
            <button id="audio-bypass" class="rounded-full border border-border bg-elevated px-4 py-2 text-[0.8rem]">Bypass: OFF</button>
            <span id="audio-status" class="font-mono text-[0.7rem] uppercase tracking-[0.08em] text-muted-text/70">stopped</span>
            <input id="audio-gain" type="range" min="0" max="1" step="0.01" value="0.35" class="w-[120px]" />
            <span class="font-mono text-[0.7rem]">Gain</span>
          </div>
          <div class="mt-4 flex flex-wrap gap-2 font-mono text-[0.7rem] text-muted-text">
            <span id="latency-note"></span>
          </div>
        </div>

        <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div>
            <div class="flex items-center justify-between"><p class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted-text">DF2T — JavaScript</p><button type="button" class="copy-btn" data-copy-target="code-js">Copy</button></div>
            <div class="mt-2 overflow-x-auto rounded-[14px] [&_pre]:!m-0 [&_pre]:!rounded-[14px] [&_pre]:!p-4 [&_pre]:text-[0.78rem]">
              <Code id="code-js" code={df2tJS} lang="js" theme="github-dark" />
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between"><p class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted-text">DF2T — Swift (Biquadia)</p><button type="button" class="copy-btn" data-copy-target="code-swift">Copy</button></div>
            <div class="mt-2 overflow-x-auto rounded-[14px] [&_pre]:!m-0 [&_pre]:!rounded-[14px] [&_pre]:!p-4 [&_pre]:text-[0.78rem]">
              <Code id="code-swift" code={swiftSnippet} lang="swift" theme="github-dark" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="anatomy-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="anatomy-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Anatomy of the designer</h2>
        <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">Every knob and curve above answers to the RBJ cookbook below. Here is what each piece is actually doing.</p>
        <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-2">
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">The cascade builder and response plot</h3>
            <ol class="mt-5 space-y-4">
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">01</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Stage cards.</strong> Each card is one biquad. Type selects the RBJ formula branch, freq sets w0 = 2πf0/Fs, Q controls alpha = sin(w0)/(2Q), and gain only affects peaking/shelf types. Removing a stage splices the chain — the remaining stages recompute and redraw instantly.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">02</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Magnitude + phase plot.</strong> For each frequency from 20 Hz to 20 kHz (log-spaced, 400 steps), the script evaluates every stage's transfer function H(e^jω) on the unit circle via exact complex arithmetic, then multiplies all Hk for the cascade. dB is 20 log10|H_total|. Phase is the sum of arg(Hk), wrapped to [-180°, 180°]. The plot is not a visual approximation — those curves are the literal mathematical response of the coefficients you see.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">03</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Coefficient readout.</strong> The real-time b0,b1,b2,a1,a2 for every stage, normalized to a0=1. These are the exact numbers fed to Web Audio's IIRFilterNode and the same format Biquadia's Metal kernel expects. Copy them into any DF2T implementation and the filter is identical.</p>
              </li>
            </ol>
          </div>
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">Audio pipeline and interaction</h3>
            <ol class="mt-5 space-y-4">
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">01</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Web Audio chain.</strong> Source → IIRFilterNode × N → Gain → destination. Each IIRFilterNode is constructed from the current biquad coefficients with feedforward [b0,b1,b2] and feedback [1,a1,a2]. Changing any parameter tears down and rebuilds the chain — new IIR nodes, clean state, no pops.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">04</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Noise generators.</strong> White noise is Math.random() × 2 − 1. Pink noise uses the Voss-McCartney algorithm (seven white noise sources at octave intervals) producing −3 dB/octave rolloff — flatter to the ear. Sine is a standard OscillatorNode at 440 Hz. The sweep does an exponential ramp from 20 Hz to 20 kHz over 8 seconds.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">05</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Bypass toggle.</strong> Disconnects the IIR chain and reconnects source directly to gain — zero added latency, direct A/B. The coefficients stay live in the readout, so the plot still shows what you are not hearing. Toggling bypass back rebuilds the chain from the same coefficients.</p>
              </li>
            </ol>
            <div class="mt-6 math-card">
              <p class="math-label">What the render loop evaluates per pixel</p>
              <Math math="H_{\text{total}}(e^{j\omega}) = \prod_{k=1}^{N} \frac{b_{0,k} + b_{1,k}e^{-j\omega} + b_{2,k}e^{-j2\omega}}{1 + a_{1,k}e^{-j\omega} + a_{2,k}e^{-j2\omega}}" display class="mt-2" />
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">This is computed 400 times per plot redraw — once per log-spaced frequency bin. Each evaluation unpacks to a complex division: real/imag numerator divided by real/imag denominator. The cascade multiplies complex numbers, not dB — the dB display is the final step.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="gotchas-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="gotchas-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Two gotchas worth knowing</h2>
        <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">RBJ α inversion</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">LLMs love writing <Math math="\alpha = Q \sin w_0" /> (inverted). The correct formula is <Math math="\alpha = \sin w_0 / (2Q)" />. A high-Q filter with inverted α shifts the cutoff by an octave and changes the shape entirely. This page uses the real RBJ — check the α line in the script if you are porting it to your own codebase.</p>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Cascade phase pile-up</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">Each biquad adds its phase shift to the total. Four stages can easily exceed ±360° of total phase at Nyquist. That is not a bug — it is real group delay. If you stack four high-Q peaking filters, you will hear audible pre-ringing on transients. Phase-wrapping the plot to ±180° hides this, but your ears and an oscilloscope will not be fooled.</p>
          </div>
        </div>
      </div>
    </section>

    {gear.length > 0 && (
      <section class="border-b border-border" aria-labelledby="gear-title">
        <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 id="gear-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Gear behind this build</h2>
              <AffiliateDisclosure class="mt-3 max-w-2xl" />
            </div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary-cta align-middle mr-1.5" aria-hidden="true"></span>
              Biquadia stack · {gear.length} picks
            </p>
          </div>
          <div class="mt-10 flex items-center gap-3">
            <h3 class="inline-flex items-center gap-2 rounded-full border border-border bg-card-bg px-3.5 py-1.5 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">
              <span class="size-1.5 rounded-full bg-primary-cta" aria-hidden="true"></span>
              Audio & DSP hardware
              <span class="ml-1 rounded-full bg-elevated px-1.5 py-0.5 text-[0.6rem] text-muted-text">{gear.length}</span>
            </h3>
            <div class="h-px flex-1 bg-gradient-to-r from-border to-transparent"></div>
          </div>
          <GearCarousel gear={gear} />
          <p class="mt-6 text-[0.78rem] text-muted-text">More gear across every app: <a href="/resources#gear" class="text-brand-anchor hover:text-primary-text">the full Gear list →</a></p>
        </div>
      </section>
    )}

    <section class="border-b border-border" aria-labelledby="faq-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="faq-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Frequently asked questions</h2>
        <div class="mt-8 divide-y divide-border border-y border-border">
          {faqs.map((f) => (
            <details class="group py-4">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-[0.98rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">
                {f.q}
                <span class="text-muted-text transition-transform duration-200 group-open:rotate-180" aria-hidden="true">⌄</span>
              </summary>
              <p class="mt-3 text-[0.88rem] leading-[1.65] text-muted-text">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </PlaygroundShell>
</Layout>

<style>
  .copy-btn{border-radius:9999px;border:1px solid var(--mp-border);background:var(--mp-elevated);padding:0.3rem 0.8rem;font-family:var(--font-mono);font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--mp-muted);transition:color 0.15s,border-color 0.15s}
  .copy-btn:hover{color:var(--mp-text);border-color:var(--mp-cta)}
  input[type=range]{accent-color:var(--mp-cta)}
  .tool-input{margin-top:0.25rem;display:block;width:100%;border-radius:10px;border:1px solid var(--mp-border);background:var(--mp-canvas);padding:0.45rem 0.6rem;font-size:0.85rem;color:var(--mp-text)}
  .tool-input:focus{outline:none;border-color:var(--mp-cta);box-shadow:0 0 0 3px color-mix(in srgb,var(--mp-cta) 20%,transparent)}
  .stage-card{border-radius:16px;border:1px solid var(--mp-border);background:var(--mp-canvas);padding:14px}
  .pill{border-radius:9999px;border:1px solid var(--mp-border);background:var(--mp-elevated);padding:0.25rem 0.6rem;font-family:var(--font-mono);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.07em}
  .math-card {
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--mp-elevated) 48%, transparent);
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    color: var(--mp-text);
  }
  .math-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--mp-muted);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
// @ts-nocheck
function initBiquad(){
  const stagesEl = document.getElementById('stages');
  const addBtn = document.getElementById('add-stage');
  const clearBtn = document.getElementById('clear-stages');
  const srEl = document.getElementById('sample-rate');
  const magCanvas = document.getElementById('mag-canvas');
  const coeffOut = document.getElementById('coeff-out');
  const showPhase = document.getElementById('show-phase');
  if(!stagesEl || !magCanvas || stagesEl.dataset.init) return;
  stagesEl.dataset.init='true';
  const mCtx = magCanvas.getContext('2d');
  const dpr = Math.min(window.devicePixelRatio||1,2);
  const W = magCanvas.width, H = magCanvas.height;
  magCanvas.width = W*dpr; magCanvas.height = H*dpr;
  magCanvas.style.width=W+'px'; magCanvas.style.height=H+'px';
  mCtx.scale(dpr,dpr);

  type FilterStage = { type: string; freq: number; q: number; gain: number; };
  let chain: FilterStage[] = [{type:'lowpass', freq:1000, q:0.7071, gain:0}];

  function clamp(n,lo,hi){return Math.max(lo,Math.min(hi,n));}

  // RBJ coefficients
  function coeffsFor(type,freq,q,gain,Fs){
    const w0 = 2*Math.PI*freq/Fs;
    const cosw0 = Math.cos(w0);
    const sinw0 = Math.sin(w0);
    const A = Math.pow(10,gain/40);
    const sqrtA = Math.sqrt(A);
    let alpha, b0,b1,b2,a0,a1,a2;
    // default Q handling
    const Q = q<=0 ? 0.0001 : q;
    switch(type){
      case 'lowpass':
        alpha = sinw0/(2*Q);
        b0=(1-cosw0)/2; b1=1-cosw0; b2=(1-cosw0)/2;
        a0=1+alpha; a1=-2*cosw0; a2=1-alpha;
        break;
      case 'highpass':
        alpha=sinw0/(2*Q);
        b0=(1+cosw0)/2; b1=-(1+cosw0); b2=(1+cosw0)/2;
        a0=1+alpha; a1=-2*cosw0; a2=1-alpha;
        break;
      case 'bandpass': // constant 0dB peak
        alpha=sinw0/(2*Q);
        b0=alpha; b1=0; b2=-alpha;
        a0=1+alpha; a1=-2*cosw0; a2=1-alpha;
        break;
      case 'notch':
        alpha=sinw0/(2*Q);
        b0=1; b1=-2*cosw0; b2=1;
        a0=1+alpha; a1=-2*cosw0; a2=1-alpha;
        break;
      case 'allpass':
        alpha=sinw0/(2*Q);
        b0=1-alpha; b1=-2*cosw0; b2=1+alpha;
        a0=1+alpha; a1=-2*cosw0; a2=1-alpha;
        break;
      case 'peaking':
        alpha=sinw0/(2*Q);
        b0=1+alpha*A; b1=-2*cosw0; b2=1-alpha*A;
        a0=1+alpha/A; a1=-2*cosw0; a2=1-alpha/A;
        break;
      case 'lowshelf': {
        alpha=sinw0/2*Math.sqrt((A+1/A)*(1/1-1)+2); // S=1
        b0=A*((A+1)-(A-1)*cosw0+2*sqrtA*alpha);
        b1=2*A*((A-1)-(A+1)*cosw0);
        b2=A*((A+1)-(A-1)*cosw0-2*sqrtA*alpha);
        a0=(A+1)+(A-1)*cosw0+2*sqrtA*alpha;
        a1=-2*((A-1)+(A+1)*cosw0);
        a2=(A+1)+(A-1)*cosw0-2*sqrtA*alpha;
        break;
      }
      case 'highshelf': {
        alpha=sinw0/2*Math.sqrt((A+1/A)*(1/1-1)+2);
        b0=A*((A+1)+(A-1)*cosw0+2*sqrtA*alpha);
        b1=-2*A*((A-1)+(A+1)*cosw0);
        b2=A*((A+1)+(A-1)*cosw0-2*sqrtA*alpha);
        a0=(A+1)-(A-1)*cosw0+2*sqrtA*alpha;
        a1=2*((A-1)+(A+1)*cosw0);
        a2=(A+1)-(A-1)*cosw0-2*sqrtA*alpha;
        break;
      }
      default:
        alpha=sinw0/(2*Q); b0=1; b1=0; b2=0; a0=1; a1=0; a2=0;
    }
    // normalize
    b0/=a0; b1/=a0; b2/=a0; a1/=a0; a2/=a0; a0=1;
    return {b0,b1,b2,a0,a1,a2, A, alpha};
  }

  function freqResponse(coeffs, f, Fs){
    const w = 2*Math.PI*f/Fs;
    const cosw = Math.cos(w), cos2w=Math.cos(2*w);
    const sinw = Math.sin(w), sin2w=Math.sin(2*w);
    let nr = coeffs.b0 + coeffs.b1*cosw + coeffs.b2*cos2w;
    let ni = -coeffs.b1*sinw - coeffs.b2*sin2w;
    let dr = 1 + coeffs.a1*cosw + coeffs.a2*cos2w;
    let di = -coeffs.a1*sinw - coeffs.a2*sin2w;
    const denom = dr*dr+di*di || 1e-12;
    const re = (nr*dr+ni*di)/denom;
    const im = (ni*dr - nr*di)/denom;
    const mag = Math.hypot(re,im);
    const phase = Math.atan2(im,re);
    return {mag, phase, re, im};
  }

  function totalResponse(freq, Fs){
    let mag=1, phase=0, reTotal=1, imTotal=0;
    for(const st of chain){
      const c = coeffsFor(st.type, st.freq, st.q, st.gain, Fs);
      const r = freqResponse(c,freq,Fs);
      const newRe = reTotal*r.re - imTotal*r.im;
      const newIm = reTotal*r.im + imTotal*r.re;
      reTotal=newRe; imTotal=newIm;
      mag *= r.mag;
      phase += r.phase;
    }
    return {mag, phase, re:reTotal, im:imTotal};
  }

  function logFreqSteps(minF,maxF,count){
    const out=[];
    for(let i=0;i<count;i++){
      const t=i/(count-1);
      const f = minF*Math.pow(maxF/minF,t);
      out.push(f);
    }
    return out;
  }

  function renderPlots(){
    const Fs = parseFloat(srEl.value)||48000;
    const width=W, height=H;
    const ctx=mCtx;
    ctx.clearRect(0,0,width,height);
    const bg = getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#f8f4ed';
    ctx.fillStyle=bg; ctx.fillRect(0,0,width,height);
    const freqsGrid=[20,50,100,200,500,1000,2000,5000,10000,20000];
    const minF=20, maxF=20000;
    function xForF(f){ return Math.log(f/minF)/Math.log(maxF/minF)*width; }
    ctx.strokeStyle='rgba(0,0,0,0.06)'; ctx.lineWidth=1;
    for(const f of freqsGrid){
      if(f<minF||f>maxF) continue;
      const x=xForF(f);
      ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,height); ctx.stroke();
    }
    function yForDb(db){
      const minDb=-36,maxDb=36;
      return height - (db-minDb)/(maxDb-minDb)*height;
    }
    const dbGrid=[-24,-18,-12,-6,0,6,12,18,24];
    for(const db of dbGrid){
      const y=yForDb(db);
      ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(width,y); ctx.strokeStyle=db===0?'rgba(0,0,0,0.15)':'rgba(0,0,0,0.06)'; ctx.stroke();
    }
    const steps=400;
    const freqSteps=logFreqSteps(minF,maxF,steps);
    const mags=freqSteps.map(f=>{ const r=totalResponse(f,Fs); return 20*Math.log10(r.mag||1e-12); });
    const phases=freqSteps.map(f=>{ const r=totalResponse(f,Fs); return r.phase*180/Math.PI; });
    ctx.beginPath(); ctx.strokeStyle='#b8324f'; ctx.lineWidth=2;
    for(let i=0;i<steps;i++){
      const x=xForF(freqSteps[i]); const y=yForDb(clamp(mags[i],-36,36));
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();
    if(showPhase.checked){
      function yForPhase(ph){ const minP=-180,maxP=180; return height - (ph-minP)/(maxP-minP)*height; }
      ctx.strokeStyle='rgba(0,0,0,0.04)'; ctx.setLineDash([4,4]);
      for(const ph of [-90,0,90]){ const y=yForPhase(ph); ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(width,y); ctx.stroke();}
      ctx.setLineDash([]);
      ctx.beginPath(); ctx.strokeStyle='#4a7bb8'; ctx.lineWidth=1.5;
      for(let i=0;i<steps;i++){
        const x=xForF(freqSteps[i]); const y=yForPhase(((phases[i]+540)%360)-180);
        if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
      }
      ctx.stroke();
    }
    ctx.fillStyle='rgba(0,0,0,0.5)'; ctx.font='10px ui-monospace, monospace';
    for(const f of [20,100,1000,10000]){ const x=xForF(f); ctx.fillText(f>=1000? (f/1000)+'k' : String(f), x+2, height-4); }
    let txt='';
    chain.forEach((st,i)=>{
      const c=coeffsFor(st.type,st.freq,st.q,st.gain,Fs);
      txt+=`Stage ${i+1} ${st.type} f=${st.freq}Hz Q=${st.q} gain=${st.gain}dB\n`;
      txt+=`  b0=${c.b0.toFixed(6)} b1=${c.b1.toFixed(6)} b2=${c.b2.toFixed(6)}\n`;
      txt+=`  a1=${c.a1.toFixed(6)} a2=${c.a2.toFixed(6)}\n\n`;
    });
    const at1k=totalResponse(1000,Fs);
    txt+=`Total @1k: ${ (20*Math.log10(at1k.mag)).toFixed(2)} dB, phase ${(at1k.phase*180/Math.PI).toFixed(1)}°\n`;
    coeffOut.textContent=txt;
  }

  function renderStages(){
    stagesEl.innerHTML='';
    chain.forEach((st,idx)=>{
      const card=document.createElement('div');
      card.className='stage-card';
      card.innerHTML=`
        <div class="flex items-center justify-between">
          <span class="pill">Stage ${idx+1}</span>
          <button type="button" class="pill hover:!border-red-300" data-remove="${idx}">Remove</button>
        </div>
        <div class="mt-3 grid grid-cols-2 gap-3">
          <label class="block"><span class="font-mono text-[0.62rem] uppercase tracking-[0.08em] text-muted-text">Type</span>
            <select data-field="type" data-idx="${idx}" class="tool-input">
              <option value="lowpass">lowpass</option><option value="highpass">highpass</option>
              <option value="bandpass">bandpass</option><option value="notch">notch</option>
              <option value="allpass">allpass</option><option value="peaking">peaking</option>
              <option value="lowshelf">lowshelf</option><option value="highshelf">highshelf</option>
            </select>
          </label>
          <label class="block"><span class="font-mono text-[0.62rem] uppercase tracking-[0.08em] text-muted-text">Freq Hz</span>
            <input type="number" data-field="freq" data-idx="${idx}" class="tool-input" min="20" max="20000" step="1" value="${st.freq}" />
          </label>
          <label class="block"><span class="font-mono text-[0.62rem] uppercase tracking-[0.08em] text-muted-text">Q / S=1</span>
            <input type="range" data-field="q" data-idx="${idx}" min="0.1" max="18" step="0.01" value="${st.q}" class="w-full" />
            <span class="font-mono text-[0.7rem]">${st.q}</span>
          </label>
          <label class="block"><span class="font-mono text-[0.62rem] uppercase tracking-[0.08em] text-muted-text">Gain dB (peak/shelf)</span>
            <input type="range" data-field="gain" data-idx="${idx}" min="-24" max="24" step="0.1" value="${st.gain}" class="w-full" />
            <span class="font-mono text-[0.7rem]">${st.gain}dB</span>
          </label>
        </div>`;
      stagesEl.appendChild(card);
      const sel=card.querySelector(`select[data-field="type"]`);
      sel.value=st.type;
      const gainRow=card.querySelectorAll('label')[3];
      if(['lowpass','highpass','bandpass','notch','allpass'].includes(st.type)) gainRow.style.opacity='0.4';
    });
    stagesEl.querySelectorAll('select[data-field], input[data-field]').forEach(el=>{
      el.addEventListener('input',(e)=>{
        const idx=parseInt(e.target.dataset.idx,10);
        const field=e.target.dataset.field;
        let v=e.target.value;
        if(field==='freq') v=parseFloat(v)||20;
        if(field==='q') v=parseFloat(v)||0.707;
        if(field==='gain') v=parseFloat(v)||0;
        chain[idx][field]=v;
        renderStages(); renderPlots(); rebuildAudioChain();
      });
    });
    stagesEl.querySelectorAll('button[data-remove]').forEach(btn=>{
      btn.addEventListener('click',()=>{ const idx=parseInt(btn.dataset.remove,10); if(chain.length>1){ chain.splice(idx,1); renderStages(); renderPlots(); rebuildAudioChain(); }});
    });
  }

  let audioCtx=null, sourceNode=null, gainNode=null, iirNodes=[], isPlaying=false, isBypass=false, oscNode=null, sweepOsc=null;
  const playBtn=document.getElementById('audio-play');
  const bypassBtn=document.getElementById('audio-bypass');
  const statusEl=document.getElementById('audio-status');
  const sourceSel=document.getElementById('source-type');
  const gainSlider=document.getElementById('audio-gain');
  const latencyNote=document.getElementById('latency-note');

  function ensureCtx(){
    if(!audioCtx) audioCtx=new (window.AudioContext||window.webkitAudioContext)({sampleRate: parseFloat(srEl.value)||48000});
    return audioCtx;
  }
  function makeWhiteNoiseBuffer(ctx, seconds=4){
    const len=ctx.sampleRate*seconds;
    const buf=ctx.createBuffer(1,len,ctx.sampleRate);
    const data=buf.getChannelData(0);
    for(let i=0;i<len;i++) data[i]=Math.random()*2-1;
    return buf;
  }
  function makePinkNoiseBuffer(ctx, seconds=4){
    const len=ctx.sampleRate*seconds;
    const buf=ctx.createBuffer(1,len,ctx.sampleRate);
    const data=buf.getChannelData(0);
    let b0,b1,b2,b3,b4,b5,b6; b0=b1=b2=b3=b4=b5=b6=0;
    for(let i=0;i<len;i++){
      const white=Math.random()*2-1;
      b0=0.99886*b0+white*0.0555179;
      b1=0.99332*b1+white*0.0750759;
      b2=0.96900*b2+white*0.153852;
      b3=0.86650*b3+white*0.3104856;
      b4=0.55000*b4+white*0.5329522;
      b5=-0.7616*b5-white*0.016898;
      data[i]=(b0+b1+b2+b3+b4+b5+b6+white*0.5362)*0.11;
      b6=white*0.115926;
    }
    return buf;
  }
  function rebuildAudioChain(){
    if(!audioCtx || !isPlaying) return;
    try{ iirNodes.forEach(n=>{ try{n.disconnect();}catch{}}); }catch{}
    iirNodes=[];
    const Fs=audioCtx.sampleRate;
    let prev = sourceNode;
    chain.forEach(st=>{
      const c=coeffsFor(st.type, st.freq, st.q, st.gain, Fs);
      try{
        const iir=audioCtx.createIIRFilter([c.b0,c.b1,c.b2],[1,c.a1,c.a2]);
        if(prev) prev.connect(iir);
        prev=iir;
        iirNodes.push(iir);
      }catch(e){
        const bq=audioCtx.createBiquadFilter();
        bq.type=st.type; bq.frequency.value=st.freq; bq.Q.value=st.q; bq.gain.value=st.gain;
        if(prev) prev.connect(bq);
        prev=bq; iirNodes.push(bq);
      }
    });
    if(prev && gainNode) prev.connect(gainNode);
    if(isBypass){
      try{ sourceNode.disconnect(); }catch{}
      sourceNode.connect(gainNode);
      iirNodes.forEach(n=>{ try{n.disconnect();}catch{}});
    }
  }

  async function startAudio(){
    const ctx=ensureCtx();
    await ctx.resume();
    stopAudio();
    const type=sourceSel.value;
    gainNode=ctx.createGain(); gainNode.gain.value=parseFloat(gainSlider.value)||0.35; gainNode.connect(ctx.destination);
    if(type==='sine'){
      oscNode=ctx.createOscillator(); oscNode.frequency.value=440; oscNode.type='sine';
      sourceNode=oscNode;
      rebuildAudioChain();
      if(!isBypass){ oscNode.connect(iirNodes[0]||gainNode); } else oscNode.connect(gainNode);
      oscNode.start();
    } else if(type==='sweep'){
      oscNode=ctx.createOscillator(); oscNode.type='sine'; oscNode.frequency.value=20;
      const now=ctx.currentTime;
      oscNode.frequency.exponentialRampToValueAtTime(20000, now+8);
      sourceNode=oscNode;
      rebuildAudioChain();
      if(!isBypass) oscNode.connect(iirNodes[0]||gainNode); else oscNode.connect(gainNode);
      oscNode.start(); oscNode.stop(now+8.2);
      setTimeout(()=>{ if(isPlaying) stopAudio(); }, 8500);
    } else {
      const buf = type==='pink' ? makePinkNoiseBuffer(ctx,5) : makeWhiteNoiseBuffer(ctx,5);
      const src=ctx.createBufferSource(); src.buffer=buf; src.loop=true;
      sourceNode=src;
      rebuildAudioChain();
      if(!isBypass) src.connect(iirNodes[0]||gainNode); else src.connect(gainNode);
      src.start();
    }
    isPlaying=true; statusEl.textContent='playing • '+(isBypass?'bypassed':'filtered');
    latencyNote.textContent=`Ctx ${ctx.sampleRate}Hz, baseLatency ${ (ctx.baseLatency||0).toFixed(4)}s`;
    playBtn.textContent='Stop';
  }
  function stopAudio(){
    try{ if(oscNode){ oscNode.stop(); oscNode.disconnect(); } }catch{}
    try{ if(sourceNode){ sourceNode.stop?.(); sourceNode.disconnect(); } }catch{}
    try{ if(gainNode) gainNode.disconnect(); }catch{}
    try{ iirNodes.forEach(n=>n.disconnect()); }catch{}
    oscNode=null; sourceNode=null; gainNode=null; iirNodes=[];
    if(isPlaying){ isPlaying=false; statusEl.textContent='stopped'; playBtn.textContent='Play'; }
  }

  playBtn.addEventListener('click', ()=>{ if(isPlaying) stopAudio(); else startAudio(); });
  bypassBtn.addEventListener('click', ()=>{
    isBypass=!isBypass;
    bypassBtn.textContent='Bypass: '+(isBypass?'ON':'OFF');
    if(isPlaying){
      const ctx=audioCtx;
      try{ sourceNode.disconnect(); }catch{}
      try{ iirNodes.forEach(n=>n.disconnect()); }catch{}
      if(isBypass){ sourceNode.connect(gainNode); }
      else { rebuildAudioChain(); }
      statusEl.textContent='playing • '+(isBypass?'bypassed':'filtered');
    }
  });
  gainSlider.addEventListener('input', ()=>{ if(gainNode) gainNode.gain.value=parseFloat(gainSlider.value); });
  sourceSel.addEventListener('change', ()=>{ if(isPlaying){ stopAudio(); startAudio(); }});
  srEl.addEventListener('change', ()=>{ renderPlots(); if(audioCtx) { rebuildAudioChain(); } });
  showPhase.addEventListener('change', renderPlots);
  addBtn.addEventListener('click', ()=>{ if(chain.length<4){ chain.push({type:'peaking', freq:2000, q:1, gain:6}); renderStages(); renderPlots(); rebuildAudioChain(); }});
  clearBtn.addEventListener('click', ()=>{ chain=[{type:'lowpass', freq:1000, q:0.7071, gain:0}]; renderStages(); renderPlots(); rebuildAudioChain(); });

  document.querySelectorAll('.copy-btn').forEach(btn=>{
    btn.addEventListener('click', async()=>{
      const id=btn.dataset.copyTarget; const el=id?document.getElementById(id):null; if(!el) return;
      try{ await navigator.clipboard.writeText(el.textContent||''); const o=btn.textContent; btn.textContent='Copied'; setTimeout(()=>btn.textContent=o,1200);}catch{}
    });
  });

  renderStages(); renderPlots();
  document.addEventListener('astro:before-swap', ()=>{ stopAudio(); try{audioCtx?.close();}catch{} }, {once:true});
}
document.addEventListener('astro:page-load', initBiquad);
initBiquad();
</script>
