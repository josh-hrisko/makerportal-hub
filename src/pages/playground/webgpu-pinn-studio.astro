  function playClick(loss){
    if(!audioOn) return;
    try{
      const ctx=ensureAudio(); if(ctx.state==='suspended') ctx.resume();
      const osc=ctx.createOscillator(), gain=ctx.createGain();
      const logL=Math.log10(Math.max(loss,1e-7));
      // map logL 0 -> -4 -> 0->1
      const t=Math.max(0, Math.min(1, (-logL)/4));
      const freq=220 + t*880 + Math.random()*30;
      osc.frequency.value=freq;
      osc.type='sine';
      gain.gain.setValueAtTime(0.22, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime+0.16);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(); osc.stop(ctx.currentTime+0.17);
    }catch{}
  }
  btnAudio.addEventListener('click',()=>{
