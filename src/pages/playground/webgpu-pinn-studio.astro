  // MLP utils
  function actEval(z,kind){
    if(kind==='tanh'){ const f=Math.tanh(z); const fp=1-f*f; const fpp=-2*f*fp; return {f,fp,fpp}; }
    if(kind==='sin'){ const f=Math.sin(z); const fp=Math.cos(z); const fpp=-Math.sin(z); return {f,fp,fpp}; }
    const s=1/(1+Math.exp(-z)); const f=z*s; const ds=s*(1-s); const fp=s+z*ds; const d2=ds*(1-2*s); const fpp=2*ds+z*d2; return {f,fp,fpp};
  }
  function xavier(inDim,outDim){
    const lim=Math.sqrt(6/(inDim+outDim));
    return (Math.random()*2-1)*lim;
  }
  function initModel(nLayers, hiddenDim, act){
    const layers=[];
    for(let i=0;i<nLayers;i++){
      const inDim=i===0?2:hiddenDim; const outDim=hiddenDim;
      const W=[]; for(let k=0;k<inDim;k++){ const row=[]; for(let j=0;j<outDim;j++) row.push(xavier(inDim,outDim)); W.push(row); }
      const b=new Array(outDim).fill(0).map(()=> (Math.random()*2-1)*0.05);
      layers.push({W,b});
    }
    const Wout=new Array(hiddenDim).fill(0).map(()=> xavier(hiddenDim,1));
    const bout=(Math.random()*2-1)*0.05;
    return {layers, Wout, bout, act, hiddenDim, nLayers};
  }

  function forwardFull(x,t,model){
    // a_list[0]=input, etc.
    const a_list=[], z_list=[], dadx_list=[], dadt_list=[], d2adx2_list=[], d2adt2_list=[];
    let a=[x,t], dadx=[1,0], dadt=[0,1], d2adx2=[0,0], d2adt2=[0,0];
    a_list.push(a.slice()); dadx_list.push(dadx.slice()); dadt_list.push(dadt.slice()); d2adx2_list.push(d2adx2.slice()); d2adt2_list.push(d2adt2.slice());
    const cacheZ=[];
    for(let li=0; li<model.layers.length; li++){
      const {W,b}=model.layers[li];
      const inDim=a.length, outDim=W[0].length;
      const z=new Array(outDim).fill(0), dzdx=new Array(outDim).fill(0), dzdt=new Array(outDim).fill(0), d2zdx2=new Array(outDim).fill(0), d2zdt2=new Array(outDim).fill(0);
      for(let j=0;j<outDim;j++){
        let s=b[j], sx=0, st=0, sxx=0, stt=0;
        for(let k=0;k<inDim;k++){ s+=a[k]*W[k][j]; sx+=dadx[k]*W[k][j]; st+=dadt[k]*W[k][j]; sxx+=d2adx2[k]*W[k][j]; stt+=d2adt2[k]*W[k][j]; }
        z[j]=s; dzdx[j]=sx; dzdt[j]=st; d2zdx2[j]=sxx; d2zdt2[j]=stt;
      }
      const an=new Array(outDim), adx=new Array(outDim), adt=new Array(outDim), adxx=new Array(outDim), adtt=new Array(outDim);
      for(let j=0;j<outDim;j++){ const {f,fp,fpp}=actEval(z[j], model.act); an[j]=f; adx[j]=fp*dzdx[j]; adt[j]=fp*dzdt[j]; adxx[j]=fpp*dzdx[j]*dzdx[j]+fp*d2zdx2[j]; adtt[j]=fpp*dzdt[j]*dzdt[j]+fp*d2zdt2[j]; }
      cacheZ.push(z);
      a=an; dadx=adx; dadt=adt; d2adx2=adxx; d2adt2=adtt;
      a_list.push(a.slice()); z_list.push(z.slice()); dadx_list.push(dadx.slice()); dadt_list.push(dadt.slice()); d2adx2_list.push(d2adx2.slice()); d2adt2_list.push(d2adt2.slice());
    }
    let u=model.bout, ut=0, ux=0, uxx=0, utt=0;
    for(let k=0;k<a.length;k++){ u+=a[k]*model.Wout[k]; ut+=dadt[k]*model.Wout[k]; ux+=dadx[k]*model.Wout[k]; uxx+=d2adx2[k]*model.Wout[k]; utt+=d2adt2[k]*model.Wout[k]; }
    return {u, ut, ux, uxx, utt, a_last:a, dadx, dadt, d2adx2, d2adt2, a_list, z_list, dadx_list, dadt_list, d2adx2_list, d2adt2_list};
  }

  function residualFromForward(f, pde, params){
    if(pde==='heat') return f.ut - params.alpha*f.uxx;
    if(pde==='wave') return f.utt - params.c*params.c*f.uxx;
    return f.ut + f.u*f.ux - params.nu*f.uxx;
  }

  let model=null;
  let colloc=[], dataPts=[];
  let epoch=0;
  let histTot=[], histPhys=[], histData=[];
  let playing=false;
  let raf=0;

  function genPoints(nCol){
    const col=[];
    for(let i=0;i<nCol;i++) col.push({x:Math.random(), t:Math.random()});
    const data=[];
    const nIC=Math.floor(nCol/1.5);
    const nBC=nCol;
    for(let i=0;i<nIC;i++){ const x=Math.random(); const target=Math.sin(Math.PI*x); data.push({x, t:0, target}); }
    for(let i=0;i<nBC;i++){ const t=Math.random(); const x=Math.random()<0.5?0:1; data.push({x, t, target:0}); }
    // add a few interior supervised from analytic heat for stability (optional)
    for(let i=0;i<8;i++){ const x=Math.random(); const t=Math.random()*0.2; const target=Math.sin(Math.PI*x)*Math.exp(-0.1*Math.PI*Math.PI*t); data.push({x,t,target}); }
    return {col, data};
  }

  function zeroGrads(m){
    const layers=m.layers.map(l=>{
      const inDim=l.W.length, outDim=l.W[0].length;
      const W=[]; for(let k=0;k<inDim;k++) W.push(new Array(outDim).fill(0));
      const b=new Array(outDim).fill(0);
      return {W,b};
    });
    const Wout=new Array(m.hiddenDim).fill(0);
    let bout=0;
    return {layers, Wout, bout};
  }

  function trainOneEpoch(){
    if(!model) return null;
    const params={alpha:parseFloat(slAlpha.value), nu:parseFloat(slNu.value), c:parseFloat(slC.value)};
    const lambda=parseFloat(slLambda.value);
    const lr=parseFloat(slLr.value);

    // data grads
    const grads=zeroGrads(model);
    let lossData=0;
    // accum for Wout data
    let gWoutData=new Array(model.hiddenDim).fill(0);
    let gBoutData=0;

    for(const pt of dataPts){
      const f=forwardFull(pt.x, pt.t, model);
      const err=f.u-pt.target;
      lossData+=err*err;
      const dLdu=2*err;
      for(let k=0;k<model.hiddenDim;k++) gWoutData[k]+=dLdu*f.a_last[k];
      gBoutData+=dLdu;
      // backprop hidden
      let dLda=new Array(model.hiddenDim).fill(0);
      for(let k=0;k<model.hiddenDim;k++) dLda[k]=dLdu*model.Wout[k];
      for(let li=model.layers.length-1; li>=0; li--){
        const layer=model.layers[li];
        const aPrev=model.layers.length>0 ? (li===0? [pt.x, pt.t] : null) : null;
        // we have forward caches in f
        const z=f.z_list[li];
        const aPrevActual=f.a_list[li];
        const deltaZ=new Array(layer.W[0].length);
        for(let j=0;j<layer.W[0].length;j++){
          const {fp}=actEval(z[j], model.act); // recompute fp (we could store but recompute)
          // Actually actEval returns f,fp,fpp; we need fp
          deltaZ[j]=dLda[j]*fp;
          for(let k=0;k<aPrevActual.length;k++) grads.layers[li].W[k][j]+=deltaZ[j]*aPrevActual[k];
          grads.layers[li].b[j]+=deltaZ[j];
        }
        const dLdaPrev=new Array(aPrevActual.length).fill(0);
        for(let k=0;k<aPrevActual.length;k++){
          let s=0;
          for(let j=0;j<layer.W[0].length;j++) s+=layer.W[k][j]*deltaZ[j];
          dLdaPrev[k]=s;
        }
        dLda=dLdaPrev;
      }
    }
    lossData/=dataPts.length;

    // physics
    let lossPhys=0;
    let gWoutPhys=new Array(model.hiddenDim).fill(0);
    let gBoutPhys=0;
    let maxRes=0;
    for(const pt of colloc){
      const f=forwardFull(pt.x, pt.t, model);
      const res=residualFromForward(f, selectedPDE, params);
      lossPhys+=res*res;
      maxRes=Math.max(maxRes, Math.abs(res));
      if(selectedPDE==='heat'){
        for(let k=0;k<model.hiddenDim;k++){ const G=f.dadt[k]-params.alpha*f.d2adx2[k]; gWoutPhys[k]+=2*res*G; }
      } else if(selectedPDE==='wave'){
        for(let k=0;k<model.hiddenDim;k++){ const G=f.d2adt2[k]-params.c*params.c*f.d2adx2[k]; gWoutPhys[k]+=2*res*G; }
      } else {
        // burgers
        for(let k=0;k<model.hiddenDim;k++){
          const dres = f.dadt[k] + f.a_last[k]*f.ux + f.u*f.dadx[k] - params.nu*f.d2adx2[k];
          gWoutPhys[k]+=2*res*dres;
        }
        gBoutPhys+=2*res*f.ux;
      }
    }
    lossPhys/=colloc.length;

    // update
    const invData=dataPts.length, invCol=colloc.length;
    for(let k=0;k<model.hiddenDim;k++){
      const gd=gWoutData[k]/invData / (1) ; // already sum
      // Actually gWoutData sum of dLdu*a ; average
      const gp=gWoutPhys[k]/invCol;
      const totalGrad= gd*0 + 0; // placeholder
    }
    // correct averaging and update
    for(let k=0;k<model.hiddenDim;k++){
      const gradDataAvg=gWoutData[k]/dataPts.length;
      const gradPhysAvg=gWoutPhys[k]/colloc.length;
      const total=gradDataAvg + lambda*gradPhysAvg;
      model.Wout[k]-=lr*total;
    }
    model.bout -= lr*(gBoutData/dataPts.length + lambda*(gBoutPhys/colloc.length));

    for(let li=0; li<model.layers.length; li++){
      const layer=model.layers[li];
      const gL=grads.layers[li];
      const inDim=layer.W.length, outDim=layer.W[0].length;
      for(let k=0;k<inDim;k++) for(let j=0;j<outDim;j++){
        const avg=gL.W[k][j]/dataPts.length;
        layer.W[k][j]-=lr*avg;
      }
      for(let j=0;j<outDim;j++) layer.b[j]-=lr*(gL.b[j]/dataPts.length);
    }

    const total=lossData + lambda*lossPhys;
    return {total, lossPhys, lossData, maxRes};
  }

  function resetModel(){
    const nLayers=parseInt(slLayers.value), hDim=parseInt(slHidden.value), act=selAct.value;
    model=initModel(nLayers, hDim, act);
    const {col, data}=genPoints(parseInt(slCol.value));
    colloc=col; dataPts=data;
    epoch=0; histTot=[]; histPhys=[]; histData=[];
    roEpoch.textContent='0'; roLoss.textContent='—'; roPhys.textContent='—'; roData.textContent='—'; roResMax.textContent='—';
    drawLoss(); drawResidual(); drawLandscape(0.5);
  }

  // Drawing
  function drawLoss(){
    const W=900,H=240; lCtx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#10151f';
    lCtx.fillStyle=bg; lCtx.fillRect(0,0,W,H);
    if(histTot.length<2){ lCtx.fillStyle='#a8b9cc'; lCtx.font='12px ui-monospace'; lCtx.fillText('Train to see log-loss',12,20); return; }
    const minLog=Math.log10(Math.max(1e-8, Math.min(...histTot, ...histPhys, ...histData)));
    const maxLog=Math.log10(Math.max(...histTot, ...histPhys, ...histData, 1e-6));
    const pad=40;
    const plotW=W-pad-10, plotH=H-30;
    // grid
    lCtx.strokeStyle='rgba(255,255,255,0.07)'; lCtx.lineWidth=1;
    for(let i=0;i<=4;i++){ const y=10 + i/4*plotH; lCtx.beginPath(); lCtx.moveTo(pad,y); lCtx.lineTo(W-5,y); lCtx.stroke(); lCtx.fillStyle='rgba(255,255,255,0.35)'; lCtx.font='10px ui-monospace'; const v=maxLog - i/4*(maxLog-minLog); lCtx.fillText(v.toFixed(1),2,y+3); }
    function plot(arr,color){
      lCtx.beginPath(); lCtx.strokeStyle=color; lCtx.lineWidth=1.5;
      arr.forEach((v,i)=>{
        const x=pad + i/Math.max(1,arr.length-1)*plotW;
        const logv=Math.log10(Math.max(v,1e-8));
        const y=10 + (maxLog - logv)/(maxLog-minLog||1)*plotH;
        if(i===0) lCtx.moveTo(x,y); else lCtx.lineTo(x,y);
      }); lCtx.stroke();
    }
    plot(histData,'#60a5fa');
    plot(histPhys,'#f07a94');
    plot(histTot,'#e8eef6');
  }

  function drawResidual(){
    const W=resC.width/dpr, H=resC.height/dpr;
    rCtx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#10151f';
    rCtx.fillStyle=bg; rCtx.fillRect(0,0,W,H);
    if(!model){ rCtx.fillStyle='#a8b9cc'; rCtx.font='12px ui-monospace'; rCtx.fillText('Reset model',10,20); return; }
    const gw=64, gh=64;
    const params={alpha:parseFloat(slAlpha.value), nu:parseFloat(slNu.value), c:parseFloat(slC.value)};
    const resGrid=[]; let maxAbs=0;
    for(let j=0;j<gh;j++){
      const row=[];
      const t=1 - j/(gh-1);
      for(let i=0;i<gw;i++){
        const x=i/(gw-1);
        const f=forwardFull(x,t,model);
        const r=residualFromForward(f, selectedPDE, params);
        const ab=Math.abs(r);
        if(ab>maxAbs) maxAbs=ab;
        row.push(r);
      }
      resGrid.push(row);
    }
    if(maxAbs<1e-8) maxAbs=1;
    roResMax.textContent=maxAbs.toExponential(2);
    const img=rCtx.createImageData(gw,gh);
    for(let j=0;j<gh;j++) for(let i=0;i<gw;i++){
      const r=resGrid[j][i];
      const norm=Math.min(1, Math.abs(r)/maxAbs);
      // colormap black->blue->pink
      let cr,cg,cb;
      if(norm<0.5){ const t=norm/0.5; cr=15+t*(96-15); cg=23+t*(165-23); cb=42+t*(250-42); } else { const t=(norm-0.5)/0.5; cr=96+t*(240-96); cg=165+t*(122-165); cb=250+t*(148-250); }
      const idx=(j*gw+i)*4; img.data[idx]=cr; img.data[idx+1]=cg; img.data[idx+2]=cb; img.data[idx+3]=255;
    }
    // draw scaled
    const off=document.createElement('canvas'); off.width=gw; off.height=gh; off.getContext('2d').putImageData(img,0,0);
    rCtx.imageSmoothingEnabled=false;
    rCtx.drawImage(off, 0,0, W, H);
