    rCtx.fillStyle='rgba(255,255,255,0.08)'; rCtx.font='10px ui-monospace'; rCtx.fillText(`max|R| ${maxAbs.toExponential(1)}`,8,H-8);
  }

  let landscapeEpoch=0;
  function drawLandscape(epochFac=0){
    const W=landC.width/dpr, H=landC.height/dpr;
    landCtx.clearRect(0,0,W,H);
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#10151f';
    landCtx.fillStyle=bg; landCtx.fillRect(0,0,W,H);
    const gw=80, gh=80;
    const tot=histTot.length?histTot[histTot.length-1]:0.5;
    const base=Math.max(1e-6, tot);
    const values=[];
    let minV=Infinity, maxV=-Infinity;
    for(let j=0;j<gh;j++) for(let i=0;i<gw;i++){
      const wx=(i/gw*2-1)*1.5, wy=(j/gh*2-1)*1.5;
      const r2=wx*wx+wy*wy;
      const warp=Math.sin(wx*3 + landscapeEpoch*0.03)*Math.cos(wy*3 + landscapeEpoch*0.02)*0.3 + Math.sin((wx+wy)*2.2)*0.15;
      const bowl=0.8*r2 + warp*0.4;
      const loss=base*(1+ bowl*3) + 0.005*r2;
      const logl=Math.log10(loss+1e-7);
      values.push(logl);
      if(logl<minV) minV=logl; if(logl>maxV) maxV=logl;
    }
    const img=landCtx.createImageData(gw,gh);
    // normalize to 0-1 for color
    for(let idx=0; idx<gw*gh; idx++){
      const norm = (values[idx]-minV)/(maxV-minV||1);
      // turbo-ish: 0 blue 1 red
      let cr,cg,cb;
      const t=norm;
      if(t<0.25){ cr=30+t/0.25*60; cg=30+t/0.25*80; cb=120+t/0.25*80; }
      else if(t<0.5){ cr=90+(t-0.25)/0.25*60; cg=110+(t-0.25)/0.25*100; cb=200-(t-0.25)/0.25*50; }
      else if(t<0.75){ cr=150+(t-0.5)/0.25*90; cg=210-(t-0.5)/0.25*60; cb=150-(t-0.5)/0.25*50; }
      else { cr=240; cg=150-(t-0.75)/0.25*30; cb=100-(t-0.75)/0.25*30; }
      const o=idx*4; img.data[o]=cr; img.data[o+1]=cg; img.data[o+2]=cb; img.data[o+3]=255;
    }
    const off=document.createElement('canvas'); off.width=gw; off.height=gh; off.getContext('2d').putImageData(img,0,0);
    landCtx.imageSmoothingEnabled=true;
    landCtx.drawImage(off,0,0,W,H);
    // contours via marching squares at 0.2,0.4,0.6,0.8
    const thresholds=[0.2,0.4,0.6,0.8];
    landCtx.strokeStyle='rgba(255,255,255,0.35)'; landCtx.lineWidth=0.8;
    thresholds.forEach(th=>{
      const iso=minV + th*(maxV-minV);
      for(let j=0;j<gh-1;j++) for(let i=0;i<gw-1;i++){
        const idx = j*gw+i;
        const v0=values[idx], v1=values[idx+1], v2=values[idx+gw+1], v3=values[idx+gw];
        const pts=[];
        const edge=(va, vb, xa,ya, xb,yb)=>{
          if((va<=iso && vb>iso)||(va>iso && vb<=iso)){
            const t=(iso-va)/(vb-va||1e-9);
            return [xa + t*(xb-xa), ya + t*(yb-ya)];
          }
          return null;
        };
        const x0=i/gw*W, y0=j/gh*H, x1=(i+1)/gw*W, y1=j/gh*H, x2=(i+1)/gw*W, y2=(j+1)/gh*H, x3=i/gw*W, y3=(j+1)/gh*H;
        const e0=edge(v0,v1,x0,y0,x1,y1), e1=edge(v1,v2,x1,y1,x2,y2), e2=edge(v2,v3,x2,y2,x3,y3), e3=edge(v3,v0,x3,y3,x0,y0);
        const segs=[e0,e1,e2,e3].filter(Boolean);
        if(segs.length===2){ landCtx.beginPath(); landCtx.moveTo(segs[0][0],segs[0][1]); landCtx.lineTo(segs[1][0],segs[1][1]); landCtx.stroke(); }
        else if(segs.length===4){ // ambiguous, draw two
          landCtx.beginPath(); landCtx.moveTo(segs[0][0],segs[0][1]); landCtx.lineTo(segs[1][0],segs[1][1]); landCtx.stroke();
          landCtx.beginPath(); landCtx.moveTo(segs[2][0],segs[2][1]); landCtx.lineTo(segs[3][0],segs[3][1]); landCtx.stroke();
        }
      }
    });
    // center dot
    landCtx.fillStyle='#e8eef6'; landCtx.beginPath(); landCtx.arc(W/2, H/2, 4,0,Math.PI*2); landCtx.fill();
    landCtx.fillStyle='rgba(255,255,255,0.6)'; landCtx.font='10px ui-monospace'; landCtx.fillText(`L ${base.toExponential(1)}`,8,H-8);
  }

  let lastResDraw=0;
  function loop(){
    if(playing && model){
      const res=trainOneEpoch();
      if(res){
        epoch++; histTot.push(res.total); histPhys.push(res.lossPhys); histData.push(res.lossData);
        if(histTot.length>200){ histTot.shift(); histPhys.shift(); histData.shift(); }
        roEpoch.textContent=epoch;
        roLoss.textContent=res.total.toExponential(2);
        roPhys.textContent=res.lossPhys.toExponential(2);
        roData.textContent=res.lossData.toExponential(2);
        drawLoss();
        playClick(res.total);
        landscapeEpoch=epoch;
        if(epoch-lastResDraw>8){ drawResidual(); drawLandscape(); lastResDraw=epoch; }
      }
    }
    raf=requestAnimationFrame(loop);
  }

  btnTrain.addEventListener('click',()=>{ playing=true; btnTrain.classList.add('is-active'); btnPause.classList.remove('is-active'); });
  btnPause.addEventListener('click',()=>{ playing=false; btnPause.classList.add('is-active'); btnTrain.classList.remove('is-active'); });
  btnReset.addEventListener('click',()=>{ playing=false; resetModel(); btnTrain.classList.remove('is-active'); btnPause.classList.remove('is-active'); });
  slLayers.addEventListener('change',()=>{ resetModel(); });
  slHidden.addEventListener('change',()=>{ resetModel(); });
  slCol.addEventListener('change',()=>{ const {col,data}=genPoints(parseInt(slCol.value)); colloc=col; dataPts=data; });
  selAct.addEventListener('change',()=>{ resetModel(); });

  resetModel();
  loop();
  document.addEventListener('astro:before-swap',()=>{cancelAnimationFrame(raf); try{audioCtx?.close();}catch{}},{once:true});
}
document.addEventListener('astro:page-load', initPINN);
initPINN();
</script>
</Layout>
