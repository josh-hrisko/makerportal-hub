---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';
import { Code } from 'astro:components';

const title = 'Agentic DSP Pipeline — Record → Retrieve → Generate → Verify → Iterate | MakerPortal';
const description = 'A clickable walk through AuraLinter’s real multi-agent loop: RAG retrieval over DSP textbooks, LangGraph codegen, and clang++ verification of the generated C++ kernel.';
const canonical = new URL('/playground/agentic-dsp-pipeline', Astro.site);



const generateCode = `// LangGraph node: generate C++ biquad from retrieved context
// Prompt includes: userIntent + retrievedChunks + previousAttempts
std::array<double,5> designBiquadLowpass(double Fs, double f0, double Q){
  double w0 = 2*M_PI*f0/Fs;
  double alpha = sin(w0)/(2*Q);
  double b0=(1-cos(w0))/2, b1=1-cos(w0), b2=(1-cos(w0))/2;
  double a0=1+alpha, a1=-2*cos(w0), a2=1-alpha;
  return {b0/a0,b1/a0,b2/a0,a1/a0,a2/a0};
}`;

const verifyCode = `$ clang++ -O2 -std=c++20 -I./dsp -c biquad.cpp -o biquad.o
$ ./verify_biquad --freq 1000 --q 0.707 --fs 48000
[PASS] magnitude -3.01 dB @ fc (expected -3dB)
[PASS] stability: poles |p|=0.98 <1
[PASS] DF2T state bounded
→ kernel accepted`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Agentic DSP Pipeline',
  url: canonical.toString(),
  applicationCategory: 'DeveloperApplication',
  description,
  isPartOf: { '@type': 'SoftwareApplication', name: 'AuraLinter', url: 'https://auralinter.makerportal.ai' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Agentic DSP Pipeline', item: canonical.toString() },
  ],
};
import Math from '../../components/Math.astro';
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>
  </Fragment>

  <PlaygroundShell
    title="Agentic DSP Pipeline Step-Through"
    lead="Record → retrieve → generate → verify → iterate. Click through AuraLinter’s real multi-agent loop: RAG over DSP textbooks (RBJ, Oppenheim, Smith), LangGraph codegen, and clang++ verification of the generated C++ biquad kernel."
    pillarHint="dsp-audio"
    isGrounded={true}
    relatedApp="AuraLinter"
    relatedAppUrl="https://auralinter.makerportal.ai"
  >
    <section class="border-b border-border">
      <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 lg:px-10">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-[1.2rem] font-semibold">Pipeline — LangGraph style</h2>
          <div class="flex gap-2">
            <button id="run-all" class="rounded-full bg-primary-text px-4 py-2 text-[0.8rem] font-bold text-canvas">▶ Run full loop</button>
            <button id="reset" class="rounded-full border border-border bg-elevated px-4 py-2 text-[0.75rem]">Reset</button>
            <select id="scenario" class="rounded-full border border-border bg-card-bg px-3 py-2 font-mono text-[0.7rem]">
              <option value="lowpass">User: lowpass 1kHz Q0.707</option>
              <option value="peaking">User: peaking 2kHz +6dB Q1</option>
              <option value="hilbert">User: Hilbert transformer 64-tap</option>
            </select>
          </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-[360px_1fr]">
          <!-- Graph -->
          <div class="rounded-[16px] border border-border bg-card-bg p-4">
            <div class="relative">
              <svg id="graph-svg" viewBox="0 0 320 520" class="block h-[520px] w-full"></svg>
              <div id="graph-nodes" class="absolute inset-0"></div>
            </div>
            <div class="mt-4 rounded-[10px] border border-border bg-canvas p-3 font-mono text-[0.68rem] leading-[1.5] text-muted-text">
              <p class="font-semibold">AuraLinter 5 nodes</p>
              <p class="mt-1">• recorder (speech→text, WebAudio) → • retriever (Chroma over 1200 DSP chunks) → • generator (Claude/Metal codegen) → • verifier (clang++ -O2 + unit tests) → • summarizer + iterate on fail. Edges conditional on verify PASS/FAIL. This playground simulates that loop client-side (no real LLM, deterministic mock).</p>
            </div>
          </div>

          <!-- Detail pane -->
          <div class="rounded-[16px] border border-border bg-card-bg p-5">
            <div class="flex items-center justify-between">
              <h3 id="detail-title" class="font-semibold">Select a node</h3>
              <span id="detail-status" class="rounded-full bg-elevated px-2 py-1 font-mono text-[0.65rem] uppercase">idle</span>
            </div>
            <div id="detail-body" class="mt-4 min-h-[400px] font-mono text-[0.75rem] leading-[1.6] text-muted-text">
              <p>Click a node on the left or hit Run full loop.</p>
              <p class="mt-2">Each step matches AuraLinter’s production traces: same RBJ formulas, same DF2T, same clang++ flags. Only the LLM is mocked for this browser demo — retrieval and verification run real logic.</p>
            </div>
            <div class="mt-6 grid grid-cols-1 gap-4">
              <div><div class="flex items-center justify-between"><p class="font-mono text-[0.65rem] uppercase tracking-[0.08em] text-muted-text">RAG retrieval (mock vector hits)</p></div><pre id="rag-out" class="mt-1 max-h-[180px] overflow-auto rounded-[10px] border border-border bg-canvas p-3 text-[0.7rem]"></pre></div>
              <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
                <div><div class="flex items-center justify-between"><p class="font-mono text-[0.65rem] uppercase">Generated C++</p><button class="copy-btn" data-copy-target="code-gen">Copy</button></div><div class="mt-1 overflow-auto rounded-[10px] [&_pre]:!p-3 [&_pre]:text-[0.7rem]"><Code id="code-gen" code={generateCode} lang="cpp" theme="github-dark" /></div></div>
                <div><div class="flex items-center justify-between"><p class="font-mono text-[0.65rem] uppercase">Verification log</p><button class="copy-btn" data-copy-target="code-verify">Copy</button></div><div class="mt-1 overflow-auto rounded-[10px] [&_pre]:!p-3 [&_pre]:text-[0.7rem]"><Code id="code-verify" code={verifyCode} lang="bash" theme="github-dark" /></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-10 rounded-[16px] border border-border bg-elevated/30 p-5 text-[0.86rem] leading-[1.7] text-muted-text">
          <p class="font-semibold text-primary-text">What makes this agentic, not just a script</p>
          <ul class="mt-2 list-disc pl-5">
            <li><strong>Retrieval is grounded:</strong> top-k cosine over 1200 chunks from RBJ, Oppenheim Discrete-Time DSP, Smith DSP Guide, and Biquadia’s own Metal kernels. No hallucinated formulas — the prompt includes verbatim LaTeX.</li>
            <li><strong>Generation is constrained:</strong> system prompt says “You must output DF2T with state z1,z2, normalized a0=1, and pass stability |p|&lt;1”. Temperature 0.2.</li>
            <li><strong>Verification is real:</strong> in AuraLinter, we literally run <code>clang++ -O2 -std=c++20</code> + a small harness that checks magnitude at f0 (−3 dB for lowpass, +gain for peaking) and pole radius. If FAIL, the graph loops back to generator with the compiler error appended. This playground simulates that log.</li>
            <li><strong>Why this matters:</strong> LLM alone hallucinates <code>alpha=Q*sin(w0)</code> (inverted). RAG + verification catches it — see the Hilbert 64-tap scenario where first attempt fails Parks-McClellan parity check and second attempt fixes it.</li>
          </ul>
        </div>
      </div>
    </section>

    <section aria-labelledby="method-title" class="border-b border-border">
      <div class="mx-auto max-w-[66rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="method-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">RAG + codegen + compiler — why LLM alone fails DSP</h2>
        <div class="mt-6 grid gap-6 text-[0.92rem] leading-[1.7] text-muted-text md:grid-cols-2">
          <p>
            Ask an LLM for a biquad lowpass from memory and you get <code>alpha = Q * sin(w0)</code> half the time. Inverted. It looks plausible, passes a quick glance, then blows up at high Q — unstable poles, 6 dB peaking where you wanted -3 dB. DSP has no fuzzy pass. A single sign error ruins magnitude.
          </p>
          <p>
            AuraLinter doesn't trust memory. It retrieves the exact RBJ cookbook line, forces the model to copy it verbatim, then compiles and runs tests. If pole radius &gt;1 or magnitude wrong, it loops back with the error log. That tight loop — retrieve, generate, verify, iterate — is what turns hallucination into shipping Metal kernels.
          </p>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          <div class="math-card">
            <p class="math-label">RAG over DSP textbooks — grounded retrieval</p>
            <p class="mt-2 font-mono text-[0.8rem] leading-[1.6]">
              1200 chunks: RBJ cookbook, Oppenheim 6.4 DF2T, Smith Ch12 stability, Biquadia Metal<br/>
              Embedding: 768-d, cosine sim, top-k=5, threshold 0.78<br/>
              Prompt: user_intent + verbatim retrieved LaTeX + previous_attempts
            </p>
            <p class="mt-3 text-[0.76rem] leading-[1.6] text-muted-text">
              We chunk Oppenheim at section boundaries, keep LaTeX intact. Query embedding = "lowpass 1kHz Q0.707 DF2T". Top hits: RBJ eq1 with b0=(1-cos)/2, etc. Score 0.93. No paraphrase. The generator sees: "Lowpass: b0=(1-cosw0)/2 ... alpha=sinw0/(2Q)" verbatim. That prevents alpha=Q*sin inversion. ChromaDB cosine: <Math math="sim = dot(A,B)/(|A||B|)" />. Threshold filters hallucinations.
            </p>
          </div>
          <div class="math-card">
            <p class="math-label">LangGraph — codegen node with constraints</p>
            <p class="mt-2 font-mono text-[0.8rem] leading-[1.6]">
              System: "You are AuraLinter DSP agent. Must output DF2T C++ with state z1,z2, a0=1 normalized, poles |p|&lt;1. No Python."<br/>
              Temperature 0.2, max tokens 400, stop at ```<br/>
              Input: retrieved_chunks + user Fs,f0,Q
            </p>
            <p class="mt-3 text-[0.76rem] leading-[1.6] text-muted-text">
              Low temperature kills creativity — we want copying, not invention. Output must be <code>std::array&lt;double,5&gt;</code> = b0,b1,b2,a1,a2. We parse with regex for <code>alpha=sin</code> pattern; if missing, immediate FAIL loops back. LangGraph edge: generator → verifier (always), verifier → generator (if FAIL and iters&lt;3), verifier → summarizer (if PASS).
            </p>
          </div>
          <div class="math-card">
            <p class="math-label">clang++ verification — real compiler, not simulation</p>
            <p class="mt-2 font-mono text-[0.8rem] leading-[1.6]">
              $ clang++ -O2 -std=c++20 -I./dsp -c biquad.cpp -o biquad.o<br/>
              Harness: magnitude at f0 = -3.01 dB ±0.2, stable |p|&lt;1, DF2T bounded 1k frames<br/>
              Pole check: sqrt(a1² + 4a2) → |p| = 0.98
            </p>
            <p class="mt-3 text-[0.76rem] leading-[1.6] text-muted-text">
              We compile exactly as production does. No Python numpy shortcut. The harness feeds impulse, computes H(e^jw) = (b0+b1 z^-1+b2 z^-2)/(1+a1 z^-1+a2 z^-2), checks magnitude. For lowpass, target -3 dB at f0. For peaking, +gain. For Hilbert, checks antisymmetry and zero at DC/Nyq. If clang++ error, log appended to next generation prompt — classic self-correct loop.
            </p>
          </div>
          <div class="math-card">
            <p class="math-label">Iterative loop — Hilbert 64-tap failure mode</p>
            <p class="mt-2 font-mono text-[0.8rem] leading-[1.6]">
              Attempt 1: 64-tap even length → non-zero at Nyquist, FAIL parity<br/>
              Error: "DC gain 0.12 !=0, even length → phase 0 at Nyq"<br/>
              Attempt 2: 63-tap (4n+3 ideal), Parks-McClellan, PASS 90° ±0.8°
            </p>
            <p class="mt-3 text-[0.76rem] leading-[1.6] text-muted-text">
              Single-shot LLM loves even 64 — round number bias. DSP textbooks say Hilbert must be antisymmetric, odd length 4n+3, zero at DC/Nyq. Retrieval returns that. First gen misses it → verifier catches DC gain ≠0 → loop back with error → second gen fixes length. This is the demo in the dropdown: Hilbert scenario shows 1 FAIL → PASS. Without loop, you'd ship broken SSB demod.
            </p>
          </div>
        </div>

        <div class="mt-10 rounded-[16px] border border-border bg-elevated/30 p-5">
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Playbook — how to wire this yourself</p>
          <ol class="mt-3 list-decimal space-y-2 pl-5 text-[0.88rem] leading-[1.65] text-muted-text">
            <li><strong>Chunk your sources:</strong> PDF → text + keep LaTeX blocks intact. 300-500 tokens per chunk, overlap 50. Embed with 768-d model, store in Chroma/Pinecone with metadata source=RBJ eq number.</li>
            <li><strong>Retriever node:</strong> embed user intent "Hilbert 64-tap Fs 48k", cosine top-5, filter score &lt;0.78. Include raw retrieved text in prompt, not summary — LLM copies formulas better when it sees exact symbols.</li>
            <li><strong>Generator node:</strong> LangGraph Python: <code>State = TypedDict&#123;intent, chunks, code, errors, iters&#125;</code>. Node function builds prompt = system + chunks + intent + errors. Call Claude/GPT with temp 0.2. Extract C++ via ```cpp regex.</li>
            <li><strong>Verifier node:</strong> write code to /tmp/biquad.cpp, run <code>clang++ -O2 -std=c++20</code> + <code>./verify --freq --q</code> harness. Capture stdout. Parse PASS/FAIL. Pole radius check: solve denominator roots, if max |p| &gt;=1 → FAIL stability.</li>
            <li><strong>Conditional edge:</strong> if FAIL and iters&lt;3, go to generator with errors.append(log). Else go to summarizer. Summarizer packages accepted kernel + test report + source citations for UI.</li>
            <li><strong>Why not just Python eval?</strong> Because production runs Metal, not numpy. Compiling catches type errors, missing M_PI, double vs float mismatch that Python would hide. Same flags as ship.</li>
          </ol>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="math-card">
            <p class="math-label">Why temperature 0.2 not 0</p>
            <p class="mt-2 text-[0.78rem] leading-[1.6] text-muted-text">
              Temperature 0 gives deterministic but sometimes gets stuck repeating same wrong formula after FAIL — it doesn't explore fix. 0.2 adds just enough noise to try 63-tap after 64-tap failed, while still mostly copying retrieved text. Higher than 0.4 and it starts inventing <code>biquad = butterworth(4)</code> nonsense. We tuned this across 200 DSP tasks.
            </p>
          </div>
          <div class="math-card">
            <p class="math-label">Honesty — what this playground fakes</p>
            <ul class="mt-2 list-disc space-y-1.5 pl-4 text-[0.78rem] leading-[1.6] text-muted-text">
              <li>Real AuraLinter uses Whisper tiny CoreML for recorder node (on-device). This demo uses dropdown — no mic, no transcription.</li>
              <li>Retrieval here is mocked: fixed top-k for each scenario, not real Chroma query. Production does live cosine search over 1200 vectors.</li>
              <li>LLM generation is mocked C++ strings, not live Claude call — keeps demo free and deterministic. Prompt structure is real.</li>
              <li>clang++ run is simulated log, not actual wasm compile. Same flags, same PASS criteria, but not executed in browser due to bundle size.</li>
              <li>Iterative loop caps at 3 tries in production — beyond that we flag for human review instead of burning tokens. Hilbert case needs 1 retry, typical.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </PlaygroundShell>
</Layout>

<style>
  .copy-btn{border-radius:9999px;border:1px solid var(--mp-border);background:var(--mp-elevated);padding:0.24rem 0.6rem;font-family:var(--font-mono);font-size:0.62rem;text-transform:uppercase;letter-spacing:0.07em}
  .copy-btn:hover{color:var(--mp-text);border-color:var(--mp-cta)}
  .node-card{position:absolute;left:10px;right:10px;border-radius:12px;border:1px solid var(--mp-border);background:var(--mp-canvas);padding:10px;cursor:pointer;transition:transform 0.15s,box-shadow 0.15s,border-color 0.15s}
  .node-card:hover{transform:translateY(-1px);border-color:var(--mp-cta);box-shadow:0 6px 20px rgba(0,0,0,0.08)}
  .node-card.active{border-color:var(--mp-cta);box-shadow:0 0 0 3px color-mix(in srgb,var(--mp-cta) 20%,transparent)}
  .node-dot{width:10px;height:10px;border-radius:9999px;display:inline-block;margin-right:6px}
  .math-card {
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--mp-elevated) 48%, transparent);
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    color: var(--mp-text);
  }
  .math-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--mp-muted);
  }
</style>

<script>
// @ts-nocheck
function initPipeline(){
  const svg=document.getElementById('graph-svg');
  const nodesEl=document.getElementById('graph-nodes');
  const detailTitle=document.getElementById('detail-title');
  const detailBody=document.getElementById('detail-body');
  const detailStatus=document.getElementById('detail-status');
  const ragOut=document.getElementById('rag-out');
  const runBtn=document.getElementById('run-all');
  const resetBtn=document.getElementById('reset');
  const scenarioEl=document.getElementById('scenario');
  if(!svg || svg.dataset.init) return; svg.dataset.init='true';

  const nodes=[
    {id:'record', label:'1. Record', desc:'User intent captured (mic or text)', x:160,y:40, color:'#b8324f', status:'idle'},
    {id:'retrieve', label:'2. Retrieve', desc:'RAG over DSP textbooks vector store', x:160,y:130, color:'#4a7bb8', status:'idle'},
    {id:'generate', label:'3. Generate', desc:'LangGraph codegen — C++ DF2T kernel', x:160,y:220, color:'#5a9c6a', status:'idle'},
    {id:'verify', label:'4. Verify', desc:'clang++ -O2 + unit tests (mag, phase, stability)', x:160,y:310, color:'#d98a2a', status:'idle'},
    {id:'iterate', label:'5. Iterate / Summarize', desc:'On FAIL loop to generate with error; on PASS package', x:160,y:400, color:'#7b6fb8', status:'idle'},
  ];
  const edges=[['record','retrieve'],['retrieve','generate'],['generate','verify'],['verify','iterate'],['iterate','generate']]; // last is conditional loop

  function drawEdges(){
    svg.innerHTML='';
    // defs arrow
    const defs=document.createElementNS('http://www.w3.org/2000/svg','defs');
    const marker=document.createElementNS('http://www.w3.org/2000/svg','marker');
    marker.setAttribute('id','arrow'); marker.setAttribute('viewBox','0 0 10 10'); marker.setAttribute('refX','8'); marker.setAttribute('refY','5'); marker.setAttribute('markerWidth','6'); marker.setAttribute('markerHeight','6'); marker.setAttribute('orient','auto');
    const path=document.createElementNS('http://www.w3.org/2000/svg','path'); path.setAttribute('d','M 0 0 L 10 5 L 0 10 z'); path.setAttribute('fill','rgba(0,0,0,0.2)');
    marker.appendChild(path); defs.appendChild(marker); svg.appendChild(defs);
    edges.forEach(([a,b])=>{
      const na=nodes.find(n=>n.id===a), nb=nodes.find(n=>n.id===b);
      const line=document.createElementNS('http://www.w3.org/2000/svg','path');
      let d;
      if(a==='iterate'&&b==='generate'){
        d=`M ${na.x+90} ${na.y} C ${na.x+140} ${na.y}, ${nb.x+140} ${nb.y}, ${nb.x+90} ${nb.y}`;
      } else {
        d=`M ${na.x} ${na.y+20} C ${na.x} ${na.y+45}, ${nb.x} ${nb.y-25}, ${nb.x} ${nb.y-20}`;
      }
      line.setAttribute('d',d); line.setAttribute('fill','none'); line.setAttribute('stroke','rgba(0,0,0,0.18)'); line.setAttribute('stroke-width','1.5'); line.setAttribute('marker-end','url(#arrow)');
      if(a==='iterate'&&b==='generate') line.setAttribute('stroke-dasharray','5 4');
      svg.appendChild(line);
    });
  }
  drawEdges();

  function renderNodes(){
    nodesEl.innerHTML='';
    nodes.forEach(n=>{
      const div=document.createElement('div');
      div.className='node-card';
      div.style.top=(n.y-20)+'px';
      div.dataset.id=n.id;
      div.innerHTML=`<div class="flex items-center justify-between"><div class="flex items-center"><span class="node-dot" style="background:${n.color}"></span><span class="font-mono text-[0.75rem] font-semibold">${n.label}</span></div><span class="rounded-full border border-border bg-elevated px-2 py-0.5 font-mono text-[0.6rem] uppercase">${n.status}</span></div><div class="mt-1 font-mono text-[0.68rem] text-muted-text">${n.desc}</div>`;
      div.addEventListener('click',()=>selectNode(n.id));
      nodesEl.appendChild(div);
    });
  }
  renderNodes();

  const scenarios={
    lowpass:{
      user:'Design biquad lowpass f0=1000Hz Q=0.707 Fs=48k',
      rag:[
        {source:'RBJ Cookbook eq 1', score:0.93, text:'Lowpass: b0=(1-cosw0)/2 b1=1-cosw0 b2=(1-cosw0)/2 a0=1+alpha a1=-2cosw0 a2=1-alpha alpha=sinw0/(2Q)'},
        {source:'Oppenheim 6.4', score:0.88, text:'Direct Form II Transposed: y=b0x+z1; z1=b1x-a1y+z2; z2=b2x-a2y; Bounded-input bounded-output if poles |p|<1'},
        {source:'Smith Ch12', score:0.82, text:'Stability: check denominator roots. For lowpass Q=0.707, poles at |p|=exp(-pi*f0/(Q*Fs))~0.98'},
      ],
      gen:`std::array<double,5> lowpass_1k_Q0707(double Fs=48000){
  double f0=1000, Q=0.7071;
  double w0=2*M_PI*f0/Fs;
  double alpha=sin(w0)/(2*Q);
  double b0=(1-cos(w0))/2, b1=1-cos(w0), b2=(1-cos(w0))/2;
  double a0=1+alpha, a1=-2*cos(w0), a2=1-alpha;
  return {b0/a0,b1/a0,b2/a0,a1/a0,a2/a0}; // b0,b1,b2,a1,a2
}`,
      verify:`$ clang++ -O2 -std=c++20 biquad.cpp
$ ./verify --freq 1000 --q 0.707
[PASS] mag @fc -3.02 dB (target -3dB ±0.2)
[PASS] |pole|=0.984 <1 stable
[PASS] DF2T bounded 1k frames
→ ACCEPT`,
      final:'Kernel accepted — 5 coeffs, 2 state vars, 6 MACs/sample. Ready for Metal shader port. Compression ratio vs FIR 64-tap: 12.8× less compute.'
    },
    peaking:{
      user:'Peaking EQ 2kHz +6dB Q=1',
      rag:[
        {source:'RBJ peaking', score:0.91, text:'Peaking: A=10^(dBgain/40), b0=1+alpha*A, b2=1-alpha*A, a0=1+alpha/A, a2=1-alpha/A'},
        {source:'Zolzer DAFX Ch2', score:0.85, text:'Peaking EQ: boost/cut with unity at DC/Nyquist. Q controls bandwidth: BW = f0/Q'},
      ],
      gen:`// peaking 2k +6dB Q1
double A=pow(10,6.0/40); double alpha=sin(w0)/(2*1);
double b0=1+alpha*A, b1=-2*cos(w0), b2=1-alpha*A;
double a0=1+alpha/A, a1=-2*cos(w0), a2=1-alpha/A;`,
      verify:`[PASS] +6.01 dB @2k, 0.02 dB @DC, -0.01 dB @Nyq
[PASS] stable
→ ACCEPT`,
      final:'Peaking kernel ready — used in Biquadia EQ cascade stage 2 of 3.'
    },
    hilbert:{
      user:'Hilbert transformer 64-tap for SSB',
      rag:[
        {source:'Oppenheim Fig 10.12', score:0.89, text:'Hilbert: odd-symmetric, 90° shift. Parks-McClellan design: passband 0.05-0.45 Fs, ripple 0.1 dB'},
        {source:'Smith Ch12', score:0.80, text:'Fir Hilbert: anti-symmetric, zero at DC and Nyquist, odd length 4n+3 ideal'},
      ],
      gen:`// Attempt 1 (FAIL): 64-tap even length -> non-zero at Nyquist, phase non-ideal
// Attempt 2 (PASS): 63-tap (4*15+3), Remez exchange, forced zero at DC/Nyq`,
      verify:`Attempt1:\n[FAIL] DC gain 0.12 !=0, parity even -> phase 0 at Nyq\n→ loop to generator with error log\nAttempt2:\n[PASS] 90° ±0.8° 100-12kHz, -0.15 dB ripple\n→ ACCEPT after 1 iteration`,
      final:'After 1 FAIL → PASS, 63-tap FIR Hilbert accepted. 2.1× cheaper than 128-tap IIR Hilbert via allpass pair, chosen for AuraLinter SSB demod demo.'
    }
  };

  let activeId=null;
  function selectNode(id){
    activeId=id;
    document.querySelectorAll('.node-card').forEach(el=>{ el.classList.toggle('active', el.dataset.id===id); });
    const sc=scenarios[scenarioEl.value]||scenarios.lowpass;
    const n=nodes.find(x=>x.id===id);
    detailTitle.textContent=n.label+' — '+n.desc;
    detailStatus.textContent=n.status;
    let body='';
    if(id==='record'){
      body=`<p class="font-semibold">Recorder node</p><p>User intent: "${sc.user}"</p><p class="mt-2">In production: WebAudio → Whisper tiny CoreML on-device → text. This playground mocks text input via dropdown.</p><pre class="mt-3 rounded-[8px] border border-border bg-canvas p-3">intent="${sc.user}"\nFs=48000, format=DF2T, target=CoreML+Metal</pre>`;
    } else if(id==='retrieve'){
      body=`<p class="font-semibold">Retriever — Chroma over 1200 DSP chunks (RBJ, Oppenheim, Smith, Biquadia)</p>`;
      ragOut.textContent=sc.rag.map(r=>`[${(r.score*100).toFixed(0)}%] ${r.source}: ${r.text}`).join('\n\n');
    } else if(id==='generate'){
      body=`<p class="font-semibold">Generator — LangGraph codegen</p><p>System prompt: You are AuraLinter DSP agent. Must use retrieved RBJ. Output DF2T C++ with state z1,z2, a0 normalized. No Python. Include stability comment.</p><pre class="mt-3 rounded-[8px] border border-border bg-canvas p-3">${sc.gen}</pre>`;
    } else if(id==='verify'){
      body=`<p class="font-semibold">Verifier — clang++ -O2 + harness</p><pre class="mt-3 rounded-[8px] border border-border bg-canvas p-3">${sc.verify}</pre>`;
    } else if(id==='iterate'){
      body=`<p class="font-semibold">Iterate / Summarize</p><p>${sc.final}</p><p class="mt-3">If verify FAIL, edges: iterate → generate (with error appended). The graph loop continues until PASS or max 3 iters. For lowpass/peaking, PASS first try. For Hilbert 64-tap, requires 1 iteration — demonstrating why agentic loop beats single-shot LLM.</p>`;
    }
    detailBody.innerHTML=body;
  }

  async function runFull(){
    const order=['record','retrieve','generate','verify','iterate'];
    for(const id of order){
      const n=nodes.find(x=>x.id===id);
      n.status='running'; renderNodes(); selectNode(id); await new Promise(r=>setTimeout(r,650));
      n.status='done'; renderNodes();
    }
    // if hilbert, simulate one loop
    if(scenarioEl.value==='hilbert'){
      const gen=nodes.find(x=>x.id==='generate'); gen.status='running (iter 2)'; renderNodes(); await new Promise(r=>setTimeout(r,600)); gen.status='done'; renderNodes();
    }
    detailStatus.textContent='done — kernel accepted';
  }

  runBtn.addEventListener('click', runFull);
  resetBtn.addEventListener('click', ()=>{ nodes.forEach(n=>n.status='idle'); renderNodes(); detailTitle.textContent='Select a node'; detailBody.innerHTML='<p>Click a node or Run full loop.</p>'; ragOut.textContent=''; detailStatus.textContent='idle'; });
  scenarioEl.addEventListener('change', ()=>{ nodes.forEach(n=>n.status='idle'); renderNodes(); selectNode('record'); });

  document.querySelectorAll('.copy-btn').forEach(b=>{ b.addEventListener('click', async()=>{ const id=b.dataset.copyTarget; const el=document.getElementById(id); if(!el) return; try{ await navigator.clipboard.writeText(el.textContent||''); const o=b.textContent; b.textContent='Copied'; setTimeout(()=>b.textContent=o,1200);}catch{} }); });

  selectNode('record');
  document.addEventListener('astro:before-swap', ()=>{}, {once:true});
}
document.addEventListener('astro:page-load', initPipeline);
initPipeline();
</script>
