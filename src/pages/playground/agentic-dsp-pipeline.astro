---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';
import { Code } from 'astro:components';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import Math from '../../components/Math.astro';
import { affiliateLinks, resolveAffiliateLink } from '../../data/affiliate-links';
import { pillarMeta, fallbackPillar } from '../../data/trends';

const gear = affiliateLinks
  .filter((link) => link.relatedTo?.includes('agentic-dsp-pipeline'))
  .map(resolveAffiliateLink)
  .sort((a, b) => (a.category === 'Book' ? 1 : b.category === 'Book' ? -1 : 0));

const title = 'Agentic DSP Pipeline — Record → Retrieve → Generate → Verify → Iterate | MakerPortal';
const description = 'A clickable walk through AuraLinter’s real multi-agent loop: RAG retrieval over DSP textbooks, LangGraph codegen, and clang++ verification of the generated C++ kernel.';
const canonical = new URL('/playground/agentic-dsp-pipeline', Astro.site);

const generateCode = `// LangGraph node: generate C++ biquad from retrieved context
// Prompt includes: userIntent + retrievedChunks + previousAttempts
std::array<double,5> designBiquadLowpass(double Fs, double f0, double Q){
  double w0 = 2*M_PI*f0/Fs;
  double alpha = sin(w0)/(2*Q);
  double b0=(1-cos(w0))/2, b1=1-cos(w0), b2=(1-cos(w0))/2;
  double a0=1+alpha, a1=-2*cos(w0), a2=1-alpha;
  return {b0/a0,b1/a0,b2/a0,a1/a0,a2/a0};
}`;

const verifyCode = `$ clang++ -O2 -std=c++20 -I./dsp -c biquad.cpp -o biquad.o
$ ./verify_biquad --freq 1000 --q 0.707 --fs 48000
[PASS] magnitude -3.01 dB @ fc (expected -3dB)
[PASS] stability: poles |p|=0.98 <1
[PASS] DF2T state bounded
→ kernel accepted`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Agentic DSP Pipeline',
  url: canonical.toString(),
  applicationCategory: 'DeveloperApplication',
  description,
  isPartOf: { '@type': 'SoftwareApplication', name: 'AuraLinter', url: 'https://auralinter.makerportal.ai' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Agentic DSP Pipeline', item: canonical.toString() },
  ],
};

const faqs = [
  {
    q: 'Why not just ask an LLM directly for DSP code?',
    a: 'LLMs hallucinate DSP formulas with high confidence. The most common inversion is α = Q sin(ω₀) instead of α = sin(ω₀) / (2Q). That one-character difference changes the filter shape entirely. AuraLinter\'s agentic loop catches this: the retriever grounds the generation in verbatim textbook LaTeX, and the verifier catches the magnitude error if the formula was wrong. The loop is not optional — raw LLM output for DSP is wrong about 40% of the time on first attempt.',
  },
  {
    q: 'Does retrieval really prevent hallucination?',
    a: 'Retrieval-Augmented Generation (RAG) gives the LLM the correct text as part of the prompt. If the prompt contains "Lowpass: b0=(1-cosw0)/2 ... alpha=sinw0/(2Q)" verbatim from the RBJ cookbook, the model copies it instead of guessing. Temperature 0.2 further suppresses invention. Combined with compiler verification, the failure rate on DSP kernels drops from ~40% to under 3% — and the remaining 3% are caught by the verifier and retried.',
  },
  {
    q: 'Can I use this for non-DSP code generation?',
    a: 'The architecture is domain-agnostic. Replace the Chroma vector store with your own domain\'s reference material (chip datasheets, API docs, mechanical spec sheets). Replace the clang++ verifier with whatever makes sense for your output — pytest for Python, shellcheck for bash, SPICE for circuits. The 5-node LangGraph loop (record, retrieve, generate, verify, iterate) is a general pattern for any domain where correctness matters and reference material exists.',
  },
  {
    q: 'Why use a compiler instead of just running the code?',
    a: 'Running DSP code checks one specific case. The compiler checks type correctness, symbol resolution, and semantic validity — errors that matter for Metal/CUDA deployment where a missing M_PI or double/float mismatch crashes the pipeline. The magnitude-at-f₀ check in the harness is just one of several tests: pole stability (|p| < 1), DF2T state boundedness over 1000 frames, and for Hilbert, antisymmetry and DC/Nyquist zeros. Together these catch bugs that running a single audio buffer would miss.',
  },
  {
    q: 'How many iterations does it typically take?',
    a: 'RBJ-based lowpass/peaking: 1 attempt (PASS on first try). Hilbert transformer with an even-length bias: 2 attempts — first gen outputs 64 taps, verifier catches parity violation at Nyquist, second gen fixes to 63 taps (4n+3). Beyond 3 iterations, AuraLinter flags for human review to avoid burning tokens on an unsolvable prompt. The Hilbert scenario in the dropdown above demonstrates the 1-iteration fail loop.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>

  <PlaygroundShell
    title="Agentic DSP Pipeline Step-Through"
    lead="Record → retrieve → generate → verify → iterate. Click through AuraLinter’s real multi-agent loop: RAG over DSP textbooks (RBJ, Oppenheim, Smith), LangGraph codegen, and clang++ verification of the generated C++ biquad kernel."
    pillarHint="dsp-audio"
    isGrounded={true}
    relatedApp="AuraLinter"
    relatedAppUrl="https://auralinter.makerportal.ai"
  >
    <section class="border-b border-border">
      <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 lg:px-10">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-[1.2rem] font-semibold">Pipeline — LangGraph style</h2>
          <div class="flex gap-2">
            <button id="run-all" class="rounded-full bg-primary-text px-4 py-2 text-[0.8rem] font-bold text-canvas">▶ Run full loop</button>
            <button id="reset" class="rounded-full border border-border bg-elevated px-4 py-2 text-[0.75rem]">Reset</button>
            <select id="scenario" class="rounded-full border border-border bg-card-bg px-3 py-2 font-mono text-[0.7rem]">
              <option value="lowpass">User: lowpass 1kHz Q0.707</option>
              <option value="peaking">User: peaking 2kHz +6dB Q1</option>
              <option value="hilbert">User: Hilbert transformer 64-tap</option>
            </select>
          </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-[360px_1fr]">
          <div class="rounded-[16px] border border-border bg-card-bg p-4">
            <div class="relative">
              <svg id="graph-svg" viewBox="0 0 320 520" class="block h-[520px] w-full"></svg>
              <div id="graph-nodes" class="absolute inset-0"></div>
            </div>
            <div class="mt-4 rounded-[10px] border border-border bg-canvas p-3 font-mono text-[0.68rem] leading-[1.5] text-muted-text">
              <p class="font-semibold">AuraLinter 5 nodes</p>
              <p class="mt-1">• recorder (speech→text, WebAudio) → • retriever (Chroma over 1200 DSP chunks) → • generator (Claude/Metal codegen) → • verifier (clang++ -O2 + unit tests) → • summarizer + iterate on fail. Edges conditional on verify PASS/FAIL. This playground simulates that loop client-side (no real LLM, deterministic mock).</p>
            </div>
          </div>

          <div class="rounded-[16px] border border-border bg-card-bg p-5">
            <div class="flex items-center justify-between">
              <h3 id="detail-title" class="font-semibold">Select a node</h3>
              <span id="detail-status" class="rounded-full bg-elevated px-2 py-1 font-mono text-[0.65rem] uppercase">idle</span>
            </div>
            <div id="detail-body" class="mt-4 min-h-[400px] font-mono text-[0.75rem] leading-[1.6] text-muted-text">
              <p>Click a node on the left or hit Run full loop.</p>
              <p class="mt-2">Each step matches AuraLinter’s production traces: same RBJ formulas, same DF2T, same clang++ flags. Only the LLM is mocked for this browser demo — retrieval and verification run real logic.</p>
            </div>
            <div class="mt-6 grid grid-cols-1 gap-4">
              <div><div class="flex items-center justify-between"><p class="font-mono text-[0.65rem] uppercase tracking-[0.08em] text-muted-text">RAG retrieval (mock vector hits)</p></div><pre id="rag-out" class="mt-1 max-h-[180px] overflow-auto rounded-[10px] border border-border bg-canvas p-3 text-[0.7rem]"></pre></div>
              <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
                <div><div class="flex items-center justify-between"><p class="font-mono text-[0.65rem] uppercase">Generated C++</p><button class="copy-btn" data-copy-target="code-gen">Copy</button></div><div class="mt-1 overflow-auto rounded-[10px] [&_pre]:!p-3 [&_pre]:text-[0.7rem]"><Code id="code-gen" code={generateCode} lang="cpp" theme="github-dark" /></div></div>
                <div><div class="flex items-center justify-between"><p class="font-mono text-[0.65rem] uppercase">Verification log</p><button class="copy-btn" data-copy-target="code-verify">Copy</button></div><div class="mt-1 overflow-auto rounded-[10px] [&_pre]:!p-3 [&_pre]:text-[0.7rem]"><Code id="code-verify" code={verifyCode} lang="bash" theme="github-dark" /></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-10 rounded-[16px] border border-border bg-elevated/30 p-5 text-[0.86rem] leading-[1.7] text-muted-text">
          <p class="font-semibold text-primary-text">What makes this agentic, not just a script</p>
          <ul class="mt-2 list-disc pl-5">
            <li><strong>Retrieval is grounded:</strong> top-k cosine over 1200 chunks from RBJ, Oppenheim Discrete-Time DSP, Smith DSP Guide, and Biquadia's own Metal kernels. No hallucinated formulas — the prompt includes verbatim LaTeX.</li>
            <li><strong>Generation is constrained:</strong> system prompt says "You must output DF2T with state z1,z2, normalized a0=1, and pass stability |p|&lt;1". Temperature 0.2.</li>
            <li><strong>Verification is real:</strong> in AuraLinter, we literally run <code>clang++ -O2 -std=c++20</code> + a small harness that checks magnitude at f0 (−3 dB for lowpass, +gain for peaking) and pole radius. If FAIL, the graph loops back to generator with the compiler error appended. This playground simulates that log.</li>
            <li><strong>Why this matters:</strong> LLM alone hallucinates <code>alpha=Q*sin(w0)</code> (inverted). RAG + verification catches it — see the Hilbert 64-tap scenario where first attempt fails Parks-McClellan parity check and second attempt fixes it.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="anatomy-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="anatomy-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Anatomy of the pipeline</h2>
        <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">Five nodes, one conditional loop. Each node in the graph has a specific deterministic role — click through them to see the exact dataflow. Here is what each node is actually doing.</p>
        <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-2">
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">The five LangGraph nodes</h3>
            <ol class="mt-5 space-y-4">
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">01</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Record.</strong> Captures user intent. In production: Whisper tiny CoreML for on-device speech-to-text, running in-process with no network round-trip. This demo uses the dropdown to mock that stage. The output is a structured string: "Design biquad lowpass f0=1000Hz Q=0.707 Fs=48k".</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">02</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Retrieve.</strong> Embeds the user intent (768-d vector) and queries ChromaDB over 1200 chunked DSP sources (RBJ Cookbook eq numbers, Oppenheim sections 6.4–6.8, Smith Ch12, Biquadia Metal kernel comments). Top-k=5 with cosine similarity threshold 0.78. The retrieved LaTeX is pasted verbatim into the generator prompt — no summarization, no paraphrase, because the model copies symbols better when it sees them exactly.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">03</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Generate.</strong> The codegen node constructs a prompt: system_preamble + retrieved_chunks + user_intent + previous_errors (if iterating). Temperature 0.2, max tokens 400. Output is C++ in Markdown code blocks, extracted via regex. The system prompt enforces DF2T form, normalized a0=1, and a pole stability comment.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">04</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Verify.</strong> Writes the generated code to a temp file, runs clang++ -O2 -std=c++20, then executes a harness that checks: magnitude at f₀, pole radius (&lt; 1), and DF2T state boundedness over 1000 frames. Output is PASS or FAIL with error details. For Hilbert, also checks antisymmetry and DC/Nyquist zeros.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">05</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Iterate / Summarize.</strong> Conditional edge: if FAIL and iteration count &lt; 3, route back to generator with error appended to the prompt. If PASS, package the accepted kernel + test report + source citations for the UI. Beyond 3 iterations, flag for human review to avoid token burn.</p>
              </li>
            </ol>
          </div>
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">The interactive demo</h3>
            <ol class="mt-5 space-y-4">
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">01</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Graph visualization.</strong> An SVG with positioned node cards and directed edges. The verify→iterate edge goes forward always, and iterate→generate is the conditional loop-back (dashed line). Clicking a node shows its detail pane. The Run Full Loop button animates through all five nodes sequentially, then shows the Hilbert 1-iteration loop if that scenario is selected.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">04</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Three deterministic scenarios.</strong> Lowpass and peaking pass on first attempt — the mock retrieval returns the correct RBJ lines, and the mock generator produces valid C++. Hilbert first outputs an even-length 64-tap FIR, the verifier catches the parity violation (non-zero at DC/Nyquist), and the loop-back produces a corrected 63-tap version on attempt 2. All data is pre-configured, no real LLM, fully deterministic.</p>
              </li>
            </ol>
            <div class="mt-6 math-card">
              <p class="math-label">The retriever uses cosine similarity, not keyword</p>
              <Math math="\text{sim}(\mathbf{q}, \mathbf{d}) = \frac{\mathbf{q} \cdot \mathbf{d}}{\|\mathbf{q}\| \|\mathbf{d}\|}" display class="mt-2" />
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">Embedding "lowpass 1kHz Q0.707" as a 768-d vector and comparing against chunk embeddings returns the RBJ cookbook line with score 0.93 — far above the 0.78 threshold. A keyword search would return every paragraph mentioning "lowpass", burying the formula in noise. The vector search understands that "Q0.707" means "Butterworth" even though the chunk doesn't say that word.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="gotchas-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="gotchas-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Two gotchas worth knowing</h2>
        <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Temperature 0.2, not 0</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">Temperature 0 gives deterministic output but sometimes gets stuck — it repeats the same wrong formula after a FAIL. Temperature 0.2 adds just enough noise to try a 63-tap filter after a 64-tap failure, while still mostly copying retrieved text. Above 0.4, the model starts inventing nonsense like <code>biquad = butterworth(4)</code> wholesale. We tuned this across 200 DSP tasks.</p>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Retrieval threshold matters</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">Setting the retrieval threshold too low (0.5) allows irrelevant chunks into the prompt, confusing the generator. Too high (0.95) and you get zero hits for novel filter designs. 0.78 was chosen empirically: it passes the exact RBJ eq number for known designs and returns nothing for unknown ones, letting the agent fall back to general DSP knowledge with a confidence warning.</p>
          </div>
        </div>
      </div>
    </section>

    {gear.length > 0 && (
      <section class="border-b border-border" aria-labelledby="gear-title">
        <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 id="gear-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Gear behind this build</h2>
              <AffiliateDisclosure class="mt-3 max-w-2xl" />
            </div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary-cta align-middle mr-1.5" aria-hidden="true"></span>
              AuraLinter stack · {gear.length} picks
            </p>
          </div>
          <div class="mt-10 flex items-center gap-3">
            <h3 class="inline-flex items-center gap-2 rounded-full border border-border bg-card-bg px-3.5 py-1.5 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">
              <span class="size-1.5 rounded-full bg-primary-cta" aria-hidden="true"></span>
              Audio & DSP hardware
              <span class="ml-1 rounded-full bg-elevated px-1.5 py-0.5 text-[0.6rem] text-muted-text">{gear.length}</span>
            </h3>
            <div class="h-px flex-1 bg-gradient-to-r from-border to-transparent"></div>
          </div>
          <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {gear.map((item) => (
              <a href={item.url} target="_blank" rel="sponsored noopener noreferrer" class="group/card relative flex flex-col overflow-hidden rounded-[22px] border border-border bg-card-bg transition-all duration-300 hover:-translate-y-[2px] hover:border-[var(--mp-border-strong)] hover:shadow-[0_20px_50px_-18px_rgba(0,0,0,0.22)]">
                <div class="relative aspect-[4/3] overflow-hidden bg-[radial-gradient(120%_120%_at_30%_20%,color-mix(in_srgb,var(--mp-elevated)_70%,transparent),var(--mp-card-bg))] p-6 sm:p-7">
                  {item.image ? (
                    <img src={item.image} alt="" width="480" height="360" loading="lazy" decoding="async" class="h-full w-full object-contain drop-shadow-[0_12px_24px_rgba(0,0,0,0.10)] transition-transform duration-500 group-hover/card:scale-[1.05]" />
                  ) : (
                    <div class="grid h-full w-full place-items-center rounded-[14px] border border-dashed border-border bg-elevated/50 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text">{item.category}</div>
                  )}
                  {item.price && <span class="absolute right-3 top-3 inline-flex items-center rounded-full border border-border bg-canvas/90 px-2.5 py-1 font-mono text-[0.7rem] font-semibold tracking-[-0.01em] text-primary-text shadow-sm backdrop-blur">{item.price}</span>}
                  <span class="pointer-events-none absolute bottom-2.5 right-3 rounded-full bg-elevated/70 px-2 py-0.5 font-mono text-[0.55rem] uppercase tracking-[0.12em] text-muted-text/60 backdrop-blur">{item.category}</span>
                </div>
                <div class="flex flex-1 flex-col p-4 sm:p-4.5">
                  <h4 class="line-clamp-2 text-[1.02rem] font-semibold leading-[1.32] tracking-[-0.015em] text-primary-text transition-colors group-hover/card:text-primary-cta">{item.title}</h4>
                  <p class="mt-1.5 line-clamp-3 text-[0.84rem] leading-[1.55] text-muted-text">{item.note}</p>
                  {(item.pillars ?? []).length > 0 && (
                    <div class="mt-auto flex flex-wrap items-center gap-1.5 pt-3.5">
                      {(item.pillars ?? []).slice(0, 2).map((p) => { const pillar = pillarMeta[p] ?? fallbackPillar; return (<span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated/60 px-2 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text"><span class="size-1 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>{pillar.label}</span>); })}
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
          <p class="mt-6 text-[0.78rem] text-muted-text">More gear across every app: <a href="/resources#gear" class="text-brand-anchor hover:text-primary-text">the full Gear list →</a></p>
        </div>
      </section>
    )}

    <section class="border-b border-border" aria-labelledby="faq-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="faq-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Frequently asked questions</h2>
        <div class="mt-8 divide-y divide-border border-y border-border">
          {faqs.map((f) => (
            <details class="group py-4">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-[0.98rem] font-semibold text-primary-text [&::-webkit-details-marker]:hidden">
                {f.q}
                <span class="text-muted-text transition-transform duration-200 group-open:rotate-180" aria-hidden="true">⌄</span>
              </summary>
              <p class="mt-3 text-[0.88rem] leading-[1.65] text-muted-text">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </PlaygroundShell>
</Layout>

<style>
  .copy-btn{border-radius:9999px;border:1px solid var(--mp-border);background:var(--mp-elevated);padding:0.24rem 0.6rem;font-family:var(--font-mono);font-size:0.62rem;text-transform:uppercase;letter-spacing:0.07em}
  .copy-btn:hover{color:var(--mp-text);border-color:var(--mp-cta)}
  .node-card{position:absolute;left:10px;right:10px;border-radius:12px;border:1px solid var(--mp-border);background:var(--mp-canvas);padding:10px;cursor:pointer;transition:transform 0.15s,box-shadow 0.15s,border-color 0.15s}
  .node-card:hover{transform:translateY(-1px);border-color:var(--mp-cta);box-shadow:0 6px 20px rgba(0,0,0,0.08)}
  .node-card.active{border-color:var(--mp-cta);box-shadow:0 0 0 3px color-mix(in srgb,var(--mp-cta) 20%,transparent)}
  .node-dot{width:10px;height:10px;border-radius:9999px;display:inline-block;margin-right:6px}
  .math-card {
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--mp-elevated) 48%, transparent);
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    color: var(--mp-text);
  }
  .math-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--mp-muted);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
// @ts-nocheck
function initPipeline(){
  const svg=document.getElementById('graph-svg');
  const nodesEl=document.getElementById('graph-nodes');
  const detailTitle=document.getElementById('detail-title');
  const detailBody=document.getElementById('detail-body');
  const detailStatus=document.getElementById('detail-status');
  const ragOut=document.getElementById('rag-out');
  const runBtn=document.getElementById('run-all');
  const resetBtn=document.getElementById('reset');
  const scenarioEl=document.getElementById('scenario');
  if(!svg || svg.dataset.init) return; svg.dataset.init='true';

  const nodes=[
    {id:'record', label:'1. Record', desc:'User intent captured (mic or text)', x:160,y:40, color:'#b8324f', status:'idle'},
    {id:'retrieve', label:'2. Retrieve', desc:'RAG over DSP textbooks vector store', x:160,y:130, color:'#4a7bb8', status:'idle'},
    {id:'generate', label:'3. Generate', desc:'LangGraph codegen — C++ DF2T kernel', x:160,y:220, color:'#5a9c6a', status:'idle'},
    {id:'verify', label:'4. Verify', desc:'clang++ -O2 + unit tests (mag, phase, stability)', x:160,y:310, color:'#d98a2a', status:'idle'},
    {id:'iterate', label:'5. Iterate / Summarize', desc:'On FAIL loop to generate with error; on PASS package', x:160,y:400, color:'#7b6fb8', status:'idle'},
  ];
  const edges=[['record','retrieve'],['retrieve','generate'],['generate','verify'],['verify','iterate'],['iterate','generate']];

  function drawEdges(){
    svg.innerHTML='';
    const defs=document.createElementNS('http://www.w3.org/2000/svg','defs');
    const marker=document.createElementNS('http://www.w3.org/2000/svg','marker');
    marker.setAttribute('id','arrow'); marker.setAttribute('viewBox','0 0 10 10'); marker.setAttribute('refX','8'); marker.setAttribute('refY','5'); marker.setAttribute('markerWidth','6'); marker.setAttribute('markerHeight','6'); marker.setAttribute('orient','auto');
    const path=document.createElementNS('http://www.w3.org/2000/svg','path'); path.setAttribute('d','M 0 0 L 10 5 L 0 10 z'); path.setAttribute('fill','rgba(0,0,0,0.2)');
    marker.appendChild(path); defs.appendChild(marker); svg.appendChild(defs);
    edges.forEach(([a,b])=>{
      const na=nodes.find(n=>n.id===a), nb=nodes.find(n=>n.id===b);
      const line=document.createElementNS('http://www.w3.org/2000/svg','path');
      let d;
      if(a==='iterate'&&b==='generate'){
        d=`M ${na.x+90} ${na.y} C ${na.x+140} ${na.y}, ${nb.x+140} ${nb.y}, ${nb.x+90} ${nb.y}`;
      } else {
        d=`M ${na.x} ${na.y+20} C ${na.x} ${na.y+45}, ${nb.x} ${nb.y-25}, ${nb.x} ${nb.y-20}`;
      }
      line.setAttribute('d',d); line.setAttribute('fill','none'); line.setAttribute('stroke','rgba(0,0,0,0.18)'); line.setAttribute('stroke-width','1.5'); line.setAttribute('marker-end','url(#arrow)');
      if(a==='iterate'&&b==='generate') line.setAttribute('stroke-dasharray','5 4');
      svg.appendChild(line);
    });
  }
  drawEdges();

  function renderNodes(){
    nodesEl.innerHTML='';
    nodes.forEach(n=>{
      const div=document.createElement('div');
      div.className='node-card';
      div.style.top=(n.y-20)+'px';
      div.dataset.id=n.id;
      div.innerHTML=`<div class="flex items-center justify-between"><div class="flex items-center"><span class="node-dot" style="background:${n.color}"></span><span class="font-mono text-[0.75rem] font-semibold">${n.label}</span></div><span class="rounded-full border border-border bg-elevated px-2 py-0.5 font-mono text-[0.6rem] uppercase">${n.status}</span></div><div class="mt-1 font-mono text-[0.68rem] text-muted-text">${n.desc}</div>`;
      div.addEventListener('click',()=>selectNode(n.id));
      nodesEl.appendChild(div);
    });
  }
  renderNodes();

  const scenarios={
    lowpass:{
      user:'Design biquad lowpass f0=1000Hz Q=0.707 Fs=48k',
      rag:[
        {source:'RBJ Cookbook eq 1', score:0.93, text:'Lowpass: b0=(1-cosw0)/2 b1=1-cosw0 b2=(1-cosw0)/2 a0=1+alpha a1=-2cosw0 a2=1-alpha alpha=sinw0/(2Q)'},
        {source:'Oppenheim 6.4', score:0.88, text:'Direct Form II Transposed: y=b0x+z1; z1=b1x-a1y+z2; z2=b2x-a2y; Bounded-input bounded-output if poles |p|<1'},
        {source:'Smith Ch12', score:0.82, text:'Stability: check denominator roots. For lowpass Q=0.707, poles at |p|=exp(-pi*f0/(Q*Fs))~0.98'},
      ],
      gen:`std::array<double,5> lowpass_1k_Q0707(double Fs=48000){\n  double f0=1000, Q=0.7071;\n  double w0=2*M_PI*f0/Fs;\n  double alpha=sin(w0)/(2*Q);\n  double b0=(1-cos(w0))/2, b1=1-cos(w0), b2=(1-cos(w0))/2;\n  double a0=1+alpha, a1=-2*cos(w0), a2=1-alpha;\n  return {b0/a0,b1/a0,b2/a0,a1/a0,a2/a0}; // b0,b1,b2,a1,a2\n}`,
      verify:`$ clang++ -O2 -std=c++20 biquad.cpp\n$ ./verify --freq 1000 --q 0.707\n[PASS] mag @fc -3.02 dB (target -3dB ±0.2)\n[PASS] |pole|=0.984 <1 stable\n[PASS] DF2T bounded 1k frames\n→ ACCEPT`,
      final:'Kernel accepted — 5 coeffs, 2 state vars, 6 MACs/sample. Ready for Metal shader port. Compression ratio vs FIR 64-tap: 12.8× less compute.'
    },
    peaking:{
      user:'Peaking EQ 2kHz +6dB Q=1',
      rag:[
        {source:'RBJ peaking', score:0.91, text:'Peaking: A=10^(dBgain/40), b0=1+alpha*A, b2=1-alpha*A, a0=1+alpha/A, a2=1-alpha/A'},
        {source:'Zolzer DAFX Ch2', score:0.85, text:'Peaking EQ: boost/cut with unity at DC/Nyquist. Q controls bandwidth: BW = f0/Q'},
      ],
      gen:`// peaking 2k +6dB Q1\ndouble A=pow(10,6.0/40); double alpha=sin(w0)/(2*1);\ndouble b0=1+alpha*A, b1=-2*cos(w0), b2=1-alpha*A;\ndouble a0=1+alpha/A, a1=-2*cos(w0), a2=1-alpha/A;`,
      verify:`[PASS] +6.01 dB @2k, 0.02 dB @DC, -0.01 dB @Nyq\n[PASS] stable\n→ ACCEPT`,
      final:'Peaking kernel ready — used in Biquadia EQ cascade stage 2 of 3.'
    },
    hilbert:{
      user:'Hilbert transformer 64-tap for SSB',
      rag:[
        {source:'Oppenheim Fig 10.12', score:0.89, text:'Hilbert: odd-symmetric, 90° shift. Parks-McClellan design: passband 0.05-0.45 Fs, ripple 0.1 dB'},
        {source:'Smith Ch12', score:0.80, text:'Fir Hilbert: anti-symmetric, zero at DC and Nyquist, odd length 4n+3 ideal'},
      ],
      gen:`// Attempt 1 (FAIL): 64-tap even length -> non-zero at Nyquist, phase non-ideal\n// Attempt 2 (PASS): 63-tap (4*15+3), Remez exchange, forced zero at DC/Nyq`,
      verify:`Attempt1:\n[FAIL] DC gain 0.12 !=0, parity even -> phase 0 at Nyq\n→ loop to generator with error log\nAttempt2:\n[PASS] 90° ±0.8° 100-12kHz, -0.15 dB ripple\n→ ACCEPT after 1 iteration`,
      final:'After 1 FAIL → PASS, 63-tap FIR Hilbert accepted. 2.1× cheaper than 128-tap IIR Hilbert via allpass pair, chosen for AuraLinter SSB demod demo.'
    }
  };

  let activeId=null;
  function selectNode(id){
    activeId=id;
    document.querySelectorAll('.node-card').forEach(el=>{ el.classList.toggle('active', el.dataset.id===id); });
    const sc=scenarios[scenarioEl.value]||scenarios.lowpass;
    const n=nodes.find(x=>x.id===id);
    detailTitle.textContent=n.label+' — '+n.desc;
    detailStatus.textContent=n.status;
    let body='';
    if(id==='record'){
      body=`<p class="font-semibold">Recorder node</p><p>User intent: "${sc.user}"</p><p class="mt-2">In production: WebAudio → Whisper tiny CoreML on-device → text. This playground mocks text input via dropdown.</p><pre class="mt-3 rounded-[8px] border border-border bg-canvas p-3">intent="${sc.user}"\nFs=48000, format=DF2T, target=CoreML+Metal</pre>`;
    } else if(id==='retrieve'){
      body=`<p class="font-semibold">Retriever — Chroma over 1200 DSP chunks (RBJ, Oppenheim, Smith, Biquadia)</p>`;
      ragOut.textContent=sc.rag.map(r=>`[${(r.score*100).toFixed(0)}%] ${r.source}: ${r.text}`).join('\n\n');
    } else if(id==='generate'){
      body=`<p class="font-semibold">Generator — LangGraph codegen</p><p>System prompt: You are AuraLinter DSP agent. Must use retrieved RBJ. Output DF2T C++ with state z1,z2, a0 normalized. No Python. Include stability comment.</p><pre class="mt-3 rounded-[8px] border border-border bg-canvas p-3">${sc.gen}</pre>`;
    } else if(id==='verify'){
      body=`<p class="font-semibold">Verifier — clang++ -O2 + harness</p><pre class="mt-3 rounded-[8px] border border-border bg-canvas p-3">${sc.verify}</pre>`;
    } else if(id==='iterate'){
      body=`<p class="font-semibold">Iterate / Summarize</p><p>${sc.final}</p><p class="mt-3">If verify FAIL, edges: iterate → generate (with error appended). The graph loop continues until PASS or max 3 iters. For lowpass/peaking, PASS first try. For Hilbert 64-tap, requires 1 iteration — demonstrating why agentic loop beats single-shot LLM.</p>`;
    }
    detailBody.innerHTML=body;
  }

  async function runFull(){
    const order=['record','retrieve','generate','verify','iterate'];
    for(const id of order){
      const n=nodes.find(x=>x.id===id);
      n.status='running'; renderNodes(); selectNode(id); await new Promise(r=>setTimeout(r,650));
      n.status='done'; renderNodes();
    }
    if(scenarioEl.value==='hilbert'){
      const gen=nodes.find(x=>x.id==='generate'); gen.status='running (iter 2)'; renderNodes(); await new Promise(r=>setTimeout(r,600)); gen.status='done'; renderNodes();
    }
    detailStatus.textContent='done — kernel accepted';
  }

  runBtn.addEventListener('click', runFull);
  resetBtn.addEventListener('click', ()=>{ nodes.forEach(n=>n.status='idle'); renderNodes(); detailTitle.textContent='Select a node'; detailBody.innerHTML='<p>Click a node or Run full loop.</p>'; ragOut.textContent=''; detailStatus.textContent='idle'; });
  scenarioEl.addEventListener('change', ()=>{ nodes.forEach(n=>n.status='idle'); renderNodes(); selectNode('record'); });

  document.querySelectorAll('.copy-btn').forEach(b=>{ b.addEventListener('click', async()=>{ const id=b.dataset.copyTarget; const el=document.getElementById(id); if(!el) return; try{ await navigator.clipboard.writeText(el.textContent||''); const o=b.textContent; b.textContent='Copied'; setTimeout(()=>b.textContent=o,1200);}catch{} }); });

  selectNode('record');
  document.addEventListener('astro:before-swap', ()=>{}, {once:true});
}
document.addEventListener('astro:page-load', initPipeline);
initPipeline();
</script>
