<script>
import { setupHiDPI, resolveTheme, clearCanvas, drawText } from '../../lib/chart-core.ts';
import { websterHornArea } from '../../lib/acoustics.ts';

function initWaveguide() {
  const state: Record<string, any> = {
    type: 'exponential',
    d0: 25.4,
    param: 15,
    len: 150,
  };

  let _syncing = false;
  let _rafPending = false;

  const sliderEls: Record<string, HTMLInputElement> = {
    d0: document.getElementById('d0-slider') as HTMLInputElement,
    param: document.getElementById('param-slider') as HTMLInputElement,
    len: document.getElementById('len-slider') as HTMLInputElement,
  };
  const numEls: Record<string, HTMLInputElement> = {
    d0: document.getElementById('d0-num') as HTMLInputElement,
    param: document.getElementById('param-num') as HTMLInputElement,
    len: document.getElementById('len-num') as HTMLInputElement,
  };

  const canvas = document.getElementById('profile-canvas') as HTMLCanvasElement;

  let ctx: CanvasRenderingContext2D;
  let cw: number;
  let ch: number;

  function initCanvas() {
    const rect = canvas.getBoundingClientRect();
    cw = rect.width;
    ch = rect.height;
    ctx = setupHiDPI(canvas, cw, ch);
  }

  function compute() {
    const d0_m = state.d0 * 1e-3;
    const S0 = Math.PI * Math.pow(d0_m / 2, 2);
    const L_m = state.len * 1e-3;
    
    let paramVal = state.param;
    if (state.type === 'conical' || state.type === 'oblate-spheroidal') {
      paramVal = paramVal * (Math.PI / 180);
    }

    const S_mouth = websterHornArea(state.type as any, S0, paramVal, L_m);
    const d_mouth_m = 2 * Math.sqrt(S_mouth / Math.PI);
    
    let fc = 0;
    let dir = 0;
    
    if (state.type === 'exponential') {
      fc = (state.param * 343) / (4 * Math.PI);
      dir = 0;
    } else if (state.type === 'conical' || state.type === 'oblate-spheroidal') {
      fc = 0;
      dir = state.param * 2;
    }

    return { S0, L_m, paramVal, S_mouth, d_mouth_m, fc, dir };
  }

  function updateResults(r: ReturnType<typeof compute>) {
    document.getElementById('res-mouth-d')!.textContent = (r.d_mouth_m * 1000).toFixed(1);
    document.getElementById('res-mouth-area')!.textContent = (r.S_mouth * 10000).toFixed(1);
    
    if (state.type === 'exponential') {
      document.getElementById('res-fc')!.textContent = r.fc.toFixed(0);
      document.getElementById('res-directivity')!.textContent = '—';
    } else {
      document.getElementById('res-fc')!.textContent = '—';
      document.getElementById('res-directivity')!.textContent = r.dir.toFixed(0);
    }
  }

  function renderCanvas() {
    initCanvas();
    const theme = resolveTheme();
    clearCanvas(ctx, theme, cw, ch);

    const r = compute();
    
    const marginX = 40;
    const marginY = 40;
    const maxRadiusM = r.d_mouth_m / 2;
    
    const scaleX = (cw - 2 * marginX) / r.L_m;
    const maxScaleY = (ch - 2 * marginY) / (maxRadiusM * 2);
    const scale = Math.min(scaleX, maxScaleY);
    
    const drawW = r.L_m * scale;
    const cx = cw / 2;
    const cy = ch / 2;
    const startX = cx - drawW / 2;

    ctx.beginPath();
    ctx.strokeStyle = theme.muted;
    ctx.lineWidth = 1;
    ctx.setLineDash([5, 5]);
    ctx.moveTo(startX - 20, cy);
    ctx.lineTo(startX + drawW + 20, cy);
    ctx.stroke();
    ctx.setLineDash([]);

    const steps = 200;
    const ptsTop: [number, number][] = [];
    const ptsBot: [number, number][] = [];
    
    for (let i = 0; i <= steps; i++) {
      const x_m = (i / steps) * r.L_m;
      const Sx = websterHornArea(state.type as any, r.S0, r.paramVal, x_m);
      const rad_m = Math.sqrt(Sx / Math.PI);
      
      const px = startX + x_m * scale;
      ptsTop.push([px, cy - rad_m * scale]);
      ptsBot.push([px, cy + rad_m * scale]);
    }

    ctx.beginPath();
    ctx.moveTo(ptsTop[0][0], ptsTop[0][1]);
    for (let i = 1; i <= steps; i++) ctx.lineTo(ptsTop[i][0], ptsTop[i][1]);
    for (let i = steps; i >= 0; i--) ctx.lineTo(ptsBot[i][0], ptsBot[i][1]);
    ctx.closePath();
    ctx.fillStyle = theme.magColor + '15';
    ctx.fill();

    ctx.beginPath();
    ctx.strokeStyle = theme.magColor;
    ctx.lineWidth = 2.5;
    ctx.moveTo(ptsTop[0][0], ptsTop[0][1]);
    for (let i = 1; i <= steps; i++) ctx.lineTo(ptsTop[i][0], ptsTop[i][1]);
    ctx.stroke();

    ctx.beginPath();
    ctx.moveTo(ptsBot[0][0], ptsBot[0][1]);
    for (let i = 1; i <= steps; i++) ctx.lineTo(ptsBot[i][0], ptsBot[i][1]);
    ctx.stroke();

    ctx.fillStyle = theme.text;
    ctx.font = '11px ui-monospace, monospace';
    ctx.textAlign = 'center';
    
    const lY = cy + maxRadiusM * scale + 20;
    ctx.beginPath();
    ctx.strokeStyle = theme.muted;
    ctx.lineWidth = 1;
    ctx.moveTo(startX, lY - 5);
    ctx.lineTo(startX, lY + 5);
    ctx.moveTo(startX + drawW, lY - 5);
    ctx.lineTo(startX + drawW, lY + 5);
    ctx.moveTo(startX, lY);
    ctx.lineTo(startX + drawW, lY);
    ctx.stroke();
    drawText(ctx, `${state.len.toFixed(0)} mm`, cx, lY + 14, theme.text, 11);
    
    ctx.textAlign = 'right';
    drawText(ctx, `${state.d0.toFixed(1)}ø`, startX - 8, cy + 4, theme.text, 11);
    
    ctx.textAlign = 'left';
    drawText(ctx, `${(r.d_mouth_m * 1000).toFixed(1)}ø`, startX + drawW + 8, cy + 4, theme.text, 11);
  }

  function updateAll() {
    const r = compute();
    updateResults(r);
    renderCanvas();
  }

  function syncFromSlider(key: string) {
    if (_syncing) return;
    _syncing = true;
    const val = parseFloat(sliderEls[key].value);
    state[key] = val;
    numEls[key].value = val.toFixed(1);
    _syncing = false;
    scheduleUpdate();
  }

  function syncFromNum(key: string) {
    if (_syncing) return;
    _syncing = true;
    let val = parseFloat(numEls[key].value);
    if (isNaN(val)) val = 0;
    state[key] = val;
    sliderEls[key].value = String(val);
    numEls[key].value = val.toFixed(1);
    _syncing = false;
    scheduleUpdate();
  }

  function scheduleUpdate() {
    if (_rafPending) return;
    _rafPending = true;
    requestAnimationFrame(() => {
      _rafPending = false;
      updateAll();
    });
  }

  for (const key of Object.keys(sliderEls)) {
    sliderEls[key].addEventListener('input', () => syncFromSlider(key));
    numEls[key].addEventListener('change', () => syncFromNum(key));
  }

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.copyTarget;
      const el = document.getElementById(id ?? '');
      if (!el) return;
      try {
        const text = (el as HTMLElement).textContent ?? '';
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => { btn.textContent = orig; }, 1200);
      } catch {}
    });
  });

  const typeBtns = document.querySelectorAll('.type-btn');
  typeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      typeBtns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const newType = (btn as HTMLElement).dataset.type!;
      state.type = newType;
      
      const label = document.getElementById('param-label')!;
      if (newType === 'exponential') {
        label.innerHTML = `Flare m <span class="eyebrow">(1/m)</span>`;
        sliderEls['param'].min = '1';
        sliderEls['param'].max = '50';
        if (state.param > 50 || state.param < 1) {
          state.param = 15;
          sliderEls['param'].value = '15';
          numEls['param'].value = '15.0';
        }
      } else {
        label.innerHTML = `Half-Angle θ <span class="eyebrow">(deg)</span>`;
        sliderEls['param'].min = '5';
        sliderEls['param'].max = '85';
        if (state.param > 85 || state.param < 5) {
          state.param = 45;
          sliderEls['param'].value = '45';
          numEls['param'].value = '45.0';
        }
      }
      
      updateAll();
    });
  });

  window.addEventListener('resize', scheduleUpdate);

  updateAll();
  observeThemeChange();
}

let _themeRedraw: (() => void) | null = null;

function observeThemeChange() {
  const observer = new MutationObserver(() => {
    _themeRedraw?.();
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
}

document.addEventListener('astro:page-load', () => {
  initWaveguide();
  _themeRedraw = () => {
    const state = document.getElementById('profile-canvas');
    if (state) initWaveguide();
  };
});

initWaveguide();
_themeRedraw = () => initWaveguide();
</script>
