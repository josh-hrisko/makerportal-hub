---
import { Code } from 'astro:components';
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { affiliateLinks, resolveAffiliateLink } from '../../data/affiliate-links';

const gear = affiliateLinks
  .filter((link) => link.relatedTo?.includes('motionlink') || link.relatedTo?.includes('quaternion-euler-converter'))
  .map(resolveAffiliateLink);
const gearById = Object.fromEntries(gear.map((g) => [g.id, g]));

const title = 'Quaternion to Euler Angle Converter (and back) — Swift, verified round-trip | MakerPortal';
const description =
  `Convert quaternion attitude to yaw/pitch/roll and back, with a live 3D orientation preview and copyable Swift — the exact math from MotionLink\u2019s CMHeadphoneMotionManager handling.`;
const canonical = new URL('/playground/quaternion-euler-converter', Astro.site);

const quatToEulerSwift = `func yawPitchRoll(from q: CMQuaternion) -> (yaw: Double, pitch: Double, roll: Double) {
    let yaw = atan2(2 * (q.w * q.z + q.x * q.y), 1 - 2 * (q.y * q.y + q.z * q.z))
    let pitch = asin(max(-1, min(1, 2 * (q.w * q.y - q.z * q.x))))
    let roll = atan2(2 * (q.w * q.x + q.y * q.z), 1 - 2 * (q.x * q.x + q.y * q.y))
    return (yaw, pitch, roll)
}`;

const eulerToQuatSwift = `func quaternion(fromYaw yaw: Double, pitch: Double, roll: Double) -> CMQuaternion {
    let cy = cos(yaw * 0.5), sy = sin(yaw * 0.5)
    let cp = cos(pitch * 0.5), sp = sin(pitch * 0.5)
    let cr = cos(roll * 0.5), sr = sin(roll * 0.5)
    return CMQuaternion(
        x: sr * cp * cy - cr * sp * sy,
        y: cr * sp * cy + sr * cp * sy,
        z: cr * cp * sy - sr * sp * cy,
        w: cr * cp * cy + sr * sp * sy
    )
}`;

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Quaternion to Euler Angle Converter',
  url: canonical.toString(),
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any (browser-based)',
  description,
  isPartOf: { '@type': 'SoftwareApplication', name: 'MotionLink', url: 'https://makersportal.com/apps/motionlink' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Quaternion ↔ Euler Converter', item: canonical.toString() },
  ],
};

const faqs = [
  {
    q: 'What is the difference between a quaternion and Euler angles?',
    a: 'Euler angles (yaw, pitch, roll) describe an orientation as three sequential rotations around three axes — intuitive, but subject to gimbal lock at ±90° pitch. A unit quaternion describes the same orientation as a single axis and angle packed into four numbers — no gimbal lock, and it composes and interpolates cleanly, at the cost of not being directly human-readable.',
  },
  {
    q: 'Why do quaternions avoid gimbal lock?',
    a: 'Gimbal lock happens because Euler angles apply three rotations in sequence around three DIFFERENT axes that can become parallel (at pitch = ±90° for the yaw-pitch-roll convention used here), collapsing three degrees of freedom into two. A quaternion represents one rotation around one fixed axis directly — there is no sequence of dependent axes to collapse, so the singularity never occurs.',
  },
  {
    q: 'How do I convert a quaternion to Euler angles in Swift?',
    a: 'Use the yawPitchRoll(from:) function on this page: yaw = atan2(2(wz + xy), 1 − 2(y² + z²)), pitch = asin(clamp(2(wy − zx), −1, 1)), roll = atan2(2(wx + yz), 1 − 2(x² + y²)). The clamp on the pitch term is required — floating-point drift can push the asin argument outside [−1, 1] and produce NaN otherwise.',
  },
  {
    q: 'Why does CMHeadphoneMotionManager attitude drift or reset unexpectedly?',
    a: "CMHeadphoneMotionManager's reference frame is entirely relative, not gravity/north-referenced — whatever orientation the headphones are in when you call startDeviceMotionUpdates becomes the implicit zero point. There is no absolute frame to reset to; the practical fix is a manual recenter (capture the current attitude as a baseline offset on a user action, then subtract it from every subsequent reading). See the MotionLink field note linked below for the full writeup.",
  },
  {
    q: 'Why must a quaternion be a unit quaternion?',
    a: 'A quaternion only represents a pure rotation — no scaling — when x² + y² + z² + w² = 1. An un-normalized quaternion still encodes a valid rotation axis and angle, but applying it directly (e.g. to a rotation matrix) introduces scaling artifacts, which is why every conversion on this page normalizes the input first.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>

  <PlaygroundShell
    title="Quaternion ↔ Euler Converter"
    lead="Convert quaternion attitude to yaw/pitch/roll and back, both directions, live. Same round-trip-verified formulas — including the gimbal-lock clamp — as MotionLink's CMHeadphoneMotionManager handling."
    pillarHint="ios-craft"
    isGrounded={true}
    relatedApp="MotionLink"
    relatedAppUrl="https://makersportal.com/apps/motionlink"
    relatedFieldNote="motionlink-headphone-motion-api"
  >
    <section class="border-b border-border" aria-labelledby="preview-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="preview-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Live preview</h2>
        <p class="max-w-2xl text-[0.95rem] text-muted-text">
          Sculpted-head preview — a real head model finished in an openly synthetic brand-blue, facing you by default, driven by whichever panel you last edited. The color is deliberate: a realistic skin tone on a real head edges toward uncanny, while an obviously fake one reads as a stylized figure instead. The face tilts and dips as you yaw and pitch; the ears and neckline bank clearly as you roll — a head is naturally asymmetric front-to-back (nose vs. occiput) and top-to-bottom (crown vs. neck), so roll reads at a glance without needing a painted stripe or a color-coded marker. The starting view is <strong>180° yaw</strong> so the face reads immediately; at the mathematical <strong>0°</strong> you'd instead be looking from directly behind the head — X forward (face, red axis arrow), Y left (green), Z up (blue axis arrow, unrelated to the head's own color). The rotation matrix is built <strong>directly from the quaternion</strong> — no intermediate Euler decomposition. Drag left/right to yaw, up/down to pitch. Hold <strong>Shift</strong> to roll around the head's own nose-to-back axis, no matter how it's currently pitched or yawed.
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-3">
          <p id="preview-source" class="font-mono text-[0.72rem] uppercase tracking-[0.1em] text-muted-text/70">From Quaternion → Euler panel</p>
          <button type="button" id="btn-reset-zero" class="rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.68rem] uppercase tracking-[0.08em] text-muted-text hover:border-primary-cta hover:text-primary-text">Reset to 0°</button>
          <button type="button" id="btn-reset-face" class="rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.68rem] uppercase tracking-[0.08em] text-muted-text hover:border-primary-cta hover:text-primary-text">Reset to face (180°)</button>
          <button type="button" id="btn-reset-sample" class="rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.68rem] uppercase tracking-[0.08em] text-muted-text hover:border-primary-cta hover:text-primary-text">180° / -35° / 35° sample</button>
        </div>
        <div class="mt-10 flex flex-col items-center gap-10 lg:flex-row lg:justify-center lg:items-start">
          <div class="flex flex-col items-center gap-3">
            <div class="quat-canvas-wrap" aria-hidden="true">
              <canvas id="quat-canvas" width="520" height="440"></canvas>
            </div>
            <p class="text-center text-[0.72rem] text-muted-text">3D model: <a href="https://sketchfab.com/3d-models/practice-head-sculpt-d8a4e76948b54b978fc8640040f529b9" target="_blank" rel="noopener noreferrer" class="text-brand-anchor hover:text-primary-text">"Practice Head Sculpt"</a> by OverlyWiseBat, via Sketchfab.</p>
          </div>
          <dl class="grid grid-cols-3 gap-6 font-mono text-center sm:gap-10" aria-live="polite">
            <div>
              <dt class="text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Yaw · Z</dt>
              <dd id="preview-yaw" class="mt-1 min-w-[8ch] text-[1.4rem] font-semibold text-primary-text">0.00°</dd>
            </div>
            <div>
              <dt class="text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Pitch · Y</dt>
              <dd id="preview-pitch" class="mt-1 min-w-[8ch] text-[1.4rem] font-semibold text-primary-text">0.00°</dd>
            </div>
            <div>
              <dt class="text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Roll · X</dt>
              <dd id="preview-roll" class="mt-1 min-w-[8ch] text-[1.4rem] font-semibold text-primary-text">0.00°</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="converters-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="converters-title" class="sr-only">Converters</h2>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div class="rounded-[20px] border border-border bg-card-bg p-6 sm:p-7">
            <h3 class="text-[1.05rem] font-semibold text-primary-text">Quaternion → Euler</h3>
            <p class="mt-1 text-[0.82rem] leading-[1.5] text-muted-text">Same as <code>yawPitchRoll(from:)</code> below. Arbitrary input is auto-normalized to unit length first.</p>
            <div class="mt-5 grid grid-cols-2 gap-4">
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">x</span>
                <input type="number" step="0.001" id="q-x" value="0" class="tool-input" />
              </label>
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">y</span>
                <input type="number" step="0.001" id="q-y" value="0" class="tool-input" />
              </label>
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">z</span>
                <input type="number" step="0.001" id="q-z" value="1" class="tool-input" />
              </label>
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">w</span>
                <input type="number" step="0.001" id="q-w" value="0" class="tool-input" />
              </label>
            </div>
            <p id="q-norm-note" class="mt-3 text-[0.72rem] text-muted-text">Magnitude: 1.0000 (already unit length)</p>
            <div class="mt-5 grid grid-cols-3 gap-4 border-t border-border pt-5 font-mono" aria-live="polite">
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">Yaw</p>
                <p id="q-yaw" class="mt-1 text-[1.1rem] font-semibold text-primary-text">0.00°</p>
              </div>
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">Pitch</p>
                <p id="q-pitch" class="mt-1 text-[1.1rem] font-semibold text-primary-text">0.00°</p>
              </div>
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">Roll</p>
                <p id="q-roll" class="mt-1 text-[1.1rem] font-semibold text-primary-text">0.00°</p>
              </div>
            </div>
          </div>

          <div class="rounded-[20px] border border-border bg-card-bg p-6 sm:p-7">
            <h3 class="text-[1.05rem] font-semibold text-primary-text">Euler → Quaternion</h3>
            <p class="mt-1 text-[0.82rem] leading-[1.5] text-muted-text">The reverse direction — <code>quaternion(fromYaw:pitch:roll:)</code> below. Degrees in, unit quaternion out.</p>
            <div class="mt-5 grid grid-cols-3 gap-4">
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">Yaw°</span>
                <input type="number" step="0.1" id="e-yaw" value="180" class="tool-input" />
              </label>
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">Pitch°</span>
                <input type="number" step="0.1" id="e-pitch" value="0" class="tool-input" />
              </label>
              <label class="block">
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-muted-text">Roll°</span>
                <input type="number" step="0.1" id="e-roll" value="0" class="tool-input" />
              </label>
            </div>
            <div class="mt-8 grid grid-cols-4 gap-3 border-t border-border pt-5 font-mono" aria-live="polite">
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">x</p>
                <p id="e-x" class="mt-1 text-[0.95rem] font-semibold text-primary-text">0.0000</p>
              </div>
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">y</p>
                <p id="e-y" class="mt-1 text-[0.95rem] font-semibold text-primary-text">0.0000</p>
              </div>
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">z</p>
                <p id="e-z" class="mt-1 text-[0.95rem] font-semibold text-primary-text">0.0000</p>
              </div>
              <div>
                <p class="text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">w</p>
                <p id="e-w" class="mt-1 text-[0.95rem] font-semibold text-primary-text">0.0000</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="math-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="math-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">The math and physics, in full</h2>
        <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">Everything above runs on four numbers. This section works through what those four numbers actually mean, why the three-number alternative (yaw/pitch/roll) has a hard mathematical failure mode, and why rotation order isn't a stylistic choice — it changes the answer, which is exactly the bug this page's own drag interaction had until it didn't (see the callout below).</p>

        <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center">
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">What a quaternion actually is</h3>
            <p class="mt-3 text-[0.92rem] leading-[1.7] text-muted-text">Pick any axis in 3D space — a unit vector <code>(aₓ, a_y, a_z)</code> — and an angle <code>θ</code> to rotate around it. Every possible 3D rotation can be described exactly this way (this is <strong class="text-primary-text">Euler's rotation theorem</strong>), and a unit quaternion is just that axis and angle, repackaged into four numbers:</p>
            <div class="mt-5 math-card">
              <p class="math-label">Axis–angle form</p>
              <p class="mt-2">q = ( aₓ·sin(θ/2), a_y·sin(θ/2), a_z·sin(θ/2), cos(θ/2) )</p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">This is exactly <code>quatFromAxisAngle()</code> in the script above — the same formula behind every drag on the 3D preview, and the formula CoreMotion's sensor fusion uses internally to hand you <code>attitude.quaternion</code>. If you're reading attitude from your own hardware instead of CoreMotion, an <a href={gearById['mpu9250-imu']?.url} target="_blank" rel="sponsored noopener noreferrer" class="text-brand-anchor hover:text-primary-text">MPU9250 breakout</a>'s onboard DMP outputs the identical shape of data — a unit quaternion, straight off the sensor.</p>
            </div>
            <div class="mt-4 math-card">
              <p class="math-label">Unit constraint</p>
              <p class="mt-2">x² + y² + z² + w² = 1</p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">A quaternion only represents a pure rotation — no stretching, no scaling — when it has unit length. That's why every conversion above normalizes first, and why an un-normalized <code>(x, y, z, w)</code> pasted into the Quaternion → Euler panel gets rescaled before anything else happens to it.</p>
            </div>
          </div>
          <div class="rounded-[20px] border border-border bg-card-bg p-6">
            <svg viewBox="0 0 320 260" role="img" aria-labelledby="axisangle-svg-title" class="mx-auto w-full max-w-[320px]">
              <title id="axisangle-svg-title">Diagram of a rotation axis a with rotation angle theta around it</title>
              <ellipse cx="160" cy="192" rx="108" ry="34" fill="none" stroke="var(--mp-border)" stroke-width="1.5" stroke-dasharray="4 4" />
              <path d="M 268 192 A 108 34 0 0 1 214.6 220.6" fill="none" stroke="#CE445D" stroke-width="2.5" />
              <path d="M 214.6 220.6 l 10.8 -1.4 l -3.6 10.4 z" fill="#CE445D" />
              <text x="238" y="248" text-anchor="middle" font-family="var(--font-mono)" font-size="15" fill="#CE445D">θ</text>
              <line x1="160" y1="192" x2="160" y2="38" stroke="#3E6C99" stroke-width="3" />
              <path d="M 160 38 l -9 16 l 18 0 z" fill="#3E6C99" />
              <text x="176" y="46" font-family="var(--font-mono)" font-size="15" fill="#3E6C99">a</text>
              <circle cx="160" cy="192" r="3.5" fill="var(--mp-text)" />
              <path d="M 100 176 A 60 19 0 0 1 130 168" fill="none" stroke="var(--mp-muted)" stroke-width="1.5" marker-end="url(#arrow-muted)" />
              <defs>
                <marker id="arrow-muted" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
                  <path d="M0,0 L8,4 L0,8 z" fill="var(--mp-muted)" />
                </marker>
              </defs>
              <text x="140" y="252" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--mp-muted)" letter-spacing="0.05em">ROTATION PLANE ⊥ a</text>
            </svg>
            <p class="mt-3 text-center text-[0.78rem] text-muted-text">The steel-blue arrow is the axis <code>a</code>; the plane it pierces is where the actual spinning happens, by angle <code>θ</code>.</p>
          </div>
        </div>

        <div class="mt-14 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center">
          <div class="rounded-[20px] border border-border bg-card-bg p-6 lg:order-2">
            <svg viewBox="0 0 460 180" role="img" aria-labelledby="gimbal-svg-title" class="mx-auto w-full max-w-[460px]">
              <title id="gimbal-svg-title">Two panels comparing three independent rotation rings versus gimbal lock at ninety degrees pitch, where the yaw and roll rings collapse onto the same axis</title>
              <g>
                <ellipse cx="115" cy="90" rx="88" ry="24" fill="none" stroke="#6f9ad4" stroke-width="2.5" />
                <ellipse cx="115" cy="90" rx="88" ry="24" fill="none" stroke="#6cba78" stroke-width="2.5" transform="rotate(62 115 90)" />
                <ellipse cx="115" cy="90" rx="88" ry="24" fill="none" stroke="#e07a7a" stroke-width="2.5" transform="rotate(124 115 90)" />
                <circle cx="115" cy="90" r="4" fill="var(--mp-text)" />
              </g>
              <g transform="translate(230,0)">
                <ellipse cx="115" cy="90" rx="88" ry="24" fill="none" stroke="#6cba78" stroke-width="2.5" transform="rotate(62 115 90)" />
                <ellipse cx="115" cy="90" rx="88" ry="24" fill="none" stroke="#6f9ad4" stroke-width="4" transform="rotate(124 115 90)" />
                <ellipse cx="115" cy="90" rx="95" ry="30" fill="none" stroke="#e07a7a" stroke-width="2.5" stroke-dasharray="7 5" transform="rotate(124 115 90)" />
                <circle cx="115" cy="90" r="4" fill="var(--mp-text)" />
              </g>
            </svg>
            <div class="mt-3 grid grid-cols-2 gap-3 text-center font-mono text-[0.68rem] uppercase tracking-[0.04em] text-muted-text">
              <p>pitch ≈ 0°<br />three independent axes</p>
              <p>pitch = 90°<br />yaw ≡ roll axis</p>
            </div>
            <p class="mt-3 text-center text-[0.78rem] text-muted-text">Blue = yaw ring, green = pitch ring, red = roll ring. At 90° pitch the blue and red rings become the same physical ring (the dashed red ring traces the same axis as the solid blue one, just slightly larger so both remain visible) — one degree of freedom is gone.</p>
          </div>
          <div class="lg:order-1">
            <h3 class="text-[1.15rem] font-[650] text-primary-text">Why Euler angles break: gimbal lock</h3>
            <p class="mt-3 text-[0.92rem] leading-[1.7] text-muted-text">Yaw/pitch/roll rotate around three axes in sequence — yaw around <strong class="text-primary-text">Z</strong>, then pitch around the <em>new</em> <strong class="text-primary-text">Y</strong>, then roll around the <em>newest</em> <strong class="text-primary-text">X</strong>. That's the intuitive part. The failure shows up when the middle rotation (pitch) reaches ±90°: at that exact angle, the first and third rotation axes swing around to become parallel, and the system loses a degree of freedom — yaw and roll now spin the craft around the <em>same</em> physical axis, so only their difference is recoverable, not the two angles individually.</p>
            <div class="mt-5 math-card">
              <p class="math-label">Verified, not asserted</p>
              <p class="mt-2 text-[0.8rem] leading-[1.6]">(yaw 30°, pitch 90°, roll 0°) → same quaternion as (yaw 50°, pitch 90°, roll 20°) → same quaternion as (yaw 0°, pitch 90°, roll −30°)</p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">All three have <code>yaw − roll = 30°</code> and produce the identical <code>(x, y, z, w)</code> to six decimal places — try it in the Euler → Quaternion panel above. This is the exact singularity the <code>asin</code> clamp in the gotchas below is guarding against: <code>pitch = 90°</code> is precisely where the clamp's domain edge lives.</p>
            </div>
          </div>
        </div>

        <div class="mt-14">
          <h3 class="text-[1.15rem] font-[650] text-primary-text">Composing rotations: why multiplication order matters</h3>
          <p class="mt-3 max-w-3xl text-[0.92rem] leading-[1.7] text-muted-text">Quaternions combine by the <strong class="text-primary-text">Hamilton product</strong> — quaternion multiplication, not the dot or cross product. It's associative, but <strong class="text-primary-text">not commutative</strong>: <code>q₁⊗q₂ ≠ q₂⊗q₁</code> in general. That's not a footnote — it's the difference between rotating around a <em>fixed world axis</em> and rotating around the object's <em>own current axis</em>, and mixing them up is a real, easy-to-miss bug, not a hypothetical one.</p>
          <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="math-card">
              <p class="math-label">Hamilton product</p>
              <p class="mt-2 text-[0.82rem] leading-[1.7]">w = a_w·b_w − a·b (vector part)<br />v = a_w·b + b_w·a + a×b</p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">Exactly <code>quatMul()</code> above. <code>quatMul(delta, current)</code> applies <code>delta</code> in the fixed world frame (pre-multiply); <code>quatMul(current, delta)</code> applies it in the object's own current local frame (post-multiply).</p>
            </div>
            <div class="math-card">
              <p class="math-label">A real bug this caused</p>
              <p class="mt-2 text-[0.8rem] leading-[1.6]">Craft yawed 40° + pitched 25°, then rolled by <code>quatFromAxisAngle([1,0,0], 0.6)</code>:</p>
              <p class="mt-2 font-mono text-[0.78rem]">pre-multiply → nose moves <span class="text-primary-cta">0.4254</span><br />post-multiply → nose moves <span class="text-primary-cta">0.0000</span></p>
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">A true roll should never move the nose. The 3D preview's shift-drag used the wrong order until this session — see <code>docs/DECISIONS.md</code> D-020 for the full numeric write-up.</p>
            </div>
          </div>
        </div>

        <div class="mt-14 overflow-x-auto">
          <h3 class="text-[1.15rem] font-[650] text-primary-text">Euler angles vs. quaternions, side by side</h3>
          <table class="mt-5 w-full min-w-[560px] border-collapse text-[0.85rem]">
            <thead>
              <tr class="border-b border-border text-left font-mono text-[0.65rem] uppercase tracking-[0.1em] text-muted-text">
                <th class="py-2 pr-4">Property</th>
                <th class="py-2 pr-4">Euler angles (yaw/pitch/roll)</th>
                <th class="py-2">Unit quaternion</th>
              </tr>
            </thead>
            <tbody class="text-muted-text">
              <tr class="border-b border-border">
                <td class="py-3 pr-4 font-semibold text-primary-text">Storage</td>
                <td class="py-3 pr-4">3 numbers</td>
                <td class="py-3">4 numbers (1 redundant, via the unit constraint)</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-3 pr-4 font-semibold text-primary-text">Gimbal lock</td>
                <td class="py-3 pr-4">Yes — at pitch = ±90° for this ZYX convention</td>
                <td class="py-3">No singularities anywhere</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-3 pr-4 font-semibold text-primary-text">Composing two rotations</td>
                <td class="py-3 pr-4">Multiply 3×3 matrices, or re-derive new angles — order-sensitive and easy to get backwards</td>
                <td class="py-3">One Hamilton product — order still matters, but it's one explicit operation, not implicit in a matrix chain</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-3 pr-4 font-semibold text-primary-text">Smooth interpolation</td>
                <td class="py-3 pr-4">Naively interpolating each angle can take the long way round or pass through gimbal lock</td>
                <td class="py-3">Slerp gives constant angular velocity along the shortest path — the standard choice for animation and sensor fusion</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 font-semibold text-primary-text">Human-readable</td>
                <td class="py-3 pr-4">Yes — this is why the panels above show yaw/pitch/roll, not raw <code>(x, y, z, w)</code></td>
                <td class="py-3">Not directly — hence this whole page</td>
              </tr>
            </tbody>
          </table>
          <p class="mt-4 text-[0.8rem] text-muted-text">In practice: sensors and physics engines compute and store quaternions (CoreMotion's <code>attitude.quaternion</code> included) because they're numerically well-behaved; humans and UI sliders think in yaw/pitch/roll. This page — and MotionLink's own conversion function — exists at exactly that boundary.</p>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="gotchas-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="gotchas-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Two gotchas worth knowing</h2>
        <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Gimbal-lock clamp</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">Floating-point drift can push the pitch <code>asin</code> argument fractionally outside <code>[-1, 1]</code>, returning <code>NaN</code> that silently propagates downstream. Clamp it — the tool above does, try feeding it an extreme quaternion.</p>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Relative reference frame</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">On real hardware (<code>CMHeadphoneMotionManager</code>), the "zero" orientation is wherever the headphones were facing when tracking started — not gravity/north-referenced. This calculator has no such frame; that gotcha only applies on-device.</p>
          </div>
        </div>
        <p class="mt-6 text-[0.85rem] text-muted-text">Full writeup, including why this cost an afternoon on real AirPods Pro: <a href="/blog/motionlink-headphone-motion-api" class="text-brand-anchor hover:text-primary-text">the field note →</a></p>
      </div>
    </section>

    <section aria-labelledby="code-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="code-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Swift, both directions</h2>
        <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">Copy either function directly — this is the same code driving the converters above. The math ports directly to C/C++ too, if you're reading a quaternion off an <a href={gearById['mpu9250-imu']?.url} target="_blank" rel="sponsored noopener noreferrer" class="text-brand-anchor hover:text-primary-text">IMU breakout</a> on an <a href={gearById['elegoo-arduino-uno-r3']?.url} target="_blank" rel="sponsored noopener noreferrer" class="text-brand-anchor hover:text-primary-text">Arduino</a> instead of CoreMotion.</p>
        <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div>
            <div class="flex items-center justify-between">
              <p class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted-text">Quaternion → Euler</p>
              <button type="button" class="copy-btn" data-copy-target="code-quat-to-euler">Copy</button>
            </div>
            <div class="mt-2 overflow-x-auto rounded-[14px] [&_pre]:!m-0 [&_pre]:!rounded-[14px] [&_pre]:!p-4 [&_pre]:text-[0.8rem]">
              <Code id="code-quat-to-euler" code={quatToEulerSwift} lang="swift" theme="github-dark" />
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between">
              <p class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted-text">Euler → Quaternion</p>
              <button type="button" class="copy-btn" data-copy-target="code-euler-to-quat">Copy</button>
            </div>
            <div class="mt-2 overflow-x-auto rounded-[14px] [&_pre]:!m-0 [&_pre]:!rounded-[14px] [&_pre]:!p-4 [&_pre]:text-[0.8rem]">
              <Code id="code-euler-to-quat" code={eulerToQuatSwift} lang="swift" theme="github-dark" />
            </div>
          </div>
        </div>
      </div>
    </section>

    {gear.length > 0 && (
      <section class="border-b border-border" aria-labelledby="gear-title">
        <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
          <h2 id="gear-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Gear behind this build</h2>
          <AffiliateDisclosure class="mt-3 max-w-2xl" />
          <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
            {gear.map((item) => (
              <div class="flex items-start gap-3 rounded-[14px] border border-border bg-card-bg p-4">
                {item.image && (
                  <img src={item.image} alt="" width="48" height="48" loading="lazy" decoding="async" class="size-12 shrink-0 rounded-[8px] border border-border bg-card-bg object-contain p-1" />
                )}
                <div class="min-w-0 flex-1">
                  <a href={item.url} target="_blank" rel="sponsored noopener noreferrer" class="text-[0.92rem] font-semibold leading-[1.35] text-primary-text hover:text-primary-cta">{item.title} ↗</a>
                  <p class="mt-1 text-[0.78rem] leading-[1.5] text-muted-text">{item.note}</p>
                  {item.price && <span class="mt-2 inline-block rounded-full border border-border bg-elevated px-2 py-0.5 font-mono text-[0.65rem] text-primary-text">{item.price}</span>}
                </div>
