</style>

<script>
  import * as THREE from 'three';
  import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

  function initQuaternionPreview() {
    const pageCanvas = document.getElementById('quat-canvas') as HTMLCanvasElement | null;
    if (!pageCanvas || pageCanvas.dataset.initialized === 'true') return;
    pageCanvas.dataset.initialized = 'true';

    // Math core
    function clamp(n: number, lo: number, hi: number): number { return Math.max(lo, Math.min(hi, n)); }
    function yawPitchRoll(x: number, y: number, z: number, w: number) {
      const yaw = Math.atan2(2 * (w * z + x * y), 1 - 2 * (y * y + z * z));
      const pitch = Math.asin(clamp(2 * (w * y - z * x), -1, 1));
      const roll = Math.atan2(2 * (w * x + y * z), 1 - 2 * (x * x + y * y));
      return { yaw, pitch, roll };
    }
    function quaternionFromEuler(yaw: number, pitch: number, roll: number) {
      const cy = Math.cos(yaw * 0.5), sy = Math.sin(yaw * 0.5);
      const cp = Math.cos(pitch * 0.5), sp = Math.sin(pitch * 0.5);
      const cr = Math.cos(roll * 0.5), sr = Math.sin(roll * 0.5);
      return {
        x: sr * cp * cy - cr * sp * sy,
        y: cr * sp * cy + sr * cp * sy,
        z: cr * cp * sy - sr * sp * cy,
        w: cr * cp * cy + sr * sp * sy,
      };
    }

    const degFromRad = (rad: number) => (rad * 180) / Math.PI;
    const radFromDeg = (d: number) => (d * Math.PI) / 180;
    const fmtDeg = (r: number) => `${degFromRad(r).toFixed(2)}°`;
    const fmtNum = (n: number) => n.toFixed(4);

    type Quat = { x: number; y: number; z: number; w: number };
    function quatMul(a: Quat, b: Quat): Quat {
      return {
        w: a.w * b.w - a.x * b.x - a.y * b.y - a.z * b.z,
        x: a.w * b.x + a.x * b.w + a.y * b.z - a.z * b.y,
        y: a.w * b.y - a.x * b.z + a.y * b.w + a.z * b.x,
        z: a.w * b.z + a.x * b.y - a.y * b.x + a.z * b.w,
      };
    }
    function quatNormalize(q: Quat): Quat {
      const mag = Math.sqrt(q.x * q.x + q.y * q.y + q.z * q.z + q.w * q.w);
      if (mag < 1e-10) return { x: 0, y: 0, z: 0, w: 1 };
      return { x: q.x / mag, y: q.y / mag, z: q.z / mag, w: q.w / mag };
    }
    function quatFromAxisAngle(axis: [number, number, number], angle: number): Quat {
      const ha = angle * 0.5;
      const s = Math.sin(ha);
      return { x: axis[0] * s, y: axis[1] * s, z: axis[2] * s, w: Math.cos(ha) };
    }

    // Three.js Setup
    const CW = 520;
    const CH = 440;

    // Color-theory decision for this dark-gallery direction — reversed from
    // the previous two iterations: the glossy-white version read as plasticky
    // and the matte-terracotta version, while tasteful, still read as an
    // attempt at a real skin tone on a real head, edging toward uncanny. The
    // fix isn't a "more correct" realistic tone — it's the opposite: an
    // openly synthetic color (brand blue) so the object reads immediately as
    // a stylized figure, not a body. No accent materials: with the missile's
    // fins/ring and the earlier mannequin-head's AirPods/wordmark all
    // dropped, the head is the only element on the model. Background
    // #10141d is ~5% luminance; brand blue at ~40% luminance is still
    // comfortably brighter, just not straining to look "loudest."
    const BG_COLOR = 0x10141d;

    // Neutral tone mapping is the right choice for a lit product on a dark
    // background: it avoids the mid-tone crush that ACES introduces, keeping the
    // cream body predictable and bright without a milky haze.
    const renderer = new THREE.WebGLRenderer({ canvas: pageCanvas, antialias: true, alpha: false });
    renderer.setSize(CW, CH, false);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.NeutralToneMapping;
    renderer.toneMappingExposure = 1.0;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(BG_COLOR);

    const camera = new THREE.PerspectiveCamera(35, CW / CH, 0.1, 100);
    camera.position.set(-5.5, 0, 2);
    camera.up.set(0, 0, 1);
    camera.lookAt(0, 0, 0);

    // ── Dark-gallery lighting for a warm craft on a cool graphite field ──
    // RoomEnvironment IBL gives the clearcoat believable micro-reflections;
    // three directional lights provide the key/fill/rim sculpting on the body.
    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;
    pmremGenerator.dispose();

    const hemiLight = new THREE.HemisphereLight(0x9cb4d4, BG_COLOR, 0.55);
    scene.add(hemiLight);

    const keyLight = new THREE.DirectionalLight(0xfff0e0, 1.35);
    keyLight.position.set(4, -3, 5); // upper-front-right from the camera's POV
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0x7a9bd4, 0.55);
    fillLight.position.set(-3, 3, 2); // cool fill from the opposite side
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0xffe4c4, 0.7);
    rimLight.position.set(-2, 0, 4); // warm rim from behind/above
    scene.add(rimLight);

    const modelGroup = new THREE.Group();
    scene.add(modelGroup);

    // ═══════════════════════════════════════════════════════════════════
    //  Real sculpted-head asset via GLTFLoader, replacing the procedural
    //  mannequin-head geometry that preceded it (which read as "balloon-like"
    //  no matter how the proportions were tuned). Source: public/models/
    //  practice-head-sculpt.glb — a Sketchfab download ("Practice Head
    //  Sculpt" by OverlyWiseBat, Sketchfab Standard license — reviewed and
    //  confirmed usable here without attribution).
    //  Optimized via `gltf-transform optimize` (weld + join + meshopt
    //  simplify, ratio 0.1, error 0.003): 185k -> ~18k vertices, 7.9MB ->
    //  520KB, no visible quality loss at this render size (verified by
    //  side-by-side screenshot at 0°, 90° yaw profile, and a tight zoom on
    //  the nose/lips). Original untouched at /Users/josh/Downloads/
    //  practice_head_sculpt.glb if a different simplification pass is
    //  ever needed.
    //  +X nose/face · +Y left ear · +Z up, same convention as every model
    //  before it — the loaded mesh's own axes get remapped on load, below.
    // ═══════════════════════════════════════════════════════════════════

    // Plain MeshStandardMaterial, not MeshPhysicalMaterial — the earlier
    // porcelain/clearcoat look was the whole source of the "shiny" complaint,
    // so there's no clearcoat layer to carry over here, and no reason to pay
    // for MeshPhysicalMaterial's extra shader cost without using it.
    const bodyMat = new THREE.MeshStandardMaterial({
      color: 0x3e6c99,        // brand blue (BrandIconConcepts' "bl" grid tile) — deliberately unrealistic skin tone
      metalness: 0,
      roughness: 0.92,        // flat matte — a toy/figurine finish, not a glossy one
      envMapIntensity: 0.15,  // just enough IBL to read as lit, not reflective
    });

    const gltfLoader = new GLTFLoader();
    gltfLoader.load(
      '/models/practice-head-sculpt.glb',
      (gltf) => {
        const loaded = gltf.scene;

        // The source file ships flat-gray, untextured clay materials (a
        // sculpting-practice export), so swapping every mesh to bodyMat
        // isn't fighting existing texture data.
        loaded.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            (child as THREE.Mesh).material = bodyMat;
          }
        });

        // The source model is Y-up, Z-forward (determined by inspecting its
        // bounding box: the eye geometry sits at positive local Z, confirming
        // +Z is the face-forward direction — typical of an FBX-via-Sketchfab
        // export). Remap local (X, Y, Z) -> world (Y, Z, X) via an explicit
        // basis matrix so the model's forward becomes +X and up becomes +Z.
        // This is a best-effort first guess, not verified against a render
        // yet — check the screenshot before trusting the nose direction.
        const reorient = new THREE.Group();
        reorient.add(loaded);
        reorient.quaternion.setFromRotationMatrix(
          new THREE.Matrix4().makeBasis(
            new THREE.Vector3(0, 1, 0), // old local X (left-right) -> new Y
            new THREE.Vector3(0, 0, 1), // old local Y (up)         -> new Z
            new THREE.Vector3(1, 0, 0), // old local Z (forward)    -> new X
          )
        );

        // Center on the model's own bounding-box center so quaternion
        // rotation (applied to modelGroup, always around the world origin)
        // spins it in place instead of swinging it around empty space.
        const preCenterBox = new THREE.Box3().setFromObject(reorient);
        const center = preCenterBox.getCenter(new THREE.Vector3());
        reorient.position.sub(center);
        modelGroup.add(reorient);

        // Same "fill the frame without ever clipping" formula as every
        // previous model on this page (see git history for the full
        // derivation) — here the design radius comes directly from the
        // loaded geometry's own bounding sphere instead of a hand-derived
        // constant, since we don't know this mesh's proportions by hand.
        const sphere = new THREE.Box3().setFromObject(reorient).getBoundingSphere(new THREE.Sphere());
        const CAMERA_DISTANCE = camera.position.length();
        const HALF_FOV_RAD = THREE.MathUtils.degToRad(camera.fov / 2);
        const MAX_SAFE_RADIUS = CAMERA_DISTANCE * Math.sin(HALF_FOV_RAD);
        const FILL_FRACTION = 0.85;
        const MODEL_SCALE = (MAX_SAFE_RADIUS * FILL_FRACTION) / sphere.radius;
        modelGroup.scale.setScalar(MODEL_SCALE);

        render3D();
      },
      undefined,
      (error) => {
        console.error('Failed to load head model:', error);
      }
    );

    // --- World-fixed contact shadow: anchors the craft to the dark ground ---
    const shadowTexture = (() => {
      const canvas = document.createElement('canvas');
      const TEX = 128;
      canvas.width = TEX;
      canvas.height = TEX;
      const ctx = canvas.getContext('2d')!;
      const grad = ctx.createRadialGradient(TEX / 2, TEX / 2, 0, TEX / 2, TEX / 2, TEX / 2);
      grad.addColorStop(0, 'rgba(0,0,0,0.55)');
      grad.addColorStop(0.55, 'rgba(0,0,0,0.18)');
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, TEX, TEX);
      return new THREE.CanvasTexture(canvas);
    })();
    const shadowPlane = new THREE.Mesh(
      new THREE.PlaneGeometry(2.4, 2.4),
      new THREE.MeshBasicMaterial({
        map: shadowTexture,
        transparent: true,
        opacity: 0.65,
        depthWrite: false,
        side: THREE.DoubleSide,
      })
    );
    shadowPlane.rotation.x = -Math.PI / 2;
    shadowPlane.position.set(0, 0, -0.32);
    scene.add(shadowPlane);

    // Axes helpers (world-fixed, outside modelGroup so they stay as reference frame).
    const arrowX = new THREE.ArrowHelper(new THREE.Vector3(1, 0, 0), new THREE.Vector3(0, 0, 0), 1.55, 0xe07a7a, 0.14, 0.08);
    const arrowY = new THREE.ArrowHelper(new THREE.Vector3(0, 1, 0), new THREE.Vector3(0, 0, 0), 1.55, 0x6cba78, 0.14, 0.08);
    const arrowZ = new THREE.ArrowHelper(new THREE.Vector3(0, 0, 1), new THREE.Vector3(0, 0, 0), 1.55, 0x6f9ad4, 0.14, 0.08);
    scene.add(arrowX);
    scene.add(arrowY);
    scene.add(arrowZ);

    function render3D() {
      renderer.render(scene, camera);
    }

    // No intro "breathe" hint on this model: it animated a small procedural
    // nose-tip marker mesh from the earlier abstract designs, which isn't a
    // fit for a real sculpted head — dropped intentionally, not a placeholder.
    render3D();

    // DOM Elements
    const previewYaw = document.getElementById('preview-yaw') as HTMLElement;
    const previewPitch = document.getElementById('preview-pitch') as HTMLElement;
    const previewRoll = document.getElementById('preview-roll') as HTMLElement;
    const previewSource = document.getElementById('preview-source') as HTMLElement;

    const qx = document.getElementById('q-x') as HTMLInputElement;
    const qy = document.getElementById('q-y') as HTMLInputElement;
    const qz = document.getElementById('q-z') as HTMLInputElement;
    const qw = document.getElementById('q-w') as HTMLInputElement;
    const qYawOut = document.getElementById('q-yaw') as HTMLElement;
    const qPitchOut = document.getElementById('q-pitch') as HTMLElement;
    const qRollOut = document.getElementById('q-roll') as HTMLElement;
    const qNormNote = document.getElementById('q-norm-note') as HTMLElement;

    const eYaw = document.getElementById('e-yaw') as HTMLInputElement;
    const ePitch = document.getElementById('e-pitch') as HTMLInputElement;
    const eRoll = document.getElementById('e-roll') as HTMLInputElement;
    const eX = document.getElementById('e-x') as HTMLElement;
    const eY = document.getElementById('e-y') as HTMLElement;
    const eZ = document.getElementById('e-z') as HTMLElement;
    const eW = document.getElementById('e-w') as HTMLElement;

    let currentQuat: Quat = { x: 0, y: 0, z: 0, w: 1 };

    function updatePreview(q: Quat, source: string) {
      currentQuat = quatNormalize(q);
      
      // Update Three.js model rotation. Math convention is perfectly respected.
      modelGroup.quaternion.set(currentQuat.x, currentQuat.y, currentQuat.z, currentQuat.w);
      render3D();

      const { yaw, pitch, roll } = yawPitchRoll(currentQuat.x, currentQuat.y, currentQuat.z, currentQuat.w);
      previewYaw.textContent = fmtDeg(yaw);
      previewPitch.textContent = fmtDeg(pitch);
      previewRoll.textContent = fmtDeg(roll);
      if (previewSource) previewSource.textContent = `From ${source} panel`;
    }

    function recomputeFromQuaternion() {
      const x = parseFloat(qx.value) || 0;
      const y = parseFloat(qy.value) || 0;
      const z = parseFloat(qz.value) || 0;
      const w = parseFloat(qw.value) || 0;
      const mag = Math.sqrt(x * x + y * y + z * z + w * w);
      const norm = mag > 0 ? { x: x / mag, y: y / mag, z: z / mag, w: w / mag } : { x: 0, y: 0, z: 0, w: 1 };
      qNormNote.textContent = Math.abs(mag - 1) < 0.0005 ? `Magnitude: ${mag.toFixed(4)} (already unit length)` : `Magnitude: ${mag.toFixed(4)} — normalized before conversion`;
      const { yaw, pitch, roll } = yawPitchRoll(norm.x, norm.y, norm.z, norm.w);
      qYawOut.textContent = fmtDeg(yaw);
      qPitchOut.textContent = fmtDeg(pitch);
      qRollOut.textContent = fmtDeg(roll);
      updatePreview(norm, 'Quaternion → Euler');
    }

    [qx, qy, qz, qw].forEach((el) => el?.addEventListener('input', recomputeFromQuaternion));

    function recomputeFromEuler() {
      const yawDeg = parseFloat(eYaw.value) || 0;
      const pitchDeg = parseFloat(ePitch.value) || 0;
      const rollDeg = parseFloat(eRoll.value) || 0;
      const q = quaternionFromEuler(radFromDeg(yawDeg), radFromDeg(pitchDeg), radFromDeg(rollDeg));
      eX.textContent = fmtNum(q.x);
      eY.textContent = fmtNum(q.y);
      eZ.textContent = fmtNum(q.z);
      eW.textContent = fmtNum(q.w);
      updatePreview(q, 'Euler → Quaternion');
    }

    [eYaw, ePitch, eRoll].forEach((el) => el?.addEventListener('input', recomputeFromEuler));

    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = btn.dataset.copyTarget;
        const codeEl = targetId ? document.getElementById(targetId) : null;
        if (!codeEl) return;
        try {
          await navigator.clipboard.writeText(codeEl.textContent ?? '');
          const original = btn.textContent;
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = original; }, 1500);
        } catch {}
      });
    });

    const canvasWrap = pageCanvas.parentElement as HTMLElement;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let dragStartQuat: Quat = { x: 0, y: 0, z: 0, w: 1 };
    let rafPending = false;
    let latestDragEvent: PointerEvent | null = null;

    function processDragFrame() {
      rafPending = false;
      if (!isDragging || !latestDragEvent) return;
      const e = latestDragEvent;
      latestDragEvent = null;

      const dx = (e.clientX - dragStartX) * 0.008;
      const dy = (e.clientY - dragStartY) * 0.008;

      // CRITICAL: DRAG INTERACTION MAPPING
      // The camera is positioned behind the model (at -X, looking towards +X). You are looking at the TAIL.
      // The physical interaction model treats your mouse as dragging the visible tail:
      // 1. YAW (Horizontal drag): Uses `dx`. Right drag (dx > 0) produces a positive rotation around +Z (Up). This swings the nose left (+Y) and the tail right (-Y). Since you see the tail, dragging right visually moves the tail right.
      // 2. PITCH (Vertical drag): Uses `-dy`. Down drag (dy > 0) produces a negative rotation around +Y (Left). This pitches the nose down (-Z) and the tail up (+Z). So dragging down visually pulls the nose down.
      // 3. ROLL (Shift + Horizontal drag): Uses `dx`. Left drag (dx < 0) produces a negative rotation around +X (Forward), banking the left wing down (-Z).
      // Do NOT arbitrarily flip these signs; they are carefully calibrated for this tail-view perspective.
      //
      // YAW/PITCH are EXTRINSIC (world-frame): the delta is pre-multiplied
      // (quatMul(delta, dragStartQuat)), so `dx`/`dy` always rotate around the
      // fixed camera-relative axes — dragging right always yaws around the
      // screen's vertical, regardless of the craft's current attitude. This is
      // the arcball behavior that reads correctly no matter how the craft is
      // currently oriented.
      // ROLL is INTRINSIC (body-frame): the delta is post-multiplied
      // (quatMul(dragStartQuat, delta)), so the roll axis [1,0,0] is expressed
      // in the craft's OWN current local frame, not the world frame. This
      // makes shift-drag always spin the craft around its own current
      // nose-tail axis — true aeronautical roll — instead of tumbling around
      // a fixed world axis that no longer lines up with the nose once the
      // craft has been yawed/pitched away from 0°.
      let newQuat: Quat;
      if (e.shiftKey) {
        const rollQuat = quatFromAxisAngle([1, 0, 0], dx);
        newQuat = quatNormalize(quatMul(dragStartQuat, rollQuat));
      } else {
        const yawQuat = quatFromAxisAngle([0, 0, 1], dx);
        const pitchQuat = quatFromAxisAngle([0, 1, 0], -dy);
        const dragQuat = quatMul(yawQuat, pitchQuat);
        newQuat = quatNormalize(quatMul(dragQuat, dragStartQuat));
      }

      const { yaw, pitch, roll } = yawPitchRoll(newQuat.x, newQuat.y, newQuat.z, newQuat.w);
      eYaw.value = degFromRad(yaw).toFixed(1);
      ePitch.value = degFromRad(pitch).toFixed(1);
      eRoll.value = degFromRad(roll).toFixed(1);

      eX.textContent = fmtNum(newQuat.x);
      eY.textContent = fmtNum(newQuat.y);
      eZ.textContent = fmtNum(newQuat.z);
      eW.textContent = fmtNum(newQuat.w);

      qx.value = newQuat.x.toFixed(4);
      qy.value = newQuat.y.toFixed(4);
      qz.value = newQuat.z.toFixed(4);
      qw.value = newQuat.w.toFixed(4);
      const mag = Math.sqrt(newQuat.x ** 2 + newQuat.y ** 2 + newQuat.z ** 2 + newQuat.w ** 2);
      qNormNote.textContent = `Magnitude: ${mag.toFixed(4)} (already unit length)`;
      qYawOut.textContent = fmtDeg(yaw);
      qPitchOut.textContent = fmtDeg(pitch);
      qRollOut.textContent = fmtDeg(roll);

      updatePreview(newQuat, 'Drag interaction');
    }

    canvasWrap.addEventListener('pointerdown', (e) => {
      isDragging = true;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      dragStartQuat = { ...currentQuat };
      canvasWrap.setPointerCapture(e.pointerId);
    });

    canvasWrap.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      latestDragEvent = e;
      if (!rafPending) {
        rafPending = true;
        requestAnimationFrame(processDragFrame);
      }
    });

    function endQuaternionDrag(e: PointerEvent) {
      isDragging = false;
      if (canvasWrap.hasPointerCapture(e.pointerId)) canvasWrap.releasePointerCapture(e.pointerId);
    }

    canvasWrap.addEventListener('pointerup', endQuaternionDrag);
    canvasWrap.addEventListener('pointercancel', endQuaternionDrag);
    canvasWrap.addEventListener('lostpointercapture', () => { isDragging = false; });

    const btnResetZero = document.getElementById('btn-reset-zero') as HTMLButtonElement | null;
    const btnResetFace = document.getElementById('btn-reset-face') as HTMLButtonElement | null;
    const btnResetSample = document.getElementById('btn-reset-sample') as HTMLButtonElement | null;
    btnResetZero?.addEventListener('click', () => {
      eYaw.value = '0'; ePitch.value = '0'; eRoll.value = '0';
      recomputeFromEuler();
    });
    btnResetFace?.addEventListener('click', () => {
      eYaw.value = '180'; ePitch.value = '0'; eRoll.value = '0';
      recomputeFromEuler();
    });
    btnResetSample?.addEventListener('click', () => {
      eYaw.value = '180'; ePitch.value = '-35'; eRoll.value = '35';
      recomputeFromEuler();
    });

    recomputeFromEuler();
    recomputeFromQuaternion();
  }

  document.addEventListener('astro:page-load', initQuaternionPreview);
  initQuaternionPreview();
</script>
