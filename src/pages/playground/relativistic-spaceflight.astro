---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';
import { Code } from 'astro:components';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import Math from '../../components/Math.astro';
import { affiliateLinks, resolveAffiliateLink } from '../../data/affiliate-links';
import { pillarMeta, fallbackPillar } from '../../data/trends';

const title = 'Relativistic Starship Journey — 1g Flight, Time Dilation & Minkowski Diagram | MakerPortal';
const description =
  'Fly a starship at constant proper acceleration and watch special relativity unfold: ship time vs Earth time, Lorentz contraction, the relativistic Doppler shift of the cosmic microwave background, and a live Minkowski spacetime diagram of the hyperbolic worldline. Flip-and-burn trips to real destinations, computed exactly.';
const canonical = new URL('/playground/relativistic-spaceflight', Astro.site);
const gear = affiliateLinks
  .filter((link) => link.relatedTo?.includes('relativistic-spaceflight'))
  .map(resolveAffiliateLink)
  .sort((a, b) => a.title.localeCompare(b.title));


const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Relativistic Starship Journey',
  url: canonical.toString(),
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Any',
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'Relativistic Starship Journey', item: canonical.toString() },
  ],
};

const faqs = [
  {
    q: 'How long does it take to reach another star at 1g?',
    a: 'Because the ship accelerates the whole way (flipping to decelerate halfway), it approaches the speed of light and time dilation compresses the trip enormously for the crew. Proxima Centauri (4.24 light-years) takes about 3.6 years of ship time but roughly 5.9 years of Earth time. The galactic center, 26,000 light-years away, is about 20 ship-years — but ~26,000 Earth-years.',
  },
  {
    q: 'Why does the worldline curve toward the light cone?',
    a: 'On a Minkowski diagram (space horizontal, time vertical) a constant-proper-acceleration path is a hyperbola. As the ship gains speed its worldline tilts toward the 45° light cone but never crosses it — no amount of acceleration reaches c. The crew feels a steady 1g the entire time even as an outside observer sees them asymptotically approach light speed.',
  },
  {
    q: 'What happens to the cosmic microwave background at relativistic speed?',
    a: 'The isotropic 2.725 K background is beamed and Doppler-shifted. Directly ahead it blueshifts into a hot, bright spot (its temperature multiplied by the relativistic Doppler factor √((1+β)/(1−β))); directly behind it cools and reddens. At 0.99c the forward CMB peak shifts from the microwave band toward far-infrared and its apparent temperature climbs to tens of kelvin.',
  },
  {
    q: 'Is this simulation physically exact?',
    a: 'The special-relativistic kinematics are exact for a point ship under constant proper acceleration in flat spacetime: the hyperbolic worldline, time dilation, Lorentz contraction, and Doppler factor all come from closed-form equations. What it deliberately ignores is general relativity (no real gravity wells or cosmological expansion), the staggering fuel and energy such a flight would demand, and any redshift evolution of the background over cosmic timescales.',
  },
  {
    q: 'What is rapidity and why use it instead of velocity directly?',
    a: 'Rapidity φ = aτ/c is the natural velocity parameter in special relativity because it adds linearly: φ_total = φ₁ + φ₂. Velocity β = tanh(φ) saturates at 1, γ = cosh(φ), and the Lorentz transform becomes a hyperbolic rotation. At constant proper acceleration a, rapidity grows linearly with ship proper time τ — that simple relationship (φ = aτ/c) is why the hyperbolic worldline, time dilation, and distance formulas all simplify to clean sinh/cosh expressions. The script in src/lib/relativity.ts uses rapidity internally for all computations.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>

  <PlaygroundShell
    title="Relativistic Starship Journey"
    lead="Hold a constant proper acceleration — the steady push the crew feels — and special relativity does the rest. Watch ship time diverge from Earth time, the trip length Lorentz-contract, and the cosmic microwave background blaze into a hot forward spot, all traced on a live Minkowski spacetime diagram of the ship's hyperbolic worldline."
  >
    <section class="border-b border-border" aria-labelledby="flight-title">
      <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 lg:px-10">
        <h2 id="flight-title" class="sr-only">Flight console</h2>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-[340px_1fr]">
          <div class="rounded-[16px] border border-border bg-card-bg p-4">
            <h3 class="font-semibold text-[0.95rem]">Flight plan</h3>
            <label class="control-label mt-4">
              <span>Proper acceleration</span><output id="accel-out">1.00 g</output>
              <input id="accel-slider" type="range" min="0.1" max="3" step="0.05" value="1" />
            </label>
            <label class="mt-4 block">
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.08em] text-muted-text">Destination (flip-and-burn, arrive at rest)</span>
              <select id="dest-select" class="tool-input font-mono w-full">
                <option value="4.24">Proxima Centauri — 4.24 ly</option>
                <option value="8.6">Sirius — 8.6 ly</option>
                <option value="25.05">Vega — 25 ly</option>
                <option value="640">Betelgeuse — 640 ly</option>
                <option value="26000" selected>Galactic center — 26,000 ly</option>
                <option value="2537000">Andromeda galaxy — 2.54 Mly</option>
                <option value="46500000000">Edge of the observable universe — 46.5 Gly</option>
              </select>
            </label>

            <div class="mt-5 border-t border-border pt-4">
              <label class="control-label">
                <span>Scrub the journey (ship time)</span><output id="tau-out">0%</output>
                <input id="tau-slider" type="range" min="0" max="1000" step="1" value="0" />
              </label>
              <div class="mt-3 flex gap-2">
                <button type="button" id="play-btn" class="pill-btn">▶ Launch</button>
                <button type="button" id="reset-btn" class="pill-btn">Reset</button>
              </div>
            </div>

            <div class="mt-5 rounded-[12px] border border-border bg-elevated/40 p-3">
              <p class="font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">At this instant</p>
              <div class="mt-2 grid grid-cols-2 gap-x-3 gap-y-2 text-[0.82rem]">
                <div><span class="live-lab">velocity</span><br><span id="live-beta" class="live-val">0 c</span></div>
                <div><span class="live-lab">Lorentz γ</span><br><span id="live-gamma" class="live-val">1.00</span></div>
                <div><span class="live-lab">distance flown</span><br><span id="live-dist" class="live-val">0 ly</span></div>
                <div><span class="live-lab">CMB ahead</span><br><span id="live-cmb" class="live-val">2.7 K</span></div>
              </div>
            </div>
          </div>

          <div class="min-w-0 space-y-4">
            <div class="rounded-[16px] border border-border bg-card-bg p-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-muted-text">Minkowski diagram — Earth frame</p>
                <p class="font-mono text-[0.62rem] text-muted-text/80">space →, time ↑, light cone at 45°</p>
              </div>
              <canvas id="mink-canvas" width="820" height="440" aria-label="Minkowski spacetime diagram of the ship's hyperbolic worldline"></canvas>
            </div>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
              <div class="readout"><dt>Ship time (whole trip)</dt><dd id="ro-ship">—</dd></div>
              <div class="readout"><dt>Earth time (whole trip)</dt><dd id="ro-earth">—</dd></div>
              <div class="readout"><dt>Peak velocity</dt><dd id="ro-peakb">—</dd></div>
              <div class="readout"><dt>Peak Lorentz γ</dt><dd id="ro-peakg">—</dd></div>
              <div class="readout"><dt>Trip length (ship ruler, peak)</dt><dd id="ro-contract">—</dd></div>
              <div class="readout"><dt>CMB ahead at peak</dt><dd id="ro-cmbpeak">—</dd></div>
              <div class="readout"><dt>CMB peak wavelength ahead</dt><dd id="ro-wien">—</dd></div>
              <div class="readout"><dt>Turnaround (flip) at</dt><dd id="ro-flip">—</dd></div>
            </div>
            <p id="overflow-note" class="mt-3 text-[0.82rem] leading-[1.5] text-cta" style="display:none">
              This combination exceeds Float64 precision. The hyperbolic functions overflow above a rapidity of ~710. Reduce the distance or acceleration to bring the computation back within numerical range.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="method-title">
      <div class="mx-auto max-w-[62rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="method-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Method &amp; limitations</h2>
        <p class="mt-4 max-w-2xl text-[0.92rem] leading-[1.7] text-muted-text">
          With rapidity φ = a·τ/c accumulated over ship proper time τ, the exact relations are β = tanh φ, γ = cosh φ, Earth time t = (c/a)·sinh φ, and distance x = (c²/a)·(cosh φ − 1). A flip-and-burn trip accelerates for the first half of the coordinate distance and decelerates for the second, arriving at rest. The forward CMB temperature is the 2.725 K monopole times the relativistic Doppler factor √((1+β)/(1−β)); its peak wavelength follows from Wien's law.
        </p>
        <div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-semibold text-primary-text">What is exact</p>
            <p class="mt-2 text-[0.88rem] leading-[1.65] text-muted-text">The special-relativistic kinematics — hyperbolic worldline, time dilation, length contraction, and Doppler shift — are closed-form and exact for a point ship in flat spacetime under constant proper acceleration.</p>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-semibold text-primary-text">What it ignores</p>
            <p class="mt-2 text-[0.88rem] leading-[1.65] text-muted-text">No general relativity (no gravity wells, no cosmological expansion — so the Gly-scale trip is a flat-spacetime idealization), no fuel or energy budget (the real thing is prohibitive), and no cosmic evolution of the background over the journey.</p>
          </div>
        </div>
        <p class="mt-6 text-[0.82rem] leading-[1.6] text-muted-text/80">
          The kinematics live in <code class="text-primary-cta">src/lib/relativity.ts</code>, unit-tested against the hyperbolic identity (a·t/c)² − (a·x/c² + 1)² = −1, the β→c asymptote, and the known 4.24 ly / 1g flip-and-burn result (~3.6 ship-years, ~5.9 Earth-years).
        </p>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="anatomy-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="anatomy-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Anatomy of the flight console</h2>
        <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">One acceleration knob, seven destinations, a Minkowski diagram, and three live readouts — all driven by four hyperbolic functions. Here is exactly what each piece computes.</p>
        <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-2">
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">The relativistic kinematics engine</h3>
            <ol class="mt-5 space-y-4">
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">01</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Rapidity accumulator.</strong> The core of the computation is rapidity φ = aτ/c — it grows linearly with ship proper time τ. All other quantities derive from φ via hyperbolic trig: β = tanh φ (velocity / c), γ = cosh φ (Lorentz factor), ct = (c/a) · sinh φ (Earth time), x = (c²/a) · (cosh φ − 1) (distance traveled). No numerical integration — these are exact closed-form solutions for constant proper acceleration in flat spacetime.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">02</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Flip-and-burn trip.</strong> The ship accelerates at constant a for the first half of the coordinate distance, then flips 180° and decelerates for the second half, arriving at rest at the destination. The turnaround proper time τ_half is found by solving x(τ_half) = d/2 in closed form. The ship state function uses a mirrored time parameter for the deceleration phase: τ_effective = 2τ_half − τ.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">03</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">CMB Doppler shift.</strong> The forward CMB temperature is T = T₀ × √((1+β)/(1−β)), the relativistic Doppler factor. At β = 0.99, the factor is ~14.1 → T ≈ 38 K ahead. Peak wavelength follows Wien\'s law: λ_peak = 2.898 × 10⁻³ / T K·m. The script reads CMB_TEMPERATURE = 2.725 K from the relativity.ts library constant.</p>
              </li>
            </ol>
            <div class="mt-6 math-card">
              <p class="math-label">The hyperbolic worldline — why ct vs x is a hyperbola</p>
              <Math math="\left(\frac{a}{c^2}\,x + 1\right)^2 - \left(\frac{a}{c}\,t\right)^2 = 1" display class="mt-2" />
              <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">This is the invariant hyperbola: x = (c²/a)(cosh φ − 1), ct = (c/a) sinh φ. For any φ, (a·x/c² + 1)² − (a·t/c)² = cosh² φ − sinh² φ = 1. The light cone is the asymptote at 45°: x = ct where the hyperbola approaches but never reaches.</p>
            </div>
          </div>
          <div>
            <h3 class="text-[1.15rem] font-[650] text-primary-text">Minkowski diagram and live readouts</h3>
            <ol class="mt-5 space-y-4">
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">01</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Minkowski diagram.</strong> Canvas-drawn with space (light-years) horizontal and time (years) vertical — ct axis goes up. The light cone from the origin is a dashed 45° line. The worldline is drawn by sampling shipState(τ) at 400 evenly spaced proper times from 0 to total τ. The diagram uses coordinate time vs coordinate distance — not proper time — because the worldline is what an Earth observer would measure.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">04</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Line of simultaneity.</strong> A dashed CTA-colored line with slope β intersects the worldline at the current ship position. Points on this line are simultaneous in the ship\'s instantaneous rest frame. At high β, the line tilts dramatically — the ship\'s "now" slices through Earth time at a steep angle, which is why the twin paradox works.</p>
              </li>
              <li class="flex gap-3">
                <span class="font-mono text-[0.72rem] font-semibold text-primary-cta">05</span>
                <p class="text-[0.88rem] leading-[1.65] text-muted-text"><strong class="text-primary-text">Trip summary readouts.</strong> Ship time, Earth time, peak velocity, peak Lorentz factor, contracted trip length, peak CMB temperature and wavelength, and turnaround time. All are computed once at recompute() via the flipAndBurn function in relativity.ts — the scrubbing playback just reads the already-computed state from the closed-form formulas.</p>
              </li>
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="gotchas-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="gotchas-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Two gotchas worth knowing</h2>
        <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Float64 overflow at extreme rapidity</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">cosh(φ) and sinh(φ) overflow Float64 at φ ≈ 710. At 1g, this corresponds to τ ≈ 2.2 × 10¹⁰ seconds (~690 years) — well beyond any real mission but reachable with the "edge of observable universe" at 46.5 Gly. The trip to Andromeda (2.54 Mly) is well within range. When overflow occurs, the script displays an error banner and stops the diagram. The flipAndBurn function in relativity.ts checks Number.isFinite before returning.</p>
          </div>
          <div class="rounded-[16px] border border-border bg-elevated/40 p-5">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-primary-cta">Gly-scale trips ignore cosmological expansion</p>
            <p class="mt-2 text-[0.88rem] leading-[1.6] text-muted-text">The special-relativistic formulas assume flat, static spacetime. At 46.5 Gly, the universe has expanded significantly since the light we see was emitted — special relativity alone cannot describe it. General relativity and the FLRW metric are required. The edge-of-universe destination is included for scale comparison only: "how long would it take if spacetime were flat?" — the answer (ship time) is surprisingly short (~24 years at 1g) due to time dilation, but the Earth time (~46.5 billion years) shows how meaningless this question is in a real expanding universe.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-border" aria-labelledby="code-title">
      <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="code-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Copyable solver: constant proper acceleration in flat spacetime</h2>
        <p class="mt-3 max-w-2xl text-[0.95rem] text-muted-text">The closed-form kinematics powering every number on this page. Port to any language — the math is just sinh, cosh, tanh.</p>
        <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div>
            <div class="flex items-center justify-between"><p class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted-text">JavaScript/TypeScript — flight kinematics</p><button type="button" class="copy-btn" data-copy-target="code-rel">Copy</button></div>
            <div class="mt-2 overflow-x-auto rounded-[14px] [&_pre]:!m-0 [&_pre]:!rounded-[14px] [&_pre]:!p-4 [&_pre]:text-[0.78rem]">
              <Code id="code-rel" code={`export const C = 299792458; // m/s
export const G = 9.80665;   // standard gravity

export function gToMetric(g: number): number { return g * G; }

export function betaAtProperTime(a: number, tau: number): number {
  return Math.tanh(a * tau / C);
}

export function gammaAtProperTime(a: number, tau: number): number {
  return Math.cosh(a * tau / C);
}

export function coordinateTime(a: number, tau: number): number {
  return (C / a) * Math.sinh(a * tau / C);
}

export function distanceTraveled(a: number, tau: number): number {
  return (C * C / a) * (Math.cosh(a * tau / C) - 1);
}

export function cmbTemperatureAhead(beta: number): number {
  const CMB_T0 = 2.725; // K
  return CMB_T0 * Math.sqrt((1 + beta) / (1 - beta));
}

export function flipAndBurn(a: number, distance: number) {
  const tauHalf = (C / a) * Math.acosh(1 + (a * distance) / (2 * C * C));
  const totalTau = 2 * tauHalf;
  const totalCoordT = 2 * coordinateTime(a, tauHalf);
  const peakBeta = betaAtProperTime(a, tauHalf);
  const peakGamma = gammaAtProperTime(a, tauHalf);
  return { properTime: totalTau, coordinateTime: totalCoordT,
           turnaroundProperTime: tauHalf, peakBeta, peakGamma };
}`} lang="ts" theme="github-dark" />
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between"><p class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted-text">Constants and unit conversion</p><button type="button" class="copy-btn" data-copy-target="code-const">Copy</button></div>
            <div class="mt-2 overflow-x-auto rounded-[14px] [&_pre]:!m-0 [&_pre]:!rounded-[14px] [&_pre]:!p-4 [&_pre]:text-[0.78rem]">
              <Code id="code-const" code={`export const C = 299792458;               // speed of light, m/s
export const LIGHT_YEAR = 9.4607304725808e15;  // meters per light-year
export const JULIAN_YEAR = 31557600;            // seconds per Julian year
export const CMB_TEMPERATURE = 2.725;           // cosmic microwave background, K
export const WIEN_CONSTANT = 2.897771955e-3;    // Wien's displacement law, m·K

// Peak wavelength from Wien's law
function wienPeak(temperatureK: number): number {
  return WIEN_CONSTANT / temperatureK; // meters
}

// Example: Andromeda (2.54 Mly) at 1g
const a = 9.80665; // m/s²
const d = 2.54e6 * LIGHT_YEAR; // meters
const trip = flipAndBurn(a, d);
// → properTime: ~28.6 years ship, coordinateTime: ~2.54 Mly/c ≈ 2.54 Myr Earth`} lang="ts" theme="github-dark" />
            </div>
          </div>
        </div>
      </div>
    </section>
  
    {gear.length > 0 && (
      <section class="border-b border-border" aria-labelledby="gear-title">
        <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 id="gear-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Gear behind this build</h2>
              <AffiliateDisclosure class="mt-3 max-w-2xl" />
            </div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.12em] text-muted-text">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary-cta align-middle mr-1.5" aria-hidden="true"></span>
              Relativity stack · {gear.length} picks
            </p>
          </div>

          <div class="mt-10 flex items-center gap-3">
            <h3 class="inline-flex items-center gap-2 rounded-full border border-border bg-card-bg px-3.5 py-1.5 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-primary-text">
              <span class="size-1.5 rounded-full bg-primary-cta" aria-hidden="true"></span>
              Relativity hardware
              <span class="ml-1 rounded-full bg-elevated px-1.5 py-0.5 text-[0.6rem] text-muted-text">{gear.length}</span>
            </h3>
            <div class="h-px flex-1 bg-gradient-to-r from-border to-transparent"></div>
          </div>

          <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {gear.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="sponsored noopener noreferrer"
                class="group/card relative flex flex-col overflow-hidden rounded-[22px] border border-border bg-card-bg transition-all duration-300 hover:-translate-y-[2px] hover:border-[var(--mp-border-strong)] hover:shadow-[0_20px_50px_-18px_rgba(0,0,0,0.22)]"
              >
                <div class="relative aspect-[4/3] overflow-hidden bg-[radial-gradient(120%_120%_at_30%_20%,color-mix(in_srgb,var(--mp-elevated)_70%,transparent),var(--mp-card-bg))] p-6 sm:p-7">
                  {item.image ? (
                    <img
                      src={item.image}
                      alt=""
                      width="480"
                      height="360"
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-contain drop-shadow-[0_12px_24px_rgba(0,0,0,0.10)] transition-transform duration-500 group-hover/card:scale-[1.05]"
                    />
                  ) : (
                    <div class="grid h-full w-full place-items-center rounded-[14px] border border-dashed border-border bg-elevated/50 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-text">
                      {item.category}
                    </div>
                  )}
                  {item.price && (
                    <span class="absolute right-3 top-3 inline-flex items-center rounded-full border border-border bg-canvas/90 px-2.5 py-1 font-mono text-[0.7rem] font-semibold tracking-[-0.01em] text-primary-text shadow-sm backdrop-blur">
                      {item.price}
                    </span>
                  )}
                  <span class="pointer-events-none absolute bottom-2.5 right-3 rounded-full bg-elevated/70 px-2 py-0.5 font-mono text-[0.55rem] uppercase tracking-[0.12em] text-muted-text/60 backdrop-blur">
                    {item.category}
                  </span>
                </div>

                <div class="flex flex-1 flex-col p-4 sm:p-4.5">
                  <h4 class="line-clamp-2 text-[1.02rem] font-semibold leading-[1.32] tracking-[-0.015em] text-primary-text transition-colors group-hover/card:text-primary-cta">
                    {item.title}
                  </h4>
                  <p class="mt-1.5 line-clamp-3 text-[0.84rem] leading-[1.55] text-muted-text">{item.note}</p>
                  {(item.pillars ?? []).length > 0 && (
                    <div class="mt-auto flex flex-wrap items-center gap-1.5 pt-3.5">
                      {(item.pillars ?? []).slice(0, 2).map((p) => {
                        const pillar = pillarMeta[p] ?? fallbackPillar;
                        return (
                          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated/60 px-2 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">
                            <span class="size-1 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>
                            {pillar.label}
                          </span>
                        );
                      })}
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
          <p class="mt-6 text-[0.78rem] text-muted-text">More gear across every app: <a href="/resources#gear" class="text-brand-anchor hover:text-primary-text">the full Gear list →</a></p>
        </div>
      </section>
    )}


  </PlaygroundShell>
</Layout>

<style>
  .pill-btn { border-radius: 9999px; border: 1px solid var(--mp-border); background: var(--mp-elevated); padding: 0.4rem 0.9rem; font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--mp-muted); transition: color 0.15s, border-color 0.15s, background 0.15s; }
  .pill-btn:hover { color: var(--mp-text); border-color: var(--mp-cta); }
  .pill-btn.is-active { color: var(--mp-text); border-color: var(--mp-cta); background: color-mix(in srgb, var(--mp-cta) 12%, var(--mp-elevated)); }
  .tool-input { margin-top: 0.25rem; display: block; border-radius: 10px; border: 1px solid var(--mp-border); background: var(--mp-canvas); padding: 0.45rem 0.55rem; font-size: 0.85rem; color: var(--mp-text); }
  .tool-input:focus { outline: none; border-color: var(--mp-cta); box-shadow: 0 0 0 3px color-mix(in srgb, var(--mp-cta) 20%, transparent); }
  #mink-canvas { margin-top: 0.6rem; width: 100%; height: auto; display: block; background: var(--mp-canvas); border-radius: 10px; border: 1px solid var(--mp-border); }
  .readout { border: 1px solid var(--mp-border); border-radius: 12px; background: color-mix(in srgb, var(--mp-elevated) 45%, transparent); padding: 0.7rem 0.8rem; }
  .readout dt { font-family: var(--font-mono); font-size: 0.56rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--mp-muted); }
  .readout dd { margin-top: 0.25rem; font-size: 0.95rem; font-weight: 600; color: var(--mp-text); }
  .control-label { display: grid; grid-template-columns: 1fr auto; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--mp-muted); }
  .control-label output { color: var(--mp-text); font-weight: 600; }
  .control-label input[type='range'] { grid-column: 1 / -1; width: 100%; accent-color: var(--mp-cta); }
  .live-lab { font-family: var(--font-mono); font-size: 0.54rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--mp-muted); }
  .live-val { font-weight: 700; color: var(--mp-text); font-size: 0.98rem; }
  input[type='range'] { accent-color: var(--mp-cta); }
  .copy-btn {
    border-radius: 9999px;
    border: 1px solid var(--mp-border);
    background: var(--mp-elevated);
    padding: 0.3rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mp-muted);
    transition: color 0.15s, border-color 0.15s;
  }
  .copy-btn:hover {
    color: var(--mp-text);
    border-color: var(--mp-cta);
  }
  .math-card {
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--mp-elevated) 48%, transparent);
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    color: var(--mp-text);
  }
  .math-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--mp-muted);
  }
</style>

<script>
// @ts-nocheck
import {
  C, LIGHT_YEAR, JULIAN_YEAR, CMB_TEMPERATURE,
  gToMetric, betaAtProperTime, gammaAtProperTime, coordinateTime, distanceTraveled,
  cmbTemperatureAhead, flipAndBurn,
} from '../../lib/relativity.ts';

function initRelativisticFlight() {
  const canvas = document.getElementById('mink-canvas');
  if (!canvas || canvas.dataset.init) return;
  canvas.dataset.init = 'true';
  const ctx = canvas.getContext('2d');

  let colors = {};
  function readColors() {
    const s = getComputedStyle(document.documentElement);
    const g = (n, f) => s.getPropertyValue(n).trim() || f;
    colors = {
      canvas: g('--mp-canvas', '#0f141c'), text: g('--mp-text', '#e8eef6'),
      muted: g('--mp-muted', '#a8b9cc'), border: g('--mp-border', 'rgba(255,255,255,0.1)'),
      cta: g('--mp-cta', '#f07a94'), anchor: g('--mp-anchor', '#71b9e3'),
    };
  }
  readColors();

  const accelSlider = document.getElementById('accel-slider');
  const accelOut = document.getElementById('accel-out');
  const destSelect = document.getElementById('dest-select');
  const tauSlider = document.getElementById('tau-slider');
  const tauOut = document.getElementById('tau-out');
  const playBtn = document.getElementById('play-btn');
  const resetBtn = document.getElementById('reset-btn');

  const WIEN = 2.897771955e-3; // m·K

  let trip = null;      // flipAndBurn result
  let a = gToMetric(1); // m/s²
  let dMeters = 0;      // total coordinate distance
  let tauHalf = 0;
  let playing = false;
  let rafId = null;
  let destroyed = false;

  // Ship state as a function of proper time τ (s) for a flip-and-burn trip.
  function shipState(tau) {
    let x, ct, beta;
    if (tau <= tauHalf) {
      x = distanceTraveled(a, tau);
      ct = coordinateTime(a, tau) * C; // meters (ct)
      beta = betaAtProperTime(a, tau);
    } else {
      const tp = 2 * tauHalf - tau; // mirror
      x = dMeters - distanceTraveled(a, tp);
      ct = trip.coordinateTime * C - coordinateTime(a, tp) * C;
      beta = betaAtProperTime(a, tp);
    }
    return { x, ct, beta };
  }

  function recompute() {
    a = gToMetric(parseFloat(accelSlider.value));
    dMeters = parseFloat(destSelect.value) * LIGHT_YEAR;
    trip = flipAndBurn(a, dMeters);
    tauHalf = trip.turnaroundProperTime;

    const isValid = Number.isFinite(trip.properTime) && Number.isFinite(trip.coordinateTime);

    const yr = (s) => s / JULIAN_YEAR;
    const fmtYears = (s) => {
      if (!Number.isFinite(s)) return '—';
      const y = yr(s);
      if (y < 1) return `${(y * 12).toFixed(1)} mo`;
      if (y < 10000) return `${y.toFixed(y < 100 ? 1 : 0)} yr`;
      if (y < 1e6) return `${(y / 1e3).toFixed(1)}k yr`;
      if (y < 1e9) return `${(y / 1e6).toFixed(2)}M yr`;
      return `${(y / 1e9).toFixed(2)}B yr`;
    };
    document.getElementById('ro-ship').textContent = fmtYears(trip.properTime);
    document.getElementById('ro-earth').textContent = fmtYears(trip.coordinateTime);
    const pb = trip.peakBeta;
    document.getElementById('ro-peakb').textContent = isValid
      ? (pb > 0.999 ? `${(pb).toFixed(pb > 0.99999 ? 8 : 5)} c` : `${pb.toFixed(3)} c`)
      : '—';
    document.getElementById('ro-peakg').textContent = isValid
      ? (trip.peakGamma < 100 ? trip.peakGamma.toFixed(2) : trip.peakGamma.toExponential(2))
      : '—';
    const ly = parseFloat(destSelect.value);
    document.getElementById('ro-contract').textContent = isValid
      ? `${(ly / trip.peakGamma) < 0.01 ? (ly / trip.peakGamma).toExponential(2) : (ly / trip.peakGamma).toFixed(3)} ly`
      : '—';
    const cmbPeak = isValid ? cmbTemperatureAhead(pb) : NaN;
    document.getElementById('ro-cmbpeak').textContent = isValid
      ? `${cmbPeak < 1e4 ? cmbPeak.toFixed(cmbPeak < 100 ? 1 : 0) : cmbPeak.toExponential(2)} K`
      : '—';
    document.getElementById('ro-wien').textContent = isValid
      ? fmtWavelength(WIEN / cmbPeak)
      : '—';
    document.getElementById('ro-flip').textContent = isValid ? `${fmtYears(tauHalf)} ship` : '—';

    const statusNote = document.getElementById('overflow-note');
    if (statusNote) statusNote.style.display = isValid ? 'none' : 'block';

    draw();
  }

  function fmtWavelength(m) {
    if (m > 1e-3) return `${(m * 1e3).toFixed(2)} mm`;
    if (m > 1e-6) return `${(m * 1e6).toFixed(1)} µm`;
    return `${(m * 1e9).toFixed(0)} nm`;
  }

  function currentTau() {
    return (parseFloat(tauSlider.value) / 1000) * trip.properTime;
  }

  function draw() {
    const W = canvas.width, H = canvas.height;
    ctx.fillStyle = colors.canvas; ctx.fillRect(0, 0, W, H);
    if (!Number.isFinite(trip.coordinateTime) || !Number.isFinite(dMeters)) {
      ctx.fillStyle = colors.muted; ctx.font = '14px ui-monospace, monospace';
      ctx.textAlign = 'center';
      ctx.fillText('Rapidity exceeds Float64 range — reduce distance or acceleration.', W / 2, H / 2);
      ctx.textAlign = 'start';
      return;
    }
    const padL = 46, padR = 20, padT = 20, padB = 34;
    const plotW = W - padL - padR, plotH = H - padT - padB;

    // Diagram uses ct on the vertical axis (up), x on the horizontal.
    // Scale both to light-years / years so the light cone is 45°.
    const ctMaxYr = trip.coordinateTime / JULIAN_YEAR;
    const xMaxLy = dMeters / LIGHT_YEAR;
    const axMax = Math.max(ctMaxYr, xMaxLy) * 1.04;
    const X = (xLy) => padL + (xLy / axMax) * plotW;
    const Y = (ctYr) => padT + plotH - (ctYr / axMax) * plotH;

    // grid
    ctx.strokeStyle = colors.border; ctx.lineWidth = 1;
    ctx.strokeRect(padL, padT, plotW, plotH);

    // light cone from origin (x = ct)
    ctx.strokeStyle = colors.muted; ctx.globalAlpha = 0.5; ctx.setLineDash([5, 5]); ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(X(0), Y(0)); ctx.lineTo(X(axMax), Y(axMax)); ctx.stroke();
    ctx.setLineDash([]); ctx.globalAlpha = 1;
    ctx.fillStyle = colors.muted; ctx.font = '10px ui-monospace, monospace';
    ctx.fillText('light cone (v = c)', X(axMax * 0.62), Y(axMax * 0.72));

    // worldline
    const N = 400;
    ctx.strokeStyle = colors.anchor; ctx.lineWidth = 2;
    ctx.beginPath();
    for (let i = 0; i <= N; i++) {
      const tau = (i / N) * trip.properTime;
      const st = shipState(tau);
      const px = X(st.x / LIGHT_YEAR), py = Y(st.ct / LIGHT_YEAR);
      if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
    }
    ctx.stroke();

    // marker at current τ
    const tau = currentTau();
    const st = shipState(tau);
    const mx = X(st.x / LIGHT_YEAR), my = Y(st.ct / LIGHT_YEAR);

    // instantaneous line of simultaneity (slope β in these axes): ct = ctM + β(x − xM)
    ctx.strokeStyle = colors.cta; ctx.globalAlpha = 0.5; ctx.setLineDash([3, 4]); ctx.lineWidth = 1;
    const xMly = st.x / LIGHT_YEAR, ctMly = st.ct / LIGHT_YEAR, b = st.beta;
    ctx.beginPath();
    ctx.moveTo(X(0), Y(ctMly + b * (0 - xMly)));
    ctx.lineTo(X(axMax), Y(ctMly + b * (axMax - xMly)));
    ctx.stroke();
    ctx.setLineDash([]); ctx.globalAlpha = 1;

    ctx.fillStyle = colors.cta;
    ctx.beginPath(); ctx.arc(mx, my, 6, 0, Math.PI * 2); ctx.fill();
    ctx.strokeStyle = colors.text; ctx.lineWidth = 1.5; ctx.stroke();

    // axis labels
    ctx.fillStyle = colors.muted; ctx.font = '10px ui-monospace, monospace';
    ctx.fillText(`x → ${xMaxLy < 100 ? xMaxLy.toFixed(1) : xMaxLy.toExponential(1)} ly`, padL + 4, padT + plotH + 24);
    ctx.save(); ctx.translate(14, padT + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText(`ct ↑ ${ctMaxYr < 100 ? ctMaxYr.toFixed(1) : ctMaxYr.toExponential(1)} yr`, 0, 0); ctx.restore();

    // live readouts
    const gamma = tau <= tauHalf ? gammaAtProperTime(a, tau) : gammaAtProperTime(a, 2 * tauHalf - tau);
    document.getElementById('live-beta').textContent =
      st.beta > 0.999 ? `${st.beta.toFixed(st.beta > 0.99999 ? 7 : 5)} c` : `${st.beta.toFixed(3)} c`;
    document.getElementById('live-gamma').textContent = gamma < 100 ? gamma.toFixed(2) : gamma.toExponential(2);
    const distLy = st.x / LIGHT_YEAR;
    document.getElementById('live-dist').textContent = `${distLy < 100 ? distLy.toFixed(2) : distLy.toExponential(2)} ly`;
    const cmb = cmbTemperatureAhead(st.beta);
    document.getElementById('live-cmb').textContent = `${cmb < 1e4 ? cmb.toFixed(cmb < 100 ? 1 : 0) : cmb.toExponential(2)} K`;
  }

  function setPlaying(p) {
    playing = p;
    playBtn.textContent = playing ? '⏸ Pause' : '▶ Launch';
    playBtn.classList.toggle('is-active', playing);
    if (playing) {
      let last = performance.now();
      const step = (now) => {
        if (destroyed || !playing) return;
        const dt = (now - last) / 1000; last = now;
        let v = parseFloat(tauSlider.value) + dt * 140; // ~7s per trip
        if (v >= 1000) { v = 1000; setPlaying(false); }
        tauSlider.value = String(v);
        tauOut.textContent = `${(v / 10).toFixed(0)}%`;
        draw();
        if (playing) rafId = requestAnimationFrame(step);
      };
      rafId = requestAnimationFrame(step);
    } else if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  accelSlider.addEventListener('input', () => { accelOut.textContent = `${parseFloat(accelSlider.value).toFixed(2)} g`; recompute(); });
  destSelect.addEventListener('change', recompute);
  tauSlider.addEventListener('input', () => { tauOut.textContent = `${(parseFloat(tauSlider.value) / 10).toFixed(0)}%`; draw(); });
  playBtn.addEventListener('click', () => setPlaying(!playing));
  resetBtn.addEventListener('click', () => { setPlaying(false); tauSlider.value = '0'; tauOut.textContent = '0%'; draw(); });

  const themeObserver = new MutationObserver(() => { readColors(); draw(); });
  themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.copyTarget;
      const codeEl = targetId ? document.getElementById(targetId) : null;
      if (!codeEl) return;
      try {
        await navigator.clipboard.writeText(codeEl.textContent ?? '');
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {}
    });
  });

  document.addEventListener('astro:before-swap', () => { destroyed = true; if (rafId) cancelAnimationFrame(rafId); themeObserver.disconnect(); }, { once: true });

  recompute();
}

document.addEventListener('astro:page-load', initRelativisticFlight);
initRelativisticFlight();
</script>
