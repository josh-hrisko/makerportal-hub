---
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import { playground } from '../../data/playground';
import { pillarMeta, fallbackPillar } from '../../data/trends';

const title = 'Playground — frontier physics & math instruments | MakerPortal';
const description =
  'Research-grade interactive physics and math instruments — double pendulums, Fourier epicycles, cymatics, orbital mechanics. Each solver is numerically honest, with method and limitations stated — built for PhD-level intuition, not as claimed shipped product code.';

const pillarOf = (hint?: string) => (hint ? pillarMeta[hint] ?? fallbackPillar : null);
---

<Layout title={title} description={description}>
  <HubShell kicker="Learn · Playground" title="Frontier instruments, live in your browser." lead="Research-grade simulations and computational instruments with instant visual feedback. App-grounded instruments cite the shipped system they come from; independent research instruments disclose full method, equations, and limitations." status="Playground">
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/playground/quaternion-euler-converter" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Try an app-grounded tool</a>
        <a href="/resources" class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor">Browse resources</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {playground.map((entry) => {
          const pillar = pillarOf(entry.pillarHint);
          const isLive = entry.status === 'live';
          const Wrapper = isLive ? 'a' : 'div';
          return (
            <Wrapper
              href={isLive ? `/playground/${entry.slug}` : undefined}
              class={`group flex flex-col rounded-[20px] border p-5 transition-colors ${isLive ? 'border-border bg-card-bg hover:border-[var(--mp-border-strong)] hover:bg-elevated' : 'border-dashed border-border bg-elevated/30 opacity-70'}`}
            >
              <div class="flex items-center justify-between gap-2">
                {pillar ? (
                  <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
                    <span class="h-1.5 w-1.5 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>
                    {pillar.label}
                  </span>
                ) : <span />}
                {!isLive && <span class="rounded-full border border-border bg-canvas px-2 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">Coming soon</span>}
              </div>
              <h2 class={`mt-3 text-[1.1rem] font-semibold leading-tight text-primary-text ${isLive ? 'transition-colors group-hover:text-primary-cta' : ''}`}>{entry.title}</h2>
              <p class="mt-1.5 text-[0.85rem] leading-[1.5] text-muted-text">{entry.tagline}</p>
            </Wrapper>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
