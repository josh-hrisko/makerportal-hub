---
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import { playground } from '../../data/playground';
import { pillarMeta, fallbackPillar } from '../../data/trends';

const title = 'Playground — browser engineering, AI & physics labs | MakerPortal';
const description =
  'Interactive browser labs for WebGPU, Web Audio, edge databases, physics, math, DSP, and embedded systems. Every benchmark and model discloses its method and limitations.';

const pillarOf = (hint?: string) => (hint ? pillarMeta[hint] ?? fallbackPillar : null);
const live = playground.filter((entry) => entry.status === 'live');
const deploymentSlugs = ['elevenlabs-dsp-sandbox', 'modal-gpu-benchmarker', 'fly-edge-db-lab', 'vector-retrieval-recall-lab'];
const deploymentLabs = deploymentSlugs
  .map((slug) => live.find((entry) => entry.slug === slug))
  .filter((entry): entry is (typeof live)[number] => Boolean(entry));
const remainingLabs = live.filter((entry) => !deploymentSlugs.includes(entry.slug));

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'MakerPortal Playground',
  description,
  url: 'https://www.makerportal.ai/playground',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: live.length,
    itemListElement: live.map((entry, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: entry.title,
      url: `https://www.makerportal.ai/playground/${entry.slug}`,
    })),
  },
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)}></script>
  </Fragment>
  <HubShell kicker="Learn · Playground" title="Engineering instruments, live in your browser." lead="Measure your GPU, route an edge database, build a voice DSP chain, or explore a numerical solver. App-grounded instruments cite the shipped system they come from; independent labs disclose method, equations, and limitations." status={`${live.length} live labs`}>
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/playground/modal-gpu-benchmarker" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Benchmark this device</a>
        <a href="/playground/elevenlabs-dsp-sandbox" class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor">Build a voice DSP chain</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border bg-elevated/20" aria-labelledby="deployment-labs-title">
    <div class="mx-auto max-w-[88rem] px-5 py-14 sm:px-8 sm:py-20 lg:px-10">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="section-kicker">New · Deployment labs</p>
          <h2 id="deployment-labs-title" class="mt-3 text-[clamp(1.6rem,4vw,2.4rem)] font-[650] tracking-[-0.045em] text-primary-text">Client, cloud, and edge—measured honestly.</h2>
          <p class="mt-3 max-w-2xl text-[0.9rem] leading-[1.65] text-muted-text">Four high-intent labs connect browser primitives to production deployment decisions. Charts start empty, secrets never enter shared site code, and model-only latency is labeled as model-only.</p>
        </div>
        <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">No shared keys · No prefilled benchmarks</span>
      </div>
      <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        {deploymentLabs.map((entry, index) => {
          const pillar = pillarOf(entry.pillarHint);
          return (
            <a href={`/playground/${entry.slug}`} class="group relative overflow-hidden rounded-[20px] border border-border bg-card-bg p-5 transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated">
              <span class="absolute right-4 top-4 rounded-full border border-brand-anchor/20 bg-brand-anchor/10 px-2.5 py-1 font-mono text-[0.56rem] uppercase tracking-[0.1em] text-brand-anchor">0{index + 1}</span>
              <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
                {pillar && <span class="size-1.5 rounded-full" style={`background:${pillar.color}`} aria-hidden="true"></span>}
                {pillar?.label ?? 'Deployment'}
              </span>
              <h3 class="mt-5 max-w-[16rem] text-[1.15rem] font-semibold leading-tight text-primary-text transition-colors group-hover:text-primary-cta">{entry.title}</h3>
              <p class="mt-2 text-[0.82rem] leading-[1.55] text-muted-text">{entry.tagline}</p>
              <span class="mt-5 inline-flex min-h-10 items-center text-[0.8rem] font-semibold text-primary-text group-hover:text-primary-cta">Open lab →</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <p class="section-kicker">All instruments</p>
          <h2 class="mt-2 text-[1.5rem] font-[650] tracking-[-0.035em] text-primary-text">Physics, DSP, embedded, and ML</h2>
        </div>
        <span class="font-mono text-[0.62rem] uppercase tracking-[0.12em] text-muted-text">{remainingLabs.length} more</span>
      </div>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {remainingLabs.map((entry) => {
          const pillar = pillarOf(entry.pillarHint);
          return (
            <a
              href={`/playground/${entry.slug}`}
              class="group flex flex-col rounded-[20px] border border-border bg-card-bg p-5 transition-colors hover:border-[var(--mp-border-strong)] hover:bg-elevated"
            >
              <div class="flex items-center justify-between gap-2">
                {pillar ? (
                  <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
                    <span class="h-1.5 w-1.5 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>
                    {pillar.label}
                  </span>
                ) : <span />}
              </div>
              <h3 class="mt-3 text-[1.1rem] font-semibold leading-tight text-primary-text transition-colors group-hover:text-primary-cta">{entry.title}</h3>
              <p class="mt-1.5 text-[0.85rem] leading-[1.5] text-muted-text">{entry.tagline}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
