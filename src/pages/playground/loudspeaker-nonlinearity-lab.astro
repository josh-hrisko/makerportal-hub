<script>
  import { setupHiDPI, resolveTheme, clearCanvas, drawLine, drawText, drawCircle } from '../../lib/chart-core.ts';
  import { extractHarmonics } from '../../lib/dsp.ts';

  function initDriverNonlinearityLab() {
    const waveformCanvas = document.getElementById('waveform-canvas') as HTMLCanvasElement | null;
    const spectrumCanvas = document.getElementById('spectrum-canvas') as HTMLCanvasElement | null;
    if (!waveformCanvas || !spectrumCanvas || waveformCanvas.dataset.initialized === 'true') return;
    waveformCanvas.dataset.initialized = 'true';

    const wfCtx = setupHiDPI(waveformCanvas, 880, 440);
    const spCtx = setupHiDPI(spectrumCanvas, 880, 220);
    const W_WF = 880;
    const H_WF = 440;
    const W_SP = 880;
    const H_SP = 220;

    const theme = resolveTheme();

    const vrmsSlider = document.getElementById('vrms-slider') as HTMLInputElement;
    const vrmsNum = document.getElementById('vrms-num') as HTMLInputElement;
    const freqSlider = document.getElementById('freq-slider') as HTMLInputElement;
    const freqNum = document.getElementById('freq-num') as HTMLInputElement;
    const betaSlider = document.getElementById('beta-slider') as HTMLInputElement;
    const betaNum = document.getElementById('beta-num') as HTMLInputElement;
    const gammaSlider = document.getElementById('gamma-slider') as HTMLInputElement;
    const gammaNum = document.getElementById('gamma-num') as HTMLInputElement;
    const deltaSlider = document.getElementById('delta-slider') as HTMLInputElement;
    const deltaNum = document.getElementById('delta-num') as HTMLInputElement;
    const mmsSlider = document.getElementById('mms-slider') as HTMLInputElement;
    const mmsNum = document.getElementById('mms-num') as HTMLInputElement;
    const reSlider = document.getElementById('re-slider') as HTMLInputElement;
    const reNum = document.getElementById('re-num') as HTMLInputElement;
    const bl0Slider = document.getElementById('bl0-slider') as HTMLInputElement;
    const bl0Num = document.getElementById('bl0-num') as HTMLInputElement;
    const xmaxSlider = document.getElementById('xmax-slider') as HTMLInputElement;
    const xmaxNum = document.getElementById('xmax-num') as HTMLInputElement;

    const runToggle = document.getElementById('run-toggle') as HTMLButtonElement;
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
    const motorStatus = document.getElementById('motor-status') as HTMLSpanElement;

    const metExcursion = document.getElementById('met-excursion') as HTMLElement;
    const metThd = document.getElementById('met-thd') as HTMLElement;
    const metBl = document.getElementById('met-bl') as HTMLElement;
    const metKms = document.getElementById('met-kms') as HTMLElement;

    const coilGroup = document.getElementById('coil-group') as unknown as SVGElement;
    const forceArrow = document.getElementById('force-arrow') as unknown as SVGElement;
    const coneEl = document.getElementById('cone') as unknown as SVGElement;
    const gapIndicator = document.getElementById('gap-indicator') as unknown as SVGElement;

    const PHYSICS_DT = 1 / 8000;

    function getParams() {
      return {
        vrms: parseFloat(vrmsNum.value),
        freq: parseFloat(freqNum.value),
        beta: parseFloat(betaNum.value),
        gamma: parseFloat(gammaNum.value),
        delta: parseFloat(deltaNum.value),
        mms: parseFloat(mmsNum.value) / 1000,
        re: parseFloat(reNum.value),
        bl0: parseFloat(bl0Num.value),
        xmax: parseFloat(xmaxNum.value) / 1000,
      };
    }

    const defaults: Record<string, string> = {
      vrms: '12', freq: '60', beta: '0.10', gamma: '0.20', delta: '0.05',
      mms: '20', re: '6', bl0: '8', xmax: '5',
    };

    function resetParams() {
      for (const [id, val] of Object.entries(defaults)) {
        const slider = document.getElementById(id + '-slider') as HTMLInputElement;
        const num = document.getElementById(id + '-num') as HTMLInputElement;
        if (slider) slider.value = val;
        if (num) num.value = val;
      }
    }

    let x = 0, v = 0, i = 0;
    let running = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let destroyed = false;
    let lastFrameTime = performance.now();
    let animationFrameId = 0;
    let accumulator = 0;

    const historySize = 1024;
    let displacementHistory: number[] = new Array(historySize).fill(0);
    let voltageHistory: number[] = new Array(historySize).fill(0);
    let historyCursor = 0;
    let simTime = 0;

    function syncControls() {
      const p = getParams();
      const historicalMax = displacementHistory.reduce((max, val) => Math.max(max, Math.abs(val)), 0);
      const peakMm = historicalMax * 1000;
      const blAtPeak = p.bl0 * (1 - p.beta * Math.abs(historicalMax / (p.xmax || 1e-9)));
      const kms0 = p.mms * (2 * Math.PI * 40) * (2 * Math.PI * 40);
      const kmsAtPeak = kms0 * (1 + p.gamma * Math.pow(historicalMax / (p.xmax || 1e-9), 2));
      metExcursion.textContent = `±${peakMm.toFixed(2)} mm`;
      metBl.textContent = `${blAtPeak.toFixed(2)} N/A`;
      metKms.textContent = `${(kmsAtPeak / 1000).toFixed(2)} N/mm`;

      const motorPos = (historicalMax / (p.xmax || 1e-9)) * 30;
      const clampedMotorPos = Math.max(-30, Math.min(30, motorPos));
      coilGroup.setAttribute('transform', `translate(0, ${clampedMotorPos})`);

      if (Math.abs(historicalMax) > p.xmax) {
        motorStatus.textContent = 'Coil out of gap';
        motorStatus.style.color = theme.magColor;
        gapIndicator.setAttribute('opacity', '0.12');
      } else {
        motorStatus.textContent = 'Coil in gap';
        motorStatus.style.color = '';
        gapIndicator.setAttribute('opacity', '0.5');
      }

      const forceMag = Math.abs(p.bl0 * (1 - p.beta * Math.abs(x / (p.xmax || 1e-9))) * i);
      const forceScaled = Math.min(1, forceMag / 5);
      forceArrow.setAttribute('opacity', String(0.15 + forceScaled * 0.85));
      const arrowLen = 30 + forceScaled * 50;
      forceArrow.setAttribute('y1', '340');
      forceArrow.setAttribute('y2', String(340 - arrowLen));

      const coneOffset = clampedMotorPos * 0.5;
      coneEl.setAttribute('transform', `translate(0, ${coneOffset})`);

      function approximateTHD(): number {
        const p = getParams();
        const N = displacementHistory.length;
        if (N < 8) return 0;
        const buf = new Array(N);
        const times = new Array(N);
        for (let k = 0; k < N; k++) {
          buf[k] = displacementHistory[(historyCursor + 1 + k) % N];
          times[k] = k * PHYSICS_DT;
        }
        const mags = extractHarmonics(times, buf, p.freq, 4);
        const f1 = mags[1];
        if (f1 < 1e-12) return 0;
        const f2 = mags[2], f3 = mags[3], f4 = mags[4];
        const thd = Math.sqrt(f2 * f2 + f3 * f3 + f4 * f4) / f1 * 100;
        return Math.min(99.9, thd);
      }

      metThd.textContent = `${approximateTHD().toFixed(1)}%`;
    }

    function stepPhysics() {
      const p = getParams();
      const omega = 2 * Math.PI * p.freq;
      const vin = p.vrms * Math.sqrt(2) * Math.sin(omega * simTime);

      const bl = p.bl0 * (1 - p.beta * Math.abs(x / (p.xmax || 1e-9)));
      const kms0 = p.mms * (2 * Math.PI * 40) * (2 * Math.PI * 40);
      const kms = kms0 * (1 + p.gamma * Math.pow(x / (p.xmax || 1e-9), 2));
      const le0 = 0.5e-3;
      const le = le0 * (1 + p.delta * Math.abs(x / (p.xmax || 1e-9)));

      i = i + (vin - p.re * i - bl * v) / le * PHYSICS_DT;
      const a = (bl * i - kms * x) / p.mms;
      v = v + a * PHYSICS_DT;
      x = x + v * PHYSICS_DT;

      displacementHistory[historyCursor] = x;
      voltageHistory[historyCursor] = vin;
      historyCursor = (historyCursor + 1) % historySize;
      simTime += PHYSICS_DT;
    }

    function renderPlots() {
      const p = getParams();
      clearCanvas(wfCtx, theme, W_WF, H_WF);
      clearCanvas(spCtx, theme, W_SP, H_SP);

      const topH = H_WF * 0.52;
      const botTop = H_WF * 0.58;

      const margTop = { left: 56, right: 28, top: 28, bottom: 14 };
      const plotW = W_WF - margTop.left - margTop.right;
      const plotH = topH - margTop.top - margTop.bottom;

      const dispMax = Math.max(1e-9, displacementHistory.reduce((max, val) => Math.max(max, Math.abs(val)), 0));
      const dispRange = dispMax * 1.2;
      const vMax = Math.max(1e-9, voltageHistory.reduce((max, val) => Math.max(max, Math.abs(val)), 0));
      const vRange = Math.max(p.vrms * Math.sqrt(2) * 1.1, vMax * 1.2);

      wfCtx.strokeStyle = theme.gridLine;
      wfCtx.lineWidth = 0.5;
      for (let i = 0; i <= 5; i++) {
        const y = margTop.top + (plotH * i) / 5;
        wfCtx.beginPath();
        wfCtx.moveTo(margTop.left, y);
        wfCtx.lineTo(margTop.left + plotW, y);
        wfCtx.stroke();
      }

      drawText(wfCtx, `+${(dispRange * 1000).toFixed(1)} mm`, margTop.left - 4, margTop.top + 10, theme.muted, 9, 'right');
      drawText(wfCtx, '0', margTop.left - 4, margTop.top + plotH / 2 + 3, theme.muted, 9, 'right');
      drawText(wfCtx, `−${(dispRange * 1000).toFixed(1)}`, margTop.left - 4, margTop.top + plotH + 4, theme.muted, 9, 'right');
      drawText(wfCtx, `+${vRange.toFixed(1)} V`, margTop.left - 4, margTop.top + 22, theme.muted, 9, 'right');
      drawText(wfCtx, '0 V', margTop.left - 4, margTop.top + plotH / 2 + 15, theme.muted, 9, 'right');

      drawText(wfCtx, 'Displacement (x)', W_WF / 2, margTop.top + 12, theme.muted, 10, 'center');
      drawText(wfCtx, 'Voltage (gray)', W_WF / 2, margTop.top + 24, theme.muted, 9, 'center');

      wfCtx.beginPath();
      wfCtx.strokeStyle = '#8899aa';
      wfCtx.lineWidth = 1.0;
      for (let j = 0; j < historySize; j++) {
        const idx = (historyCursor + 1 + j) % historySize;
        const val = voltageHistory[idx];
        const xp = margTop.left + (j / (historySize - 1)) * plotW;
        const yp = margTop.top + plotH / 2 - (val / vRange) * (plotH / 2);
        if (j === 0) wfCtx.moveTo(xp, yp);
        else wfCtx.lineTo(xp, yp);
      }
      wfCtx.stroke();

      wfCtx.beginPath();
      wfCtx.strokeStyle = theme.magColor;
      wfCtx.lineWidth = 2.0;
      for (let j = 0; j < historySize; j++) {
        const idx = (historyCursor + 1 + j) % historySize;
        const val = displacementHistory[idx];
        const xp = margTop.left + (j / (historySize - 1)) * plotW;
        const yp = margTop.top + plotH / 2 - (val / dispRange) * (plotH / 2);
        if (j === 0) wfCtx.moveTo(xp, yp);
        else wfCtx.lineTo(xp, yp);
      }
      wfCtx.stroke();

      drawLine(wfCtx, margTop.left, topH + 14, W_WF - margTop.right, topH + 14, theme.border, 1);

      const blMarg = { left: 56, right: 28, top: 24, bottom: 28 };
      const blPlotW = W_WF - blMarg.left - blMarg.right;
      const blPlotH = H_WF - botTop - blMarg.top - blMarg.bottom;
      const blMaxX = p.xmax * 2.5;

      wfCtx.strokeStyle = theme.gridLine;
      wfCtx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const y = botTop + blMarg.top + (blPlotH * i) / 4;
        wfCtx.beginPath();
        wfCtx.moveTo(blMarg.left, y);
        wfCtx.lineTo(blMarg.left + blPlotW, y);
        wfCtx.stroke();
      }
      const zeroX = blMarg.left + blPlotW / 2;
      wfCtx.strokeStyle = theme.border;
      wfCtx.beginPath();
      wfCtx.moveTo(zeroX, botTop + blMarg.top);
      wfCtx.lineTo(zeroX, botTop + blMarg.top + blPlotH);
      wfCtx.stroke();

      drawText(wfCtx, 'Bl(x) curve', W_WF / 2, botTop + 14, theme.muted, 10, 'center');
      drawText(wfCtx, `Bl₀ = ${p.bl0.toFixed(1)} N/A`, blMarg.left, botTop + blMarg.top + blPlotH + 16, theme.muted, 9, 'left');
      drawText(wfCtx, `+${(blMaxX * 1000).toFixed(1)} mm`, blMarg.left + blPlotW, botTop + blMarg.top + blPlotH + 16, theme.muted, 9, 'right');
      drawText(wfCtx, `−${(blMaxX * 1000).toFixed(1)}`, blMarg.left, botTop + blMarg.top + blPlotH + 16, theme.muted, 9, 'left');
      drawText(wfCtx, '0', zeroX + 4, botTop + blMarg.top + blPlotH + 16, theme.muted, 9, 'left');

      const bl0Flat = p.bl0;
      const blMax = bl0Flat * 1.05;
      const blMin = bl0Flat * 0.3;
      const blRange = blMax - blMin;
      const Ncurves = 300;
      wfCtx.beginPath();
      wfCtx.strokeStyle = '#71b9e3';
      wfCtx.lineWidth = 2.0;
      for (let j = 0; j <= Ncurves; j++) {
        const xv = -blMaxX + (2 * blMaxX * j) / Ncurves;
        const blv = bl0Flat * (1 - p.beta * Math.abs(xv / (p.xmax || 1e-9)));
        const xp = zeroX + (xv / blMaxX) * (blPlotW / 2);
        const yp = botTop + blMarg.top + blPlotH - ((blv - blMin) / blRange) * blPlotH;
        if (j === 0) wfCtx.moveTo(xp, yp);
        else wfCtx.lineTo(xp, yp);
      }
      wfCtx.stroke();

      const opX = zeroX + (x / (p.xmax || 1e-9)) * (blPlotW / 2) * 0.5;
      const blOp = bl0Flat * (1 - p.beta * Math.abs(x / (p.xmax || 1e-9)));
      const opY = botTop + blMarg.top + blPlotH - ((blOp - blMin) / blRange) * blPlotH;
      drawCircle(wfCtx, opX, opY, 5, theme.magColor, theme.text, 1.5);

      const spMarg = { left: 56, right: 28, top: 24, bottom: 28 };
      const spPlotW = W_SP - spMarg.left - spMarg.right;
      const spPlotH = H_SP - spMarg.top - spMarg.bottom;

      const Nspec = displacementHistory.length;
      const P = getParams();
      const buf = new Array(Nspec);
      const times = new Array(Nspec);
      for (let k = 0; k < Nspec; k++) {
        buf[k] = displacementHistory[(historyCursor + 1 + k) % Nspec];
        times[k] = k * PHYSICS_DT;
      }
      const mags = extractHarmonics(times, buf, P.freq, 4);

      const harmonics: { label: string; freq: number; amp: number }[] = [];
      for (let h = 1; h <= 4; h++) {
        const f = P.freq * h;
        harmonics.push({ label: h === 1 ? 'f₀' : `${h}·f₀`, freq: f, amp: mags[h] });
      }

      const spMaxAmp = 0.0001;
      const maxHarmonic = Math.max(spMaxAmp, ...harmonics.map(hh => hh.amp));
      const spRange = maxHarmonic * 1.3;
      const spMaxFreq = P.freq * 5;

      spCtx.strokeStyle = theme.gridLine;
      spCtx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const y = spMarg.top + (spPlotH * i) / 4;
        spCtx.beginPath();
        spCtx.moveTo(spMarg.left, y);
        spCtx.lineTo(spMarg.left + spPlotW, y);
        spCtx.stroke();
      }

      drawText(spCtx, 'Displacement spectrum (approx.)', W_SP / 2, spMarg.top - 6, theme.muted, 10, 'center');
      drawText(spCtx, '0', spMarg.left - 4, spMarg.top + spPlotH + 4, theme.muted, 9, 'right');
      drawText(spCtx, `${(spRange * 1e6).toFixed(1)} μm`, spMarg.left - 4, spMarg.top + 10, theme.muted, 9, 'right');

      for (let h = 1; h <= 4; h++) {
        const f = P.freq * h;
        const xp = spMarg.left + (f / spMaxFreq) * spPlotW;
        drawText(spCtx, `${f.toFixed(0)} Hz`, xp, spMarg.top + spPlotH + 16, theme.muted, 8, 'center');
      }

      const barWidth = Math.min(60, spPlotW / 10);
      for (const h of harmonics) {
        const barH = (h.amp / spRange) * spPlotH;
        const xp = spMarg.left + (h.freq / spMaxFreq) * spPlotW - barWidth / 2;
        const yp = spMarg.top + spPlotH - barH;
        spCtx.fillStyle = h.label === 'f₀' ? theme.magColor : '#71b9e3';
        spCtx.fillRect(xp, yp, barWidth, barH);
        drawText(spCtx, h.label, xp + barWidth / 2, yp - 5, theme.text, 9, 'center');
        drawText(spCtx, `${(h.amp * 1000).toFixed(3)} mm`, xp + barWidth / 2, yp - 17, theme.muted, 8, 'center');
      }

      const thd = metThd.textContent;
      drawText(spCtx, `THD ≈ ${thd}`, spMarg.left, spMarg.top + 14, theme.muted, 10, 'left');
      drawText(spCtx, 'Approximate spectral view — educational, not measurement-grade', spMarg.left + spPlotW - 4, spMarg.top + 14, theme.muted, 8, 'right');
      drawLine(spCtx, spMarg.left, spMarg.top + spPlotH, spMarg.left + spPlotW, spMarg.top + spPlotH, theme.border, 1);
    }

    function renderFrame(frameTime: number) {
      if (destroyed) return;
      const elapsed = Math.min(0.05, Math.max(0, frameTime - lastFrameTime) / 1000);
      lastFrameTime = frameTime;
      if (!isVisible) {
        animationFrameId = requestAnimationFrame(renderFrame);
        return;
      }
      if (running) {
        accumulator += elapsed;
        let safety = 0;
        while (accumulator >= PHYSICS_DT && safety < 5000) {
          stepPhysics();
          accumulator -= PHYSICS_DT;
          safety++;
        }
      }
      syncControls();
      renderPlots();
      animationFrameId = requestAnimationFrame(renderFrame);
    }

    function setRunning(on: boolean) {
      running = on;
      runToggle.textContent = running ? 'Pause' : 'Run';
      runToggle.classList.toggle('is-active', running);
      runToggle.setAttribute('aria-pressed', String(running));
      if (running) {
        accumulator = 0;
        lastFrameTime = performance.now();
      }
    }

    let isVisible = true;
    const io = new IntersectionObserver((entries) => {
      isVisible = entries[0].isIntersecting && !document.hidden;
    });
    io.observe(document.getElementById('motor-card') || document.body);

    function handleVisibilityChange() {
      lastFrameTime = performance.now();
      isVisible = !document.hidden;
    }

    runToggle.addEventListener('click', () => setRunning(!running));
    resetBtn.addEventListener('click', () => {
      resetParams();
      x = 0; v = 0; i = 0; simTime = 0;
      displacementHistory = new Array(historySize).fill(0);
      voltageHistory = new Array(historySize).fill(0);
      historyCursor = 0;
      accumulator = 0;
    });

    const sliderNumPairs: [HTMLInputElement, HTMLInputElement][] = [
      [vrmsSlider, vrmsNum], [freqSlider, freqNum], [betaSlider, betaNum],
      [gammaSlider, gammaNum], [deltaSlider, deltaNum], [mmsSlider, mmsNum],
      [reSlider, reNum], [bl0Slider, bl0Num], [xmaxSlider, xmaxNum],
    ];

    for (const [slider, num] of sliderNumPairs) {
      slider.addEventListener('input', () => { num.value = slider.value; });
      num.addEventListener('input', () => { slider.value = num.value; });
    }

    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.copyTarget;
        const el = document.getElementById(id ?? '');
        if (!el) return;
        try {
          const text = (el as HTMLElement).textContent ?? '';
          await navigator.clipboard.writeText(text);
          const orig = btn.textContent;
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = orig; }, 1200);
        } catch {}
      });
    });

    document.addEventListener('visibilitychange', handleVisibilityChange);

    setRunning(running);
    syncControls();
    renderPlots();
    animationFrameId = requestAnimationFrame(renderFrame);

    document.addEventListener('astro:before-swap', () => {
      destroyed = true;
      cancelAnimationFrame(animationFrameId);
      io.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initDriverNonlinearityLab);
  initDriverNonlinearityLab();
</script>
