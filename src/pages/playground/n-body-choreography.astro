<script>
  // @ts-nocheck
  interface Body {
    m: number;
    x: number;
    y: number;
    vx: number;
    vy: number;
  }

  function initNBody() {
    const canvasElement = document.getElementById('nbody-canvas') as HTMLCanvasElement | null;
    if (!canvasElement || canvasElement.dataset.initialized === 'true') return;
    const canvas = canvasElement;
    canvas.dataset.initialized = 'true';

    const ctx = canvas.getContext('2d')!;
    const W = 640;
    const H = 640;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const statusEl = document.getElementById('nbody-status')!;
    const runToggle = document.getElementById('run-toggle') as HTMLButtonElement;
    const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;
    const clearTrailsBtn = document.getElementById('clear-trails-btn') as HTMLButtonElement;
    const nudgeBtn = document.getElementById('nudge-btn') as HTMLButtonElement;
    const speedSlider = document.getElementById('speed-slider') as HTMLInputElement;
    const speedReadout = document.getElementById('speed-readout')!;
    const nudgeSlider = document.getElementById('nudge-slider') as HTMLInputElement;
    const nudgeReadout = document.getElementById('nudge-readout')!;
    const presetButtons = document.querySelectorAll<HTMLButtonElement>('[data-preset]');
    const metricEnergy = document.getElementById('metric-energy')!;
    const metricMomentum = document.getElementById('metric-momentum')!;
    const metricMinSep = document.getElementById('metric-minsep')!;
    const metricGhost = document.getElementById('metric-ghost')!;

    // ------------------------------------------------------------------
    // Physics — Yoshida 4th-order symplectic composition of velocity
    // Verlet with Plummer softening. Constants validated in Node:
    // figure-eight closes to 1e-4 per period, |dE/E| ~ 1e-11 over 50 periods.
    // ------------------------------------------------------------------
    const DT = 2e-3;
    const EPS2 = 1e-6;
    const CBRT2 = Math.cbrt(2);
    const Y_W1 = 1 / (2 - CBRT2);
    const Y_W0 = -CBRT2 / (2 - CBRT2);
    const YOSHIDA = [Y_W1, Y_W0, Y_W1];
    const TRAIL_MAX = 700;
    const TRAIL_STRIDE = 4; // record every 4th step

    let bodies: Body[] = [];
    let ghost: Body[] | null = null;
    let trails: { x: number; y: number }[][] = [];
    let stepCount = 0;
    let baselineEnergy = 0;
    let baselineL = 0;
    let minSeparation = Infinity;

    function accumulate(list: Body[], ax: Float64Array, ay: Float64Array) {
      ax.fill(0);
      ay.fill(0);
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const dx = list[j].x - list[i].x;
          const dy = list[j].y - list[i].y;
          const r2 = dx * dx + dy * dy + EPS2;
          const inv = 1 / (r2 * Math.sqrt(r2));
          ax[i] += list[j].m * dx * inv;
          ay[i] += list[j].m * dy * inv;
          ax[j] -= list[i].m * dx * inv;
          ay[j] -= list[i].m * dy * inv;
        }
      }
    }

    const scratchAX = new Float64Array(8);
    const scratchAY = new Float64Array(8);

    function verletStep(list: Body[], dt: number) {
      accumulate(list, scratchAX, scratchAY);
      for (let i = 0; i < list.length; i++) {
        list[i].vx += 0.5 * dt * scratchAX[i];
        list[i].vy += 0.5 * dt * scratchAY[i];
        list[i].x += dt * list[i].vx;
        list[i].y += dt * list[i].vy;
      }
      accumulate(list, scratchAX, scratchAY);
      for (let i = 0; i < list.length; i++) {
        list[i].vx += 0.5 * dt * scratchAX[i];
        list[i].vy += 0.5 * dt * scratchAY[i];
      }
    }

    function yoshidaStep(list: Body[]) {
      for (const w of YOSHIDA) verletStep(list, w * DT);
    }

    function energy(list: Body[]): number {
      let e = 0;
      for (const b of list) e += 0.5 * b.m * (b.vx * b.vx + b.vy * b.vy);
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const dx = list[j].x - list[i].x;
          const dy = list[j].y - list[i].y;
          e -= list[i].m * list[j].m / Math.sqrt(dx * dx + dy * dy + EPS2);
        }
      }
      return e;
    }

    function totalMomentum(list: Body[]): [number, number] {
      let px = 0, py = 0;
      for (const b of list) { px += b.m * b.vx; py += b.m * b.vy; }
      return [px, py];
    }

    function angularMomentum(list: Body[]): number {
      let l = 0;
      for (const b of list) l += b.m * (b.x * b.vy - b.y * b.vx);
      return l;
    }

    function pairMinDistance(list: Body[]): number {
      let min = Infinity;
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const d = Math.hypot(list[j].x - list[i].x, list[j].y - list[i].y);
          if (d < min) min = d;
        }
      }
      return min;
    }

    // shift to center-of-momentum frame so P = 0 and the view stays put
    function centerFrame(list: Body[]) {
      let M = 0, cx = 0, cy = 0, px = 0, py = 0;
      for (const b of list) { M += b.m; cx += b.m * b.x; cy += b.m * b.y; px += b.m * b.vx; py += b.m * b.vy; }
      for (const b of list) {
        b.x -= cx / M; b.y -= cy / M;
        b.vx -= px / M; b.vy -= py / M;
      }
    }

    // ------------------------------------------------------------------
    // Presets — known configurations, all set up in the COM frame
    // ------------------------------------------------------------------
    function circularSpeed(centralMass: number, r: number): number {
      return Math.sqrt(centralMass / r);
    }

    const presets: Record<string, () => Body[]> = {
      // Chenciner–Montgomery (2000) figure-eight, period T ≈ 6.32591398
      figure8: () => [
        { m: 1, x: 0.97000436, y: -0.24308753, vx: 0.4662036850, vy: 0.4323657300 },
        { m: 1, x: -0.97000436, y: 0.24308753, vx: 0.4662036850, vy: 0.4323657300 },
        { m: 1, x: 0, y: 0, vx: -0.93240737, vy: -0.86473146 },
      ],
      // exact rigid-rotation solution; linearly unstable for equal masses
      lagrange: () => {
        const omega = Math.sqrt(1 / Math.sqrt(3));
        return [0, 1, 2].map((k) => {
          const a = (k / 3) * 2 * Math.PI;
          return { m: 1, x: Math.cos(a), y: Math.sin(a), vx: -omega * Math.sin(a), vy: omega * Math.cos(a) };
        });
      },
      // hierarchical: moon well inside the planet's Hill sphere
      hierarchy: () => {
        const planetR = 1.4;
        const moonR = 0.05;
        const vP = circularSpeed(1, planetR);
        const vM = circularSpeed(0.01, moonR);
        return [
          { m: 1, x: 0, y: 0, vx: 0, vy: 0 },
          { m: 0.01, x: planetR, y: 0, vx: 0, vy: vP },
          { m: 0.0001, x: planetR + moonR, y: 0, vx: 0, vy: vP + vM },
        ];
      },
      // tight equal binary with a distant light planet
      binary: () => {
        const sep = 0.5;
        // each body circles the COM at v = ½·√(M_total/sep) for a circular pair
        const vBin = 0.5 * Math.sqrt(2 / sep);
        const planetR = 2.2;
        const vPl = circularSpeed(2, planetR);
        return [
          { m: 1, x: -sep / 2, y: 0, vx: 0, vy: -vBin },
          { m: 1, x: sep / 2, y: 0, vx: 0, vy: vBin },
          { m: 0.001, x: planetR, y: 0, vx: 0, vy: vPl },
        ];
      },
      // hierarchical double binary: two circular pairs waltzing around the COM
      // (validated bound and non-colliding for 120 time units, dE/E ~ 3e-8)
      scatter: () => {
        const inner = 0.3;
        const outer = 3.0;
        const vIn = 0.5 * Math.sqrt(2 / inner);
        const vOut = 0.5 * Math.sqrt(4 / outer);
        return [
          { m: 1, x: -outer / 2, y: inner / 2, vx: vIn, vy: -vOut },
          { m: 1, x: -outer / 2, y: -inner / 2, vx: -vIn, vy: -vOut },
          { m: 1, x: outer / 2, y: inner / 2, vx: vIn, vy: vOut },
          { m: 1, x: outer / 2, y: -inner / 2, vx: -vIn, vy: vOut },
        ];
      },
    };

    let activePreset = 'figure8';

    function loadPreset(name: string) {
      activePreset = name;
      bodies = presets[name]().map((b) => ({ ...b }));
      centerFrame(bodies);
      ghost = null;
      trails = bodies.map(() => []);
      stepCount = 0;
      minSeparation = Infinity;
      baselineEnergy = energy(bodies);
      baselineL = angularMomentum(bodies);
      viewScaleTarget = computeFitScale();
      viewScale = viewScaleTarget;
      presetButtons.forEach((b) => b.classList.toggle('is-active', b.dataset.preset === name));
      if (name === 'lagrange') {
        statusEl.textContent = 'The Lagrange triangle is an exact solution but linearly unstable. The integration is clean enough that it holds for many revolutions — nudge it and watch the instability grow for real.';
      } else if (name === 'figure8') {
        statusEl.textContent = 'Running. Nudge a body and a faint ghost keeps dancing the unperturbed choreography for comparison.';
      } else {
        statusEl.textContent = 'Running. Watch the conserved-quantity readouts while the system evolves.';
      }
    }

    // ------------------------------------------------------------------
    // Theme colors
    // ------------------------------------------------------------------
    function resolveColor(name: string, fallback: string): string {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim() || fallback;
    }
    let colors: { canvas: string; text: string; muted: string; cta: string; border: string };
    const bodyPalette = ['#b8324f', '#327ea8', '#3a8f5f', '#a8712c'];
    function readColors() {
      colors = {
        canvas: resolveColor('--mp-canvas', '#f8f4ed'),
        text: resolveColor('--mp-text', '#16202e'),
        muted: resolveColor('--mp-muted', '#4a5d6f'),
        cta: resolveColor('--mp-cta', '#b8324f'),
        border: resolveColor('--mp-border-strong', 'rgba(22,32,46,0.22)'),
      };
    }
    readColors();
    const themeObserver = new MutationObserver(readColors);
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ------------------------------------------------------------------
    // View: auto-fit with smoothing so escapes stay on screen
    // ------------------------------------------------------------------
    let viewScale = 100;
    let viewScaleTarget = 100;

    function computeFitScale(): number {
      let extent = 0.5;
      for (const b of bodies) extent = Math.max(extent, Math.abs(b.x), Math.abs(b.y));
      if (ghost) for (const b of ghost) extent = Math.max(extent, Math.abs(b.x), Math.abs(b.y));
      return (W * 0.5 * 0.82) / extent;
    }

    const toScreenX = (x: number) => W / 2 + x * viewScale;
    const toScreenY = (y: number) => H / 2 - y * viewScale;

    // ------------------------------------------------------------------
    // Simulation stepping (fixed dt, frame-rate independent)
    // ------------------------------------------------------------------
    function stepOnce() {
      yoshidaStep(bodies);
      if (ghost) yoshidaStep(ghost);
      stepCount++;
      if (stepCount % TRAIL_STRIDE === 0) {
        for (let i = 0; i < bodies.length; i++) {
          const t = trails[i];
          t.push({ x: bodies[i].x, y: bodies[i].y });
          if (t.length > TRAIL_MAX) t.shift();
        }
      }
      const d = pairMinDistance(bodies);
      if (d < minSeparation) minSeparation = d;
    }

    // ------------------------------------------------------------------
    // Rendering
    // ------------------------------------------------------------------
    function draw() {
      ctx.fillStyle = colors.canvas;
      ctx.fillRect(0, 0, W, H);

      // faint origin cross (center of momentum)
      ctx.strokeStyle = colors.border;
      ctx.lineWidth = 0.5;
      ctx.globalAlpha = 0.5;
      ctx.beginPath();
      ctx.moveTo(W / 2 - 8, H / 2); ctx.lineTo(W / 2 + 8, H / 2);
      ctx.moveTo(W / 2, H / 2 - 8); ctx.lineTo(W / 2, H / 2 + 8);
      ctx.stroke();
      ctx.globalAlpha = 1;

      // ghost trajectories (unperturbed twin)
      if (ghost) {
        ctx.globalAlpha = 0.35;
        for (let i = 0; i < ghost.length; i++) {
          const g = ghost[i];
          ctx.fillStyle = colors.muted;
          ctx.beginPath();
          ctx.arc(toScreenX(g.x), toScreenY(g.y), bodyRadius(g.m) * 0.85, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }

      // trails with age fade
      for (let i = 0; i < bodies.length; i++) {
        const t = trails[i];
        if (t.length < 2) continue;
        const color = bodyPalette[i % bodyPalette.length];
        for (let k = 1; k < t.length; k++) {
          ctx.strokeStyle = color;
          ctx.globalAlpha = 0.05 + 0.5 * (k / t.length);
          ctx.lineWidth = 1.2;
          ctx.beginPath();
          ctx.moveTo(toScreenX(t[k - 1].x), toScreenY(t[k - 1].y));
          ctx.lineTo(toScreenX(t[k].x), toScreenY(t[k].y));
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;

      // bodies
      for (let i = 0; i < bodies.length; i++) {
        const b = bodies[i];
        const r = bodyRadius(b.m);
        const sx = toScreenX(b.x);
        const sy = toScreenY(b.y);
        ctx.fillStyle = bodyPalette[i % bodyPalette.length];
        ctx.beginPath();
        ctx.arc(sx, sy, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = colors.canvas;
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }
    }

    function bodyRadius(m: number): number {
      return Math.max(3.5, Math.min(11, 8 * Math.cbrt(m)));
    }

    // ------------------------------------------------------------------
    // Metrics
    // ------------------------------------------------------------------
    function updateMetrics() {
      const eScale = Math.max(1e-9, Math.abs(baselineEnergy));
      const drift = (energy(bodies) - baselineEnergy) / eScale;
      metricEnergy.textContent = `${drift >= 0 ? '' : '−'}${Math.abs(drift).toExponential(1)}`;
      const [px, py] = totalMomentum(bodies);
      const dL = Math.abs(angularMomentum(bodies) - baselineL);
      metricMomentum.textContent = `${Math.hypot(px, py).toExponential(1)} / ${dL.toExponential(1)}`;
      metricMinSep.textContent = minSeparation === Infinity ? '—' : minSeparation.toFixed(3);
      if (ghost) {
        let sep = 0;
        for (let i = 0; i < bodies.length; i++) {
          sep += Math.hypot(bodies[i].x - ghost[i].x, bodies[i].y - ghost[i].y) ** 2;
        }
        metricGhost.textContent = Math.sqrt(sep / bodies.length).toExponential(2);
      } else {
        metricGhost.textContent = 'no ghost yet';
      }
    }

    // ------------------------------------------------------------------
    // Controls
    // ------------------------------------------------------------------
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let running = !reducedMotion;
    let simSpeed = 1;
    let accumulator = 0;
    let lastFrameTime = performance.now();
    let animationFrameId = 0;
    let destroyed = false;
    let frameCounter = 0;

    function setRunning(next: boolean) {
      running = next;
      runToggle.textContent = running ? 'Pause' : 'Play';
      runToggle.classList.toggle('is-active', running);
      runToggle.setAttribute('aria-pressed', String(running));
    }

    // Reduced motion: integrate ahead and show the trajectories as a still
    function staticPortrait() {
      const steps = Math.round(8 / DT);
      for (let s = 0; s < steps; s++) stepOnce();
      viewScale = computeFitScale();
      draw();
      updateMetrics();
    }

    runToggle.addEventListener('click', () => setRunning(!running));
    restartBtn.addEventListener('click', () => {
      loadPreset(activePreset);
      if (reducedMotion) staticPortrait();
      else draw();
      updateMetrics();
    });
    clearTrailsBtn.addEventListener('click', () => {
      trails = bodies.map(() => []);
      draw();
    });

    speedSlider.addEventListener('input', () => {
      simSpeed = parseFloat(speedSlider.value);
      speedReadout.textContent = `${simSpeed.toFixed(2).replace(/0$/, '')}×`;
    });
    nudgeSlider.addEventListener('input', () => {
      nudgeReadout.textContent = Math.pow(10, parseFloat(nudgeSlider.value)).toExponential(1);
    });

    nudgeBtn.addEventListener('click', () => {
      ghost = bodies.map((b) => ({ ...b }));
      const magnitude = Math.pow(10, parseFloat(nudgeSlider.value));
      const target = Math.floor(Math.random() * bodies.length);
      const angle = Math.random() * Math.PI * 2;
      bodies[target].vx += magnitude * Math.cos(angle);
      bodies[target].vy += magnitude * Math.sin(angle);
      statusEl.textContent = `Nudged body ${target + 1} by |δv| = ${magnitude.toExponential(0)}. The faint ghost is the unperturbed system.`;
      if (reducedMotion) staticPortrait();
      updateMetrics();
    });

    presetButtons.forEach((b) => {
      b.addEventListener('click', () => {
        loadPreset(b.dataset.preset ?? 'figure8');
        if (reducedMotion) staticPortrait();
        else draw();
        updateMetrics();
      });
    });

    // ------------------------------------------------------------------
    // Main loop
    // ------------------------------------------------------------------
    function renderFrame(frameTime: number) {
      if (destroyed) return;
      const elapsed = Math.min(0.05, Math.max(0, frameTime - lastFrameTime) / 1000);
      lastFrameTime = frameTime;

      if (running && isVisible) {
        accumulator += elapsed * simSpeed;
        let safety = 0;
        // one simulated time unit ≈ 1 real second at 1×
        while (accumulator >= DT && safety < 120) {
          stepOnce();
          accumulator -= DT;
          safety++;
        }
        viewScaleTarget = computeFitScale();
        // zoom out fast, zoom back in slowly
        viewScale += (Math.min(viewScaleTarget, viewScale * 1.5) - viewScale) *
          (viewScaleTarget < viewScale ? 0.25 : 0.02);
        draw();
        frameCounter++;
        if (frameCounter % 12 === 0) updateMetrics();
      }
      animationFrameId = requestAnimationFrame(renderFrame);
    }

    let isVisible = true;
    const io = new IntersectionObserver((entries) => {
      isVisible = entries[0].isIntersecting && !document.hidden;
    });
    io.observe(canvas);

    function handleVisibilityChange() { 
      lastFrameTime = performance.now(); 
      isVisible = !document.hidden;
    }
    document.addEventListener('visibilitychange', handleVisibilityChange);

    // ------------------------------------------------------------------
    // Boot
    // ------------------------------------------------------------------
    loadPreset('figure8');
    if (reducedMotion) {
      setRunning(false);
      statusEl.textContent = 'Reduced motion is on: each configuration is shown as a completed orbital portrait instead of a live animation.';
      staticPortrait();
    } else {
      setRunning(true);
      draw();
    }
    updateMetrics();
    animationFrameId = requestAnimationFrame(renderFrame);

    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = btn.dataset.copyTarget;
        const codeEl = targetId ? document.getElementById(targetId) : null;
        if (!codeEl) return;
        try {
          await navigator.clipboard.writeText(codeEl.textContent ?? '');
          const original = btn.textContent;
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = original; }, 1500);
        } catch {}
      });
    });

    document.addEventListener('astro:before-swap', () => {
      destroyed = true;
      cancelAnimationFrame(animationFrameId);
      themeObserver.disconnect();
      io.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initNBody);
  initNBody();
</script>
