---
import Layout from '../../layouts/Layout.astro';
import PlaygroundShell from '../../components/PlaygroundShell.astro';

const title = 'N-Body Orbital Choreography — Figure-Eight Gravity | MakerPortal';
const description =
  'Three bodies chasing each other around the Chenciner–Montgomery figure-eight, integrated with a 4th-order symplectic scheme. Nudge the choreography and race it against an unperturbed ghost.';
const canonical = new URL('/playground/n-body-choreography', Astro.site);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Playground', item: 'https://www.makerportal.ai/playground' },
    { '@type': 'ListItem', position: 3, name: 'N-Body Orbital Choreography', item: canonical.toString() },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  </Fragment>

  <PlaygroundShell
    title="N-Body Orbital Choreography"
    lead="In 2000, Chenciner and Montgomery proved three equal masses can chase each other forever around a figure-eight. It exists in real gravity — this page integrates it live with a symplectic scheme accurate enough to hold the dance for hundreds of orbits, then lets you nudge it and watch how long the choreography survives."
  >
    <section class="border-b border-border" aria-labelledby="simulation-title">
      <div class="mx-auto max-w-[76rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h2 id="simulation-title" class="text-[clamp(1.35rem,3vw,1.8rem)] font-[650] tracking-[-0.04em] text-primary-text">A stable dance, until you touch it</h2>
            <p id="nbody-status" class="mt-2 max-w-2xl text-[0.88rem] leading-[1.55] text-muted-text">Running. Nudge a body and a faint ghost keeps dancing the unperturbed choreography for comparison.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <button type="button" class="sim-btn is-active" id="run-toggle" aria-pressed="true">Pause</button>
            <button type="button" class="sim-btn" id="restart-btn">Restart</button>
            <button type="button" class="sim-btn" id="clear-trails-btn">Clear trails</button>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-1 gap-5 lg:grid-cols-[1.15fr_1fr]">
          <div class="canvas-card">
            <div class="canvas-label-row">
              <span>Gravity, G = 1</span>
              <span>View auto-fits the system</span>
            </div>
            <canvas
              id="nbody-canvas"
              width="640"
              height="640"
              aria-label="N-body gravity simulation showing bodies and their orbital trails"
            ></canvas>
          </div>

          <div class="rounded-[20px] border border-border bg-card-bg p-5 lg:p-6">
            <div class="flex flex-wrap gap-2" aria-label="Initial condition presets">
              <button type="button" class="preset-btn is-active" data-preset="figure8">Figure-eight</button>
              <button type="button" class="preset-btn" data-preset="lagrange">Lagrange triangle</button>
              <button type="button" class="preset-btn" data-preset="hierarchy">Sun · planet · moon</button>
              <button type="button" class="preset-btn" data-preset="binary">Binary + planet</button>
              <button type="button" class="preset-btn" data-preset="scatter">Double binary</button>
            </div>

            <div class="mt-5 grid gap-5">
              <label class="control-label" for="speed-slider">
                <span>Time scale</span><output id="speed-readout">1.0×</output>
                <input type="range" id="speed-slider" min="0.25" max="4" step="0.25" value="1" />
              </label>

              <label class="control-label" for="nudge-slider">
                <span>Nudge magnitude |δv|</span><output id="nudge-readout">1.0e-3</output>
                <input type="range" id="nudge-slider" min="-5" max="-1.5" step="0.5" value="-3" aria-label="Nudge magnitude, powers of ten" />
              </label>

              <div class="flex flex-wrap items-center gap-2">
                <button type="button" class="sim-btn" id="nudge-btn">Nudge a body</button>
                <span class="font-mono text-[0.62rem] uppercase tracking-[0.1em] text-muted-text">spawns an unperturbed ghost to race</span>
              </div>
            </div>

            <dl class="mt-6 grid grid-cols-2 gap-3 font-mono text-[0.75rem]" aria-live="off">
              <div class="metric-card"><dt>Energy drift</dt><dd id="metric-energy">—</dd></div>
              <div class="metric-card"><dt>Momentum |P| / |L drift|</dt><dd id="metric-momentum">—</dd></div>
              <div class="metric-card"><dt>Min separation</dt><dd id="metric-minsep">—</dd></div>
              <div class="metric-card"><dt>Ghost divergence</dt><dd id="metric-ghost">—</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="math-title">
      <div class="mx-auto max-w-[66rem] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
        <h2 id="math-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">Why the integrator matters more than the forces</h2>
        <div class="mt-5 grid gap-6 text-[0.92rem] leading-[1.7] text-muted-text md:grid-cols-2">
          <p>
            Newtonian gravity between three bodies has no general closed-form solution — this is the original chaos problem. Ordinary integrators (like RK4) leak energy steadily, so an orbit that should repeat forever spirals in or escapes as pure numerical artifact. A <strong class="text-primary-text">symplectic</strong> integrator instead conserves a slightly-perturbed energy exactly, so the error stays bounded for hundreds of periods instead of accumulating.
          </p>
          <p>
            The figure-eight is special: it is a proven periodic solution, and mildly stable — tiny perturbations wobble around it rather than destroying it instantly. The Lagrange triangle is its opposite: an exact solution that is <em>linearly unstable</em> for equal masses. The integration here is clean enough that the triangle holds until you seed the instability yourself — nudge it, then watch the same |δv| that barely dents the figure-eight tear the triangle apart. That asymmetry is real physics, not integration error.
          </p>
        </div>
        <div class="mt-7 grid gap-4 md:grid-cols-2">
          <div class="math-card">
            <p class="math-label">Integration scheme</p>
            <p class="mt-2">Yoshida 4th-order composition of velocity Verlet, dt = 2·10⁻³</p>
            <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">Three Verlet sub-steps with weights (w₁, w₀, w₁), w₀ = −∛2·w₁. Validated: figure-eight returns to its start after one period (T ≈ 6.3259) to within 10⁻⁴, energy drift ~10⁻¹¹ over 50 periods.</p>
          </div>
          <div class="math-card">
            <p class="math-label">Collision safety</p>
            <p class="mt-2">r² → r² + ε², ε² = 10⁻⁶</p>
            <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">Plummer softening caps the force during close encounters so the integration never blows up. At choreography distances (~1) it shifts positions by less than 10⁻⁴; the min-separation readout tells you when it is actually active.</p>
          </div>
          <div class="math-card">
            <p class="math-label">Conserved quantities</p>
            <p class="mt-2">E = Σ ½mv² − Σ mᵢmⱼ/rᵢⱼ, P = Σ mv, L = Σ m(r × v)</p>
            <p class="mt-3 text-[0.74rem] leading-[1.55] text-muted-text">All three are monitored live and shown without smoothing. Initial conditions are shifted to the center-of-momentum frame, so |P| should sit at machine precision.</p>
          </div>
          <div class="math-card">
            <p class="math-label">Honest limitations</p>
            <p class="mt-2 text-[0.74rem] leading-[1.55] text-muted-text">Fixed-step integration loses accuracy during very close encounters (the softening is what keeps it finite); a production ephemeris would switch to adaptive or regularized steps. Everything is planar (2D), and the ghost comparison shares the same integrator — it measures sensitivity to the nudge, not absolute truth.</p>
          </div>
        </div>
      </div>
    </section>
  </PlaygroundShell>
</Layout>

<style>
  .sim-btn,
  .preset-btn {
    min-height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid var(--mp-border);
    background: var(--mp-elevated);
    padding: 0.45rem 0.95rem;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mp-muted);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .sim-btn:hover,
  .preset-btn:hover {
    color: var(--mp-text);
    border-color: var(--mp-border-strong);
  }
  .sim-btn.is-active,
  .preset-btn.is-active {
    color: var(--mp-canvas);
    border-color: var(--mp-text);
    background: var(--mp-text);
  }
  .canvas-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--mp-border);
    border-radius: 20px;
    background: var(--mp-card);
    align-self: start;
  }
  .canvas-label-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--mp-border);
    padding: 0.8rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mp-muted);
  }
  #nbody-canvas {
    display: block;
    max-width: 100%;
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    background: var(--mp-canvas);
  }
  .control-label {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mp-muted);
  }
  .control-label output { color: var(--mp-text); }
  .control-label input {
    grid-column: 1 / -1;
    width: 100%;
    accent-color: var(--mp-cta);
  }
  .metric-card,
  .math-card {
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--mp-elevated) 48%, transparent);
    padding: 0.85rem;
  }
  .metric-card dt,
  .math-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--mp-muted);
  }
  .metric-card dd {
    margin-top: 0.35rem;
    font-weight: 650;
    color: var(--mp-text);
  }
  .math-card {
    font-family: var(--font-mono);
    color: var(--mp-text);
  }
</style>

<script>
  interface Body {
    m: number;
    x: number;
    y: number;
    vx: number;
    vy: number;
  }

  function initNBody() {
    const canvasElement = document.getElementById('nbody-canvas') as HTMLCanvasElement | null;
    if (!canvasElement || canvasElement.dataset.initialized === 'true') return;
    const canvas = canvasElement;
    canvas.dataset.initialized = 'true';

    const ctx = canvas.getContext('2d')!;
    const W = 640;
    const H = 640;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const statusEl = document.getElementById('nbody-status')!;
    const runToggle = document.getElementById('run-toggle') as HTMLButtonElement;
    const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;
    const clearTrailsBtn = document.getElementById('clear-trails-btn') as HTMLButtonElement;
    const nudgeBtn = document.getElementById('nudge-btn') as HTMLButtonElement;
    const speedSlider = document.getElementById('speed-slider') as HTMLInputElement;
    const speedReadout = document.getElementById('speed-readout')!;
    const nudgeSlider = document.getElementById('nudge-slider') as HTMLInputElement;
    const nudgeReadout = document.getElementById('nudge-readout')!;
    const presetButtons = document.querySelectorAll<HTMLButtonElement>('[data-preset]');
    const metricEnergy = document.getElementById('metric-energy')!;
    const metricMomentum = document.getElementById('metric-momentum')!;
    const metricMinSep = document.getElementById('metric-minsep')!;
    const metricGhost = document.getElementById('metric-ghost')!;

    // ------------------------------------------------------------------
    // Physics — Yoshida 4th-order symplectic composition of velocity
    // Verlet with Plummer softening. Constants validated in Node:
    // figure-eight closes to 1e-4 per period, |dE/E| ~ 1e-11 over 50 periods.
    // ------------------------------------------------------------------
    const DT = 2e-3;
    const EPS2 = 1e-6;
    const CBRT2 = Math.cbrt(2);
    const Y_W1 = 1 / (2 - CBRT2);
    const Y_W0 = -CBRT2 / (2 - CBRT2);
    const YOSHIDA = [Y_W1, Y_W0, Y_W1];
    const TRAIL_MAX = 700;
    const TRAIL_STRIDE = 4; // record every 4th step

    let bodies: Body[] = [];
    let ghost: Body[] | null = null;
    let trails: { x: number; y: number }[][] = [];
    let stepCount = 0;
    let baselineEnergy = 0;
    let baselineL = 0;
    let minSeparation = Infinity;

    function accumulate(list: Body[], ax: Float64Array, ay: Float64Array) {
      ax.fill(0);
      ay.fill(0);
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const dx = list[j].x - list[i].x;
          const dy = list[j].y - list[i].y;
          const r2 = dx * dx + dy * dy + EPS2;
          const inv = 1 / (r2 * Math.sqrt(r2));
          ax[i] += list[j].m * dx * inv;
          ay[i] += list[j].m * dy * inv;
          ax[j] -= list[i].m * dx * inv;
          ay[j] -= list[i].m * dy * inv;
        }
      }
    }

    const scratchAX = new Float64Array(8);
    const scratchAY = new Float64Array(8);

    function verletStep(list: Body[], dt: number) {
      accumulate(list, scratchAX, scratchAY);
      for (let i = 0; i < list.length; i++) {
        list[i].vx += 0.5 * dt * scratchAX[i];
        list[i].vy += 0.5 * dt * scratchAY[i];
        list[i].x += dt * list[i].vx;
        list[i].y += dt * list[i].vy;
      }
      accumulate(list, scratchAX, scratchAY);
      for (let i = 0; i < list.length; i++) {
        list[i].vx += 0.5 * dt * scratchAX[i];
        list[i].vy += 0.5 * dt * scratchAY[i];
      }
    }

    function yoshidaStep(list: Body[]) {
      for (const w of YOSHIDA) verletStep(list, w * DT);
    }

    function energy(list: Body[]): number {
      let e = 0;
      for (const b of list) e += 0.5 * b.m * (b.vx * b.vx + b.vy * b.vy);
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const dx = list[j].x - list[i].x;
          const dy = list[j].y - list[i].y;
          e -= list[i].m * list[j].m / Math.sqrt(dx * dx + dy * dy + EPS2);
        }
      }
      return e;
    }

    function totalMomentum(list: Body[]): [number, number] {
      let px = 0, py = 0;
      for (const b of list) { px += b.m * b.vx; py += b.m * b.vy; }
      return [px, py];
    }

    function angularMomentum(list: Body[]): number {
      let l = 0;
      for (const b of list) l += b.m * (b.x * b.vy - b.y * b.vx);
      return l;
    }

    function pairMinDistance(list: Body[]): number {
      let min = Infinity;
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const d = Math.hypot(list[j].x - list[i].x, list[j].y - list[i].y);
          if (d < min) min = d;
        }
      }
      return min;
    }

    // shift to center-of-momentum frame so P = 0 and the view stays put
    function centerFrame(list: Body[]) {
      let M = 0, cx = 0, cy = 0, px = 0, py = 0;
      for (const b of list) { M += b.m; cx += b.m * b.x; cy += b.m * b.y; px += b.m * b.vx; py += b.m * b.vy; }
      for (const b of list) {
        b.x -= cx / M; b.y -= cy / M;
        b.vx -= px / M; b.vy -= py / M;
      }
    }

    // ------------------------------------------------------------------
    // Presets — known configurations, all set up in the COM frame
    // ------------------------------------------------------------------
    function circularSpeed(centralMass: number, r: number): number {
      return Math.sqrt(centralMass / r);
    }

    const presets: Record<string, () => Body[]> = {
      // Chenciner–Montgomery (2000) figure-eight, period T ≈ 6.32591398
      figure8: () => [
        { m: 1, x: 0.97000436, y: -0.24308753, vx: 0.4662036850, vy: 0.4323657300 },
        { m: 1, x: -0.97000436, y: 0.24308753, vx: 0.4662036850, vy: 0.4323657300 },
        { m: 1, x: 0, y: 0, vx: -0.93240737, vy: -0.86473146 },
      ],
      // exact rigid-rotation solution; linearly unstable for equal masses
      lagrange: () => {
        const omega = Math.sqrt(1 / Math.sqrt(3));
        return [0, 1, 2].map((k) => {
          const a = (k / 3) * 2 * Math.PI;
          return { m: 1, x: Math.cos(a), y: Math.sin(a), vx: -omega * Math.sin(a), vy: omega * Math.cos(a) };
        });
      },
      // hierarchical: moon well inside the planet's Hill sphere
      hierarchy: () => {
        const planetR = 1.4;
        const moonR = 0.05;
        const vP = circularSpeed(1, planetR);
        const vM = circularSpeed(0.01, moonR);
        return [
          { m: 1, x: 0, y: 0, vx: 0, vy: 0 },
          { m: 0.01, x: planetR, y: 0, vx: 0, vy: vP },
          { m: 0.0001, x: planetR + moonR, y: 0, vx: 0, vy: vP + vM },
        ];
      },
      // tight equal binary with a distant light planet
      binary: () => {
        const sep = 0.5;
        // each body circles the COM at v = ½·√(M_total/sep) for a circular pair
        const vBin = 0.5 * Math.sqrt(2 / sep);
        const planetR = 2.2;
        const vPl = circularSpeed(2, planetR);
        return [
          { m: 1, x: -sep / 2, y: 0, vx: 0, vy: -vBin },
          { m: 1, x: sep / 2, y: 0, vx: 0, vy: vBin },
          { m: 0.001, x: planetR, y: 0, vx: 0, vy: vPl },
        ];
      },
      // hierarchical double binary: two circular pairs waltzing around the COM
      // (validated bound and non-colliding for 120 time units, dE/E ~ 3e-8)
      scatter: () => {
        const inner = 0.3;
        const outer = 3.0;
        const vIn = 0.5 * Math.sqrt(2 / inner);
        const vOut = 0.5 * Math.sqrt(4 / outer);
        return [
          { m: 1, x: -outer / 2, y: inner / 2, vx: vIn, vy: -vOut },
          { m: 1, x: -outer / 2, y: -inner / 2, vx: -vIn, vy: -vOut },
          { m: 1, x: outer / 2, y: inner / 2, vx: vIn, vy: vOut },
          { m: 1, x: outer / 2, y: -inner / 2, vx: -vIn, vy: vOut },
        ];
      },
    };

    let activePreset = 'figure8';

    function loadPreset(name: string) {
      activePreset = name;
      bodies = presets[name]().map((b) => ({ ...b }));
      centerFrame(bodies);
      ghost = null;
      trails = bodies.map(() => []);
      stepCount = 0;
      minSeparation = Infinity;
      baselineEnergy = energy(bodies);
      baselineL = angularMomentum(bodies);
      viewScaleTarget = computeFitScale();
      viewScale = viewScaleTarget;
      presetButtons.forEach((b) => b.classList.toggle('is-active', b.dataset.preset === name));
      if (name === 'lagrange') {
        statusEl.textContent = 'The Lagrange triangle is an exact solution but linearly unstable. The integration is clean enough that it holds for many revolutions — nudge it and watch the instability grow for real.';
      } else if (name === 'figure8') {
        statusEl.textContent = 'Running. Nudge a body and a faint ghost keeps dancing the unperturbed choreography for comparison.';
      } else {
        statusEl.textContent = 'Running. Watch the conserved-quantity readouts while the system evolves.';
      }
    }

    // ------------------------------------------------------------------
    // Theme colors
    // ------------------------------------------------------------------
    function resolveColor(name: string, fallback: string): string {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim() || fallback;
    }
    let colors: { canvas: string; text: string; muted: string; cta: string; border: string };
    const bodyPalette = ['#b8324f', '#327ea8', '#3a8f5f', '#a8712c'];
    function readColors() {
      colors = {
        canvas: resolveColor('--mp-canvas', '#f8f4ed'),
        text: resolveColor('--mp-text', '#16202e'),
        muted: resolveColor('--mp-muted', '#4a5d6f'),
        cta: resolveColor('--mp-cta', '#b8324f'),
        border: resolveColor('--mp-border-strong', 'rgba(22,32,46,0.22)'),
      };
    }
    readColors();
    const themeObserver = new MutationObserver(readColors);
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ------------------------------------------------------------------
    // View: auto-fit with smoothing so escapes stay on screen
    // ------------------------------------------------------------------
    let viewScale = 100;
    let viewScaleTarget = 100;

    function computeFitScale(): number {
      let extent = 0.5;
      for (const b of bodies) extent = Math.max(extent, Math.abs(b.x), Math.abs(b.y));
      if (ghost) for (const b of ghost) extent = Math.max(extent, Math.abs(b.x), Math.abs(b.y));
      return (W * 0.5 * 0.82) / extent;
    }

    const toScreenX = (x: number) => W / 2 + x * viewScale;
    const toScreenY = (y: number) => H / 2 - y * viewScale;

    // ------------------------------------------------------------------
    // Simulation stepping (fixed dt, frame-rate independent)
    // ------------------------------------------------------------------
    function stepOnce() {
      yoshidaStep(bodies);
      if (ghost) yoshidaStep(ghost);
      stepCount++;
      if (stepCount % TRAIL_STRIDE === 0) {
        for (let i = 0; i < bodies.length; i++) {
          const t = trails[i];
          t.push({ x: bodies[i].x, y: bodies[i].y });
          if (t.length > TRAIL_MAX) t.shift();
        }
      }
      const d = pairMinDistance(bodies);
      if (d < minSeparation) minSeparation = d;
    }

    // ------------------------------------------------------------------
    // Rendering
    // ------------------------------------------------------------------
    function draw() {
      ctx.fillStyle = colors.canvas;
      ctx.fillRect(0, 0, W, H);

      // faint origin cross (center of momentum)
      ctx.strokeStyle = colors.border;
      ctx.lineWidth = 0.5;
      ctx.globalAlpha = 0.5;
      ctx.beginPath();
      ctx.moveTo(W / 2 - 8, H / 2); ctx.lineTo(W / 2 + 8, H / 2);
      ctx.moveTo(W / 2, H / 2 - 8); ctx.lineTo(W / 2, H / 2 + 8);
      ctx.stroke();
      ctx.globalAlpha = 1;

      // ghost trajectories (unperturbed twin)
      if (ghost) {
        ctx.globalAlpha = 0.35;
        for (let i = 0; i < ghost.length; i++) {
          const g = ghost[i];
          ctx.fillStyle = colors.muted;
          ctx.beginPath();
          ctx.arc(toScreenX(g.x), toScreenY(g.y), bodyRadius(g.m) * 0.85, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }

      // trails with age fade
      for (let i = 0; i < bodies.length; i++) {
        const t = trails[i];
        if (t.length < 2) continue;
        const color = bodyPalette[i % bodyPalette.length];
        for (let k = 1; k < t.length; k++) {
          ctx.strokeStyle = color;
          ctx.globalAlpha = 0.05 + 0.5 * (k / t.length);
          ctx.lineWidth = 1.2;
          ctx.beginPath();
          ctx.moveTo(toScreenX(t[k - 1].x), toScreenY(t[k - 1].y));
          ctx.lineTo(toScreenX(t[k].x), toScreenY(t[k].y));
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;

      // bodies
      for (let i = 0; i < bodies.length; i++) {
        const b = bodies[i];
        const r = bodyRadius(b.m);
        const sx = toScreenX(b.x);
        const sy = toScreenY(b.y);
        ctx.fillStyle = bodyPalette[i % bodyPalette.length];
        ctx.beginPath();
        ctx.arc(sx, sy, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = colors.canvas;
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }
    }

    function bodyRadius(m: number): number {
      return Math.max(3.5, Math.min(11, 8 * Math.cbrt(m)));
    }

    // ------------------------------------------------------------------
    // Metrics
    // ------------------------------------------------------------------
    function updateMetrics() {
      const eScale = Math.max(1e-9, Math.abs(baselineEnergy));
      const drift = (energy(bodies) - baselineEnergy) / eScale;
      metricEnergy.textContent = `${drift >= 0 ? '' : '−'}${Math.abs(drift).toExponential(1)}`;
      const [px, py] = totalMomentum(bodies);
      const dL = Math.abs(angularMomentum(bodies) - baselineL);
      metricMomentum.textContent = `${Math.hypot(px, py).toExponential(1)} / ${dL.toExponential(1)}`;
      metricMinSep.textContent = minSeparation === Infinity ? '—' : minSeparation.toFixed(3);
      if (ghost) {
        let sep = 0;
        for (let i = 0; i < bodies.length; i++) {
          sep += Math.hypot(bodies[i].x - ghost[i].x, bodies[i].y - ghost[i].y) ** 2;
        }
        metricGhost.textContent = Math.sqrt(sep / bodies.length).toExponential(2);
      } else {
        metricGhost.textContent = 'no ghost yet';
      }
    }

    // ------------------------------------------------------------------
    // Controls
    // ------------------------------------------------------------------
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let running = !reducedMotion;
    let simSpeed = 1;
    let accumulator = 0;
    let lastFrameTime = performance.now();
    let animationFrameId = 0;
    let destroyed = false;
    let frameCounter = 0;

    function setRunning(next: boolean) {
      running = next;
      runToggle.textContent = running ? 'Pause' : 'Play';
      runToggle.classList.toggle('is-active', running);
      runToggle.setAttribute('aria-pressed', String(running));
    }

    // Reduced motion: integrate ahead and show the trajectories as a still
    function staticPortrait() {
      const steps = Math.round(8 / DT);
      for (let s = 0; s < steps; s++) stepOnce();
      viewScale = computeFitScale();
      draw();
      updateMetrics();
    }

    runToggle.addEventListener('click', () => setRunning(!running));
    restartBtn.addEventListener('click', () => {
      loadPreset(activePreset);
      if (reducedMotion) staticPortrait();
      else draw();
      updateMetrics();
    });
    clearTrailsBtn.addEventListener('click', () => {
      trails = bodies.map(() => []);
      draw();
    });

    speedSlider.addEventListener('input', () => {
      simSpeed = parseFloat(speedSlider.value);
      speedReadout.textContent = `${simSpeed.toFixed(2).replace(/0$/, '')}×`;
    });
    nudgeSlider.addEventListener('input', () => {
      nudgeReadout.textContent = Math.pow(10, parseFloat(nudgeSlider.value)).toExponential(1);
    });

    nudgeBtn.addEventListener('click', () => {
      ghost = bodies.map((b) => ({ ...b }));
      const magnitude = Math.pow(10, parseFloat(nudgeSlider.value));
      const target = Math.floor(Math.random() * bodies.length);
      const angle = Math.random() * Math.PI * 2;
      bodies[target].vx += magnitude * Math.cos(angle);
      bodies[target].vy += magnitude * Math.sin(angle);
      statusEl.textContent = `Nudged body ${target + 1} by |δv| = ${magnitude.toExponential(0)}. The faint ghost is the unperturbed system.`;
      if (reducedMotion) staticPortrait();
      updateMetrics();
    });

    presetButtons.forEach((b) => {
      b.addEventListener('click', () => {
        loadPreset(b.dataset.preset ?? 'figure8');
        if (reducedMotion) staticPortrait();
        else draw();
        updateMetrics();
      });
    });

    // ------------------------------------------------------------------
    // Main loop
    // ------------------------------------------------------------------
    function renderFrame(frameTime: number) {
      if (destroyed) return;
      const elapsed = Math.min(0.05, Math.max(0, frameTime - lastFrameTime) / 1000);
      lastFrameTime = frameTime;

      if (running && isVisible) {
        accumulator += elapsed * simSpeed;
        let safety = 0;
        // one simulated time unit ≈ 1 real second at 1×
        while (accumulator >= DT && safety < 120) {
          stepOnce();
          accumulator -= DT;
          safety++;
        }
        viewScaleTarget = computeFitScale();
        // zoom out fast, zoom back in slowly
        viewScale += (Math.min(viewScaleTarget, viewScale * 1.5) - viewScale) *
          (viewScaleTarget < viewScale ? 0.25 : 0.02);
        draw();
        frameCounter++;
        if (frameCounter % 12 === 0) updateMetrics();
      }
      animationFrameId = requestAnimationFrame(renderFrame);
    }

    let isVisible = true;
    const io = new IntersectionObserver((entries) => {
      isVisible = entries[0].isIntersecting && !document.hidden;
    });
    io.observe(canvas);

    function handleVisibilityChange() { 
      lastFrameTime = performance.now(); 
      isVisible = !document.hidden;
    }
    document.addEventListener('visibilitychange', handleVisibilityChange);

    // ------------------------------------------------------------------
    // Boot
    // ------------------------------------------------------------------
    loadPreset('figure8');
    if (reducedMotion) {
      setRunning(false);
      statusEl.textContent = 'Reduced motion is on: each configuration is shown as a completed orbital portrait instead of a live animation.';
      staticPortrait();
    } else {
      setRunning(true);
      draw();
    }
    updateMetrics();
    animationFrameId = requestAnimationFrame(renderFrame);

    document.addEventListener('astro:before-swap', () => {
      destroyed = true;
      cancelAnimationFrame(animationFrameId);
      themeObserver.disconnect();
      io.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initNBody);
  initNBody();
</script>
