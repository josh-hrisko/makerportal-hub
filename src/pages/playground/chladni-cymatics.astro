<script>
  function initChladni() {
    const canvasElement = document.getElementById('chladni-canvas') as HTMLCanvasElement | null;
    if (!canvasElement || canvasElement.dataset.initialized === 'true') return;
    const canvas = canvasElement;
    canvas.dataset.initialized = 'true';

    const ctx = canvas.getContext('2d')!;
    const W = 640;
    const H = 640;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    // ------------------------------------------------------------------
    // DOM
    // ------------------------------------------------------------------
    const statusEl = document.getElementById('chladni-status')!;
    const runToggle = document.getElementById('run-toggle') as HTMLButtonElement;
    const resandBtn = document.getElementById('resand-btn') as HTMLButtonElement;
    const fieldToggle = document.getElementById('field-toggle') as HTMLButtonElement;
    const sweepToggle = document.getElementById('sweep-toggle') as HTMLButtonElement;
    const freqSlider = document.getElementById('freq-slider') as HTMLInputElement;
    const freqReadout = document.getElementById('freq-readout')!;
    const gammaSlider = document.getElementById('gamma-slider') as HTMLInputElement;
    const gammaReadout = document.getElementById('gamma-readout')!;
    const presetButtons = document.querySelectorAll<HTMLButtonElement>('[data-preset]');
    const driveButtons = document.querySelectorAll<HTMLButtonElement>('[data-drive]');
    const grainButtons = document.querySelectorAll<HTMLButtonElement>('[data-grains]');
    const metricModes = document.getElementById('metric-modes')!;
    const metricShare = document.getElementById('metric-share')!;
    const metricSettled = document.getElementById('metric-settled')!;
    const metricDriver = document.getElementById('metric-driver')!;

    // ------------------------------------------------------------------
    // Model constants — validated numerically in Node before shipping
    // (resonance selectivity, nodal-line residuals, transport convergence,
    //  frame-rate independence, separable-grid exactness).
    // ------------------------------------------------------------------
    const MAX_MODE = 8;
    const GRID = 144;                 // field grid cells per axis
    const PHYSICS_DT = 1 / 120;
    const MU = 0.12;                  // gradient mobility
    const JITTER = 0.006;             // amplitude-scaled random-walk step
    const STEP_CAP = 0.004;           // per-step displacement cap (plate units)
    const COEFF_KEEP = 16;            // strongest modes kept per rebuild
    const FADE_SECONDS = 0.7;
    const SWEEP_OCTAVES_PER_SEC = 0.1;
    const modeFreq = (m: number, n: number) => (m * m + n * n) / 2;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ------------------------------------------------------------------
    // Theme colors (resolved from CSS custom properties, never passed raw)
    // ------------------------------------------------------------------
    function resolveColor(name: string, fallback: string): string {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim() || fallback;
    }
    const probe = document.createElement('canvas');
    probe.width = probe.height = 1;
    const probeCtx = probe.getContext('2d')!;
    function colorToRGB(color: string): [number, number, number] {
      probeCtx.fillStyle = '#000';
      probeCtx.fillStyle = color;
      probeCtx.clearRect(0, 0, 1, 1);
      probeCtx.fillRect(0, 0, 1, 1);
      const d = probeCtx.getImageData(0, 0, 1, 1).data;
      return [d[0], d[1], d[2]];
    }
    let colors: { canvas: string; text: string; muted: string; cta: string; ctaRGB: [number, number, number]; textRGB: [number, number, number] };
    function readColors() {
      const cta = resolveColor('--mp-cta', '#b8324f');
      const text = resolveColor('--mp-text', '#16202e');
      colors = {
        canvas: resolveColor('--mp-canvas', '#f8f4ed'),
        text,
        muted: resolveColor('--mp-muted', '#4a5d6f'),
        cta,
        ctaRGB: colorToRGB(cta),
        textRGB: colorToRGB(text),
      };
    }
    readColors();
    const themeObserver = new MutationObserver(() => { readColors(); overlayDirty = true; });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ------------------------------------------------------------------
    // Field state
    // ------------------------------------------------------------------
    interface Coeff { m: number; n: number; c: number; }
    const G1 = GRID + 1;
    // active target grid
    let gridU = new Float32Array(G1 * G1);
    let gridGX = new Float32Array(G1 * G1);
    let gridGY = new Float32Array(G1 * G1);
    let gridUMax = 1;
    // fade-from snapshot for discrete jumps
    let fadeU = new Float32Array(G1 * G1);
    let fadeGX = new Float32Array(G1 * G1);
    let fadeGY = new Float32Array(G1 * G1);
    let fadeUMax = 1;
    let fadeT = 1; // 1 = fade finished

    let logF = Math.log2(10);         // default: the (4,2)/(2,4) star resonance
    let gamma = 0.03;
    let driveX = 0.5;
    let driveY = 0.5;
    let activeCoeffs: Coeff[] = [];

    function computeCoefficients(f: number): Coeff[] {
      const all: Coeff[] = [];
      for (let m = 0; m <= MAX_MODE; m++) {
        for (let n = 0; n <= MAX_MODE; n++) {
          if (m === 0 && n === 0) continue;
          const fmn = modeFreq(m, n);
          const coupling = Math.cos(m * Math.PI * driveX) * Math.cos(n * Math.PI * driveY);
          const denom = Math.hypot(fmn * fmn - f * f, gamma * f * fmn);
          const c = coupling / denom;
          if (Math.abs(c) > 1e-9) all.push({ m, n, c });
        }
      }
      all.sort((a, b) => Math.abs(b.c) - Math.abs(a.c));
      const kept = all.slice(0, COEFF_KEEP);
      const floor = kept.length ? Math.abs(kept[0].c) * 1e-3 : 0;
      return kept.filter((k) => Math.abs(k.c) >= floor);
    }

    // Separable evaluation: u = Σ c·cos(mπx)cos(nπy), so per-axis cos/sin
    // tables turn the grid rebuild into pure multiply-adds (validated exact).
    const cosTable: Float32Array[] = [];
    const sinTable: Float32Array[] = [];
    for (let m = 0; m <= MAX_MODE; m++) {
      const ct = new Float32Array(G1);
      const st = new Float32Array(G1);
      for (let i = 0; i < G1; i++) {
        ct[i] = Math.cos(m * Math.PI * (i / GRID));
        st[i] = Math.sin(m * Math.PI * (i / GRID));
      }
      cosTable.push(ct);
      sinTable.push(st);
    }

    function rebuildGrid() {
      activeCoeffs = computeCoefficients(Math.pow(2, logF));
      gridU.fill(0);
      gridGX.fill(0);
      gridGY.fill(0);
      for (const { m, n, c } of activeCoeffs) {
        const cm = cosTable[m], cn = cosTable[n];
        const sm = sinTable[m], sn = sinTable[n];
        const cgx = -c * m * Math.PI;
        const cgy = -c * n * Math.PI;
        for (let j = 0; j < G1; j++) {
          const cnj = cn[j], snj = sn[j];
          const row = j * G1;
          for (let i = 0; i < G1; i++) {
            gridU[row + i] += c * cm[i] * cnj;
            gridGX[row + i] += cgx * sm[i] * cnj;
            gridGY[row + i] += cgy * cm[i] * snj;
          }
        }
      }
      gridUMax = 1e-12;
      for (let k = 0; k < gridU.length; k++) {
        const a = Math.abs(gridU[k]);
        if (a > gridUMax) gridUMax = a;
      }
      overlayDirty = true;
    }

    function snapshotForFade() {
      // capture the currently displayed (possibly mid-fade) field as fade source
      if (fadeT >= 1) {
        fadeU.set(gridU); fadeGX.set(gridGX); fadeGY.set(gridGY);
        fadeUMax = gridUMax;
      } else {
        const t = easedFade();
        for (let k = 0; k < gridU.length; k++) {
          fadeU[k] = fadeU[k] + (gridU[k] - fadeU[k]) * t;
          fadeGX[k] = fadeGX[k] + (gridGX[k] - fadeGX[k]) * t;
          fadeGY[k] = fadeGY[k] + (gridGY[k] - fadeGY[k]) * t;
        }
        fadeUMax = fadeUMax + (gridUMax - fadeUMax) * t;
      }
      fadeT = 0;
    }

    const easedFade = () => {
      const t = Math.min(1, fadeT);
      return t * t * (3 - 2 * t); // smoothstep
    };

    // Bilinear sample of the blended field. Returns [u, gx, gy, umax-normalizer].
    const sampleOut = new Float64Array(3);
    function sampleField(x: number, y: number) {
      const fx = Math.min(GRID - 1e-6, Math.max(0, x * GRID));
      const fy = Math.min(GRID - 1e-6, Math.max(0, y * GRID));
      const i = Math.floor(fx), j = Math.floor(fy);
      const tx = fx - i, ty = fy - j;
      const k00 = j * G1 + i, k10 = k00 + 1, k01 = k00 + G1, k11 = k01 + 1;
      const w00 = (1 - tx) * (1 - ty), w10 = tx * (1 - ty), w01 = (1 - tx) * ty, w11 = tx * ty;
      let u = gridU[k00] * w00 + gridU[k10] * w10 + gridU[k01] * w01 + gridU[k11] * w11;
      let gx = gridGX[k00] * w00 + gridGX[k10] * w10 + gridGX[k01] * w01 + gridGX[k11] * w11;
      let gy = gridGY[k00] * w00 + gridGY[k10] * w10 + gridGY[k01] * w01 + gridGY[k11] * w11;
      if (fadeT < 1) {
        const t = easedFade();
        const fu = fadeU[k00] * w00 + fadeU[k10] * w10 + fadeU[k01] * w01 + fadeU[k11] * w11;
        const fgx = fadeGX[k00] * w00 + fadeGX[k10] * w10 + fadeGX[k01] * w01 + fadeGX[k11] * w11;
        const fgy = fadeGY[k00] * w00 + fadeGY[k10] * w10 + fadeGY[k01] * w01 + fadeGY[k11] * w11;
        u = fu + (u - fu) * t;
        gx = fgx + (gx - fgx) * t;
        gy = fgy + (gy - fgy) * t;
      }
      sampleOut[0] = u;
      sampleOut[1] = gx;
      sampleOut[2] = gy;
      return sampleOut;
    }
    function blendedUMax(): number {
      return fadeT < 1 ? fadeUMax + (gridUMax - fadeUMax) * easedFade() : gridUMax;
    }

    // ------------------------------------------------------------------
    // Particles
    // ------------------------------------------------------------------
    let grainCount = window.matchMedia('(max-width: 640px)').matches ? 2500 : 5000;
    let px = new Float32Array(0);
    let py = new Float32Array(0);

    function resand() {
      px = new Float32Array(grainCount);
      py = new Float32Array(grainCount);
      for (let p = 0; p < grainCount; p++) {
        px[p] = Math.random();
        py[p] = Math.random();
      }
    }

    function stepPhysics() {
      const umax = blendedUMax();
      const inv = 1 / umax;
      for (let p = 0; p < grainCount; p++) {
        const s = sampleField(px[p], py[p]);
        const un = s[0] * inv;
        const drift = -MU * 2 * un * inv * PHYSICS_DT;
        let dx = drift * s[1] + JITTER * Math.abs(un) * (Math.random() - 0.5);
        let dy = drift * s[2] + JITTER * Math.abs(un) * (Math.random() - 0.5);
        if (dx > STEP_CAP) dx = STEP_CAP; else if (dx < -STEP_CAP) dx = -STEP_CAP;
        if (dy > STEP_CAP) dy = STEP_CAP; else if (dy < -STEP_CAP) dy = -STEP_CAP;
        let nx = px[p] + dx;
        let ny = py[p] + dy;
        if (nx < 0) nx = -nx; else if (nx > 1) nx = 2 - nx;
        if (ny < 0) ny = -ny; else if (ny > 1) ny = 2 - ny;
        px[p] = nx;
        py[p] = ny;
      }
    }

    // ------------------------------------------------------------------
    // Field overlay (amplitude heat map, rebuilt only when the grid changes)
    // ------------------------------------------------------------------
    let overlayDirty = true;
    let overlayVisible = false;
    const overlayCanvas = document.createElement('canvas');
    overlayCanvas.width = G1;
    overlayCanvas.height = G1;
    const overlayCtx = overlayCanvas.getContext('2d')!;
    const overlayImage = overlayCtx.createImageData(G1, G1);

    function rebuildOverlay() {
      const [r, g, b] = colors.ctaRGB;
      const data = overlayImage.data;
      const umax = blendedUMax();
      for (let j = 0; j < G1; j++) {
        for (let i = 0; i < G1; i++) {
          const k = j * G1 + i;
          let u = gridU[k];
          if (fadeT < 1) {
            const t = easedFade();
            u = fadeU[k] + (u - fadeU[k]) * t;
          }
          const a = Math.min(1, Math.abs(u) / umax);
          const o = k * 4;
          data[o] = r;
          data[o + 1] = g;
          data[o + 2] = b;
          data[o + 3] = Math.round(a * 90);
        }
      }
      overlayCtx.putImageData(overlayImage, 0, 0);
      overlayDirty = false;
    }

    // ------------------------------------------------------------------
    // Rendering
    // ------------------------------------------------------------------
    function draw() {
      ctx.fillStyle = colors.canvas;
      ctx.fillRect(0, 0, W, H);

      if (overlayVisible) {
        if (overlayDirty || fadeT < 1) rebuildOverlay();
        ctx.save();
        ctx.imageSmoothingEnabled = true;
        ctx.drawImage(overlayCanvas, 0, 0, G1, G1, 0, 0, W, H);
        ctx.restore();
      }

      ctx.fillStyle = colors.text;
      ctx.globalAlpha = 0.8;
      for (let p = 0; p < grainCount; p++) {
        ctx.fillRect(px[p] * W - 1, py[p] * H - 1, 2, 2);
      }
      ctx.globalAlpha = 1;

      // driver marker
      const dxp = driveX * W;
      const dyp = driveY * H;
      ctx.strokeStyle = colors.cta;
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.arc(dxp, dyp, 9, 0, Math.PI * 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(dxp - 4, dyp); ctx.lineTo(dxp + 4, dyp);
      ctx.moveTo(dxp, dyp - 4); ctx.lineTo(dxp, dyp + 4);
      ctx.stroke();
    }

    // ------------------------------------------------------------------
    // Metrics
    // ------------------------------------------------------------------
    function updateMetrics() {
      const total = activeCoeffs.reduce((s, k) => s + Math.abs(k.c), 0) || 1;
      // fold degenerate partners (m,n)/(n,m) into one entry, keep top 3
      const shares = new Map<string, number>();
      for (const k of activeCoeffs) {
        const key = k.m <= k.n ? `${k.m},${k.n}` : `${k.n},${k.m}`;
        shares.set(key, (shares.get(key) ?? 0) + Math.abs(k.c) / total);
      }
      const top = [...shares.entries()].sort((a, b) => b[1] - a[1]).slice(0, 3);
      metricModes.textContent = top.map(([key]) => `(${key})`).join(' ') || '—';
      metricShare.textContent = top.length ? `${Math.round(top[0][1] * 100)}% leading` : '—';

      const sampleCount = Math.min(600, grainCount);
      const stride = Math.max(1, Math.floor(grainCount / sampleCount));
      const umax = blendedUMax();
      let settled = 0, counted = 0;
      for (let p = 0; p < grainCount; p += stride) {
        const s = sampleField(px[p], py[p]);
        if (Math.abs(s[0]) / umax < 0.1) settled++;
        counted++;
      }
      metricSettled.textContent = `${Math.round((settled / Math.max(1, counted)) * 100)}%`;
      metricDriver.textContent = `(${driveX.toFixed(2)}, ${driveY.toFixed(2)})`;
    }

    function updateFreqReadout() {
      const f = Math.pow(2, logF);
      freqSlider.value = logF.toFixed(4);
      freqReadout.textContent = `${f.toFixed(2)} × f₁`;
    }

    // ------------------------------------------------------------------
    // Control wiring
    // ------------------------------------------------------------------
    let running = !reducedMotion;
    let sweeping = false;
    let accumulator = 0;
    let lastFrameTime = performance.now();
    let animationFrameId = 0;
    let destroyed = false;
    let frameCounter = 0;

    function setRunning(next: boolean) {
      running = next;
      runToggle.textContent = running ? 'Pause' : 'Play';
      runToggle.classList.toggle('is-active', running);
      runToggle.setAttribute('aria-pressed', String(running));
      statusEl.textContent = running
        ? 'Running. Drag anywhere on the plate to move the driver; grains re-settle onto the new nodal lines.'
        : reducedMotion
          ? 'Reduced motion is on: each change is shown as an instantly settled pattern instead of a live animation.'
          : 'Paused. The field stays live for the overlay; grains hold their positions.';
    }

    // Instant settle for reduced-motion users: run the same fixed-step
    // physics synchronously so every parameter change shows a finished pattern.
    function instantSettle() {
      const burst = Math.round(4 / PHYSICS_DT);
      const saveFade = fadeT;
      fadeT = 1; // settle against the final field, not the blend
      for (let s = 0; s < burst; s++) stepPhysics();
      fadeT = saveFade;
    }

    // Rapid slider input under reduced motion coalesces into one settle,
    // 150 ms after the last change, instead of a synchronous burst per event.
    let pendingSettle = false;
    let lastChangeTime = 0;

    function afterFieldChange(discrete: boolean) {
      if (discrete && !reducedMotion) snapshotForFade();
      rebuildGrid();
      if (reducedMotion) {
        fadeT = 1;
        pendingSettle = true;
        lastChangeTime = performance.now();
      }
      draw();
      updateMetrics();
    }

    runToggle.addEventListener('click', () => setRunning(!running));
    resandBtn.addEventListener('click', () => {
      resand();
      if (reducedMotion) instantSettle();
      draw();
      updateMetrics();
    });
    fieldToggle.addEventListener('click', () => {
      overlayVisible = !overlayVisible;
      fieldToggle.textContent = overlayVisible ? 'Hide field' : 'Show field';
      fieldToggle.classList.toggle('is-active', overlayVisible);
      fieldToggle.setAttribute('aria-pressed', String(overlayVisible));
      overlayDirty = true;
      draw();
    });
    sweepToggle.addEventListener('click', () => {
      sweeping = !sweeping;
      sweepToggle.classList.toggle('is-active', sweeping);
      sweepToggle.setAttribute('aria-pressed', String(sweeping));
      if (sweeping && reducedMotion) {
        // sweeping is continuous motion by definition; step in discrete hops instead
        statusEl.textContent = 'Reduced motion: sweep advances in discrete steps, one resonance at a time.';
      }
    });

    freqSlider.addEventListener('input', () => {
      logF = parseFloat(freqSlider.value);
      presetButtons.forEach((b) => b.classList.remove('is-active'));
      updateFreqReadout();
      afterFieldChange(false);
    });
    gammaSlider.addEventListener('input', () => {
      gamma = parseFloat(gammaSlider.value);
      gammaReadout.textContent = gamma.toFixed(3);
      afterFieldChange(false);
    });

    const drivePoints: Record<string, [number, number]> = {
      center: [0.5, 0.5],
      offaxis: [0.353, 0.278],
      edge: [0.5, 0.02],
    };
    function markDriveButtons() {
      driveButtons.forEach((b) => {
        const dp = drivePoints[b.dataset.drive ?? ''];
        b.classList.toggle('is-active', !!dp && Math.abs(dp[0] - driveX) < 1e-3 && Math.abs(dp[1] - driveY) < 1e-3);
      });
    }
    driveButtons.forEach((b) => {
      b.addEventListener('click', () => {
        const dp = drivePoints[b.dataset.drive ?? 'center'];
        driveX = dp[0];
        driveY = dp[1];
        markDriveButtons();
        presetButtons.forEach((x) => x.classList.remove('is-active'));
        afterFieldChange(true);
      });
    });

    grainButtons.forEach((b) => {
      b.addEventListener('click', () => {
        grainCount = parseInt(b.dataset.grains ?? '5000', 10);
        grainButtons.forEach((x) => x.classList.toggle('is-active', x === b));
        resand();
        if (reducedMotion) instantSettle();
        draw();
        updateMetrics();
      });
    });

    // Presets: named patterns = (resonance, drive point). The degenerate-pair
    // mixing that shapes each figure comes from the physics, not a lookup.
    const presets: Record<string, { f: number; drive: [number, number] }> = {
      star: { f: modeFreq(4, 2), drive: drivePoints.center },
      // edge drive flips the sign of the (2,0) coupling relative to (0,2),
      // turning the center-driven diamond into the true diagonal cross
      cross: { f: modeFreq(2, 0), drive: drivePoints.edge },
      diamond: { f: modeFreq(2, 0), drive: drivePoints.center },
      windowpane: { f: modeFreq(2, 2), drive: drivePoints.center },
      lattice: { f: modeFreq(4, 4), drive: drivePoints.center },
      rosette: { f: modeFreq(6, 2), drive: drivePoints.center },
      flower: { f: modeFreq(5, 3), drive: drivePoints.offaxis },
      lace: { f: modeFreq(7, 5), drive: drivePoints.offaxis },
    };
    presetButtons.forEach((b) => {
      b.addEventListener('click', () => {
        const preset = presets[b.dataset.preset ?? 'star'];
        logF = Math.log2(preset.f);
        driveX = preset.drive[0];
        driveY = preset.drive[1];
        sweeping = false;
        sweepToggle.classList.remove('is-active');
        sweepToggle.setAttribute('aria-pressed', 'false');
        presetButtons.forEach((x) => x.classList.toggle('is-active', x === b));
        markDriveButtons();
        updateFreqReadout();
        afterFieldChange(true);
      });
    });

    // Pointer: drag the driver around the plate
    let draggingDriver = false;
    function pointToPlate(event: PointerEvent): [number, number] {
      const rect = canvas.getBoundingClientRect();
      return [
        Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width)),
        Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height)),
      ];
    }
    canvas.addEventListener('pointerdown', (event) => {
      draggingDriver = true;
      try { canvas.setPointerCapture(event.pointerId); } catch { /* pointer may already be gone */ }
      const [x, y] = pointToPlate(event);
      driveX = x; driveY = y;
      markDriveButtons();
      presetButtons.forEach((b) => b.classList.remove('is-active'));
      afterFieldChange(false);
    });
    canvas.addEventListener('pointermove', (event) => {
      if (!draggingDriver) return;
      const [x, y] = pointToPlate(event);
      driveX = x; driveY = y;
      afterFieldChange(false);
    });
    function endDriverDrag(event: PointerEvent) {
      draggingDriver = false;
      if (canvas.hasPointerCapture(event.pointerId)) canvas.releasePointerCapture(event.pointerId);
      markDriveButtons();
      updateMetrics();
    }
    canvas.addEventListener('pointerup', endDriverDrag);
    canvas.addEventListener('pointercancel', endDriverDrag);

    // Keyboard: arrow keys move the driver, Home recenters
    canvas.addEventListener('keydown', (event) => {
      const step = event.shiftKey ? 0.05 : 0.02;
      let handled = true;
      if (event.key === 'ArrowLeft') driveX = Math.max(0, driveX - step);
      else if (event.key === 'ArrowRight') driveX = Math.min(1, driveX + step);
      else if (event.key === 'ArrowUp') driveY = Math.max(0, driveY - step);
      else if (event.key === 'ArrowDown') driveY = Math.min(1, driveY + step);
      else if (event.key === 'Home') { driveX = 0.5; driveY = 0.5; }
      else handled = false;
      if (handled) {
        event.preventDefault();
        markDriveButtons();
        presetButtons.forEach((b) => b.classList.remove('is-active'));
        afterFieldChange(false);
      }
    });

    // ------------------------------------------------------------------
    // Main loop — fixed-timestep physics, frame-rate independent
    // ------------------------------------------------------------------
    let sweepSettleTimer = 0;
    function renderFrame(frameTime: number) {
      if (destroyed) return;
      const elapsed = Math.min(0.04, (frameTime - lastFrameTime) / 1000);
      lastFrameTime = frameTime;

      if (!isVisible) {
        animationFrameId = requestAnimationFrame(renderFrame);
        return;
      }

      if (running && !reducedMotion) {
        if (fadeT < 1) fadeT = Math.min(1, fadeT + elapsed / FADE_SECONDS);
        if (sweeping) {
          logF += SWEEP_OCTAVES_PER_SEC * elapsed;
          if (logF > 6.15) logF = -0.32;
          updateFreqReadout();
          presetButtons.forEach((b) => b.classList.remove('is-active'));
          rebuildGrid();
        }
        accumulator += elapsed;
        let safety = 0;
        while (accumulator >= PHYSICS_DT && safety < 8) {
          stepPhysics();
          accumulator -= PHYSICS_DT;
          safety++;
        }
        draw();
        frameCounter++;
        if (frameCounter % 15 === 0) updateMetrics();
      } else if (reducedMotion && pendingSettle && frameTime - lastChangeTime > 150) {
        pendingSettle = false;
        instantSettle();
        draw();
        updateMetrics();
      } else if (reducedMotion && sweeping) {
        // discrete-hop sweep for reduced motion: advance one resonance every 4 s
        sweepSettleTimer += elapsed;
        if (sweepSettleTimer > 4) {
          sweepSettleTimer = 0;
          logF += 0.4;
          if (logF > 6.15) logF = -0.32;
          updateFreqReadout();
          rebuildGrid();
          fadeT = 1;
          instantSettle();
          draw();
          updateMetrics();
        }
      }
      animationFrameId = requestAnimationFrame(renderFrame);
    }

    let isVisible = true;
    const io = new IntersectionObserver((entries) => {
      isVisible = entries[0].isIntersecting && !document.hidden;
    });
    io.observe(canvas);

    function handleVisibilityChange() { 
      lastFrameTime = performance.now(); 
      isVisible = !document.hidden;
    }
    document.addEventListener('visibilitychange', handleVisibilityChange);

    // ------------------------------------------------------------------
    // Boot
    // ------------------------------------------------------------------
    rebuildGrid();
    resand();
    if (reducedMotion) {
      setRunning(false);
      instantSettle();
    } else {
      setRunning(true);
    }
    updateFreqReadout();
    gammaReadout.textContent = gamma.toFixed(3);
    markDriveButtons();
    draw();
    updateMetrics();
    animationFrameId = requestAnimationFrame(renderFrame);

    document.addEventListener('astro:before-swap', () => {
      destroyed = true;
      cancelAnimationFrame(animationFrameId);
      themeObserver.disconnect();
      io.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initChladni);
  initChladni();
</script>
