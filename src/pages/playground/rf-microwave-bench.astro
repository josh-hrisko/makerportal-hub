</style>

<script>
// @ts-nocheck
function initRFBench(){
  const smithC = document.getElementById('smith-canvas');
  const schemC = document.getElementById('schem-canvas');
  const sweepC = document.getElementById('sweep-canvas');
  if(!smithC || smithC.dataset.init) return;
  smithC.dataset.init='true';

  const smithCtx = smithC.getContext('2d');
  const schemCtx = schemC.getContext('2d');
  const sweepCtx = sweepC.getContext('2d');
  const dpr = Math.min(window.devicePixelRatio||1,2);
  [smithC,schemC,sweepC].forEach(c=>{
    const W=c.width,H=c.height;
    c.width=W*dpr; c.height=H*dpr; c.style.width=W+'px'; c.style.height=H+'px';
    c.getContext('2d').scale(dpr,dpr);
  });

  const slRsrc=document.getElementById('sl-rsrc'), slXsrc=document.getElementById('sl-xsrc'), slZ0=document.getElementById('sl-z0');
  const slRl=document.getElementById('sl-rl'), slXl=document.getElementById('sl-xl'), slF0=document.getElementById('sl-f0');
  const selMatch=document.getElementById('sel-match'), selStub=document.getElementById('sel-stub'), selHum=document.getElementById('sel-hum');
  const slStubLen=document.getElementById('sl-stublen'), slStubPos=document.getElementById('sl-stubpos'), slSpan=document.getElementById('sl-span');
  const outRsrc=document.getElementById('out-rsrc'), outXsrc=document.getElementById('out-xsrc'), outZ0=document.getElementById('out-z0');
  const outRl=document.getElementById('out-rl'), outXl=document.getElementById('out-xl'), outF0=document.getElementById('out-f0');
  const outStubLen=document.getElementById('out-stublen'), outStubPos=document.getElementById('out-stubpos'), outSpan=document.getElementById('out-span');
  const roGammaL=document.getElementById('ro-gammaL'), roGammaIn=document.getElementById('ro-gammain'), roVswr=document.getElementById('ro-vswr');
  const roRloss=document.getElementById('ro-rloss'), roMloss=document.getElementById('ro-mloss'), roZ1=document.getElementById('ro-z1'), roZ2=document.getElementById('ro-z2'), roZin=document.getElementById('ro-zin');
  const roQ=document.getElementById('ro-q'), roBstub=document.getElementById('ro-bstub'), roXB=document.getElementById('ro-xb'), roLc=document.getElementById('ro-lc');
  const roGmag=document.getElementById('ro-gmag'), roVswr2=document.getElementById('ro-vswr2'), roZmatch=document.getElementById('ro-zmatch'), roAudioQ=document.getElementById('ro-audioq');
  const lblSmith=document.getElementById('lbl-smith'), lblSweep=document.getElementById('lbl-sweep'), matchState=document.getElementById('match-state'), barMatch=document.getElementById('bar-match');
  const btnAudio=document.getElementById('btn-audio'), btnAuto=document.getElementById('btn-automatch'), btnReset=document.getElementById('btn-reset');

  function updOut(){
    outRsrc.textContent=slRsrc.value; outXsrc.textContent=slXsrc.value; outZ0.textContent=slZ0.value;
    outRl.textContent=slRl.value; outXl.textContent=slXl.value; outF0.textContent=parseFloat(slF0.value).toFixed(2);
    outStubLen.textContent=slStubLen.value; outStubPos.textContent=parseFloat(slStubPos.value).toFixed(3); outSpan.textContent=slSpan.value;
  }
  [slRsrc,slXsrc,slZ0,slRl,slXl,slF0,slStubLen,slStubPos,slSpan].forEach(el=>el.addEventListener('input',()=>{updOut(); compute();}));
  selMatch.addEventListener('change',compute); selStub.addEventListener('change',compute);

  // complex helpers
  function C(re,im){ return {re,im}; }
  function cAdd(a,b){return {re:a.re+b.re, im:a.im+b.im};}
  function cSub(a,b){return {re:a.re-b.re, im:a.im-b.im};}
  function cMul(a,b){return {re:a.re*b.re - a.im*b.im, im:a.re*b.im + a.im*b.re};}
  function cDiv(a,b){
    const d=b.re*b.re+b.im*b.im || 1e-12;
    return {re:(a.re*b.re + a.im*b.im)/d, im:(a.im*b.re - a.re*b.im)/d};
  }
  function cMag(a){return Math.hypot(a.re,a.im);}
  function cInv(a){return cDiv(C(1,0),a);}
  function cAngle(a){return Math.atan2(a.im,a.re);}

  function Gamma(Z,Z0){
    const Z0c=C(Z0,0);
    return cDiv(cSub(Z,Z0c), cAdd(Z,Z0c));
  }
  function Zin_line(ZL,Z0,tanBL){
    const numer=C(ZL.re, ZL.im + Z0*tanBL);
    const denom=C(Z0 - ZL.im*tanBL, ZL.re*tanBL);
    const ratio=cDiv(numer,denom);
    return C(ratio.re*Z0, ratio.im*Z0);
  }

  function stubSus(Y0, betaL, type){
    const t=Math.tan(betaL);
    if(type==='open') return Y0*t;
    // short
    if(Math.abs(t)<1e-4) return -Y0*1e4*Math.sign(t||1);
    return -Y0 / t;
  }

  function computeJourney(){
    const Rs=parseFloat(slRsrc.value), Xs=parseFloat(slXsrc.value), Z0c=parseFloat(slZ0.value)||50;
    const Rl=parseFloat(slRl.value), Xl=parseFloat(slXl.value);
    const f0=parseFloat(slF0.value)*1e9;
    const stubType=selStub.value;
    const stubLenDeg=parseFloat(slStubLen.value)*Math.PI/180;
    const dPos=parseFloat(slStubPos.value); // fraction lambda at f0
    const Y0=1/Z0c;

    const ZL=C(Rl,Xl);
    const betaPos0=2*Math.PI*dPos; // rad at f0
    const tanPos0=Math.tan(betaPos0);
    const Z1 = Zin_line(ZL,Z0c,tanPos0);
    const Y1=cInv(Z1);
    const Bstub0=stubSus(Y0, stubLenDeg, stubType);
    const Y2=cAdd(Y1, C(0,Bstub0));
    const Z2=cInv(Y2);

    // L-match design targeting Rs - jXs (conj)
    const omega0=2*Math.PI*f0;
    const targetRs=Rs, targetXs=Xs; // want Zin = Rs - j Xs for max power? Actually conj
    // compute G,B for Z2
    const Y2c=Y2;
    const G2=Y2c.re, B2=Y2c.im;

    // Two possible topologies solving
    let solution=null, topo='none', secondSol=null;
    let Xmatch=0,Bmatch=0;

    function shuntFirst(Zmid,Rs_target,Xs_target){
      const Ym=cInv(Zmid);
      const Gm=Ym.re, Bm=Ym.im;
      const disc=Gm/Rs_target - Gm*Gm;
      if(disc < -1e-12) return null;
      const sq=Math.sqrt(Math.max(0,disc));
      const B1=-Bm+sq, B2=-Bm-sq;
      const D1=Gm*Gm + (Bm+B1)*(Bm+B1), D2=Gm*Gm + (Bm+B2)*(Bm+B2);
      const X1_f = (Bm+B1)/(D1||1e-12) - Xs_target;
      const X2_f = (Bm+B2)/(D2||1e-12) - Xs_target;
      return [{B:B1,X:X1_f,D:D1},{B:B2,X:X2_f,D:D2}];
    }
    function seriesFirst(Zmid,Rs_target,Xs_target){
      const Rm=Zmid.re, Xm=Zmid.im;
      const Gt = Rs_target / (Rs_target*Rs_target + Xs_target*Xs_target); // G target for Y_in
      const Bt = Xs_target / (Rs_target*Rs_target + Xs_target*Xs_target);
      const Dtarget = Rm / (Gt||1e-12);
      const disc = Dtarget - Rm*Rm;
      if(disc < -1e-12) return null;
      const sq=Math.sqrt(Math.max(0,disc));
      const X1=-Xm+sq, X2=-Xm-sq;
      const D1=Rm*Rm + (Xm+X1)*(Xm+X1);
      const D2=Rm*Rm + (Xm+X2)*(Xm+X2);
      const Bp1 = -(Xm+X1)/D1; // B' in our notation
      const Bp2 = -(Xm+X2)/D2;
      const B1 = Bt - Bp1, B2 = Bt - Bp2;
      return [{B:B1,X:X1},{B:B2,X:X2}];
    }

    const matchSel=selMatch.value;
    let sols=null;
    let chosen=null;
    let topoUsed='none';
    if(matchSel!=='none'){
      if(matchSel.includes('shunt')){
        sols=shuntFirst(Z2,targetRs,targetXs);
        topoUsed='shunt-first';
      }else if(matchSel.includes('series')){
        sols=seriesFirst(Z2,targetRs,targetXs);
        topoUsed='series-first';
      }
      if(sols){
        // pick based on desired signs
        const wantSeriesL = matchSel.includes('LC') && (matchSel.includes('shunt') ? matchSel.includes('Series L') : true); // our labels: shunt-LC means Series L Shunt C
        // Map signs: Series L -> X>0, Series C X<0, Shunt C B>0, Shunt L B<0
        let wantXsSign = 0, wantBsSign = 0;
        if(matchSel==='auto-shunt-LC' || matchSel==='auto-series-LC'){ wantXsSign=1; wantBsSign=1; }
        else if(matchSel==='auto-shunt-CL' || matchSel==='auto-series-CL'){ wantXsSign=-1; wantBsSign=-1; }

        // try find sol matching signs
        let best=null;
        for(const s of sols){
          const xsSign = s.X>0?1:-1;
          const bsSign = s.B>0?1:-1;
          if(wantXsSign!==0 && xsSign!==wantXsSign) continue;
          if(wantBsSign!==0 && bsSign!==wantBsSign) continue;
          best=s; break;
        }
        // fallback to first if none matches sign
        if(!best) best=sols[0];
        chosen=best;
        secondSol=sols.length>1 ? sols[1] : null;
      }
    }

    let Z_final=Z2, Xfinal=0,Bfinal=0;
    if(chosen){
      Xfinal=chosen.X; Bfinal=chosen.B;
      if(topoUsed==='shunt-first'){
        const Ymid_p=C(G2 + 0, B2 + Bfinal); // Actually Y2 + jBfinal
        const Ynew=cAdd(Y2, C(0,Bfinal));
        const Znew=cInv(Ynew);
        Z_final=C(Znew.re, Znew.im + Xfinal);
      }else{
        const Ztmp=C(Z2.re, Z2.im + Xfinal);
        const Ytmp=cInv(Ztmp);
        const Yfinal=cAdd(Ytmp, C(0,Bfinal));
        Z_final=cInv(Yfinal);
      }
    }

    const Z0ref=Z0c;
    const gammaL=Gamma(ZL,Z0ref);
    const gamma1=Gamma(Z1,Z0ref);
    const gamma2=Gamma(Z2,Z0ref);
    const gammaF=Gamma(Z_final,Z0ref);

    // Sweep for smith trace and S-params
    const span=parseFloat(slSpan.value); // GHz span
    const f0GHz=parseFloat(slF0.value);
    const fMin=Math.max(0.1, f0GHz - span/2), fMax=Math.min(6, f0GHz + span/2);
    const sweepPoints=[];
    const N=320;
    for(let i=0;i<N;i++){
      const fGHz=fMin + (fMax-fMin)*i/(N-1);
      const f=fGHz*1e9;
      const scale=f/f0;
      const betaPos=betaPos0*scale;
      const tanPos=Math.tan(betaPos);
      const Z1f=Zin_line(ZL,Z0ref,tanPos);
      const Y1f=cInv(Z1f);
      const thetaStub=stubLenDeg*scale;
      const Bstub=stubSus(Y0, thetaStub, stubType);
      const Y2f=cAdd(Y1f, C(0,Bstub));
      const Z2f=cInv(Y2f);
      let Zinf=Z2f;
      if(chosen){
        // scale reactances with frequency
        let Xf=0,Bf=0;
        // determine if X is inductive or capacitive based on sign at f0
        const isXind= chosen.X>0;
        const isBind= chosen.B<0; // inductive susceptance negative? B = -1/(wL) negative
        if(isXind) Xf=chosen.X*scale;
        else Xf=chosen.X/scale; // C: X = -1/(wC) scales 1/f
        // B: if capacitive B>0 -> B scales f, inductive B<0 -> scales 1/f (since B=-1/(wL))
        if(chosen.B>0) Bf=chosen.B*scale;
        else Bf=chosen.B/scale;
        // Note: we use chosen X,B but scaled
        if(topoUsed==='shunt-first'){
          const Ymid=cAdd(Y2f, C(0,Bf));
          const Zm=cInv(Ymid);
          Zinf=C(Zm.re, Zm.im + Xf);
        }else{
          const Zmid=C(Z2f.re, Z2f.im + Xf);
          const Ymid=cInv(Zmid);
          const Yfin=cAdd(Ymid, C(0,Bf));
          Zinf=cInv(Yfin);
        }
      }
      const g=Gamma(Zinf,Z0ref);
      const mag=cMag(g);
      const s11db=20*Math.log10(Math.max(1e-4,mag));
      const s21lin=Math.sqrt(Math.max(0,1 - mag*mag));
      const s21db=10*Math.log10(Math.max(1e-6, s21lin*s21lin));
      sweepPoints.push({fGHz,g,mag,s11db,s21db,Zinf});
    }

    return {Z0ref,Rs,Xs,ZL,Z1,Z2,Z_final,gammaL,gamma1,gamma2,gammaF,Bstub0,Y0,betaPos0,stubLenDeg,chosen,secondSol,topoUsed,Xfinal,Bfinal,f0,Rl,Xl,sweepPoints,fMin,fMax, f0GHz};
  }

  // Audio engine
  let audioCtx=null, masterGain=null, noiseBufSrc=null, noiseFilter=null, noiseGain=null, oscPure=null, oscBeat=null, oscHum1=null, oscHum2=null, gainPure=null, gainBeat=null, gainHum1=null, gainHum2=null, audioOn=false;

  function ensureAudio(){
    if(audioCtx) return audioCtx;
    audioCtx=new (window.AudioContext||window.webkitAudioContext)();
    masterGain=audioCtx.createGain(); masterGain.gain.value=0; masterGain.connect(audioCtx.destination);
    // white noise buffer 2 sec
    const len=audioCtx.sampleRate*2;
    const buf=audioCtx.createBuffer(1,len,audioCtx.sampleRate);
    const ch=buf.getChannelData(0);
    for(let i=0;i<len;i++) ch[i]=Math.random()*2-1;
    noiseBufSrc=audioCtx.createBufferSource(); noiseBufSrc.buffer=buf; noiseBufSrc.loop=true;
    noiseFilter=audioCtx.createBiquadFilter(); noiseFilter.type='bandpass'; noiseFilter.frequency.value=440; noiseFilter.Q.value=0.8;
    noiseGain=audioCtx.createGain(); noiseGain.gain.value=0;
    noiseBufSrc.connect(noiseFilter); noiseFilter.connect(noiseGain); noiseGain.connect(masterGain);
    noiseBufSrc.start();

    oscPure=audioCtx.createOscillator(); oscPure.type='sine'; oscPure.frequency.value=440;
    gainPure=audioCtx.createGain(); gainPure.gain.value=0;
    oscPure.connect(gainPure); gainPure.connect(masterGain); oscPure.start();

    oscBeat=audioCtx.createOscillator(); oscBeat.type='sine'; oscBeat.frequency.value=455;
    gainBeat=audioCtx.createGain(); gainBeat.gain.value=0;
    oscBeat.connect(gainBeat); gainBeat.connect(masterGain); oscBeat.start();

    oscHum1=audioCtx.createOscillator(); oscHum1.type='sine'; oscHum1.frequency.value=120;
    gainHum1=audioCtx.createGain(); gainHum1.gain.value=0;
    oscHum1.connect(gainHum1); gainHum1.connect(masterGain); oscHum1.start();

    oscHum2=audioCtx.createOscillator(); oscHum2.type='sine'; oscHum2.frequency.value=185;
    gainHum2=audioCtx.createGain(); gainHum2.gain.value=0;
    oscHum2.connect(gainHum2); gainHum2.connect(masterGain); oscHum2.start();

    return audioCtx;
  }

  function updateAudio(gammaMag){
    if(!audioOn) return;
    const ac=ensureAudio();
    ac.resume();
    const q=0.5 + (1 - gammaMag)*28;
    const now=ac.currentTime;
    try{
      noiseFilter.frequency.linearRampToValueAtTime(440, now+0.08);
      noiseFilter.Q.linearRampToValueAtTime(q, now+0.12);
      const gNoise=0.04 + gammaMag*0.18;
      const gPure=(1-gammaMag)*(1-gammaMag)*0.28;
      const beatFreq=440 + gammaMag*38;
      const gBeat=gammaMag*0.13;
      const gH1=gammaMag*0.07;
      const gH2=gammaMag*0.05;
      noiseGain.gain.linearRampToValueAtTime(gNoise, now+0.1);
      gainPure.gain.linearRampToValueAtTime(gPure, now+0.1);
      gainBeat.gain.linearRampToValueAtTime(gBeat, now+0.1);
      gainHum1.gain.linearRampToValueAtTime(gH1, now+0.1);
      gainHum2.gain.linearRampToValueAtTime(gH2, now+0.1);
      oscBeat.frequency.linearRampToValueAtTime(beatFreq, now+0.08);
      masterGain.gain.linearRampToValueAtTime(0.22, now+0.08);
    }catch{}
    roAudioQ.textContent=q.toFixed(2);
  }

  btnAudio.addEventListener('click',()=>{
    if(selHum.value==='off'){ audioOn=false; btnAudio.classList.remove('is-active'); btnAudio.textContent='🔇 Audio off (set hum on)'; if(masterGain) masterGain.gain.value=0; return; }
    audioOn=!audioOn;
    btnAudio.classList.toggle('is-active',audioOn);
    btnAudio.textContent=audioOn?'🔊 Audio on: hiss→440Hz':'🔊 Audio: mismatch hiss → 440 Hz pure';
    if(audioOn){
      ensureAudio(); audioCtx.resume();
      masterGain.gain.value=0.22;
    }else{
      if(masterGain) masterGain.gain.value=0;
    }
  });

  function formatComplex(z){
    const sign=z.im>=0?'+':'';
    return `${z.re.toFixed(1)}${sign}${z.im.toFixed(1)}j`;
  }

  function compute(){
    const data=computeJourney();
    if(!data) return;
    const {Z0ref, ZL, Z1, Z2, Z_final, gammaL, gamma1, gamma2, gammaF, Bstub0, Y0, chosen, topoUsed, Xfinal, Bfinal, Rl, Xl, sweepPoints, fMin, fMax, f0GHz} = data;
    const gLmag=cMag(gammaL), gFmag=cMag(gammaF);
    const vswrL = (1+gFmag)/(1 - gFmag + 1e-6);
    const rloss = -20*Math.log10(Math.max(1e-4,gFmag));
    const mloss = -10*Math.log10(Math.max(1e-6,1 - gFmag*gFmag));
    const Rp=Math.max(Rl, parseFloat(slRsrc.value)), Rs=Math.min(Rl, parseFloat(slRsrc.value));
    const Q=Math.sqrt(Math.max(0,Rp/Rs -1));

    // readouts
    roGammaL.textContent=`${gammaL.re.toFixed(3)}${gammaL.im>=0?'+':''}${gammaL.im.toFixed(3)}j |${gLmag.toFixed(3)}|`;
    roGammaIn.textContent=`${gammaF.re.toFixed(3)}${gammaF.im>=0?'+':''}${gammaF.im.toFixed(3)}j |${gFmag.toFixed(3)}|`;
    roVswr.textContent=`${gFmag.toFixed(3)} / ${vswrL.toFixed(2)}:1`;
    roRloss.textContent=`${isFinite(rloss)?rloss.toFixed(1)+' dB':'∞'}`;
    roMloss.textContent=`${mloss.toFixed(2)} dB`;
    roZ1.textContent=formatComplex(Z1)+' Ω';
    roZ2.textContent=formatComplex(Z2)+' Ω';
    roZin.textContent=formatComplex(Z_final)+' Ω';
    roQ.textContent=Q.toFixed(3);
    roBstub.textContent=`${Bstub0.toFixed(5)} S (Y0=${Y0.toFixed(4)}) ${(Bstub0>0?'C':'L')}`;
    if(chosen){
      roXB.textContent=`Xs=${Xfinal.toFixed(2)} Ω (${Xfinal>0?'L':'C'}), Bp=${Bfinal.toFixed(5)} S (${Bfinal>0?'C':'L'}) [${topoUsed}]`;
      const w0=2*Math.PI*parseFloat(slF0.value)*1e9;
      let lText='', cText='';
      if(Xfinal>0){ const Lh=Xfinal/w0*1e9; lText=`L_series=${Lh.toFixed(2)} nH`; }
      else if(Xfinal<0){ const Ch=-1/(Xfinal*w0)*1e12; lText=`C_series=${Ch.toFixed(2)} pF`; }
      if(Bfinal>0){ const Ch=Bfinal/w0*1e12; cText=`C_shunt=${Ch.toFixed(2)} pF`; }
      else if(Bfinal<0){ const Lh=-1/(Bfinal*w0)*1e9; cText=`L_shunt=${Lh.toFixed(2)} nH`; }
      roLc.textContent=`${lText} ${cText}`.trim() || '—';
    }else{
      roXB.textContent= document.getElementById('sel-match').value==='none' ? 'Bypass – no L' : 'No solution (|Γ| constraints)';
      roLc.textContent='—';
    }
    roGmag.textContent=gFmag.toFixed(4);
    roVswr2.textContent=vswrL.toFixed(3)+':1';
    roZmatch.textContent=formatComplex(Z_final);
    lblSmith.textContent=`|ΓF|=${gFmag.toFixed(3)} |ΓL|=${gLmag.toFixed(3)}`;
    const matchPct=Math.max(0,Math.min(100,(1-gFmag)*100));
    barMatch.style.width=matchPct.toFixed(1)+'%';
    if(vswrL<1.05) { matchState.textContent=`MATCHED ✓ VSWR ${vswrL.toFixed(2)}`; matchState.style.color='#4ade80'; }
    else if(vswrL<2) { matchState.textContent=`Near match VSWR ${vswrL.toFixed(2)} |Γ|=${gFmag.toFixed(3)}`; matchState.style.color='#fbbf24'; }
    else { matchState.textContent=`Mismatch VSWR ${vswrL.toFixed(2)} Return ${rloss.toFixed(1)} dB`; matchState.style.color='var(--mp-muted)'; }

    if(vswrL<1.12) barMatch.style.background='#4ade80';
    else if(vswrL<2) barMatch.style.background='#fbbf24';
    else barMatch.style.background='var(--mp-cta)';

    // update audio
    updateAudio(gFmag);

    // draw
    drawSmith(data);
    drawSweep(data);
    drawSchem(data);
  }

  function drawSmith(data){
    const W=400,H=400,cx=W/2, cy=H/2, R=175;
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    smithCtx.fillStyle=bg; smithCtx.fillRect(0,0,W,H);

    // grid outer circle
    smithCtx.strokeStyle='rgba(255,255,255,0.18)'; smithCtx.lineWidth=1.2;
    smithCtx.beginPath(); smithCtx.arc(cx,cy,R,0,Math.PI*2); smithCtx.stroke();

    // resistance circles r=0,0.2,0.5,1,2,5
    const rVals=[0,0.2,0.5,1,2,5];
    for(const r of rVals){
      const rr=R/(1+r);
      const ccx=cx + R * r/(1+r);
      smithCtx.strokeStyle= r===1 ? 'rgba(255,255,255,0.22)' : 'rgba(255,255,255,0.10)';
      smithCtx.lineWidth= r===1 ? 1.2 : 0.8;
      smithCtx.beginPath(); smithCtx.arc(ccx,cy,rr,0,Math.PI*2); smithCtx.stroke();
    }
    // reactance circles
    const xVals=[0.2,0.5,1,2,5];
    for(const xv of xVals){
      for(const sign of [1,-1]){
        const x=xv*sign;
        const rr=R/Math.abs(x);
        const ccx=cx + R;
        const ccy=cy - R/x; // formula
        smithCtx.strokeStyle='rgba(255,255,255,0.08)';
        smithCtx.lineWidth=0.7;
        smithCtx.beginPath();
        // arc of reactance circle: center (1, 1/x) radius 1/|x| – we draw full circle but clip to main circle by using arc and keeping inside? Simplify full
        smithCtx.arc(ccx, ccy, rr, 0, Math.PI*2); smithCtx.stroke();
      }
    }
    // horizontal diameter
    smithCtx.strokeStyle='rgba(255,255,255,0.10)'; smithCtx.beginPath(); smithCtx.moveTo(cx-R,cy); smithCtx.lineTo(cx+R,cy); smithCtx.stroke();

    // VSWR=2 circle
    const vswr2Rad = R * (2-1)/(2+1); // actually |Γ| = (VSWR-1)/(VSWR+1)=1/3
    smithCtx.strokeStyle='rgba(251,191,36,0.35)'; smithCtx.setLineDash([4,3]); smithCtx.beginPath(); smithCtx.arc(cx,cy,R*1/3,0,Math.PI*2); smithCtx.stroke(); smithCtx.setLineDash([]);
    smithCtx.fillStyle='rgba(251,191,36,0.55)'; smithCtx.font='9px ui-monospace'; smithCtx.fillText('VSWR 2', cx+ R*0.33+4, cy-4);

    // sweep trace
    if(data.sweepPoints){
      smithCtx.beginPath(); smithCtx.strokeStyle='rgba(96,165,250,0.38)'; smithCtx.lineWidth=1;
      data.sweepPoints.forEach((p,i)=>{
        const x=cx + p.g.re*R, y=cy - p.g.im*R;
        if(i===0) smithCtx.moveTo(x,y); else smithCtx.lineTo(x,y);
      }); smithCtx.stroke();
    }

    // journey
    const pts=[data.gammaL, data.gamma1, data.gamma2, data.gammaF];
    const colors=['#fbbf24','#22d3ee','#fb923c','#ffffff'];
    // lines
    smithCtx.lineWidth=1.8;
    for(let i=0;i<pts.length-1;i++){
      const a=pts[i], b=pts[i+1];
      if(!a||!b) continue;
      smithCtx.strokeStyle=colors[i];
      smithCtx.beginPath(); smithCtx.moveTo(cx + a.re*R, cy - a.im*R); smithCtx.lineTo(cx + b.re*R, cy - b.im*R); smithCtx.stroke();
      // arrow mid
      const mx=(a.re+b.re)/2, my=(a.im+b.im)/2;
      smithCtx.fillStyle=colors[i]; smithCtx.beginPath(); smithCtx.arc(cx+mx*R, cy - my*R, 2,0,Math.PI*2); smithCtx.fill();
    }

    // dots
    pts.forEach((g,i)=>{
      if(!g) return;
      const x=cx + g.re*R, y=cy - g.im*R;
      smithCtx.fillStyle=colors[i];
      smithCtx.beginPath(); smithCtx.arc(x,y, i===3?6:5,0,Math.PI*2); smithCtx.fill();
      smithCtx.strokeStyle=bg; smithCtx.lineWidth=1.5; smithCtx.stroke();
      smithCtx.fillStyle='#e8eef6'; smithCtx.font='10px ui-monospace';
      const label=['ΓL','Γ_line','Γ_stub','Γ_in'][i];
      smithCtx.fillText(label, x+7, y-7);
    });

    // center
    smithCtx.fillStyle='#4ade80'; smithCtx.beginPath(); smithCtx.arc(cx,cy,3,0,Math.PI*2); smithCtx.fill();
    smithCtx.fillStyle='rgba(255,255,255,0.6)'; smithCtx.font='9px ui-monospace'; smithCtx.fillText('50Ω', cx+6, cy+4);
  }

  function drawSweep(data){
    const W=900,H=280;
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    sweepCtx.fillStyle=bg; sweepCtx.fillRect(0,0,W,H);

    // grid dB -40..0
    sweepCtx.strokeStyle='rgba(255,255,255,0.06)'; sweepCtx.lineWidth=1;
    for(let db=-40; db<=0; db+=10){
      const y=H - (db+40)/40 * H;
      sweepCtx.beginPath(); sweepCtx.moveTo(0,y); sweepCtx.lineTo(W,y); sweepCtx.stroke();
      sweepCtx.fillStyle='rgba(255,255,255,0.35)'; sweepCtx.font='10px ui-monospace'; sweepCtx.fillText(db+' dB', 4, y-2);
    }
    // freq ticks
    const fMin=data.fMin, fMax=data.fMax;
    for(let i=0;i<=6;i++){
      const f=fMin + (fMax-fMin)*i/6;
      const x= (f - fMin)/(fMax - fMin) * W;
      sweepCtx.beginPath(); sweepCtx.moveTo(x,0); sweepCtx.lineTo(x,H); sweepCtx.stroke();
      sweepCtx.fillStyle='rgba(255,255,255,0.35)'; sweepCtx.fillText(f.toFixed(2)+'GHz', x-18, H-4);
    }

    // S11
    sweepCtx.beginPath(); sweepCtx.strokeStyle='#f87171'; sweepCtx.lineWidth=2.2;
    data.sweepPoints.forEach((p,i)=>{
      const x= (p.fGHz - fMin)/(fMax-fMin)*W;
      const y= H - (p.s11db +40)/40 * H;
      const yc=Math.max(0,Math.min(H,y));
      if(i===0) sweepCtx.moveTo(x,yc); else sweepCtx.lineTo(x,yc);
    }); sweepCtx.stroke();

    // S21
    sweepCtx.beginPath(); sweepCtx.strokeStyle='#60a5fa'; sweepCtx.lineWidth=1.8;
    data.sweepPoints.forEach((p,i)=>{
      const x= (p.fGHz - fMin)/(fMax-fMin)*W;
      const y= H - (p.s21db +40)/40 * H;
      const yc=Math.max(0,Math.min(H,y));
      if(i===0) sweepCtx.moveTo(x,yc); else sweepCtx.lineTo(x,yc);
    }); sweepCtx.stroke();

    // -10dB line
    const y10=H - (-10+40)/40*H;
    sweepCtx.strokeStyle='rgba(74,222,128,0.5)'; sweepCtx.setLineDash([6,4]); sweepCtx.beginPath(); sweepCtx.moveTo(0,y10); sweepCtx.lineTo(W,y10); sweepCtx.stroke(); sweepCtx.setLineDash([]);

    // f0 marker
    const f0=data.f0GHz;
    const x0=(f0 - fMin)/(fMax-fMin)*W;
    const idxClosest=data.sweepPoints.reduce((best,i,idx)=> Math.abs(i.fGHz - f0) < Math.abs(best.fGHz - f0) ? i : best, data.sweepPoints[0]);
    // find point closest
    let bestP=data.sweepPoints[0], bestDiff=1e9;
    for(const p of data.sweepPoints){ const d=Math.abs(p.fGHz - f0); if(d<bestDiff){bestDiff=d; bestP=p;} }
    const yS11=H - (bestP.s11db +40)/40*H;
    const yS21=H - (bestP.s21db +40)/40*H;
    sweepCtx.fillStyle='#fff'; sweepCtx.beginPath(); sweepCtx.arc(x0, yS11, 5,0,Math.PI*2); sweepCtx.fill();
    sweepCtx.fillStyle='#fff'; sweepCtx.beginPath(); sweepCtx.arc(x0, yS21, 4,0,Math.PI*2); sweepCtx.fill();
    sweepCtx.strokeStyle='#fff'; sweepCtx.lineWidth=1; sweepCtx.beginPath(); sweepCtx.moveTo(x0,0); sweepCtx.lineTo(x0,H); sweepCtx.stroke();

    lblSweep.textContent=`f₀=${f0.toFixed(2)}GHz S11=${bestP.s11db.toFixed(1)}dB S21=${bestP.s21db.toFixed(1)}dB BW-10dB ?`;
  }

  function drawSchem(data){
    const W=520,H=400;
    const bg=getComputedStyle(document.documentElement).getPropertyValue('--mp-canvas').trim()||'#0f141c';
    schemCtx.fillStyle=bg; schemCtx.fillRect(0,0,W,H);

    const leftX=40, rightX=W-50, midY=H/2;
    // source
    schemCtx.strokeStyle='#e8eef6'; schemCtx.lineWidth=1.5;
    schemCtx.beginPath(); schemCtx.arc(leftX,midY,18,0,Math.PI*2); schemCtx.stroke();
    schemCtx.fillStyle='#e8eef6'; schemCtx.font='11px ui-monospace'; schemCtx.fillText('Z_s', leftX-12, midY+4);
    schemCtx.fillStyle='rgba(255,255,255,0.5)'; schemCtx.font='10px ui-monospace'; schemCtx.fillText(`${parseFloat(slRsrc.value)}${parseFloat(slXsrc.value)>=0?'+':''}${parseFloat(slXsrc.value)}j`, leftX-20, midY-26);

    // line start
    let curX=leftX+18;
    const seriesGap=110;
    const shuntX=leftX+120;
    // series element from L-match
    if(data.chosen){
      const X=data.chosen.X;
      if(Math.abs(X)>0.5){
        if(X>0){ // inductor coil
          schemCtx.strokeStyle='#fbbf24'; schemCtx.lineWidth=1.8;
          schemCtx.beginPath();
          let sx=curX;
          schemCtx.moveTo(sx,midY);
          for(let k=0;k<4;k++){ const cx=sx+8 + k*12; const cy=midY + (k%2? -10:10); schemCtx.lineTo(cx,cy); }
          sx+=50; schemCtx.lineTo(sx,midY);
          schemCtx.stroke();
          const w0=2*Math.PI*parseFloat(slF0.value)*1e9;
          const Ln = X/w0*1e9;
          schemCtx.fillStyle='#fbbf24'; schemCtx.font='9px ui-monospace'; schemCtx.fillText(`L ${Ln>=0?Ln.toFixed(1)+'nH':''}`, curX, midY-16);
          curX+=60;
        }else{ // capacitor
          schemCtx.strokeStyle='#60a5fa'; schemCtx.lineWidth=1.8;
          const capX=curX+25;
          schemCtx.beginPath(); schemCtx.moveTo(curX,midY); schemCtx.lineTo(capX-6,midY); schemCtx.moveTo(capX+6,midY); schemCtx.lineTo(capX+18,midY); schemCtx.stroke();
          schemCtx.beginPath(); schemCtx.moveTo(capX-6,midY-14); schemCtx.lineTo(capX-6,midY+14); schemCtx.moveTo(capX+6,midY-14); schemCtx.lineTo(capX+6,midY+14); schemCtx.stroke();
          const w0=2*Math.PI*parseFloat(slF0.value)*1e9;
          const Cc = -1/(X*w0)*1e12;
          schemCtx.fillStyle='#60a5fa'; schemCtx.font='9px ui-monospace'; schemCtx.fillText(`C ${Cc.toFixed(2)}pF`, curX, midY-16);
          curX+=50;
        }
      }
    }

    // line to stub position
    const totalLineLen= rightX-100 - curX;
    const posFrac=parseFloat(slStubPos.value); // 0-0.5
    const posX=curX + totalLineLen* (0.3 + posFrac*1.2); // map
    // draw main line as two lines
    schemCtx.strokeStyle='#9ca3af'; schemCtx.lineWidth=1.2;
    schemCtx.beginPath(); schemCtx.moveTo(curX,midY-6); schemCtx.lineTo(rightX-80,midY-6); schemCtx.stroke();
    schemCtx.beginPath(); schemCtx.moveTo(curX,midY+6); schemCtx.lineTo(rightX-80,midY+6); schemCtx.stroke();
    // distance label
    schemCtx.fillStyle='rgba(255,255,255,0.5)'; schemCtx.font='9px ui-monospace'; schemCtx.fillText(`d=${posFrac.toFixed(3)}λ`, curX+10, midY-18);

    // shunt element at shuntX (if shunt-first, this is L-match shunt; else stub location is shunt)
    // draw shunt L-match at shuntX if exists and shunt-first
    if(data.chosen && data.topoUsed==='shunt-first'){
      const B=data.chosen.B;
      const sx=curX+20;
      schemCtx.strokeStyle= B>0 ? '#60a5fa' : '#fbbf24';
      schemCtx.beginPath(); schemCtx.moveTo(sx,midY-6); schemCtx.lineTo(sx, midY+60); schemCtx.stroke();
      // component symbol
      if(B>0){ // shunt C => capacitor to ground
        schemCtx.beginPath(); schemCtx.moveTo(sx-12, midY+24); schemCtx.lineTo(sx+12, midY+24); schemCtx.moveTo(sx-12, midY+32); schemCtx.lineTo(sx+12, midY+32); schemCtx.stroke();
      }else{
        // inductor
        schemCtx.beginPath();
        let sy=midY+20;
        schemCtx.moveTo(sx,sy);
        for(let k=0;k<3;k++){ const cy=sy+6+k*10; schemCtx.lineTo(sx + (k%2?6:-6), cy); }
        schemCtx.stroke();
      }
      // ground
      schemCtx.strokeStyle='#e8eef6'; schemCtx.beginPath(); schemCtx.moveTo(sx-14, midY+66); schemCtx.lineTo(sx+14, midY+66); schemCtx.moveTo(sx-10, midY+71); schemCtx.lineTo(sx+10, midY+71); schemCtx.moveTo(sx-6, midY+76); schemCtx.lineTo(sx+6, midY+76); schemCtx.stroke();
      schemCtx.fillStyle='#e8eef6'; schemCtx.font='8px ui-monospace'; schemCtx.fillText(`Bp ${B.toFixed(4)}S`, sx+10, midY+40);
    }

    // stub at posX
    const stubLenDeg=parseFloat(slStubLen.value);
    const lenPx= 20 + stubLenDeg*0.55;
    const stubX=posX;
    schemCtx.strokeStyle='#f472b6'; schemCtx.lineWidth=1.6;
    schemCtx.beginPath(); schemCtx.moveTo(stubX,midY-6); schemCtx.lineTo(stubX, midY- lenPx); schemCtx.stroke();
    schemCtx.strokeStyle='#f472b6';
    schemCtx.fillStyle='#f472b6'; schemCtx.font='9px ui-monospace'; schemCtx.fillText(`${selStub.value} ${stubLenDeg.toFixed(0)}°`, stubX+6, midY- lenPx+10);
    // stub end: open circle or short ground
    if(selStub.value==='open'){
      schemCtx.beginPath(); schemCtx.arc(stubX, midY- lenPx, 5,0,Math.PI*2); schemCtx.stroke();
      schemCtx.fillStyle='rgba(255,255,255,0.6)'; schemCtx.fillText('open', stubX+8, midY- lenPx);
    }else{
      // short to ground? Actually short stub shorted to ground? Usually to ground? Draw ground
      schemCtx.strokeStyle='#e8eef6'; schemCtx.beginPath(); schemCtx.moveTo(stubX-10, midY- lenPx); schemCtx.lineTo(stubX+10, midY- lenPx); schemCtx.stroke();
      schemCtx.beginPath(); schemCtx.moveTo(stubX-7, midY- lenPx+5); schemCtx.lineTo(stubX+7, midY- lenPx+5); schemCtx.stroke();
    }
    // if series-first shunt at end before load
    if(data.chosen && data.topoUsed==='series-first'){
      const B=data.chosen.B;
      const sx=rightX-90;
      schemCtx.strokeStyle= B>0 ? '#60a5fa' : '#fbbf24'; schemCtx.lineWidth=1.6;
      schemCtx.beginPath(); schemCtx.moveTo(sx,midY-6); schemCtx.lineTo(sx, midY+55); schemCtx.stroke();
      if(B>0){ schemCtx.beginPath(); schemCtx.moveTo(sx-12, midY+22); schemCtx.lineTo(sx+12, midY+22); schemCtx.moveTo(sx-12, midY+30); schemCtx.lineTo(sx+12, midY+30); schemCtx.stroke(); }
      else { schemCtx.beginPath(); let sy=midY+18; schemCtx.moveTo(sx,sy); for(let k=0;k<3;k++){ schemCtx.lineTo(sx+(k%2?6:-6), sy+6+k*10);} schemCtx.stroke();}
      schemCtx.strokeStyle='#e8eef6'; schemCtx.beginPath(); schemCtx.moveTo(sx-14, midY+64); schemCtx.lineTo(sx+14, midY+64); schemCtx.stroke();
    }

    // load
    const loadX=rightX-30;
    schemCtx.strokeStyle='#e8eef6'; schemCtx.lineWidth=1.6;
    // zigzag resistor
    schemCtx.beginPath();
    schemCtx.moveTo(rightX-80, midY);
    let lx=rightX-80;
    for(let i=0;i<4;i++){ const nx=lx+10; const ny=midY + (i%2? -8:8); schemCtx.lineTo(nx,ny); lx=nx; }
    schemCtx.lineTo(loadX,midY); schemCtx.stroke();
    schemCtx.fillStyle='#e8eef6'; schemCtx.font='11px ui-monospace'; schemCtx.fillText('Z_L', loadX-10, midY-16);
    schemCtx.fillStyle='rgba(255,255,255,0.6)'; schemCtx.font='9px ui-monospace'; schemCtx.fillText(`${formatComplex(data.ZL)}`, loadX-35, midY+24);

    // VSWR label
    const vswr=(1+cMag(data.gammaF))/(1-cMag(data.gammaF)+1e-6);
    schemCtx.fillStyle= vswr<1.2 ? '#4ade80' : '#fbbf24'; schemCtx.font='12px ui-monospace'; schemCtx.fillText(`VSWR ${vswr.toFixed(2)} |Γ| ${cMag(data.gammaF).toFixed(3)}`, curX, H-14);

    // ground line bottom
    schemCtx.strokeStyle='rgba(255,255,255,0.15)'; schemCtx.beginPath(); schemCtx.moveTo(leftX, H-36); schemCtx.lineTo(W-10, H-36); schemCtx.stroke();
  }

  smithC.addEventListener('click',(e)=>{
    const rect=smithC.getBoundingClientRect();
    const W=400,H=400,cx=W/2,cy=H/2,R=175;
    const x=(e.clientX - rect.left) * (W/rect.width);
    const y=(e.clientY - rect.top) * (H/rect.height);
    const re=(x-cx)/R, im=(cy - y)/R;
    const mag=Math.hypot(re,im);
    if(mag>0.98) return;
    // Gamma to Z: Z = Z0*(1+Γ)/(1-Γ)
    const Z0=parseFloat(slZ0.value);
    const g=C(re,im);
    const one=C(1,0);
    const num=cAdd(one,g), den=cSub(one,g);
    const ratio=cDiv(num,den);
    const Z=C(ratio.re*Z0, ratio.im*Z0);
    slRl.value= Math.max(5,Math.min(300, Z.re)).toFixed(0);
    slXl.value= Math.max(-200,Math.min(200, Z.im)).toFixed(0);
    updOut(); compute();
  });

  btnReset.addEventListener('click',()=>{
    slRl.value=50; slXl.value=0; slRsrc.value=50; slXsrc.value=0; slStubLen.value=45; slStubPos.value=0.12; selStub.value='open'; selMatch.value='auto-shunt-LC';
    updOut(); compute();
  });
  btnAuto.addEventListener('click',()=>{
    // naive auto: try find stub len that minimizes |GammaF| by brute force
    let bestLen=parseFloat(slStubLen.value), bestGamma=1e9;
    const orig=parseFloat(slStubLen.value);
    for(let len=0; len<=170; len+=1){
      slStubLen.value=len;
      const d=computeJourney();
      const mag=cMag(d.gammaF);
      if(mag<bestGamma){ bestGamma=mag; bestLen=len; }
    }
    slStubLen.value=bestLen;
    updOut(); compute();
    btnAuto.textContent=`✦ Auto ${bestLen}° |Γ|${bestGamma.toFixed(3)}`;
    setTimeout(()=>{ btnAuto.textContent='✦ Auto L-match'; },2200);
  });

  updOut();
  compute();

  document.addEventListener('astro:before-swap',()=>{ try{audioCtx?.close();}catch{} },{once:true});
}
document.addEventListener('astro:page-load', initRFBench);
initRFBench();
</script>
</Layout>
