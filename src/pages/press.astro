---
import BrandLogo from '../components/BrandLogo.astro';
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';

const title = 'Press Kit — MakerPortal';
const description =
  'Logos, wordmark, founder bio, and boilerplate for MakerPortal. San Francisco privacy-first iOS studio.';
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Press · Brand · Boilerplate"
    title="Press kit."
    lead="Assets and facts for journalists, partners, and collaborators. Prefer vector marks; do not recolor the App Grid crimson without approval."
    status="Kit scaffold"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-full bg-white px-5 text-[0.9rem] font-bold text-canvas hover:bg-primary-text">Media contact</a>
        <a href="/icon-512.png" class="inline-flex min-h-11 items-center rounded-full border border-white/10 px-5 text-[0.9rem] font-medium text-primary-text/80 hover:text-white">Icon PNG</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-white/[0.06]">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="grid gap-10 lg:grid-cols-2">
        <div class="rounded-[24px] border border-white/[0.06] bg-[#1A232E] p-8">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text/70">Lockup</p>
          <div class="mt-6 flex items-center gap-6">
            <BrandLogo variant="icon" size="lg" class="size-16" />
            <BrandLogo variant="lockup" size="lg" class="w-[200px]" />
          </div>
          <p class="mt-6 text-[0.9rem] text-primary-text/60">App Grid: 2×2 tiles, BR always crimson #CE445D. Canvas #0F141C.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-white">Boilerplate</h2>
          <p class="mt-4 text-[0.95rem] leading-[1.75] text-primary-text/65">
            MakerPortal is an independent San Francisco software studio building privacy-first iOS and iPadOS applications powered by on-device neural networks. Established in 2023, the studio ships focused utilities with zero telemetry and Apple Silicon–native intelligence.
          </p>
          <h3 class="mt-8 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text/70">Contact</h3>
          <p class="mt-2"><a href="/contact" class="text-brand-anchor hover:text-white">makerportal.ai/contact</a></p>
        </div>
      </div>
    </div>
  </section>
</Layout>
