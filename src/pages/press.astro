---
import BrandLogo from '../components/BrandLogo.astro';
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';

const title = 'Press Kit — MakerPortal';
const description =
  'Logos, wordmark, founder bio, and boilerplate for MakerPortal. San Francisco iOS studio — on-device first, transparent hybrid for agentic DSP.';
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Press · Brand · Boilerplate"
    title="Press kit."
    lead="Assets and facts for journalists, partners, and collaborators. Prefer vector marks; do not recolor the App Grid crimson without approval."
    status="Press kit"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Media contact</a>
        <a href="/icon-512.png" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Icon PNG</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="grid gap-10 lg:grid-cols-2">
        <div class="surface-card rounded-[24px] border bg-card-bg p-8">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">Lockup</p>
          <div class="mt-6 flex items-center gap-6">
            <BrandLogo variant="icon" size="lg" class="size-16" />
            <BrandLogo variant="lockup" size="lg" class="w-[200px]" />
          </div>
          <p class="mt-6 text-[0.9rem] text-muted-text">App Grid: 2×2 tiles, BR always crimson #CE445D. Canvas #0F141C. Icons 64/128/256/512 webp.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/press/makerportal-icons.zip" download class="inline-flex min-h-10 items-center rounded-full bg-primary-text px-4 text-[0.85rem] font-bold text-canvas hover:opacity-90">Download icons (128+256 webp, 98KB) ↓</a>
            <a href="/icon-512.png" class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-4 text-[0.85rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)]">Icon PNG 512</a>
          </div>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-primary-text">Boilerplate</h2>
          <p class="mt-4 text-[0.95rem] leading-[1.75] text-muted-text">
            MakerPortal is an independent San Francisco software studio building iOS and iPadOS applications — on-device ML where possible, transparent hybrid cloud for agentic DSP (AuraLinter). Established in 2023, the studio ships focused utilities with Apple Silicon–native intelligence, no dark patterns, and clear disclosure when cloud is used.
          </p>
          <h3 class="mt-6 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">11 apps — on-device first</h3>
          <p class="mt-2 text-[0.85rem] leading-[1.6] text-muted-text">AuraLinter (agentic DSP), Biquadia (neural DSP lab), Thumb-Dash (SmolLM2-360M), nymic (kNN-VC), Notiary (semantic notes), akous (Diffusion Transformer ANE), PopCloset (vision wardrobe), itria (llama.cpp), GridVerse (AI word game), MotionLink (Headphone Motion), BLExAR (BLE Arduino).</p>
          <h3 class="mt-8 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">Contact</h3>
          <p class="mt-2"><a href="/contact" class="text-brand-anchor hover:text-primary-text">makerportal.ai/contact</a> · <a href="/advertise" class="text-brand-anchor hover:text-primary-text">Sponsor kit →</a></p>
          <h3 class="mt-6 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">Pillars</h3>
          <p class="mt-2 text-[0.8rem] text-muted-text">on-device-ai · metal-ane · local-llm · dsp-audio · ios-craft · privacy-arch — see /resources#trending</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border bg-elevated/20">
    <div class="mx-auto max-w-[88rem] px-5 py-12 sm:px-8 lg:px-10">
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Usage notes</p>
      <p class="mt-2 max-w-3xl text-[0.85rem] leading-[1.6] text-muted-text">Do not recolor App Grid BR tile crimson #CE445D. Prefer vector marks; icon PNG at 512 for press. All trademarks Apple Inc. For high-res or custom assets use media contact.</p>
    </div>
  </section>
</Layout>
