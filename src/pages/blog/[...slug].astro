---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  posts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      nextPost: index > 0 ? posts[index - 1] : null,
      prevPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const canonical = new URL(`/blog/${post.id}`, Astro.site);
const publishedTime = post.data.publishedAt.toISOString();
const modifiedTime = (post.data.updatedAt ?? post.data.publishedAt).toISOString();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedTime,
  dateModified: modifiedTime,
  mainEntityOfPage: canonical.toString(),
  author: { '@id': 'https://makersportal.com/#organization' },
  publisher: { '@id': 'https://makersportal.com/#organization' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Field Notes', item: 'https://www.makerportal.ai/blog' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical.toString() },
  ],
};
---

<Layout title={`${post.data.title} — MakerPortal`} description={post.data.description} canonical={canonical} type="article" publishedTime={publishedTime} modifiedTime={modifiedTime}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  </Fragment>
  <article>
    <header class="hero-grid border-b border-muted-text/15">
      <div class="mx-auto max-w-5xl px-5 pb-16 pt-16 sm:px-8 sm:pb-24 sm:pt-24">
        <a href="/blog" class="inline-flex min-h-11 items-center text-sm font-semibold text-muted-text hover:text-white transition-colors duration-200">← All field notes</a>
        <p class="section-kicker mt-12">{post.data.eyebrow}</p>
        <h1 class="mt-5 text-balance text-5xl font-semibold leading-[0.94] tracking-[-0.055em] text-white sm:text-7xl">{post.data.title}</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-primary-text/90 sm:text-xl">{post.data.description}</p>
        <div class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-muted-text/20 pt-5 font-mono text-[0.65rem] uppercase tracking-[0.16em] text-muted-text">
          <time datetime={post.data.publishedAt.toISOString()}>{post.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</time>
          <span aria-hidden="true">/</span>
          <span>{post.data.readingTime}</span>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-24">
      <div class="prose-studio"><Content /></div>
      
      <div class="mt-16 border-t border-muted-text/20 pt-10 grid gap-6 sm:grid-cols-2">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="group flex flex-col items-start gap-2 rounded-2xl border border-muted-text/15 bg-card-bg/30 p-6 transition-colors hover:border-brand-anchor/50 hover:bg-card-bg">
            <span class="font-mono text-[0.65rem] uppercase tracking-widest text-muted-text">Previous Note</span>
            <span class="text-lg font-semibold leading-tight text-white transition-colors group-hover:text-brand-anchor">{prevPost.data.title}</span>
          </a>
        ) : <div />}
        {nextPost && (
          <a href={`/blog/${nextPost.id}`} class="group flex flex-col items-end gap-2 rounded-2xl border border-muted-text/15 bg-card-bg/30 p-6 text-right transition-colors hover:border-primary-cta/50 hover:bg-card-bg sm:col-start-2">
            <span class="font-mono text-[0.65rem] uppercase tracking-widest text-muted-text">Next Note</span>
            <span class="text-lg font-semibold leading-tight text-white transition-colors group-hover:text-primary-cta">{nextPost.data.title}</span>
          </a>
        )}
      </div>
    </div>
  </article>
</Layout>
