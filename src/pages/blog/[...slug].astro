---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  posts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      nextPost: index > 0 ? posts[index - 1] : null,
      prevPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const canonical = new URL(`/blog/${post.id}`, Astro.site);
const publishedTime = post.data.publishedAt.toISOString();
const modifiedTime = (post.data.updatedAt ?? post.data.publishedAt).toISOString();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedTime,
  dateModified: modifiedTime,
  mainEntityOfPage: canonical.toString(),
  author: { '@id': 'https://makersportal.com/#organization' },
  publisher: { '@id': 'https://makersportal.com/#organization' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Field Notes', item: 'https://www.makerportal.ai/blog' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical.toString() },
  ],
};
---

<Layout title={`${post.data.title} — MakerPortal`} description={post.data.description} canonical={canonical} type="article" publishedTime={publishedTime} modifiedTime={modifiedTime}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  </Fragment>

  <!-- Reading paper: warm light surface for long-form dwell (research polarity) -->
  <article class="reading-paper flex-1 border-b reading-line">
    <header class="border-b reading-line">
      <div class="mx-auto max-w-5xl px-5 pb-14 pt-16 sm:px-8 sm:pb-20 sm:pt-24">
        <a href="/blog" class="inline-flex min-h-11 items-center text-sm font-semibold transition-colors" style="color: var(--mp-paper-muted)">← All field notes</a>
        <p class="section-kicker mt-10">{post.data.eyebrow}</p>
        <h1 class="reading-ink mt-5 text-balance text-5xl font-semibold leading-[0.94] tracking-[-0.055em] sm:text-7xl">{post.data.title}</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 sm:text-xl" style="color: color-mix(in srgb, var(--mp-paper-ink) 88%, var(--mp-paper-muted))">{post.data.description}</p>
        <div class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 border-t reading-line pt-5 font-mono text-[0.65rem] uppercase tracking-[0.16em] reading-muted">
          <time datetime={post.data.publishedAt.toISOString()}>{post.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</time>
          <span aria-hidden="true">/</span>
          <span>{post.data.readingTime}</span>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-5 py-14 sm:px-8 sm:py-20">
      <div class="prose-paper"><Content /></div>

      <div class="mt-16 grid grid-cols-2 gap-4 border-t reading-line pt-10 sm:gap-6">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="reading-card group flex flex-col items-start gap-1 sm:gap-2 rounded-2xl p-4 sm:p-6 transition-shadow hover:shadow-md">
            <span class="font-mono text-[0.55rem] sm:text-[0.65rem] uppercase tracking-widest reading-muted">Previous Note</span>
            <span class="text-base sm:text-lg font-semibold leading-tight reading-ink transition-colors group-hover:text-[var(--mp-paper-link)]">{prevPost.data.title}</span>
          </a>
        ) : <div />}
        {nextPost && (
          <a href={`/blog/${nextPost.id}`} class="reading-card group flex flex-col items-end gap-1 sm:gap-2 rounded-2xl p-4 sm:p-6 text-right transition-shadow hover:shadow-md sm:col-start-2">
            <span class="font-mono text-[0.55rem] sm:text-[0.65rem] uppercase tracking-widest reading-muted">Next Note</span>
            <span class="text-base sm:text-lg font-semibold leading-tight reading-ink transition-colors group-hover:text-[var(--mp-paper-link)]">{nextPost.data.title}</span>
          </a>
        )}
      </div>
    </div>
  </article>
</Layout>
