---
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';

const title = 'Watch — MakerPortal Video & Demos';
const description =
  'On-device AI demos, shipping logs, and craft talks from MakerPortal. YouTube channel and embedded series live here.';

const series = [
  { title: 'Ship logs', blurb: 'Short release notes in motion — AuraLinter agentic loops, Biquadia DSP, Thumb-Dash LLM, nymic kNN-VC, 11 apps and growing.', status: 'Channel TBD' },
  { title: 'On-device labs', blurb: 'CoreML, ANE, Metal, ONNX, llama.cpp, LangGraph Production RAG — without the cloud tax.', status: 'Planned' },
  { title: 'App walkthroughs', blurb: 'AuraLinter, Biquadia, nymic, akous, itria, GridVerse, MotionLink, BLExAR — real product tours across 11 live.', status: 'Planned' },
];
---

<Layout title={title} description={description}>
  <HubShell
    kicker="Studio · Watch · Video"
    title="See the craft."
    lead="Video surface under Studio — demos, deep dives, and social clips that funnel back to apps, Lab, and the shop. Channel is scaffolding until series ship."
    status="Scaffold"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="https://www.youtube.com/@MakerPortal" target="_blank" rel="me noopener" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">YouTube ↗</a>
        <a href="/blog" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated px-5 text-[0.9rem] font-medium text-muted-text hover:border-[var(--mp-border-strong)] hover:text-primary-text">Field notes</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="mb-10 aspect-video w-full max-w-4xl overflow-hidden rounded-[24px] border border-border bg-card-bg">
        <div class="grid h-full place-items-center p-8 text-center">
          <div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.16em] text-muted-text">Featured embed</p>
            <p class="mt-3 text-lg font-semibold text-primary-text">Connect the YouTube channel to light this up</p>
            <p class="mt-2 max-w-md text-[0.9rem] text-muted-text">Placeholder stage for the latest upload or a studio playlist.</p>
          </div>
        </div>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {series.map((s) => (
          <article class="surface-card rounded-[24px] border bg-card-bg p-6">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-brand-anchor">{s.status}</p>
            <h2 class="mt-3 text-xl font-semibold text-primary-text">{s.title}</h2>
            <p class="mt-3 text-[0.92rem] leading-[1.65] text-muted-text">{s.blurb}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
