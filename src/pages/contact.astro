---
import ContactCard from '../components/ContactCard.astro';
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Contact — MakerPortal Studio';
const pageDescription =
  'Reach MakerPortal in San Francisco. Project ideas, bug reports, partnerships, and press — human-verified form, zero spam, no newsletter.';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': 'https://www.makerportal.ai/contact#page',
  name: 'Contact MakerPortal',
  description: pageDescription,
  url: 'https://www.makerportal.ai/contact',
  isPartOf: { '@id': 'https://www.makerportal.ai/#website' },
  about: { '@id': 'https://makersportal.com/#organization' },
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://makersportal.com/#organization',
    name: 'MakerPortal',
    url: 'https://www.makerportal.ai',
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      url: 'https://www.makerportal.ai/contact',
      availableLanguage: 'English',
      areaServed: 'Worldwide',
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://www.makerportal.ai/contact' },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(contactSchema)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  </Fragment>

  <!-- Rapid contact — form is ATF, no scroll wall -->
  <section class="hero-grid border-b border-border">
    <div class="mx-auto grid max-w-[88rem] gap-8 px-5 py-12 sm:gap-12 sm:px-8 sm:py-16 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:px-10 lg:py-20">
      <!-- Left: minimal headline + trust, sticky -->
      <div class="lg:sticky lg:top-28">
        <p class="section-kicker">Contact • Human inbox • Zero spam</p>
        <h1 class="mt-4 text-balance text-[clamp(2.6rem,5vw,4rem)] font-[750] leading-[0.9] tracking-[-0.06em] text-primary-text">
          Say hello.<br /><span class="text-muted-text">We read it.</span>
        </h1>
        <p class="mt-4 max-w-md text-[0.98rem] leading-[1.65] text-muted-text">
          Slide to verify, send. No newsletter, no tracking. Average reply ~4h SF time.
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-elevated px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
            <span class="size-1 rounded-full bg-emerald-500"></span> Reply ~4h
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
            No newsletter
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
            SF • Worldwide
          </span>
        </div>

        <div class="mt-8 hidden lg:block">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-muted-text">Direct</p>
          <div class="mt-3 flex flex-wrap gap-2 text-[0.85rem]">
            <a href="/apps" class="text-brand-anchor hover:text-primary-text">App matrix →</a>
            <span class="text-muted-text/40">·</span>
            <a href="/" class="text-muted-text hover:text-primary-text">Studio home</a>
            <span class="text-muted-text/40">·</span>
            <a href="/privacy" class="text-muted-text hover:text-primary-text">Privacy</a>
          </div>
        </div>
      </div>

      <!-- Right: form — instant, no scroll required on desktop -->
      <div class="min-w-0">
        <ContactCard />
        <p class="mt-4 text-center font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text/70">
          Slide to verify keeps it human • Honeypot + rate-limited • No cookies for form
        </p>
      </div>
    </div>
  </section>

  <!-- What we can help with — below the fold, after rapid action -->
  <section class="border-b border-border bg-elevated/20">
    <div class="mx-auto max-w-[88rem] px-5 py-14 sm:px-8 sm:py-20 lg:px-10">
      <div class="grid gap-10 lg:grid-cols-3">
        <div class="lg:col-span-1">
          <h2 class="text-[1.4rem] font-[650] tracking-[-0.03em] text-primary-text">What we can help with</h2>
          <p class="mt-3 text-[0.9rem] leading-[1.6] text-muted-text">Pick a topic in the form — routes to the right inbox. No extra steps.</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-3 lg:col-span-2">
          {[
            { t: 'Apps & product', d: 'Bugs, feature ideas, App Store questions for any of 11 titles.', dot: 'bg-primary-cta' },
            { t: 'Collabs & press', d: 'Interviews, partnerships, sponsor inquiries — thoughtful outreach only.', dot: 'bg-brand-anchor' },
            { t: 'On-device craft', d: 'CoreML, privacy architecture, shipping small — happy to compare notes.', dot: 'bg-emerald-500' },
          ].map((x) => (
            <div class="rounded-[18px] border border-border bg-card-bg p-5">
              <div class="flex items-center gap-2">
                <span class:list={['size-1.5 rounded-full', x.dot]}></span>
                <span class="text-[0.9rem] font-semibold text-primary-text">{x.t}</span>
              </div>
              <p class="mt-2 text-[0.85rem] leading-[1.6] text-muted-text">{x.d}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-3 border-t border-border pt-6">
        <a href="/apps" class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-4 text-[0.875rem] font-medium text-muted-text hover:text-primary-text">Browse 11 apps →</a>
        <a href="/team" class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-4 text-[0.875rem] font-medium text-muted-text hover:text-primary-text">Meet team →</a>
        <a href="/about" class="inline-flex min-h-10 items-center rounded-full border border-border bg-elevated px-4 text-[0.875rem] font-medium text-muted-text hover:text-primary-text">About studio →</a>
        <span class="ml-auto font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text/60">No tracking • No newsletter ever • SF + remote</span>
      </div>
    </div>
  </section>
</Layout>
