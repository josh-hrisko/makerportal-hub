---
import { Image } from 'astro:assets';
import HubShell from '../components/HubShell.astro';
import Layout from '../layouts/Layout.astro';
import { team } from '../data/team';

const title = 'Team — MakerPortal Studio';
const description =
  'The MakerPortal team: Principal Engineer and the people shipping privacy-first, on-device iOS software from San Francisco.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.makerportal.ai' },
    { '@type': 'ListItem', position: 2, name: 'Team', item: 'https://www.makerportal.ai/team' },
  ],
};

const orgPeople = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://makersportal.com/#organization',
  name: 'MakerPortal',
  employee: team.map((m) => ({
    '@type': 'Person',
    jobTitle: m.title,
    worksFor: { '@id': 'https://makersportal.com/#organization' },
    description: m.bio,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'San Francisco',
      addressRegion: 'CA',
      addressCountry: 'US',
    },
  })),
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgPeople)}></script>
  </Fragment>

  <HubShell
    kicker="Studio · Team · San Francisco"
    title="People behind the craft."
    lead="A small studio. Direct ownership. The people who design, ship, and stand behind every release."
    status="Team"
  >
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/about" class="inline-flex min-h-11 items-center rounded-full border border-border bg-elevated/50 px-5 text-[0.9rem] font-medium text-primary-text hover:border-brand-anchor/30">About studio</a>
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Contact</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border" aria-labelledby="roster-title">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <h2 id="roster-title" class="text-[clamp(1.4rem,3vw,1.85rem)] font-[650] tracking-[-0.04em] text-primary-text">
        Roster
      </h2>
      <p class="mt-3 max-w-xl text-[0.95rem] text-muted-text">
        Roles first. Studio identity over personal branding.
      </p>

      <ul class="mt-12 grid gap-8 lg:grid-cols-2" role="list">
        {team.map((member) => (
          <li class="surface-card group overflow-hidden rounded-[28px] border shadow-[0_16px_48px_-20px_rgba(0,0,0,0.35)]">
            <div class="grid gap-0 sm:grid-cols-[minmax(0,11rem)_1fr]">
              <div class="relative flex items-center justify-center bg-elevated/60 p-6 sm:p-8">
                <div class="relative size-[9.5rem] overflow-hidden rounded-full border-2 border-border shadow-[0_12px_40px_-12px_rgba(0,0,0,0.45)] ring-4 ring-canvas sm:size-[10.5rem]">
                  <Image
                    src={member.image}
                    alt={member.imageAlt}
                    width={320}
                    height={314}
                    densities={[1, 2]}
                    class="size-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              </div>
              <div class="flex flex-col justify-center p-6 sm:p-8">
                <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-primary-cta">{member.role}</p>
                <h3 class="mt-2 text-[1.65rem] font-bold tracking-[-0.03em] text-primary-text">{member.title}</h3>
                <p class="mt-1 font-mono text-[0.68rem] uppercase tracking-[0.12em] text-muted-text">{member.location}</p>
                <p class="mt-4 text-[0.92rem] leading-[1.7] text-muted-text">{member.bio}</p>
                <div class="mt-5 flex flex-wrap gap-1.5">
                  {member.focus.map((tag) => (
                    <span class="rounded-full border border-border bg-elevated/40 px-2.5 py-1 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>

      <div class="mt-14 rounded-[24px] border border-border bg-elevated/30 px-6 py-6 sm:px-8">
        <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-muted-text">Open source · Studio</p>
        <p class="mt-3 max-w-2xl text-[0.95rem] leading-[1.65] text-muted-text">
          Code and public experiments live under the MakerPortal organization on GitHub.
        </p>
        <a
          href="https://github.com/makerportal"
          target="_blank"
          rel="me noopener noreferrer"
          class="mt-4 inline-flex min-h-10 items-center gap-1.5 text-[0.9rem] font-semibold text-brand-anchor hover:text-primary-text"
        >
          github.com/makerportal ↗
        </a>
      </div>
    </div>
  </section>
</Layout>
