---
import Layout from '../../layouts/Layout.astro';
import HubShell from '../../components/HubShell.astro';
import { tools } from '../../data/tools';
import { pillarMeta, fallbackPillar } from '../../data/trends';

const title = 'Lab — interactive tools | MakerPortal';
const description =
  'Interactive tools built from real, shipped app code — not generic reference calculators. Every tool traces back to a specific MakerPortal app.';

const pillarOf = (pillar: string) => pillarMeta[pillar] ?? fallbackPillar;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: tools
    .filter((t) => t.status === 'live')
    .map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.makerportal.ai/tools/${t.slug}`,
      name: t.title,
    })),
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)}></script>
  </Fragment>

  <HubShell kicker="Learn · Lab" title="Tools built from real, shipped code." lead="Every tool here traces back to a specific MakerPortal app — the same math, the same functions, made interactive. Not reskinned reference calculators." status="Lab">
    <Fragment slot="hero-actions">
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/resources" class="inline-flex min-h-11 items-center rounded-full bg-primary-text px-5 text-[0.9rem] font-bold text-canvas hover:opacity-90">Browse resources</a>
        <a href="/blog" class="inline-flex min-h-11 items-center rounded-full border border-border px-5 text-[0.9rem] font-semibold text-primary-text hover:border-brand-anchor hover:text-brand-anchor">Field notes</a>
      </div>
    </Fragment>
  </HubShell>

  <section class="border-b border-border">
    <div class="mx-auto max-w-[88rem] px-5 py-16 sm:px-8 sm:py-24 lg:px-10">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => {
          const pillar = pillarOf(tool.pillar);
          const isLive = tool.status === 'live';
          const Wrapper = isLive ? 'a' : 'div';
          return (
            <Wrapper
              href={isLive ? `/tools/${tool.slug}` : undefined}
              class={`group flex flex-col rounded-[20px] border p-5 transition-colors ${isLive ? 'border-border bg-card-bg hover:border-[var(--mp-border-strong)] hover:bg-elevated' : 'border-dashed border-border bg-elevated/30 opacity-70'}`}
            >
              <div class="flex items-center justify-between gap-2">
                <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] uppercase tracking-[0.12em] text-muted-text">
                  <span class="h-1.5 w-1.5 rounded-full" style={`background: ${pillar.color};`} aria-hidden="true"></span>
                  {pillar.label}
                </span>
                {!isLive && <span class="rounded-full border border-border bg-canvas px-2 py-0.5 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-muted-text">Coming soon</span>}
              </div>
              <h2 class={`mt-3 text-[1.1rem] font-semibold leading-tight text-primary-text ${isLive ? 'transition-colors group-hover:text-primary-cta' : ''}`}>{tool.title}</h2>
              <p class="mt-1.5 text-[0.85rem] leading-[1.5] text-muted-text">{tool.tagline}</p>
              <p class="mt-3 text-[0.62rem] font-mono uppercase tracking-[0.1em] text-muted-text/70">Grounded in {tool.relatedApp}</p>
            </Wrapper>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
